 := Instance.Outputs.Command_Sent_Count;\nUnexpected_Message_Count := Instance.Outputs.Unexpected_Message_Count;\nInvalid_Configuration_Pdc_Id_Count := Instance.Outputs.Invalid_Configuration_Pdc_Id_Count;\nInvalid_Pmu_Station_Name_Count := Instance.Outputs.Invalid_Pmu_Station_Name_Count;\nInvalid_Pmu_Id_Count := Instance.Outputs.Invalid_Pmu_Id_Count;\nInvalid_Data_Rate_Count := Instance.Outputs.Invalid_Data_Rate_Count;\nInvalid_Nominal_Frequency_Count := Instance.Outputs.Invalid_Nominal_Frequency_Count;\nInvalid_Data_Pdc_Id_Count := Instance.Outputs.Invalid_Data_Pdc_Id_Count;\nInvalid_Data_Size_Count := Instance.Outputs.Invalid_Data_Size_Count;\nConfiguration_Change_Count := Instance.Outputs.Configuration_Change_Count;\nMissed_Data_Count := Instance.Outputs.Missed_Data_Count;\nDuplicate_Data_Count := Instance.Outputs.Duplicate_Data_Count;\nPast_Data_Count := Instance.Outputs.Past_Data_Count;\n\nMessage_Sent_Count := Command_Sent_Count;\nMessage_Received_Count := Configuration_Received_Count +\n                          Data_Received_Count;\n\nMessage_Failure_Count := Invalid_Configuration_Pdc_Id_Count +\n                         Invalid_Pmu_Station_Name_Count +\n                         Invalid_Pmu_Id_Count +\n                         Invalid_Data_Rate_Count +\n                         Invalid_Nominal_Frequency_Count +\n                         Invalid_Data_Pdc_Id_Count +\n                         Invalid_Data_Size_Count;\n\nIF Message_Failure_Count <> Previous_Message_Failure_Count THEN\n    Message_Failure := TRUE;\n    Previous_Message_Failure_Count := Message_Failure_Count;\nELSE\n    Message_Failure := FALSE;\nEND_IF;\n\nMessage_Success_Count := Configuration_Received_Count +\n                         Data_Received_Count +\n                         Command_Sent_Count;\n\nAuto_Configuration_Count := Invalid_Configuration_Pdc_Id_Count +\n                            Invalid_Pmu_Station_Name_Count +\n                            Invalid_Pmu_Id_Count +\n                            Invalid_Data_Rate_Count +\n                            Invalid_Nominal_Frequency_Count;\nIF Auto_Configuration_Count <> Previous_Auto_Configuration_Count THEN\n   Auto_Configuration_Failure := TRUE;\n   Previous_Auto_Configuration_Count := Auto_Configuration_Count;\nELSE\n   Auto_Configuration_Failure := FALSE;\nEND_IF;\n\nIF Unresolved_Tag_Reference_Count > 0 THEN\n   Unresolved_Tag_Reference_Error := TRUE;\nELSE\n   Unresolved_Tag_Reference_Error := FALSE;\nEND_IF;","LineInfoPersistence":"(string)ea1a9721-d202-496d-a49c-7cb0c94ffeb7_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK PM1_C37_118_POU_TYPE\n\tVAR_INPUT\n\t\tEN : BOOL := TRUE;\n\t\tDisable_Tag_Updates : BOOL := FALSE;\n\t\tReconfigure : BOOL := FALSE;\n\t\tReset_Statistics : BOOL := FALSE;\n\tEND_VAR\n\tVAR_OUTPUT\n\t\tENO : BOOL := FALSE;\n\t\tOffline : BOOL := TRUE;\n\t\tMessage_Sent_Count : UDINT := 0;\n\t\tMessage_Received_Count : UDINT := 0;\n\t\tMessage_Failure : BOOL := FALSE;\n\t\tMessage_Failure_Count : UDINT := 0;\n\t\tMessage_Success_Count : UDINT := 0;\n\t\tAuto_Configuration_Pending : BOOL := FALSE;\n\t\tAuto_Configuration_Failure : BOOL := FALSE;\n\t\tUnresolved_Tag_Reference_Error : BOOL := FALSE;\n\t\tUnresolved_Tag_Reference_Count : UDINT := 0;\n\tEND_VAR\n\tVAR\n\t\t{attribute 'hide'}\n\t\tfb_instance_id : UDINT := 102;\n\t\t{attribute 'hide'}\n\t\tConfiguration_Received_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tData_Received_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tCommand_Sent_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tUnexpected_Message_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tInvalid_Configuration_Pdc_Id_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tInvalid_Pmu_Station_Name_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tInvalid_Pmu_Id_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tInvalid_Data_Rate_Count : UDINT := 0;\n\t\t{at