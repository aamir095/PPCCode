{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)2fd07dcf-ae60-4e3b-9888-dbc1b1244ee1","ParentGuid":"(Guid)1660e08e-db52-4f80-ad9a-cd01be274ae1","Name":"(string)PPCDNPServer_R2ToR1_DNP_POU_TYPE","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)f0c53092-f40e-4d0e-9845-7961f9f44ef1"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Start running Startup Delay timer at Project Load/Initialization\nStartup_Delay_Msec := 0;\nStartup_Delay_Time := UDINT_TO_TIME(Startup_Delay_Msec);\nStartup_Delay_Timer(IN := TRUE, PT := Startup_Delay_Time);\n\nDNPServerInstance.ins.EN := (EN AND Startup_Delay_Timer.Q AND (NOT FALSE ));\nEN_Rtrig(CLK := DNPServerInstance.ins.EN);\nDisabled_Edge( CLK := DNPServerInstance.outs.ENO );\n\n// Capture the initial modes on the rising edge of EN.\nIF (EN_Rtrig.Q) THEN\n   DNPServerInstance.ins.Disable_Tag_Updates := Disable_Tag_Updates;\n   DNPServerInstance.ins.Allow_Client_Control_Of_Unsolicited_Messaging_Fcn_20_21 := Allow_Client_Control_Of_Unsolicited_Messaging_Fcn_20_21;\n   DNPServerInstance.ins.Stop_Unsolicited_Messages := Stop_Unsolicited_Messages;\n   DNPServerInstance.ins.Accept_Client_Time_Sync_Obj_50 := Accept_Client_Time_Sync_Obj_50;\n   DNPServerInstance.ins.Disable_Controls := Disable_Controls;\n   DNPServerInstance.ins.Force_Device_Trouble_IIN_Bit := Force_Device_Trouble_IIN_Bit;\nEND_IF\n\n\nIF DNPServerInstance.outs.ENO THEN\n   // Execute Timers.\n   Request_Time_Sync_Timer(\n      IN := Request_Time_Sync_IIN_1_4_Need_Time,\n      PT := Request_Time_Sync_IIN_1_4_Need_Time_Period);\n\n   Service_Incoming_Digitals_Timer(\n      IN := Service_Incoming_Digital_Data_Obj_10_12,\n      PT := Service_Incoming_Digital_Data_Obj_10_12_Period);\n\n   Service_Incoming_Analogs_Timer(\n      IN := Service_Incoming_Analog_Data_Obj_40_41,\n      PT := Service_Incoming_Analog_Data_Obj_40_41_Period);\n\n   Service_Outgoing_Digitals_Timer(\n      IN := Service_Outgoing_Digital_Data_Obj_01_02,\n      PT := Service_Outgoing_Digital_Data_Obj_01_02_Period);\n\n   Service_Outgoing_Analogs_Timer(\n      IN := Service_Outgoing_Analog_Data_Obj_30_32,\n      PT := Service_Outgoing_Analog_Data_Obj_30_32_Period);\n\n   Service_Outgoing_Counters_Timer(\n      IN := Service_Outgoing_Counter_Data_Obj_20_22,\n      PT := Service_Outgoing_Counter_Data_Obj_20_22_Period);\n\n   // Execute Rising edge triggers.\n   Reset_Status_Rtrig(CLK := Reset_Statistics);\n\n   // Update DNPServer inputs\n   DNPServerInstance.ins.Disable_Tag_Updates := Disable_Tag_Updates;\n   DNPServerInstance.ins.Allow_Client_Control_Of_Unsolicited_Messaging_Fcn_20_21 := Allow_Client_Control_Of_Unsolicited_Messaging_Fcn_20_21;\n   DNPServerInstance.ins.Stop_Unsolicited_Messages := Stop_Unsolicited_Messages;\n   DNPServerInstance.ins.Accept_Client_Time_Sync_Obj_50 := Accept_Client_Time_Sync_Obj_50;\n   DNPServerInstance.ins.Disable_Controls := Disable_Controls;\n   DNPServerInstance.ins.Force_Device_Trouble_IIN_Bit := Force_Device_Trouble_IIN_Bit;\n   DNPServerInstance.ins.Force_Buffer_Overflow_IIN_Bit := Force_Buffer_Overflow_IIN_Bit;\n   DNPServerInstance.ins.Request_Time_Sync_IIN_1_4_Need_Time := Request_Time_Sync_Timer.Q;\n   DNPServerInstance.ins.Service_Incoming_Digital_Data_Obj_10_12 := Service_Incoming_Digitals_Timer.Q;\n   DNPServerInstance.ins.Service_Incoming_Analog_Data_Obj_40_41 := Service_Incoming_Analogs_Timer.Q;\n   DNPServerInstance.ins.Service_Outgoing_Digital_Data_Obj_01_02 := Service_Outgoing_Digitals_Timer.Q;\n   DNPServerInstance.ins.Service_Outgoing_Analog_Data_Obj_30_32 := Service_Outgoing_Analogs_Timer.Q;\n   DNPServerInstance.ins.Service_Outgoing_Counter_Data_Obj_20_22 := Service_Outgoing_Counters_Timer.Q;\n   DNPServerInstance.ins.Reset_Statistics := Reset_Status_Rtrig.Q;\n\nELSIF Disabled_Edge.Q THEN\n   // Execute Timers.\n   Request_Time_Sync_Timer( IN := FALSE, PT := TIME#0MS );\n\n   Service_Incoming_Digitals_Timer( IN := FALSE, PT := TIME#0MS );\n\n   Service_Incoming_Analogs_Timer( IN := FALSE, PT := TIME#0MS );\n\n   Service_Outgoing_Digitals_Timer( IN := FALSE, PT := TIME#0MS );\n\n   Service_Outgoing_Analogs_Timer( IN := FALSE, PT := TIME#0MS );\n\n   Service_Outgoing_Counters_Timer( IN := FALSE, PT := TIME#0MS );\n\n   // Execute Rising edge triggers.\n   Reset_Status_Rtrig(CLK := FALSE );\n\nEND_IF\n\n// Execute DNPServer.\nDNPServerInstance();\n\n// Update outputs.\nENO := DNPServerInstance.outs.ENO;\nOffline := DNPServerInstance.outs.Offline;\n\n\nDirect_Transparent_Connection := FALSE;\nService_Incoming_Digital_Data_Obj_10_12_DN := DNPServerInstance.outs.Service_Incoming_Digital_Data_Obj_10_12_DN;\nService_Incoming_Analog_Data_Obj_40_41_DN := DNPServerInstance.outs.Service_Incoming_Analog_Data_Obj_40_41_DN;\nMessage_Sent_Count := DNPServerInstance.outs.Message_Sent_Count;\nMessage_Received_Count := DNPServerInstance.outs.Message_Received_Count;\nMessage_Failure := DNPServerInstance.outs.Message_Failure;\nMessage_Failure_Count := DNPServerInstance.outs.Message_Error_Count;\nMessage_Success_Count := DNPServerInstance.outs.Message_Success_Count;\nApplication_Confirmation_Timeout_Count := DNPServerInstance.outs.Application_Confirmation_Timeout_Count;\nData_Link_Timeout_Count := DNPServerInstance.outs.Data_Link_Timeout_Count;\nClient_IP_Address_Validation_Fail := DNPServerInstance.outs.Client_IP_Address_Validation_Fail;\nUnsolicited_Messaging_Currently_Enabled := DNPServerInstance.outs.Unsolicited_Messaging_Currently_Enabled;\nUnexpected_Message_Count := DNPServerInstance.outs.Unexpected_Message_Count;\nAuthorization_Failure_Count := DNPServerInstance.outs.Authorization_Failure_Count;\nAuthentication_Failure_Count := DNPServerInstance.outs.Authentication_Failure_Count;\nAuthentication_Reply_Timeout_Count := DNPServerInstance.outs.Authentication_Reply_Timeout_Count;\nRekey_Authentication_Failure_Count := DNPServerInstance.outs.Rekey_Authentication_Failure_Count;\nSecure_Messages_Sent_Count := DNPServerInstance.outs.Secure_Messages_Sent_Count;\nSecure_Messages_Received_Count := DNPServerInstance.outs.Secure_Messages_Received_Count;\nCritical_Messages_Sent_Count := DNPServerInstance.outs.Critical_Messages_Sent_Count;\nCritical_Messages_Received_Count := DNPServerInstance.outs.Critical_Messages_Received_Count;\nDiscarded_Message_Count := DNPServerInstance.outs.Discarded_Message_Count;\nError_Messages_Sent_Count := DNPServerInstance.outs.Error_Messages_Sent_Count;\nError_Messages_Received_Count := DNPServerInstance.outs.Error_Messages_Received_Count;\nAuthentication_Success_Count := DNPServerInstance.outs.Authentication_Success_Count;\nSession_Key_Change_Count := DNPServerInstance.outs.Session_Key_Change_Count;\nFailed_Session_Key_Change_Count := DNPServerInstance.outs.Failed_Session_Key_Change_Count;\nUpdate_Key_Change_Count := DNPServerInstance.outs.Update_Key_Change_Count;\nFailed_Update_Key_Change_Count := DNPServerInstance.outs.Failed_Update_Key_Change_Count;\nSession_Rekey_Restart_Count := DNPServerInstance.outs.Session_Rekey_Restart_Count;\n\nInvalid_Function_Block_Input :=\n   DNPServerInstance.outs.Invalid_Function_Block_Input OR\n   Request_Time_Sync_Timer.invalid_input OR\n   Service_Incoming_Digitals_Timer.invalid_input OR\n   Service_Incoming_Analogs_Timer.invalid_input OR\n   Service_Outgoing_Digitals_Timer.invalid_input OR\n   Service_Outgoing_Analogs_Timer.invalid_input OR\n   Service_Outgoing_Counters_Timer.invalid_input;\n\nAbsolute_Time_Obj_50_Var_4_Index_0 := DNPServerInstance.outs.Absolute_Time_Obj_50_Var_4_Index_0;\nInterval_Count_Obj_50_Var_4_Index_0 := DNPServerInstance.outs.Interval_Count_Obj_50_Var_4_Index_0;\nInterval_Units_Obj_50_Var_4_Index_0 := DNPServerInstance.outs.Interval_Units_Obj_50_Var_4_Index_0;\nAbsolute_Time_Obj_50_Var_4_Index_1 := DNPServerInstance.outs.Absolute_Time_Obj_50_Var_4_Index_1;\nInterval_Count_Obj_50_Var_4_Index_1 := DNPServerInstance.outs.Interval_Count_Obj_50_Var_4_Index_1;\nInterval_Units_Obj_50_Var_4_Index_1 := DNPServerInstance.outs.Interval_Units_Obj_50_Var_4_Index_1;\nIIN_1_0_All_Stations := DNPServerInstance.outs.IIN_1_0_All_Stations;\nIIN_1_1_Class_1 := DNPServerInstance.outs.IIN_1_1_Class_1;\nIIN_1_2_Class_2 := DNPServerInstance.outs.IIN_1_2_Class_2;\nIIN_1_3_Class_3 := DNPServerInstance.outs.IIN_1_3_Class_3;\nIIN_1_4_Need_Time := DNPServerInstance.outs.IIN_1_4_Need_Time;\nIIN_1_5_Local := DNPServerInstance.outs.IIN_1_5_Local;\nIIN_1_6_Device_Trouble := DNPServerInstance.outs.IIN_1_6_Device_Trouble;\nIIN_1_7_Restart := DNPServerInstance.outs.IIN_1_7_Restart;\nIIN_2_0_Bad_Function := DNPServerInstance.outs.IIN_2_0_Bad_Function;\nIIN_2_1_Object_Unknown := DNPServerInstance.outs.IIN_2_1_Object_Unknown;\nIIN_2_2_Parameter_Error := DNPServerInstance.outs.IIN_2_2_Parameter_Error;\nIIN_2_3_Buffer_Overflow := DNPServerInstance.outs.IIN_2_3_Buffer_Overflow;\nIIN_2_4_Already_Executing := DNPServerInstance.outs.IIN_2_4_Already_Executing;\nIIN_2_5_Bad_Configuration := DNPServerInstance.outs.IIN_2_5_Bad_Configuration;\n\n// only allow pin to assert for 1 processing interval\nIF (Last_Freeze) THEN\n    Freeze := FALSE;\nELSE\n    Freeze := DNPServerInstance.outs.Freeze;\nEND_IF\n\nLast_Freeze := Freeze;","LineInfoPersistence":"(string)2fd07dcf-ae60-4e3b-9888-dbc1b1244ee1_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK PPCDNPServer_R2ToR1_DNP_POU_TYPE\n\tVAR_INPUT\n\t\tEN : BOOL := TRUE;\n\t\tDisable_Tag_Updates : BOOL := FALSE;\n\t\tForce_Device_Trouble_IIN_Bit : BOOL := FALSE;\n\t\tForce_Buffer_Overflow_IIN_Bit : BOOL := FALSE;\n\t\tDisable_Controls : BOOL := FALSE;\n\t\tReset_Statistics : BOOL := FALSE;\n\tEND_VAR\n\tVAR_OUTPUT\n\t\tENO : BOOL := FALSE;\n\t\tOffline : BOOL := TRUE;\n\t\tMessage_Sent_Count : UDINT := 0;\n\t\tMessage_Received_Count : UDINT := 0;\n\t\tMessage_Failure : BOOL := TRUE;\n\t\tMessage_Failure_Count : UDINT := 0;\n\t\tMessage_Success_Count : UDINT := 0;\n\t\tApplication_Confirmation_Timeout_Count : UINT := 0;\n\t\tData_Link_Timeout_Count : UINT := 0;\n\t\tDirect_Transparent_Connection : BOOL := FALSE;\n\tEND_VAR\n\tVAR\n\t\t{attribute 'hide'}\n\t\tfb_instance_id : UDINT := 159;\n\t\t{attribute 'hide'}\n\t\tAllow_Client_Control_Of_Unsolicited_Messaging_Fcn_20_21 : BOOL := TRUE;\n\t\t{attribute 'hide'}\n\t\tStop_Unsolicited_Messages : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tRequest_Time_Sync_IIN_1_4_Need_Time : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tRequest_Time_Sync_IIN_1_4_Need_Time_Period : TIME := T#120M;\n\t\t{attribute 'hide'}\n\t\tAccept_Client_Time_Sync_Obj_50 : BOOL := TRUE;\n\t\t{attribute 'hide'}\n\t\tService_Incoming_Digital_Data_Obj_10_12 : BOOL := TRUE;\n\t\t{attribute 'hide'}\n\t\tService_Incoming_Digital_Data_Obj_10_12_Period : TIME := T#1MS;\n\t\t{attribute 'hide'}\n\t\tService_Incoming_Analog_Data_Obj_40_41 : BOOL := TRUE;\n\t\t{attribute 'hide'}\n\t\tService_Incoming_Analog_Data_Obj_40_41_Period : TIME := T#1MS;\n\t\t{attribute 'hide'}\n\t\tService_Outgoing_Digital_Data_Obj_01_02 : BOOL := TRUE;\n\t\t{attribute 'hide'}\n\t\tService_Outgoing_Digital_Data_Obj_01_02_Period : T