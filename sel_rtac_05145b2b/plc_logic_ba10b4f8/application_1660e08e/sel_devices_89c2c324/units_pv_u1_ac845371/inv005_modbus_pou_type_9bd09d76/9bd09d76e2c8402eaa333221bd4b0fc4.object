{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)9bd09d76-e2c8-402e-aa33-3221bd4b0fc4","ParentGuid":"(Guid)1660e08e-db52-4f80-ad9a-cd01be274ae1","Name":"(string)Inv005_MODBUS_POU_TYPE","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)ac845371-100e-49bb-aca8-5ab082360eaa"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)Direct_Transparent_Connection := FALSE;\nimpl.EN := EN AND NOT Direct_Transparent_Connection;\n\nDisabled_Edge( CLK := impl.outs.ENO );\n\nIF impl.EN THEN\n\t//update timers, triggers, and slow poll\n\tIF impl.outs.ENO THEN\n\t\tIF impl.outs.Slow_Poll_Mode_Enabled THEN\n\t\t\tmultiplier := MULTIPLIER_SETTING;\n\t\tELSE\n\t\t\tmultiplier := 1;\n\t\tEND_IF\n\n\t\t// 0 Coil timers\n\t\t// 0 Discrete Input timers\n\t\t// 1 Holding Register timers\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Holding_Register_Timer_1.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Holding_Register_Timer_1.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Holding_Registers_1_Period) THEN\n\t\t\t\t       Holding_Register_Timer_1.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Holding_Register_Timer_1.PT := Issue_Read_Holding_Registers_1_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tHolding_Register_Timer_1 ( IN := Issue_Read_Holding_Registers_1);\n\t\t// 5 Input Register timers\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Input_Register_Timer_1.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_1.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Input_Registers_1_Period) THEN\n\t\t\t\t       Input_Register_Timer_1.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_1.PT :=  Issue_Read_Input_Registers_1_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tInput_Register_Timer_1 ( IN := Issue_Read_Input_Registers_1);\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Input_Register_Timer_2.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_2.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Input_Registers_2_Period) THEN\n\t\t\t\t       Input_Register_Timer_2.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_2.PT :=  Issue_Read_Input_Registers_2_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tInput_Register_Timer_2 ( IN := Issue_Read_Input_Registers_2);\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Input_Register_Timer_3.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_3.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Input_Registers_3_Period) THEN\n\t\t\t\t       Input_Register_Timer_3.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_3.PT :=  Issue_Read_Input_Registers_3_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tInput_Register_Timer_3 ( IN := Issue_Read_Input_Registers_3);\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Input_Register_Timer_4.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_4.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Input_Registers_4_Period) THEN\n\t\t\t\t       Input_Register_Timer_4.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_4.PT :=  Issue_Read_Input_Registers_4_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tInput_Register_Timer_4 ( IN := Issue_Read_Input_Registers_4);\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t       Input_Register_Timer_5.PT_MAX := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_5.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t\t   END_IF\n\n\t\t\t\t   IF ((TIMER_MAX/multiplier) < Issue_Read_Input_Registers_5_Period) THEN\n\t\t\t\t       Input_Register_Timer_5.PT := TIMER_MAX ;\n\t\t\t\t   ELSE\n\t\t\t\t\t   Input_Register_Timer_5.PT :=  Issue_Read_Input_Registers_5_Period * multiplier ;\n\t\t\t\t   END_IF\n\n\t\tInput_Register_Timer_5 ( IN := Issue_Read_Input_Registers_5);\n\t\t\t   IF ((TIMER_MAX/multiplier) < TIMER_PT_MAX) THEN\n\t\t\t\t   Report_Server_ID_Timer.PT_MAX := TIMER_MAX ;\n\t\t\t   ELSE\n\t\t\t\t   Report_Server_ID_Timer.PT_MAX := TIMER_PT_MAX * multiplier ;\n\t\t\t   END_IF\n\n\t\t\t   IF ((TIMER_MAX/multiplier) < Report_Server_ID_Poll_Period) THEN\n\t\t\t\t   Report_Server_ID_Timer.PT := TIMER_MAX ;\n\t\t\t   ELSE\n\t\t\t\t   Report_Server_ID_Timer.PT := Report_Server_ID_Poll_Period * multiplier ;\n\t\t\t   END_IF\n\n\t\tReport_Server_ID_Timer(IN := Report_Server_ID_Poll);\n\n\n\t\tService_Tx_Coil_Timer( IN := Service_Tx_Coil_Write,\n\t\t                       PT := Service_Tx_Coil_Write_Period );\n\t\t\n\t\tService_Tx_Holding_Register_Timer( IN := Service_Tx_Holding_Register_Write,\n\t\t                                   PT := Service_Tx_Holding_Register_Write_Period );\n\t\t\n\t\tReset_Statistics_Trigger( CLK := Reset_Statistics );\n\tEND_IF\n\n\t// --- update inputs --- //\n\timpl.Disable_Tag_Updates := Disable_Tag_Updates;\n\n\t// 0 Coil timers\n\t// 0 Discrete Input timers\n\t// 1 Holding Register timers\n\timpl.Read_Holding_Register_Status_Poll[1] := Holding_Register_Timer_1.Q;\n\t// 5 Input Register timers\n\timpl.Read_Input_Register_Status_Poll[1] := Input_Register_Timer_1.Q;\n\timpl.Read_Input_Register_Status_Poll[2] := Input_Register_Timer_2.Q;\n\timpl.Read_Input_Register_Status_Poll[3] := Input_Register_Timer_3.Q;\n\timpl.Read_Input_Register_Status_Poll[4] := Input_Register_Timer_4.Q;\n\timpl.Read_Input_Register_Status_Poll[5] := Input_Register_Timer_5.Q;\n\n\timpl.Report_Server_ID_Poll := Report_Server_ID_Timer.Q;\n\n\timpl.Disable_Controls := Disable_Controls;\n\timpl.Reset_Statistics := Reset_Statistics_Trigger.Q;\n\n\timpl.Service_Tx_Coil_Write := Service_Tx_Coil_Timer.Q;\n\timpl.Service_Tx_Holding_Register_Write := Service_Tx_Holding_Register_Timer.Q;\n\n\timpl.Enable_Event_Collection := Enable_Event_Collection;\n\timpl.Enable_ASCII_SER_Logging := Enable_ASCII_SER_Logging;\n\nELSIF Disabled_Edge.Q Then\n\n\t// 0 Coil timers\n\t// 0 Discrete Input timers\n\t// 1 Holding Register timers\n\tHolding_Register_Timer_1 ( IN := FALSE, PT := TIME#0MS );\n\t// 5 Input Register timers\n\tInput_Register_Timer_1 ( IN := FALSE, PT := TIME#0MS );\n\tInput_Register_Timer_2 ( IN := FALSE, PT := TIME#0MS );\n\tInput_Register_Timer_3 ( IN := FALSE, PT := TIME#0MS );\n\tInput_Register_Timer_4 ( IN := FALSE, PT := TIME#0MS );\n\tInput_Register_Timer_5 ( IN := FALSE, PT := TIME#0MS );\n\n\tReport_Server_ID_Timer( IN := FALSE, PT := TIME#0MS );\n\tService_Tx_Coil_Timer( IN := FALSE, PT := TIME#0MS );\n\tService_Tx_Holding_Register_Timer( IN := FALSE, PT := TIME#0MS );\n\tReset_Statistics_Trigger( CLK := FALSE );\n\nEND_IF\n\n// --- Execute Function Block --- //\nimpl();\n\n// --- Update outputs --- //\nENO     := impl.outs.ENO;\nOffline := impl.outs.Offline;\n\nMessage_Sent_Count     := impl.outs.Message_Sent_Count;\nMessage_Received_Count := impl.outs.Message_Received_Count;\nMessage_Failure        := impl.outs.Message_Error;\nMessage_Failure_Count  := impl.outs.Message_Error_Count;\nMessage_Timeout        := impl.outs.Message_Timeout;\nMessage_Timeout_Count  := impl.outs.Message_Timeout_Count;\nMessage_Success_Count  := impl.outs.Message_Success_Count;\nBuffer_Overflow        := impl.outs.Buffer_Overflow;\nBuffer_Overflow_Count  := impl.outs.Buffer_Overflow_Count;\n\nControls_Disabled := Disable_Controls;\nSlow_Poll_Mode_Enabled := impl.outs.Slow_Poll_Mode_Enabled;\n\nInvalid_Function_Block_Input :=\n\tReport_Server_ID_Timer.invalid_input OR\n\tService_Tx_Coil_Timer.invalid_input  OR\n\tService_Tx_Holding_Register_Timer.invalid_input\n\t// 0 Coil Timers\n\t// 0 Discrete Input timers\n\t// 1 Holding Register Timers\n\tOR Holding_Register_Timer_1.invalid_input\n\t// 5 Input Register Timers\n\tOR Input_Register_Timer_1.invalid_input\n\tOR Input_Register_Timer_2.invalid_input\n\tOR Input_Register_Timer_3.invalid_input\n\tOR Input_Register_Timer_4.invalid_input\n\tOR Input_Register_Timer_5.invalid_input\n;\nEvent_Collection_Enabled := impl.outs.Event_Collection_Enabled;\nEvent_Collection_Stored := impl.outs.Event_Collection_Stored;\nEvent_Collection_Stored_Count := impl.outs.Event_Collection_Stored_Count;\nEvent_Collection_Pending := impl.outs.Event_Collection_Pending;\n\t\nASCII_SER_Logging_Enabled := impl.outs.ASCII_SER_Logging_Enabled;\nASCII_SER_Logging_Stored := impl.outs.ASCII_SER_Logging_Stored;\nASCII_SER_Logging_Stored_Count := impl.outs.ASCII_SER_Logging_Stored_Count;\nASCII_SER_Logging_Pending := impl.outs.ASCII_SER_Logging_Pending;\nASCII_SER_Logging_Sequence_Restart := impl.outs.ASCII_SER_Logging_Sequence_Restart;\n\nMessage_Exception               := impl.outs.Message_Exception;\nIllegal_Function_Exception      := impl.outs.Illegal_Function_Exception;\nIllegal_Data_Address_Exception  := impl.outs.Illegal_Data_Address_Exception;\nIllegal_Data_Value_Exception    := impl.outs.Illegal_Data_Value_Exception;\nServer_Device_Failure_Exception := impl.outs.Server_Device_Failure_Exception;\nAcknowledge_Exception           := impl.outs.Acknowledge_Exception;\nServer_Device_Busy_Exception    := impl.outs.Server_Device_Busy_Exception;\nMemory_Parity_Error_Exception   := impl.outs.Memory_Parity_Error_Exception;\nGateway_Path_Unavailable_Exception := impl.outs.Gateway_Path_Unavailable_Exception;\nGateway_Target_Failure_Exception := impl.outs.Gateway_Target_Failure_Exception;\nOther_Exception                 := impl.outs.Other_Exception;","LineInfoPersistence":"(string)9bd09d76-e2c8-402e-aa33-3221bd4b0fc4_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK Inv005_MODBUS_POU_TYPE\n\tVAR_INPUT\n\t\tEN : BOOL := TRUE;\n\t\tDisable_Tag_Updates : BOOL := FALSE;\n\t\tDisable_Controls : BOOL := FALSE;\n\t\tReset_Statistics : BOOL := FALSE;\n\t\tEnable_Event_Collection : BOOL := FALSE;\n\t\tEnable_ASCII_SER_Logging : BOOL := FALSE;\n\t\tIssue_Read_Holding_Registers_1 : BOOL := TRUE;\n\t\tIssue_Read_Holding_Registers_1_Period : TIME := T#1000MS;\n\t\tIssue_Read_Input_Registers_1 : BOOL := TRUE;\n\t\tIssue_Read_Input_Registers_1_Period : TIME := T#2000MS;\n\t\tIssue_Read_Input_Registers_2 : BOOL := TRUE;\n\t\tIssue_Read_Input_Registers_2_Period : TIME := T#2000MS;\n\t\tIssue_Read_Input_Registers_3 : BOOL := TRUE;\n\t\tIssue_Read_Input_Registers_3_Period : TIME := T#2000MS;\n\t\tIssue_Read_Input_Registers_4 : BOOL := TRUE;\n\t\tIssue_Read_Input_Registers_4_Period : TIME := T#2000MS;\n\t\tIssue_Read_Input_Registers_5 : BOOL := TRUE;\n\t\tIssue_Read_Input_Registers_5_Period : TIME := T#2000MS;\n\tEND_VAR\n\tVAR_OUTPUT\n\t\tENO : BOOL := FALSE;\n\t\tOffline : BOOL := TRUE;\n\t\tMessage_Sent_Count : UDINT := 0;\n\t\tMessage_Received_Count : UDINT := 0;\n\t\tMessage_Failure : BOOL := FALSE;\n\t\tMessage_Failure_Count : UDINT := 0;\n\t\tMessage_Timeout : BOOL := FALSE;\n\t\tMessage_Timeout_Count : UDINT := 0;\n\t\tMessage_Success_Count : UDINT := 0;\n\t\tInvalid_Function_Block_Input : BOOL := FALSE;\n\t\tControls_Disabled : BOOL := FALSE;\n\t\tSlow_Poll_Mode_Enabled : BOOL := FALSE;\n\t\tMessage_Exception : USINT := 0;\n\t\tIllegal_Function_Exception : BOOL := FALSE;\n\t\tIllegal_Data_Address_Exception : BOOL := FALSE;\n\t\tIllegal_Data_Value_Exception : BOOL := FALSE;\n\t\tServer_Device_Failure_Exception : BOOL := FALSE;\n\t\tAcknowledge_Exception : BOOL := FALSE;\n\t\tServer_Device_Busy_Exception : BOOL := FALSE;\n\t\tMemory_Parity_Error_Exception : BOOL := FALSE;\n\t\tGateway_Path_Unavailable_Exception : BOOL := FALSE;\n\t\tGateway_Target_Failure_Exception : BOOL := FALSE;\n\t\tOther_Exception : BOOL := FALSE;\n\t\tDirect_Transparent_Connection : BOOL := FALSE;\n\tEND_VAR\n\tVAR\n\t\t{attribute 'hide'}\n\t\tfb_instance_id : UDINT := 166;\n\t\t{attribute 'hide'}\n\t\tSlow_Poll_Mode_Multiplier : UINT := 5;\n\t\t{attribute 'hide'}\n\t\tReport_Server_ID_Poll : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tReport_Server_ID_Poll_Period : TIME := T#0MS;\n\t\t{attribute 'hide'}\n\t\tService_Tx_Coil_Write : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tService_Tx_Coil_Write_Period : TIME := T#1MS;\n\t\t{attribute 'hide'}\n\t\tService_Tx_Holding_Register_Write : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tService_Tx_Holding_Register_Write_Period : TIME := T#1MS;\n\t\t{attribute 'hide'}\n\t\tBuffer_Overflow_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tBuffer_Overflow : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tEvent_Collection_Enabled : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tEvent_Collection_Stored : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tEvent_Collection_Stored_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tEvent_Collection_Pending : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tASCII_SER_Logging_Enabled : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tASCII_SER_Logging_Stored : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tASCII_SER_Logging_Stored_Count : UDINT := 0;\n\t\t{attribute 'hide'}\n\t\tASCII_SER_Logging_Pending : BOOL := FALSE;\n\t\t{attribute 'hide'}\n\t\tASCII_SER_Logging_Sequence_Restart : BOOL := FALSE;\n\tEND_VAR\n\nVAR CONSTANT\n\t{ attribute 'hide' }\n\tTIMER_PT_MIN : TIME := TIME#100MS;\n\t{ attribute 'hide' }\n\tTIMER_PT_MAX : TIME := TIME#100000000MS;\n\t{attribute 'hide'}\n    TIMER_MAX : TIME := T#4294967295MS;\n\t{ attribute 'hide' }\n\tMULTIPLIER_SETTING : UINT := 5;\nEND_VAR\n\nVAR\n\t{attribute 'hide' }\n\timpl : ModbusClient( FB_Instance_ID := fb_instance_id );\n\t{ attribute 'hide' }\n\tmultiplier : UINT := 1;\n\n\t// 0 Coil Timers\n\t// 0 Discrete Input timers\n\t// 1 Holding Register timers\n\t{ attribute 'hide' }\n\tHolding_Register_Timer_1 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t// 5 Input Register timers\n\t{ attribute 'hide' }\n\tInput_Register_Timer_1 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t{ attribute 'hide' }\n\tInput_Register_Timer_2 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t{ attribute 'hide' }\n\tInput_Register_Timer_3 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t{ attribute 'hide' }\n\tInput_Register_Timer_4 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t{ attribute 'hide' }\n\tInput_Register_Timer_5 : TIV := ( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\n\t{ attribute 'hide' }\n\tReport_Server_ID_Timer : TIV :=\n\t\t( PT_MIN := TIMER_PT_MIN, PT_MAX := TIMER_PT_MAX );\n\t{ attribute 'hide' }\n\tService_Tx_Coil_Timer : TIV :=\n\t\t( PT_MIN := TIME#1MS, PT_MAX := TIME#60000MS );\n\t{ attribute 'hide' }\n\tService_Tx_Holding_Register_Timer : TIV :=\n\t\t( PT_MIN := TIME#1MS, PT_MAX := TIME#60000MS );\n\t{ attribute 'hide' }\n\tReset_Statistics_Trigger : R_TRIG;\n\t{ attribute 'hide' }\n\tDisabled_Edge : F_TRIG;\nEND_VAR","LineInfoPersistence":"(string)9bd09d76-e2c8-402e-aa33-3221bd4b0fc4_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)358","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}