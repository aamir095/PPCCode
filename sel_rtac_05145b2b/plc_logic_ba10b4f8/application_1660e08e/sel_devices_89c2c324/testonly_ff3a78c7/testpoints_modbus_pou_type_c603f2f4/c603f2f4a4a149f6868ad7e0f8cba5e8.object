{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c603f2f4-a4a1-49f6-868a-d7e0f8cba5e8","ParentGuid":"(Guid)1660e08e-db52-4f80-ad9a-cd01be274ae1","Name":"(string)TestPoints_MODBUS_POU_TYPE","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)ff3a78c7-eff3-4b65-a77a-69bc2bebde33"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)Direct_Transparent_Connection := FALSE;\n\n// Start running Startup Delay timer at Project Load/Initialization\nStartup_Delay_Msec := 0;\nStartup_Delay_Time := UDINT_TO_TIME(Startup_Delay_Msec);\nStartup_Delay_Timer(IN := TRUE, PT := Startup_Delay_Time);\n\n// Ignore inputs until we are enabled.\nFB.controls.EN := (EN AND Startup_Delay_Timer.Q AND (NOT Direct_Transparent_Connection));\n\nDisabled_Edge( CLK := FB.status.ENO );\n\nInvalid_Function_Block_Input := false;\nIF FB.controls.EN THEN\n\tIF FB.status.ENO THEN\n\t\tReset_Stat_Edge(CLK := Reset_Statistics);\n\n\t\tIF Communications_Offline_Timer < TIME#100MS THEN\n\t\t\tInvalid_Function_Block_Input := true;\n\t\tELSIF Communications_Offline_Timer > TIME#100000000MS THEN\n\t\t\tInvalid_Function_Block_Input := true;\n\t\tELSE\n\t\t\tFB.controls.Communications_Offline_Timer :=\n\t\t\t\tTIME_TO_DWORD(Communications_Offline_Timer);\n\t\tEND_IF\n\n\tEND_IF\n\n\tFB.FB_Instance_ID := fb_instance_id;\n\tFB.controls.Disable_controls := Disable_Controls;\n\tFB.controls.Disable_Tag_Updates := Disable_Tag_Updates;\n\n\tFB.controls.Service_Outbound_Digital_Data := true;\n\n\tFB.controls.Service_Outbound_Analog_Data := true;\n\n\tFB.controls.Reset_Statistics := Reset_Stat_Edge.Q;\n\nELSIF Disabled_Edge.Q THEN\n\tReset_Stat_Edge( CLK := FALSE );\n\nEND_IF\n\n\nFB();\n\nENO := FB.status.ENO;\nControls_Disabled := FB.status.Controls_Disabled;\nOffline := FB.status.from_application.Offline;\n\nIllegal_Data_Address := FB.status.from_application.Illegal_Data_Address;\nIllegal_Data_Value := FB.status.from_application.Illegal_Data_Value;\nIllegal_Function_Code := FB.status.from_application.Illegal_Function_Code;\n\nMessage_Failure := NOT(Message_Failure_Count =\n\t\t\t\t\t\tFB.status.from_application.Message_Failure_Count) AND\n\t\t\t\t\t\tNOT(0 = FB.status.from_application.Message_Failure_Count);\n\nMessage_Failure_Count := FB.status.from_application.Message_Failure_Count;\nMessage_Success_Count := FB.status.from_application.Message_Success_Count;\nMessages_Received_Count := FB.status.from_application.Messages_Received_Count;\nMessages_Sent_Count := FB.status.from_application.Messages_Sent_Count;","LineInfoPersistence":"(string)c603f2f4-a4a1-49f6-868a-d7e0f8cba5e8_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK TestPoints_MODBUS_POU_TYPE\n\tVAR_INPUT\n\t\tEN : BOOL := TRUE;\n\t\tCommunications_Offline_Timer : TIME := T#10000MS;\n\t\tDisable_Tag_Updates : BOOL := FALSE;\n\t\tDisable_Controls : BOOL := FALSE;\n\t\tReset_Statistics : BOOL := FALSE;\n\tEND_VAR\n\tVAR_OUTPUT\n\t\tENO : BOOL := FALSE;\n\t\tOffline : BOOL := TRUE;\n\t\tMessages_Sent_Count : UDINT := 0;\n\t\tMessages_Received_Count : UDINT := 0;\n\t\tMessage_Failure : BOOL := FALSE;\n\t\tMessage_Failure_Count : UDINT := 0;\n\t\tMessage_Success_Count : UDINT := 0;\n\t\tInvalid_Function_Block_Input : BOOL := FALSE;\n\t\tControls_Disabled : BOOL := FALSE;\n\t\tIllegal_Function_Code : BOOL := FALSE;\n\t\tIllegal_Data_Address : BOOL := FALSE;\n\t\tIllegal_Data_Value : BOOL := FALSE;\n\t\tDirect_Transparent_Connection : BOOL := FALSE;\n\tEND_VAR\n\tVAR\n\t\t{attribute 'hide'}\n\t\tfb_instance_id : UDINT := 167;\n\tEND_VAR\n\nVAR\n\t{attribute 'hide'}\n\tFB: Modbus_server;\n\t{attribute 'hide'}\n\tReset_Stat_Edge: R_TRIG := (CLK := Reset_Statistics);\n\t{attribute 'hide'}\n\tDisabled_Edge : F_TRIG;\n\n\t{attribute 'hide'}\n\tStartup_Delay_Msec : UDINT;\n\t{attribute 'hide'}\n\tStartup_Delay_Time : TIME;\n\t{attribute 'hide'}\n\tStartup_Delay_Timer : TON;\nEND_VAR","LineInfoPersistence":"(string)c603f2f4-a4a1-49f6-868a-d7e0f8cba5e8_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)105","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}