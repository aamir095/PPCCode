1's\n\n\tIF ((TIMER_MAX/Poll_Period_Multiplier) < T#100000000MS ) THEN\n\t    Event_Poll_CLK.PT_MAX := TIMER_MAX;\n\t\tIntegrity_Poll_CLK.PT_MAX := TIMER_MAX;\n\tELSE\n\t    Event_Poll_CLK.PT_MAX := T#100000000MS * Poll_Period_Multiplier;\n\t\tIntegrity_Poll_CLK.PT_MAX := T#100000000MS * Poll_Period_Multiplier;\n\tEND_IF\n\n\tIF ((TIMER_MAX/Poll_Period_Multiplier) < T#1440M ) THEN\n\t    Issue_Time_Sync_CLK.PT_MAX := TIMER_MAX;\n\tELSE\n\t    Issue_Time_Sync_CLK.PT_MAX :=  T#1440M * Poll_Period_Multiplier;\n\tEND_IF\n\n    /// Prevent the overflow of the PT for the timers\n\n\tIF ((TIMER_MAX/Poll_Period_Multiplier) < Poll_Events_Obj_60_Cls_123_Period ) THEN\n\t    Event_Poll_CLK.PT := TIMER_MAX;\n\tELSE\n\t    Event_Poll_CLK.PT := Poll_Events_Obj_60_Cls_123_Period * Poll_Period_Multiplier;\n\tEND_IF\n\n\tIF ((TIMER_MAX/Poll_Period_Multiplier) < Issue_Time_Sync_Period) THEN\n\t    Issue_Time_Sync_CLK.PT := TIMER_MAX;\n\tELSE\n\t    Issue_Time_Sync_CLK.PT := Issue_Time_Sync_Period * Poll_Period_Multiplier;\n\tEND_IF\n\n\tEvent_Poll_CLK(IN := Poll_Events_Obj_60_Cls_123);\n    Client.controls.app_ctls.Issue_Poll_Event_Obj_60_Cls_123 := Event_Poll_CLK.Q;\n\tInvalid_Function_Block_Input := Invalid_Function_Block_Input OR Event_Poll_CLK.invalid_input;\n\tDont_Force_Integrity_Poll := Dont_Force_Integrity_Poll OR (Poll_Events_Obj_60_Cls_123_Period <> TIME#0MS);\n\n\tIssue_Time_Sync_CLK(IN := Issue_Time_Sync);\n\tClient.controls.app_ctls.Issue_Time_Sync := Issue_Time_Sync_CLK.Q;\n\tInvalid_Function_Block_Input := Invalid_Function_Block_Input OR Issue_Time_Sync_CLK.invalid_input;\n\tDont_Force_Integrity_Poll := Dont_Force_Integrity_Poll OR (Issue_Time_Sync_Period <> TIME#0MS);\n\n\t// 0 Custom Requests\n\n\tDont_Force_Integrity_Poll := Dont_Force_Integrity_Poll OR (Poll_Integrity_Obj_60_Cls_1230_Period <> TIME#0MS);\n\n\tIF Dont_Force_Integrity_Poll THEN\n\t\tIF ((TIMER_MAX/Poll_Period_Multiplier) < Poll_Integrity_Obj_60_Cls_1230_Period ) THEN\n\t\t\tIntegrity_Poll_CLK.PT := TIMER_MAX;\n\t\tELSE\n\t\t\tIntegrity_Poll_CLK.PT := Poll_Integrity_Obj_60_Cls_1230_Period * Poll_Period_Multiplier;\n\t\tEND_IF\n\tELSE\n\t\tIntegrity_Poll_Clk.PT := Default_Integrity_Poll_Period;\n\tEND_IF\n\t\t\n\tForce_Integrity_Poll_Rtrig(CLK := NOT Dont_Force_Integrity_Poll);\n\tIntegrity_Poll_CLK(IN := Poll_Integrity_Obj_60_Cls_1230 OR Force_Integrity_Poll_Rtrig.Q);\n\tClient.controls.app_ctls.Issue_Poll_Integrity_Obj_60_Cls_1230 := Integrity_Poll_CLK.Q;\n\tInvalid_Function_Block_Input := Invalid_Function_Block_Input OR Integrity_Poll_CLK.invalid_input;\n\n\tClient.controls.app_ctls.Enable_Unsolicited[1] := Enable_Class_1_Unsolicited;\n\tClient.controls.app_ctls.Enable_Unsolicited[2] := Enable_Class_2_Unsolicited;\n\tClient.controls.app_ctls.Enable_Unsolicited[3] := Enable_Class_3_Unsolicited;\n\n\tReset_Stat_Edge(CLK := Reset_Statistics);\n\tClient.controls.app_ctls.Reset_Statistics := Reset_Stat_Edge.Q;\n\n\tClient.controls.Set_ClockFail := Set_ClockFail;\n\tClient.controls.Set_ClockNotSynchronized := Set_ClockNotSynchronized;\n\n\tClient.controls.app_ctls.Enable_Auto_Respond_IIN_1_1_Class1 := Auto_Respond_to_IIN_1_1_Class_1;\n\tClient.controls.app_ctls.Enable_Auto_Respond_IIN_1_2_Class2 := Auto_Respond_to_IIN_1_2_Class_2;\n\tClient.controls.app_ctls.Enable_Auto_Respond_IIN_1_3_Class3 := Auto_Respond_to_IIN_1_3_Class_3;\n\tClient.controls.app_ctls.Enable_Auto_Respond_IIN_1_4_Need_Time := Auto_Respond_to_IIN_1_4_Need_Time;\n\tClient.controls.app_ctls.Enable_Auto_Respond_IIN_1_7_Restart := Auto_Respond_to_IIN_1_7_Restart;\n\n\tService_Incoming_Digital_Data_Obj_01_02_10_11_CLK(IN := Service_Incoming_Digital_Data_Obj_01_02_10_11,\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t  PT := Service_Incoming_Digital_Data_Obj_01_02_10_11_Period);\n\tClient.controls.Service_Incoming_Digital_Data_Obj_01_02_10_11 :=  Service_Incoming_Digital_Data_Obj_01_02_10_11_CLK.Q;\n\tInvalid_Function_Block_Input := Invalid_Function_Block_Input OR Service_Incoming_Digital_Data_Obj_01_02_10_11_CLK.i