ncoming_Digital_Data_Obj_01_02_10_11_CLK( IN := FALSE, PT := TIME#0MS );\n\tService_Incoming_Analog_Data_Obj_30_32_34_40_42_CLK( IN := FALSE, PT := TIME#0MS );\n\tService_Incoming_Counter_Data_Obj_20_21_22_23_CLK( IN := FALSE, PT := TIME#0MS );\n\tService_Outgoing_Digital_Data_Obj_12_CLK( IN := FALSE, PT := TIME#0MS );\n\tService_Outgoing_Analog_Data_Obj_41_CLK( IN := FALSE, PT := TIME#0MS );\n\tIssue_Time_Sync_CLK( IN := FALSE, PT := TIME#0MS );\n\tReset_Stat_Edge(CLK := FALSE);\n\tDont_Force_Integrity_Poll := TRUE;\n\tIn_Slow_Poll_Mode := FALSE;\n\nEND_IF\n\nClient();\n\nENO := Client.status.ENO;\nOffline := Client.status.from_trans_server.Offline;\nDirect_Transparent_Connection := FALSE;\nPoll_Integrity_Obj_60_Cls_1230_DN := Client.status.Poll_Integrity_Obj_60_Cls_1230_DN;\nPoll_Events_Obj_60_Cls_123_DN := Client.status.Poll_Events_Obj_60_Cls_123_DN;\n\n// 0 Custom Requests\n\nBuffer_Overflow := Client.status.Buffer_Overflow;\nBuffer_Overflow_Count := Client.status.Buffer_Overflow_Count;\nIncoming_Event_Buffer_Empty := Client.status.Incoming_Event_Buffer_Empty;\n\nMessage_Sent_Count := Client.status.from_trans_server.Messages_Sent_Count;\nMessage_Received_Count := Client.status.from_trans_server.Messages_Received_Count;\nMessage_Failure := Client.status.from_trans_server.Message_Failure;\nMessage_Failure_Count := Client.status.from_trans_server.Message_Failure_Count;\nResponse_Timeout_Count := Client.status.from_trans_server.Response_Timeout_Count;\nData_Link_Timeout_Count := Client.status.from_trans_server.Data_Link_Timeout_Count;\nMessage_Success_Count := Client.status.from_trans_server.Message_Success_Count;\nClass_1_Unsolicited_Enabled := Client.status.from_trans_server.Class1_Unsolicited_Enabled;\nClass_2_Unsolicited_Enabled := Client.status.from_trans_server.Class2_Unsolicited_Enabled;\nClass_3_Unsolicited_Enabled := Client.status.from_trans_server.Class3_Unsolicited_Enabled;\nIIN_2_0_Bad_Function := Client.status.from_trans_server.IIN[0];\nIIN_2_1_Object_U