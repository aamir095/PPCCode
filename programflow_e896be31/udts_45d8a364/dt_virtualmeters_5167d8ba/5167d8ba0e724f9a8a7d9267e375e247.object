eter Fbk + Virtual BESS Feeder Meter Fbk\n\tPVInvMeterFbk\t\t\t: TBE_PPC.dt_VirtualMeterFbk;\t//Virtual PV meter feedback calculated using sum of PV Inverter Level Feedback\n\tBESSInvMeterFbk\t\t\t: TBE_PPC.dt_VirtualMeterFbk;\t//Virtual BESS meter feedback calculated using sum of BESS Inverter/EMS Level Feedback\n\tPOIInvMeterFbk\t\t\t: TBE_PPC.dt_VirtualMeterFbk;\t//Virtual POI meter feedback calculated as sum of Virtual PV Inverter Meter Fbk + Virtual BESS Inverter Meter Fbk\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)5167d8ba-0e72-4f9a-8a7d-9267e375e247_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)32"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}