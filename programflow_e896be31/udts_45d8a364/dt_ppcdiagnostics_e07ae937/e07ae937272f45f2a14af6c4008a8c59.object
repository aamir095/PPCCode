{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)e07ae937-272f-45f2-a14a-f6c4008a8c59","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_PPCDiagnostics","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)45d8a364-0cc6-418d-abd8-9087f31a2c5c"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tDiagnostics Structure\n|\tContains diagnostic information from core logic\n*)\nTYPE dt_PPCDiagnostics :\nSTRUCT\n\tPCtrl_Aux_Outputs\t\t\t: TBE_PPC.dt_PCtlAuxOutputs; \t\t\t\t\t\t\t\t\t\t\t//Outputs from real power aux control\n\tQCtrl_Aux_Outputs\t\t\t: TBE_PPC.dt_AVRCtlAuxOutputs; \t\t\t\t\t\t\t\t\t\t\t//Outputs from reactive power aux control\n\tOpModeSts\t\t\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t\t\t\t\t\t\t\t\t//Operating mode status\n\tPV_PCtrlDiagnostics\t\t\t: TBE_PPC.dt_PCtrlDiagnostics; \t\t\t\t\t\t\t\t\t\t\t//Diagnostic outputs from PV active power control block\n\tBESS_PCtrlDiagnostics\t\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Diagnostic outputs from BESS active power control block\n\tPSp_Diagnostics\t\t\t\t: TBE_PPC.dt_PSpDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Diagnostic outputs related to active power setpoints and frequency control\n\tQCtrlDiagnostics\t\t\t: TBE_PPC.dt_QCtrlDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Diagnostic outputs for Reactive power control block\n\t//InvCtrlSts\t\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\t\t\t\t//Array of control status values related to inverters\n\t//EMSCtrlSts\t\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\t\t\t\t//Array of control status values related to EMS modules\n\tPlantInvDiagnostics\t\t\t: TBE_PPC.dt_PlantInvDiagnostics;\t\t\t\t\t\t\t\t\t\t//Inverter diagnostics\n\tPlantEMSDiagnostics\t\t\t: TBE_PPC.dt_PlantEMSDiagnostics;\t\t\t\t\t\t\t\t\t\t//Structure of plant-level EMS status/diagnostic values\n\tHSL                     \t: REAL;                                                         \t\t//Diagnostic High Sustainable Limit, or potential MW, or net output capability\n\tActivePwrPotentialOutput\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Active power potential output, based on irradiance and site capacity (not based on inv availability)\n\tMetAvgFbk\t\t\t\t\t: TBE_PPC.dt_MetStationFbk;\t\t\t\t\t\t\t\t\t\t\t\t//Average feedback from all online met stations\n\tCapBankDiagnostics\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankSts;\t\t\t//Array of capacitor bank status/diagnostic structures\n\tPlantEvents\t\t\t\t\t: TBE_PPC.dt_PlantEvents;\t\t\t\t\t\t\t\t\t\t\t\t//Structure of events to be logged in RTAC SOE\n\tSysTags\t\t\t\t\t\t: TBE_PPC.dt_SELSysTags;\t\t\t\t\t\t\t\t\t\t\t\t//Structure of SEL RTAC System Tags\n\tVoltageSchDiagnostics\t\t: TBE_PPC.dt_VSchDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Array for Voltage Schedule Diagranostics\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)e07ae937-272f-45f2-a14a-f6c4008a8c59_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)66"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}