{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)2a7bb31c-c152-4342-b9f5-9a477b364c40","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_PPCInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)45d8a364-0cc6-418d-abd8-9087f31a2c5c"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tPPC Inputs Structure\n|\tContains all inputs to the PPC\n*)\nTYPE dt_PPCInputs :\nSTRUCT\n\t//HMI Inputs\n\tPlantHMIInputs\t\t\t: TBE_PPC.dt_PlantHMIInputs; \t\t\t\t\t\t\t\t\t\t\t//Plant HMI Inputs\n\tInvHMIInputs\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs;\t\t//Inverter level HMI commands\n\tEMSHMIInputs\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceHMIInputs;\t\t\t//EMS level HMI commands\n\t\n\t//Meter Fbk\n\tHVMeterFbk\t\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\t\t\t//Array of HV Meter feedback/status values\n\tMVMeterFbk\t\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; \t\t\t//Array MV Meter feedback/status values\n\tMeterFbk\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_PV\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//PV Meter Feedback\n\tMeterFbk_BESS\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//BESS Meter Feedback\n\tVirtualMeterFbk\t\t\t: dt_VirtualMeters; \t\t\t\t\t\t\t\t\t\t\t\t\t//Virtual Meter Feedback Structure\n\n\t//Inv Fbk\n\tInvFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\t\t\t\t//Inverter Feedback/Status values\n\t\n\t//BESS/EMS Fbk\n\tBESSFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\t\t\t\t\t//BESS/EMS feedback structure\n\tPlantEMSSts\t\t\t\t: TBE_PPC.dt_PlantEMSDiagnostics;\t\t\t\t\t\t\t\t\t\t//Plant-level EMS status/diagnostics structure\n\t\n\t//Cap Bank Fbk\n\tCapBankFbk\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankFbk;\t\t\t//Capacitor bank feedback/status values\n\tCapBankHMIInputs\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankHMIInputs;\t//Capacitor bank inputs from HMI\n\tCapBankOperMode         : UINT := 2;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Capacitor bank operation mode selection (1 = Staged Mode, 2 = Number of Operations Mode)\n\t\n\t//Remote Inputs (inputs from remote source)\n\tPlantRemoteInputs1\t\t: TBE_PPC.dt_PlantRemoteInputs; \t\t\t\t\t\t\t\t\t\t//Inputs from remote source 1\n\tPlantRemoteInputs2\t\t: TBE_PPC.dt_PlantRemoteInputs; \t\t\t\t\t\t\t\t\t\t//Inputs from remote source 2\n\tPlantCurtailmentInputs\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t\t\t\t//Inputs from remote curtailment source\n\t\n\t//Scheduler Inputs (setpoints/commands generated from scheduler)\n\tPlantSchInputs\t\t\t: TBE_PPC.dt_PlantHMIInputs; \t\t\t\t\t\t\t\t\t\t\t//Inputs from scheduler\n\t\n\t//Line Drop Compensation Inputs\n\tLDCSts\t\t\t\t\t: TBE_PPC.dt_LDCSts;\t \t\t\t\t\t\t\t\t\t\t\t\t\t\t//Line drop compensation status\n\t\n\t//Met station feedback\n\tMetStationFbk\t\t\t: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\t//Met station feedback\n\t\n\t//Misc. Status Values\n\tHSL\t\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//High sustainable limit\n\tHSL_PV\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//PV High Sustainable limit\n\tQCapAbs\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Plant reactive power absorption capability (negative value), calculated based on unit availability\n\tQCapInj\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Plant reactive power injection capability (positive value), calculated based on unit availability\n\t\n\t//Redundancy Status (Local controller only)\n\tRedundancySts_Local\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t\t\t\t\t//Redundancy status structure of local controller\n\t\n\t//Redundancy Inputs\n\tRedundancyHMIInputs\t\t: TBE_PPC.dt_RedundancyHMIInputs;\t\t\t\t\t\t\t\t\t\t//Redundancy HMI Inputs\n\t\n\t//Inputs from remote controller\n\tRemoteCtrlInputs\t\t: TBE_PPC.dt_RemoteCtrlInputs;\t\t\t\t\t\t\t\t\t\t\t//Inputs from remote controller\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)2a7bb31c-c152-4342-b9f5-9a477b364c40_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)125"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}