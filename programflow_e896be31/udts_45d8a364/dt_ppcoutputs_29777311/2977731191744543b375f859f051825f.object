{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)29777311-9174-4543-b375-f859f051825f","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_PPCOutputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)45d8a364-0cc6-418d-abd8-9087f31a2c5c"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tPPC Outputs Structure\n|\tContains outputs from the PPC to external devices\n*)\nTYPE dt_PPCOutputs :\nSTRUCT\n\tInvCmds\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds; \t\t\t//Commands for all Inverter modules\n\tEMSCmds\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCmds;\t\t\t\t//Commands for all EMS modules\n\tCapBankCmds\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankCmds;\t\t//Commands for all cap banks\n\tDiagnostics\t\t: dt_PPCDiagnostics; \t\t\t\t\t\t\t\t\t\t\t\t\t//Diagnostics from core logic\n\tAlarms\t\t\t: TBE_PPC.dt_PlantAlarms; \t\t\t\t\t\t\t\t\t\t\t\t//Plant alarms\n\tInvSts\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice; \t\t\t\t//Array of inverter control/status values\n\tEMSSts\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\t\t\t\t//Array of eMS control/status values\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)29777311-9174-4543-b375-f859f051825f_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)37"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}