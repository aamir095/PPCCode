tion structure (in engineering units)\n\tUnitTypeCfg   \t\t: ARRAY [0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;   \t//Array of structures for unit type configuration\n\tDeviceCfg\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg; \t\t\t\t//Array of device configuration structures\n\tHVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\t\t\t//Array of HV meter configuration structures\n\tMVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\t\t\t//Array of MV meter configuration structures\n\tRedundancyCfg\t\t: TBE_PPC.dt_RedundancyCfg;\t\t\t\t\t\t\t\t\t\t\t\t//Structure of redundancy configuration tags\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)60281cd7-b856-4179-85a3-6d66e795dc38_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)35"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}