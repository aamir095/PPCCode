igger\t: BOOL;\t\t//Mode command trigger\n\t\n\t//STS\n\tSTS_PAuto:BOOL;\n\tSTS_QAuto:BOOL;\n\tSTS_P:REAL; // AC Real Power e.u.\n\tSTS_Q:REAL;  // AC Reactive Power\n\tSTS_PF:REAL; // Power Factor\n\tSTS_Vab:REAL; // Phase A-B Voltage\n\tSTS_Vbc:REAL; // Phase B-C Voltage\n\tSTS_Vca:REAL; // Phase C-A Voltage\n\tSTS_Ia:REAL; // Phase A Current\n\tSTS_Ib:REAL; // Phase B Current\n\tSTS_Ic:REAL; // Phase C Current\n\tSTS_PDC:REAL; //DC Power\n\tSTS_PDel_kWh:REAL;\n\tSTS_PDelDaily_kWh:REAL;\n\tEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)828e3cb4-0467-4834-ad63-d686fe7bb7a0_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)76"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}