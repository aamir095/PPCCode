{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)427c6701-6bef-4207-becb-27724a173cd2","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)dt_CapBankCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)45d8a364-0cc6-418d-abd8-9087f31a2c5c"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)TYPE dt_CapBankCfg :\nSTRUCT\n\t//New Config Values\n\tCapCloseThresh\t: ARRAY[0..SiteConstants.NumCapBanks] OF REAL;\t//Reactive power measurement above which the capacitor bank will be closed, one index per capacitor bank\n\tCapOpenThresh\t: ARRAY[0..SiteConstants.NumCapBanks] OF REAL;\t//Reactive power measurement below which the capacitor bank will be opened, onen index per capacitor bank\n\tThreshWaitTime\t: TIME;\t\t\t\t\t\t\t\t\t\t\t//Time value for capacitor bank logic to wait once the threshold conditions are met before issuing an open/close command\n\tOpTime   \t\t: TIME;   \t\t\t\t\t\t\t\t\t\t//Operation Time\n\tSuspendTime  \t: TIME;  \t\t\t\t\t\t\t\t\t\t//Suspend automatic switching time\n\tCapNomRating\t: ARRAY[0..SiteConstants.NumCapBanks] OF REAL;\t//Capacitor bank nominal reactive power rating\n\tOperAttempt     : UINT\t:= 1;\t\t\t\t\t\t\t\t\t//The max allowed attempt for open/close operation. Default is 1, e.g. only 1 close/open trail allowed for each command issued to the cap bank\n\tQMeasSrc\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t//The source of Q measurement, 0 = HV Meter, 1 = MV Meter, 2 = Inverter Sum\n\tCapBankOperMode\t: UINT := 2;\t\t\t\t\t\t\t\t\t//Capacitor bank operation mode selection (1 = Staged Mode, 2 = Number of Operations Mode)\nEND_STRUCT\nEND_TYPE","LineInfoPersistence":"(string)427c6701-6bef-4207-becb-27724a173cd2_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)36"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}