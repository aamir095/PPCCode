{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)79c0baec-28f5-4b38-af99-3b4fe1d53850","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_ENV","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// AVR control mode\nIF Qmd = PlantCfg.AVR_PF THEN\n\tPfFlag:=1; // power factor control mode \nELSE\n\tPfFlag:=0;\nEND_IF;\t\n\nIF Qmd = PlantCfg.AVR_V OR Qmd = PlantCfg.AVR_VLM THEN // voltage control mode\n\tIF MeterFbk.Sts_Vreg >= PlantCfg.VoltageCfg.Vmax THEN Out:=PlantCfg.VoltageCfg.Vmax; VmaxOn:=TRUE;  QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=FALSE;\n\tELSIF MeterFbk.Sts_Vreg <= PlantCfg.VoltageCfg.Vmin THEN Out:=PlantCfg.VoltageCfg.Vmin; VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=TRUE;  QminOn:=FALSE;\n\tELSIF MeterFbk.Sts_Q <= PlantCfg.ReactivePwrCfg.Qmin THEN Out:=PlantCfg.ReactivePwrCfg.Qmin; VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=TRUE;\n\tELSIF MeterFbk.Sts_Q >= PlantCfg.ReactivePwrCfg.Qmax THEN Out:=PlantCfg.ReactivePwrCfg.Qmax; VmaxOn:=FALSE; QmaxOn:=TRUE;  Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=FALSE;\n\tELSE Out:=V;    VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=TRUE;  Qon:=FALSE; VminOn:=FALSE; QminOn:=FALSE;\n\tEND_IF;\nELSE // power factor or reactive power control mode\n\tIF MeterFbk.Sts_Vreg >= PlantCfg.VoltageCfg.Vmax THEN Out:=PlantCfg.VoltageCfg.Vmax; VmaxOn:=TRUE;  QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=FALSE;\n\tELSIF MeterFbk.Sts_Vreg <= PlantCfg.VoltageCfg.Vmin THEN Out:=PlantCfg.VoltageCfg.Vmin; VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=TRUE;  QminOn:=FALSE;\n\tELSIF MeterFbk.Sts_Q >= PlantCfg.ReactivePwrCfg.Qmax THEN Out:=PlantCfg.ReactivePwrCfg.Qmax; VmaxOn:=FALSE; QmaxOn:=TRUE;  Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=FALSE;\n\tELSIF MeterFbk.Sts_Q <= PlantCfg.ReactivePwrCfg.Qmin THEN Out:=PlantCfg.ReactivePwrCfg.Qmin; VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=FALSE; Qon:=FALSE; VminOn:=FALSE; QminOn:=TRUE;\n\tELSE Out:=Q;    VmaxOn:=FALSE; QmaxOn:=FALSE; Von:=FALSE; Qon:=TRUE;  VminOn:=FALSE; QminOn:=FALSE;\n\tEND_IF;\t\nEND_IF","LineInfoPersistence":"(string)79c0baec-28f5-4b38-af99-3b4fe1d53850_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_ENV \n\n// Envelope control\n// is designed to keep AVR operating point within reactive power, power factor, and voltage limits   \n// providing bumpless switchover between the control modes\n// v.1 [ADA] 1/28/2016 initial version \n\nVAR_INPUT\n\tPlantCfg\t\t: TBE_PPC.dt_PlantCfg; \t\t//Plant configuration struct\n\tMeterFbk\t\t: TBE_PPC.dt_MeterFbk; \t\t//Meter Feedback\n\tQmd\t\t\t\t: UINT;\t\t\t\t\t\t//Reactive power operating mode\nEND_VAR\nVAR\n\tV:REAL;\n\tQ:REAL;\nEND_VAR\nVAR_OUTPUT\n\tOut:REAL;\n    VmaxOn:BOOL;\n    QmaxOn:BOOL;\n\tVon:BOOL;\n\tQon:BOOL;\n\tVminOn:BOOL;\t\n    QminOn:BOOL;\t\n\tPfFlag:BOOL;\nEND_VAR","LineInfoPersistence":"(string)79c0baec-28f5-4b38-af99-3b4fe1d53850_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)71","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}