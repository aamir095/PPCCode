{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)09ed71ac-ffc4-4370-b670-28ffa15b72f4","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_RedundancyCheck","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF NOT FirstScanTag THEN\n\tEnabledSts := TRUE;\nEND_IF\n//Determine watchdog status of remote controller\nRedundancyTmr(IN := (RemoteCtrlWatchdog = RemoteCtrlWatchdogPrev), PT := Cfg_Timeout); \n\n//Determine running status of local controller\nTimeDelta_ms := SysTimeCore.SysTimeGetMs() - TimePrev_ms;\nLocalCtrlRunningSts := (TimeDelta_ms < LocalCtrlRunning_TimeMultiplier * PPC.TaskTime AND TimeDelta_ms > 0) OR TimeDelta_ms < 0;\t\t\nLocalCtrlRunningTmr(IN := LocalCtrlRunningSts, PT := Cfg_Timeout); \n\n//Enable/Disable Logic\nIF MaintModeEn THEN\n\t//Controller has put into maintenance mode -> Set Enabled to FALSE\n\tMaintModeActive := TRUE;\nELSIF MaintModeDis THEN\n\t//Controller has been removed from maintenance mode -> Set Enabled to True\n\tMaintModeActive := FALSE; \nEND_IF\n\nIF En AND (NOT MaintModeActive) AND LocalCtrlRunningTmr.Q THEN\n\tEnabled := TRUE;\n\tIF LocalCtrlRedundancySts THEN\n\t\t//Local controller is currently active\n\t\tIF (RemoteCtrlRedundancySts AND NOT RedundancyTmr.Q) THEN\n\t\t\t//Both controllers are active -> if both are active for longer than 1s, disable controller 2\n\t\t\tBothCtrlActiveTmr(IN := TRUE, PT := Cfg_Timeout); \n\t\t\tIF BothCtrlActiveTmr.Q AND (SystemTags.Serial_Number.strVal > RemoteCtrlSN OR Backup) THEN\n\t\t\t\t//Both controllers are active, timer has elapsed, and Local SN is higher OR local controller is configured as backup -> set local controller to passive status\n\t\t\t\tLocalCtrlRedundancySts := FALSE;\n\t\t\tEND_IF\n\t\tELSIF (NOT RedundancyTmr.Q) AND RemoteCtrlEn AND Backup THEN\n\t\t\t//Remote controller is online/communicating AND enabled AND local controller is configured as backup -> Force local controller to yield control to remote controller\n\t\t\tLocalCtrlRedundancySts := FALSE;\n\t\t\tBothCtrlActiveTmr(In := FALSE, PT := Cfg_Timeout); \n\t\tELSE\n\t\t\tBothCtrlActiveTmr(In := FALSE, PT := Cfg_Timeout); \n\t\tEND_IF\n\tELSE\n\t\t//Local controller is currently passive - check status of remote controller\n\t\tIF RedundancyTmr.Q OR (NOT RemoteCtrlRedundancySts AND NOT RedundancyTmr.Q) THEN\n\t\t\t//Communication to remote controller lost OR remote controller is not active - transition local controller to Active status\n\t\t\tLocalCtrlRedundancySts := TRUE;\n\t\tEND_IF\n\tEND_IF\nELSE\n\tEnabled := FALSE;\n\tLocalCtrlRedundancySts := FALSE;\nEND_IF\n\n//Output comms status\nCtrlCommsSts := NOT RedundancyTmr.Q; \n\n//Set Watchdog prev to watchdog value\nRemoteCtrlWatchdogPrev := RemoteCtrlWatchdog; \nTimePrev_ms := SysTimeCore.SysTimeGetMs(); \n\n//Set first scan tag\nFirstScanTag := TRUE; ","LineInfoPersistence":"(string)09ed71ac-ffc4-4370-b670-28ffa15b72f4_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRedundancy check function block\n|\tDetermine redundancy status of controller\n*)\nFUNCTION_BLOCK fb_RedundancyCheck\nVAR_INPUT\n\tEn\t\t\t\t\t\t: BOOL;\t\t\t\t//Logic will only run if En is true - used to have same FB on RTAC1 and RTAC2\n\tMaintModeEn\t\t\t\t: BOOL;\t\t\t\t//Rising Edge will disable the controller/put it into maintenance mode\n\tMaintModeDis\t\t\t: BOOL;\t\t\t\t//Rising Edge will re-enable the controller after being disabled\n\tRemoteCtrlWatchdog\t\t: UINT;\t\t\t\t//Watchdog input from remote controller\n\tRemoteCtrlRedundancySts\t: BOOL;\t\t\t\t//Redundancy status of remote controller. TRUE = Active controller, FALSE = Passive controller\n\tCfg_Timeout\t\t\t\t: TIME;\t\t\t\t//Redundancy timeout value - if communication with remote controller is lost for longer than this timeout value, local controller will assume control responsibility\n\tRemoteCtrlSN\t\t\t: STRING(255);\t\t//Serial Number of remote RTAC\n\tBackup\t\t\t\t\t: BOOL;\t\t\t\t//True = RTAC is configured as the backup and will yield control if the remote RTAC is online/communicating, False = RTAC is allowed to remain active regardless of the online status of the remote controller\n\tRemoteCtrlEn\t\t\t: BOOL;\t\t\t\t//True = Remote Controller is enabled\nEND_VAR\nVAR_OUTPUT\n\tLocalCtrlRedundancySts\t: BOOL;\t\t//Redundancy status of local controller. TRUE = Active controller, FALSE = Passive controller\n\tCtrlCommsSts\t\t\t: BOOL;\t\t//Communication status between local/remote controller. TRUE = Comms good, FALSE = Comms bad\n\tEnabled\t\t\t\t\t: BOOL;\t\t//True = Local controller may be the Active controller, FALSE = Local controller cannot be the Active controller\nEND_VAR\nVAR\n\tLocalCtrlRunningSts\t\t\t\t: BOOL;\t\t\t//True when local controller is running consistently\n\tLocalCtrlRunningTmr\t\t\t\t: TON;\t\t\t//Timer used to verify that local controller is up and running (controller cannot transition to active until after Cfg_Timeout has elapsed since starting)\n\tLocalCtrlRunning_TimeMultiplier\t: UDINT := 3;\t//Multiplier used to determine if local controller is running (multiplied by task time)\n\tTimePrev_ms\t\t\t\t\t\t: UDINT;\t\t//Timestamp of previous cycle, in ms\n\tTimeDelta_ms\t\t\t\t\t: UDINT;\t\t//Current timestamp - Previous timestamp, in ms\n\tRedundancyTmr\t\t\t\t\t: TON;\t\t\t//Redundancy timer\n\tBothCtrlActiveTmr\t\t\t\t: TON;\t\t\t//Timer to disable 1 controller is other is active\n\tRemoteCtrlWatchdogPrev\t\t\t: UINT;\t\t\t//Previous value of watchdog input from remote controller\n\tEnabledSts\t\t\t\t\t\t: BOOL := TRUE;\t//Enabled status, true by default\n\tMaintModeEn_Prev\t\t\t\t: BOOL;\t\t\t//Previous value of enable input\n\tMaintModeDis_Prev\t\t\t\t: BOOL;\t\t\t//Previous value of enable input\n\tFirstScanTag\t\t\t\t\t: BOOL;\nEND_VAR\nVAR RETAIN\n\tMaintModeActive\t\t\t\t\t: BOOL;\nEND_VAR","LineInfoPersistence":"(string)09ed71ac-ffc4-4370-b670-28ffa15b72f4_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)157","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}