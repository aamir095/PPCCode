{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)3e66f4c2-f3da-4ad8-ae17-3a266a5af447","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_PI","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF NOT .RtacOnline THEN\n\tIout:=0;\n\tOut:=0;\nEND_IF\n\n// reset alarms\n(*\nFOR I:=1 TO UINT_TO_INT(SIZEOF(Alarm)) DO\n\tAlarm[I]:=FALSE;\nEND_FOR\n*)\nDiag.PVHi := FALSE;\nDiag.PVLo := FALSE;\nDiag.SPHi := FALSE;\nDiag.SPLo := FALSE;\nDiag.CVHi := FALSE;\nDiag.CVLo := FALSE;\n\n// Fault communications\nIF Fault THEN Auto:=FALSE; END_IF;\n\n// input limiting\nIF PV > MaxIn THEN\n\tAlarm[1]:=TRUE;\n\tPV:=MaxIn;\n\tDiag.PVHi := TRUE; \nEND_IF;\nIF PV < MinIn THEN\n\tAlarm[2]:=TRUE;\n\tPV:=MinIn;  \t\n\tDiag.PVLo := TRUE; \nEND_IF\nIF SP > MaxIn THEN\n\tAlarm[3]:=TRUE;\n\tSP:=MaxIn;\n\tDiag.SPHi := TRUE; \nEND_IF;\nIF SP < MinIn THEN\n\tAlarm[4]:=TRUE;\n\tSP:=MinIn;  \n\tDiag.SPLo := TRUE; \t\nEND_IF\n\n// setpoint tracking\n//IF NOT Auto THEN PV:=SP; END_IF; \nIF NOT Auto THEN SP:=PV; END_IF; //[MCT] - Replaces line above - SP should track PV \n\n// velocity PI controller\nE:= SP - PV; // Error\n\n//Plant PID Overshoot Protection\nIF SP > PV THEN\n\t//Process variable is less than setpoint -> set IsItrack to false\n\tIsITrack := FALSE;\n\tDiag.OvshtResp1Active := FALSE;\n\tDiag.OvshtResp2Active := FALSE;\nELSIF Itrack AND NOT IsITrack AND Auto AND (PV > (HOL + OvshtDbd2)) THEN\n\t//PV overshoot is greater than deadband 2 (larger deadband) -> limit output to HOL\n\tOut := HOL;\n\tOutPrev := HOL;\n\tIsItrack := TRUE;\n\tDiag.OvshtResp2Active := TRUE;\nELSIF Itrack AND NOT IsItrack AND Auto AND (PV > (HOL + OvshtDbd1)) THEN\n\t//Plant PID overshoot protection - reduce the OutPrev by Overshoot Protection Response value to articifically lower the PID output\n\tOutPrev := OutPrev - OvshtResponse;\n\tDiag.OvshtResp1Active := TRUE; \nEND_IF\n(*\n// Integral tracking - set output to a measured value\nIF SP > PV + Dbd THEN\n\tIsItrack:=FALSE;\nELSIF E < 0 AND Itrack AND NOT IsItrack AND Auto THEN\t\n    OutPrev:=OutTrack; // track output\n    IsItrack:=TRUE;\n\tE1:=0;\nEND_IF\n*)\n//<MCT> - separated the proportional and integral terms into separate tags to limit the size of the integral output\nPout:=Kp*(E-E1);\t//Proportional output calculation\nIout:=Iout+Ki*E*T;\t//Integral output calculation\n//<MCT> Keep the integral output from exceeding the limit\nIF ABS(Iout)>ABS(Out*ILimit) THEN\n\tIout:=Out*ILimit;\nEND_IF\n\nIF Freeze THEN\n\tOut:=OutPrev + Kp*(E-E1);\nELSE\n    Out:=OutPrev + Kp*(E-E1) + Ki*E*T;\nEND_IF\n\n// manual output\nIF NOT Auto THEN Out:=ManOut; END_IF;\n\n// output bias\nOut:=Out+OutBias;\n\nE1:=E; // save error for next cycle\n\n// test fix for NAN in Qout\nIF NOT (out = out)  THEN\n\tOut:=Mem_Out;\nEND_IF\n\nMem_out:=Out;\n\n// output limiting\nIF Out > MaxOut THEN\n\tAlarm[5]:=TRUE;\n\tOut:=MaxOut;\n\tDiag.CVHi := TRUE; \nEND_IF;\nIF Out < MinOut THEN\n\tAlarm[6]:=TRUE;\n\tOut:=MinOut;  \t\n\tDiag.CVLo := TRUE; \nEND_IF\n\nIF Auto THEN ManOut:=Out; END_IF; // track manual output\n\n//Update Diagnostics\nDiag.Error := E; \nDiag.IOut := Iout;\nDiag.POut := Pout;\nDiag.AutoSts := Auto; \nDiag.MinOut := MinOut;\nDiag.MaxOut := MaxOut; ","LineInfoPersistence":"(string)3e66f4c2-f3da-4ad8-ae17-3a266a5af447_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_PI\n// Proportional–integral controller\n// v.1 [ADA] 1/28/2016 initial version \n\nVAR_INPUT\n\tSP:REAL;       // Setpoint\n\tPV:REAL;       // Process variable\n    OutPrev:REAL;  // Previous output\n\tKp:REAL;       // Proportional gain\n\tKi:REAL;       // Integral gain\n    Auto: BOOL;    // Automatic/manual mode\n    ManOut:REAL;   // Output in manual mode\n    OutBias:REAL;  // Value added to the output for feed forward control\n    MaxIn:REAL;    // Maximum PV and SP\n    MinIn:REAL;    // Minumum PV and SP\n    MaxOut:REAL;   // Maximum output\n    MinOut:REAL;   // munimum output\n\tIt:INT;\t\t   //<MCT>Iterations for integral output\n    Freeze:BOOL;   // Freezes integral term\n\tFault:BOOL;\n\tItrack:BOOL:=FALSE; // integral tracking/PID overshoot response enabled\n\tOutTrack:REAL; // output backtracking \n\tT:REAL:=TaskCycleTime;\n\tILimit:REAL;\t//<MCT>Integral output limit to X% of the output\n\tHOL:REAL; //High Operating Limit for PV in p.u.\n\tOvshtDbd1\t\t: REAL;\t\t\t\t//Smaller error deadband after which plant overshoot protection is activated\n\tOvshtDbd2\t\t: REAL;\t\t\t\t//Larger error deadband after which PID output is limited to the HOL of the plant\n\tOvshtResponse\t: REAL;\t\t\t\t//Adjustable value used to tune the P PID overshoot response. This value is subtracted from the PID output each execution cycle\nEND_VAR\nVAR_OUTPUT\n\tOut\t\t: REAL;\t\t\t\t\t\t\t//PID Output/Control Variable\n\tDiag\t: TBE_PPC.dt_PIDDiagnostics; \t//PID Diagnostics\n    Alarm:ARRAY[1..6] OF BOOL; // 1- pv hi/2- pv lo/ 3-sp hi/ 4 - sp lo/ 5 - out hi/ 6 - out lo\nEND_VAR\nVAR\n\tPout:REAL;\t//<MCT>Proportional Output\n\tIout:REAL;\t//<MCT>Integral Output\n\tE:REAL:=0;\t//Error\n\tE1:REAL:=0;\n\tIsItrack:BOOL:=FALSE; // single shot\n\tDbd:REAL; //Deadband\n\tI:INT;\n\t\n\tMem_Out:REAL;\n\ttest:BOOL;\nEND_VAR","LineInfoPersistence":"(string)3e66f4c2-f3da-4ad8-ae17-3a266a5af447_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)246","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}