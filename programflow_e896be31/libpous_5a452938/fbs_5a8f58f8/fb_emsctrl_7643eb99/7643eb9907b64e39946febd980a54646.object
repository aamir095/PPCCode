{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)7643eb99-07b6-4e39-946f-ebd980a54646","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_EMSCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//EMS Cfg FB call\n\n//Timer to trigger periodic writes to EMS\nCmdTmr(IN := NOT CmdTmr.Q, PT := EMSUnitType.CmdDelayPT);\n\n//Auto/Manual Control\nEMS_in.STS_PAuto := HMICmds.PAutoEn;\nEMS_in.Sts_QAuto := HMICmds.QAutoEn;\n\n//Start/Stop Control\nIF HMICmds.Estop THEN\n\tEMSCmds.Start := 0;\nELSIF HMICmds.Run OR (EMS_in.Sts_Pauto OR EMS_in.Sts_Qauto) THEN\n\t//EMS is in auto\n\tEMSCmds.Start := 1;\nELSE\n\tEMSCmds.Start := 0;\nEND_IF\n\n//Start Trigger\nIF EMSCmds.Start <> StartCmdPrev THEN\n\tEMSCmds.StartTrigger := TRUE;\nELSE\n\tEMSCmds.StartTrigger := FALSE;\nEND_IF\n\n//Active power setpoint\nIF EMS_in.STS_PAuto THEN\n\t//EMS is in auto - use plant-level active power command and trigger periodically based on CmdTmr\n\tIF CmdTmr.Q THEN\n\t\tEMSCmds.PCmd := Plant_EMS_PCmd;\n\t\tEMSCmds.PTrigger := TRUE;\n\tELSE\n\t\tEMSCmds.PTrigger := FALSE;\n\tEND_IF\nELSIF EMSCmds.PCmd <> HMICmds.PSp OR (PeriodicPQTrigger AND CmdTmr.Q) THEN\n\t//EMS is in manual - use HMI Command and trigger on change or periodically if PeriodicPQTrigger is true\n\tEMSCmds.PCmd := HMICmds.PSp;\n\tEMSCmds.PTrigger := TRUE;\nELSE\n\tEMSCmds.PTrigger := FALSE;\nEND_IF\n\n//Reactive power setpoint\nIF EMS_in.Sts_QAuto THEN\n\t//EMS is in auto - use plant-level reactive power command and trigger periodically based on CmdTmr\n\tIF CmdTmr.Q THEN\n\t\tEMSCmds.QCmd := Plant_EMS_QCmd;\n\t\tEMSCmds.QTrigger := TRUE;\n\tELSE\n\t\tEMSCmds.QTrigger := FALSE;\n\tEND_IF\nELSIF EMSCmds.QCmd <> HMICmds.QSp OR (PeriodicPQTrigger AND CmdTmr.Q) THEN\n\t//EMS is in manual - use HMI Command and trigger on change or periodically if PeriodicPQTrigger is true\n\tEMSCmds.QCmd := HMICmds.QSp;\n\tEMSCmds.QTrigger := TRUE;\nELSE\n\tEMSCmds.QTrigger := FALSE;\nEND_IF\n\nStartCmdPrev := EMSCmds.Start;\nEMS_out := EMS_in; \n","LineInfoPersistence":"(string)7643eb99-07b6-4e39-946f-ebd980a54646_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tEMS control function block\n*)\nFUNCTION_BLOCK fb_EMSCtrl\nVAR_INPUT\n\tEMS_in\t\t\t\t: TBE_PPC.dt_InvDevice;\t\t\t\t//Device structure\n\tPlant_EMS_PCmd\t\t: REAL;\t\t\t\t\t\t\t\t//Plant-level EMS active power command\n\tPlant_EMS_QCmd\t\t: REAL;\t\t\t\t\t\t\t\t//Plant-level EMS reactive power command\n\tEMSUnitType\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//EMS unit type\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\nEND_VAR\nVAR_OUTPUT\n\tEMS_out\t\t\t\t: TBE_PPC.dt_InvDevice;\n\tEMSCmds\t\t\t\t: TBE_PPC.dt_DeviceCmds;\nEND_VAR\nVAR\n\tCmdTmr\t\t\t\t: TON;\t\t//Command timer used to issue P/Q triggers when in Auto\n\tStartCmdPrev\t\t: INT;\t\t//Previous value of start command\n\tPeriodicPQTrigger\t: BOOL := FALSE;\t//True = P/Q will be triggered periodically, regardless of auto/manual mode, False = P/Q will be triggered periodically in P/Q Auto mode and on change in P/Q Manual mode\nEND_VAR","LineInfoPersistence":"(string)7643eb99-07b6-4e39-946f-ebd980a54646_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)110","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}