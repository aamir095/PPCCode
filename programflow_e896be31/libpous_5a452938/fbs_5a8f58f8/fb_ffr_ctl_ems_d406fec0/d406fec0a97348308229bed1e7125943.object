{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d406fec0-a973-4830-8229-bed1e7125943","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_FFR_CTL_EMS","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine enabled status based on overall configuration en/disable and the under/overfreq response en/disable tags\nEnabled := (EN AND FFRCfg.FFREn_PV AND (FFRCfg.OverFreqRespEn OR FFRCfg.UnderFreqRespEn));\n\n//Check to see if there are any configuration related errors\nCfgErr := (FFRCfg.OverFreqResetThresh > FFRCfg.OverFreqDbd OR FFRCfg.UnderFreqResetThresh < FFRCfg.UnderFreqDbd);\n\n//Determine charge/discharge capability\nIF UseDynCap THEN\n\tPlantCapabilityDisch := DischCap; \n\tPlantCapabilityChrg := ChrgCap;\nELSE\n\t//Use static PMin/PMax values\n\tPlantCapabilityDisch := -PMin;\n\tPlantCapabilityChrg := PMax; \nEND_IF\n\n//Determine state\nIF NOT Enabled THEN\n\t//FFR is disabled\n\tDiag.State := TBE_PPC.enum_FFRState.Inhibited;\n\tOutTemp := 0; \nELSIF CfgErr  THEN\n\t//Faulted state\n\tDiag.State := TBE_PPC.enum_FFRState.Fault;\n\tOutTemp := 0; \nELSE\n\t//Idle/Active/Recovery block\n\tIF ((FreqFbk > 1.0 + FFRCfg.OverFreqDbd AND FFRCfg.OverFreqRespEn) OR (FreqFbk < 1.0 + FFRCfg.UnderFreqDbd AND FFRCfg.UnderFreqRespEn) OR EventActive) AND NOT RecoveryActive THEN\n\t\t//FFR event active\n\t\tEventActive := TRUE;\n\t\tDiag.State := TBE_PPC.enum_FFRState.Active;\n\t\t\n\t\t//Calculate output based on desired mode (droop vs. fixed magnitude)\n\t\tIF FFRCfg.DroopModeEn THEN\n\t\t\t//Calculate output based on droop calculation\n\t\t\tIF FreqFbk > 1.0 THEN\n\t\t\t\t//Overfrequency (1.0 used as nominal frequency)\n\t\t\t\tOutTemp := -(FreqFbk - 1.0 - FFRCfg.OverFreqDbd) * FFRCfg.OverFreqDrooopCoeff * PlantCapabilityChrg ;\n\t\t\t\t//Add Error\n\t\t\t\tIF PErr > 0.0 THEN\n\t\t\t\t\tOutTemp := OutTemp - PErr; \n\t\t\t\tEND_IF\n\t\t\tELSE\n\t\t\t\t//Underfrequency\n\t\t\t\tOutTemp := -(FreqFbk - 1.0 - FFRCfg.UnderFreqDbd) * FFRCfg.OverFreqDrooopCoeff * PlantCapabilityDisch ;\n\t\t\t\t//Add Error\n\t\t\t\tIF PErr < 0.0 THEN\n\t\t\t\t\tOutTemp := OutTemp + Perr;\n\t\t\t\tEND_IF\n\t\t\tEND_IF\n\t\t\t\n\t\t\t//Determine if in recovery mode\n\t\t\tIF (Out < 0 AND FreqFbk < 1.0 + FFRCfg.OverFreqDbd) OR (Out > 0 AND FreqFbk > 1.0 + FFRCfg.UnderFreqDbd) THEN\n\t\t\t\tEventActive := FALSE;\n\t\t\t\tRecoveryActive := TRUE;\n\t\t\tEND_IF\n\t\tELSE\n\t\t\t//Set output to fixed magnitude adjustment - Use the sign of the frequency error to determine sign of adjustment\n\t\t\tIF FreqFbk <> 1 AND NOT RecoveryActive THEN\n\t\t\t\tOutTemp := (ABS(1.0 - FreqFbk) / (1.0 - FreqFbk)) * FFRCfg.FixedMagAdj_PV;\n\t\t\t\tIF OutTemp < 0.0 AND PErr > 0.0 THEN\n\t\t\t\t\tOutTemp := OutTemp - PErr;\n\t\t\t\tELSIF \tOutTemp > 0.0 AND PERR < 0.0 THEN\n\t\t\t\t\tOutTemp := OutTemp + PErr;\n\t\t\t\tEND_IF\n\t\t\t\tSustainTON(IN := TRUE, PT := FFRCfg.SustainTime); \t//Call sustain timer\n\t\t\tELSE\n\t\t\t\tOutTemp := 0; \n\t\t\tEND_IF\n\t\t\t//Determine if in recovery mode (fixed magnitude)\n\t\t\t//FreqOutDb is TRUE when frequency remains outside  deadband\n\t\t\tFreqOutDb := (FreqFbk > 1.0 + FFRCfg.OverFreqDbd AND FFRCfg.OverFreqRespEn) OR (FreqFbk < 1.0 + FFRCfg.UnderFreqDbd AND FFRCfg.UnderFreqRespEn);\n\t\t\t\n\t\t\t//Frequency-based reset (freq returned within reset threshold)\n\t\t\tFreqWithinResetDb := (Out < 0 AND FreqFbk < 1.0 + FFRCfg.OverFreqResetThresh) OR (Out > 0 AND FreqFbk > 1.0 + FFRCfg.UnderFreqResetThresh);\n\t\t\t\n\t\t\tIF FFRCfg.FixedMagFreqContEn THEN\n\t\t\t\t//Mode 2: Hold until sustain expires AND frequency is back within deadband\n\t\t\t\tIF FreqWithinResetDb OR (SustainTON.Q AND NOT FreqOutDb) THEN\n\t\t\t\t\tEventActive := FALSE;\n\t\t\t\t\tRecoveryActive := TRUE;\n\t\t\t\t\tSustainTON(IN := FALSE, PT := FFRCfg.SustainTime);\n\t\t\t\t\tOutTemp := 0;\n\t\t\t\tEND_IF\n\t\t\tELSE\n\t\t\t\t//Mode 1: Timed hold only - release after SustainTime regardless of frequency\n\t\t\t\tIF FreqWithinResetDb OR SustainTON.Q THEN\n\t\t\t\t\tEventActive := FALSE;\n\t\t\t\t\tRecoveryActive := TRUE;\n\t\t\t\t\tSustainTON(IN := FALSE, PT := FFRCfg.SustainTime);\n\t\t\t\t\tOutTemp := 0;\n\t\t\t\tEND_IF\t\n\t\t\tEND_IF\t\n\t\tEND_IF\t\n\tEND_IF\t\n\t//Recovery is active\n\tIF RecoveryActive THEN\n\t\tDiag.State := TBE_PPC.enum_FFRState.Recovery;\n\t\tIF FFRCfg.DroopModeEn THEN\n\t\t\t//Droop Mode -> Set Out to 0 and start recovery time. Once recover timer has elapsed, set Recovery Active flag to FALSE.\n\t\t\tOutTemp := 0;\n\t\t\tRecoverTON(IN := TRUE, PT := FFRCfg.RecoverTime); \n\t\t\tIF RecoverTON.Q THEN\n\t\t\t\tRecoveryActive := FALSE;\n\t\t\tEND_IF\n\t\tELSE\n\t\t\t//Fixed Magnitude Mode -> Ramp Out to 0 at the specified ramp rate. Once it reaches 0, start the recovery timer. Once recovery timer has elapsed, set Recovery Active flag to FALSE.\n\t\t\tOutTemp := 0; \n\t\t\tRecoverTON(IN := ABS(Out) < RecoverThresh, PT := FFRCfg.RecoverTime); \n\t\t\tIF RecoverTON.Q THEN\n\t\t\t\tRecoveryActive := FALSE;\n\t\t\tEND_IF\n\t\tEND_IF\n\tEND_IF\n\t\n\tIF NOT RecoveryActive AND NOT EventActive THEN\n\t\t//Current state is idle -> Set Out to 0\n\t\tOutTemp := 0;\n\t\tDiag.State := TBE_PPC.enum_FFRState.Standby;\n\tEND_IF\nEND_IF\n\n\n//Ramp Output - Ramp will only apply during recovery and when fixed magnitude mode is enabled\nIF RecoveryActive AND NOT FFRCfg.DroopModeEn THEN\n\tRampUpRate := FFRCfg.RecoverRampUpRate;\n\tRampDownRate := FFRCfg.RecoverRampDnRate;\nELSE\n\tRampUpRate := 0; \t//Ramp block disabled (rate of 0 will disable ramp block)\n\tRampDownRate := 0; \t//Ramp block disabled (rate of 0 will disable ramp block)\nEND_IF\nRampBlock(En := TRUE, SP := OutTemp, UpLim := RampUpRate, DnLim := RampDownRate, TaskTime := TaskTime, Out => Out);\nRecoverTON(IN := RecoveryActive, PT := FFRCfg.RecoverTime); \nPErr:=Pref - Pmeas; \n//Diagnostics\nDiag.FFROutput \t\t:= Out;\t\t\t\t\nDiag.FFFRActive\t\t:=  EventActive;\nDiag.Enabled        := Enabled;","LineInfoPersistence":"(string)d406fec0-a973-4830-8229-bed1e7125943_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tFast Frequency Response control function block \n*)\nFUNCTION_BLOCK fb_FFR_CTL_EMS \nVAR_INPUT\n\tEn\t\t\t: BOOL;\t\t\t\t\t//True = Primary Frequency Response is enabled, False = Primary Frequency Response is disabled\n\tFreqFbk\t\t: REAL;\t\t\t\t\t//[pu], Measured frequency\n\tPref\t\t: REAL;\t\t\t\t\t//[pu], Active power reference value/setpoint - used to determine error between active power SP/PV and calculate droop output accordingly\n\tPmeas\t\t: REAL;\t\t\t\t\t//[pu], Active power feedback - used to determine error between active power SP/PV and calculate droop output accordingly\n\tUseDynCap\t: BOOL;\t\t\t\t\t//True = Dynamic charge/discharge capacity will be used for frequency calculation, False = PMin/Pmax will be used for frequency calculation\n\tDischCap\t: REAL;\t\t\t\t\t//[pu], EMS available discharge capacity\n\tChrgCap\t\t: REAL;\t\t\t\t\t//[pu], EMS available charge capacity\n\tPMax\t\t: REAL;\t\t\t\t\t//[pu], EMS/BESS maximum active power capability (static value)\n\tPMin\t\t: REAL;\t\t\t\t\t//[pu], EMS/BESS minimum active poewr capability (static value) - negative value, converted within FB\n\tFFRCfg\t\t: TBE_PPC.dt_FFRCfg;\t//FFR configuration struct\n\tTaskTime\t: REAL;\t\t\t\t\t//PPC Task Time\nEND_VAR\nVAR_OUTPUT\n\tOut\t\t: REAL;\t\t\t\t\t\t\t\t\t//[pu], Frequency Droop Output - Active power adjustment value that should be added to plant active power setpoint post-ramp block\n\tDiag\t: TBE_PPC.dt_FFRDiag; \t\t\t\t\t//FFR diagnostics structure\nEND_VAR\nVAR\n\tDev\t\t\t\t\t: REAL;\t\t\t\t//Frequency deviation from nominal frequency, pu\n\tPErr\t\t\t\t: REAL;\t\t\t\t//Active power error between reference and measured power, pu\n\tPlantCapability\t\t: REAL;\t\t\t\t//[pu], Plant capability used in droop calculation (HSL or HOL)\n\tOut_Prev\t\t\t: REAL;\t\t\t\t//Previous output value\n\tEnabled\t\t\t\t: BOOL;\t\t\t\t//TRUE = FFR function enabled and valid\n\tCfgErr\t\t\t\t: BOOL;\t\t\t\t//TRUE = Configuration error detected\n\tEventActive\t\t\t: BOOL;\t\t\t\t//TRUE = Frequency response event is currently active\n\tRecoveryActive\t\t: BOOL;\t\t\t\t//TRUE = Recovery state active\n\tRampBlock\t\t\t: TBE_PPC.fb_R_LIM;\t\t\t//Ramp limiter block used during recovery\n\tRecoverThresh\t\t: REAL := 0.0001;\t//Threshold at which output is considered recovered to zero\n\tRecoverTON\t\t\t: TON;\t\t\t\t//Recovery timer\n\tSustainTON\t\t\t: TON;\t\t\t\t//Fixed magnitude sustain timer\n\tOutTemp\t\t\t    : REAL;\t\t\t\t//Temporary active power adjustment value before ramp limiting\n\tRampUpRate\t\t\t: REAL;\t\t\t\t//Ramp up rate used during recovery\n\tRampDownRate\t\t: REAL;\t\t\t\t//Ramp down rate used during recovery\n\tFreqResFixedMagEn\t: BOOL;\t\t\t\t//TRUE = Hold fixed magnitude response until frequency returns inside deadband, FALSE = Release response immediately after SustainTime expires\n\tFreqOutDb\t\t\t: BOOL;\t\t\t\t//TRUE = Frequency is currently outside deadband\n\tFreqWithinResetDb\t: BOOL;\t\t\t\t//TRUE = Frequency has returned inside reset threshold/deadband\n\tSustainElapsed\t\t: BOOL;\t\t\t\t//TRUE = Sustain timer has elapsed and hold period is complete\n\tPlantCapabilityDisch: REAL;\t\t\t\t//Plant discharge capability, used wihtin frequency calculation\n\tPlantCapabilityChrg\t: REAL;\t\t\t\t//Plant charge capability, used within frequency calculation\nEND_VAR","LineInfoPersistence":"(string)d406fec0-a973-4830-8229-bed1e7125943_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)259","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}