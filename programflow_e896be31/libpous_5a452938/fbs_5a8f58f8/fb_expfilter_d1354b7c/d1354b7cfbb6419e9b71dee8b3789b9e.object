{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d1354b7c-fbb6-419e-9b71-dee8b3789b9e","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_ExpFilter","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF NOT .RtacOnline THEN\n\ty:=RawIn;\nEND_IF\ny:=RawIn;\nIF Tcon <> 0 THEN\n\tExponent:=UDINT_TO_REAL(Interval)/UDINT_TO_REAL(Tcon);\nELSE\n\tExponent := 1; //Divide by 0 protection - set exponent to 1\nEND_IF\na:=1-EXP(-Exponent);\t//Calculate the smoothing factor\n//Check a to limits 0<=a<=1\nIF a<0.0 THEN\n\ta:=0.0;\n\tELSIF a>1.0 THEN\n\ta:=1.0;\nEND_IF\n\n//Check against limits\nIF y1<Outmin THEN\n\ty1:=Outmin;\n\tELSIF y1>Outmax THEN\n\ty1:=Outmax;\n\tELSE\n\ty1:=y;\t\t\nEND_IF\n\ny:=a*y1+(1-a)*RawIn;\t//Calculate result\ny1:=y;\t//Update y1\nOut:=y;\t//Update output","LineInfoPersistence":"(string)d1354b7c-fbb6-419e-9b71-dee8b3789b9e_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_ExpFilter\n\n//Exponential Filter\n//A filter to be applied to the PI control PV\n// v.1 [MCT] 6/15/2016 initial version \n\nVAR\n\ta:REAL;\t//Smoothing factor\n\ty:REAL;\t//Result\n\ty1:REAL;\t//Last result\n\tExponent:real;\t//Exponent\nEND_VAR\nVAR_INPUT\n\tTcon:UDINT;\t\t//Time Constant\n\tInterval:UDINT;\t//Sample Interval\n\tRawIn:REAL;\t//Raw Input\n\tOutmin:REAL;\t//Min output\n\tOutmax:REAL;\t//Max output\nEND_VAR\nVAR_OUTPUT\n\tOut:REAL;\t//FB Output\nEND_VAR","LineInfoPersistence":"(string)d1354b7c-fbb6-419e-9b71-dee8b3789b9e_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)78","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}