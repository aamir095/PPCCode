{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)80468261-eeb8-484c-b2ec-e7e9c2ccc617","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_VQDroop","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5a8f58f8-c6ba-4ffa-94ba-cef74e922e26"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Calculate the voltage error (Vref) as the difference between measured voltage and setpoint voltage\n//Determine if the droop calculation logic needs to recalculate a Q setpoint (Q setpoint will only be calculated if the error changes by greater than the hysteresis value)\nVref := Vmeas - Vsp;          \t\t\t\t//Voltage Droop reference value - Error between the measured voltage and voltage setpoint\nVchange := ABS(VrefLast - Vref);  \t\t\t//Change in vref since last update - Difference in Vref between current cycle and when the droop calculation was last run\nIF Vchange > Hyst THEN\n\tVrefLast := Vref;\t\t\t\t\t\t//Store Vref for comparison\n\tDroopCalc := TRUE;\t\t\t\t\t\t//Set droop calc flag to true so that droop logic recalculates the Q setpoint\nEND_IF\n\n//Recalculate Droop Output based on voltage droop curve w/ deadband\n//If voltage error is within the deadband region, then Q Setpoint will be 0. Otherwise, the Q Setpoint will be calculated based on \nIF DroopCalc THEN\n\tDroopCalc := FALSE;\n\tIF Vref <= -Dbd_Lo AND InjDroop > 0.0 THEN\n\t\tOutDb   := TRUE;\n\t\tVOffset := Gain_Kp * Qmeas;   \t\t //Voltage Offset Based on curent MVAR generation\n\t\tVsp_Offset \t:= Vsp - VOffset;  \t\t // Apply V-Q droop compensation to the voltage reference\n\t\t//Reference is below the low deadband value, Reactive power injection required\n\t\t//Droop := -(Vref + Dbd_Lo) / InjDroop * Outmax;\n\tELSIF Vref > Dbd_Hi AND AbsDroop > 0.0 THEN\n\t\tOutDb   := TRUE;\n\t\tVOffset := Gain_Kp * Qmeas;   \t\t //Voltage Offset Based on curent MVAR generation\n\t\tVsp_Offset \t:= Vsp - VOffset;  \t \t// Apply V-Q droop compensation to the voltage reference\n\t\t//Reference is above the high deadband value, Reactive power absorption required\n\t\t//Droop := (Vref - Dbd_Hi) / AbsDroop * Outmin;\n\tELSE\n\t\t//Vref is within the deadband region or invalid droop settings -> Set Droop output to 0. \n\t\tDroop := 0.0;\n\t\tVQDroopOffset :=0.0;\n\t\tOutDb   := FALSE;\n\t\tVsp_Offset := Vsp;                                                        \n\tEND_IF\n\t//VQDroop PI Block; output(Q) from this will be input to AVR PI Block\n\tIF OutDb THEN\n\t\tVQDroop_PI(SP:=Vsp_Offset,PV:=Vmeas,OutPrev:=VQDroop_PI.Out,Kp:=0.2,Ki:=0.3,Auto:=TRUE,MaxIn:=1.1,MinIn:=0.9,MaxOut:=1,MinOut:=-1,Freeze:=FALSE,OutTrack:=VQDroop_PI.Out*0.999,T:=UDINT_TO_REAL(PPC.TaskTime)/1000,HOL:=1);\n\t\tDroop := VQDroop_PI.Out;\n\tEND_IF\nEND_IF\n\n \n//Keep QDroop within reactive power limits\nIF Droop < Outmin THEN\n\tDroop := Outmin;\nELSIF Droop > Outmax THEN\n\tDroop := Outmax;\nEND_IF\n\n//Assign droop output to Q Sp\nOut := Droop;\n\n//Diagnostics Mapping\nVQDroopOffset\t\t\t\t\t  \t:= VOffset;\nVQDroopDiag.VQDroopPID_SP \t\t\t:= Vsp;\nVQDroopDiag.VQDroopPID_PV\t\t\t:= Vmeas;\nVQDroopDiag.VQDroopPID_CV \t\t\t:= VQDroop_PI.Out;\nVQDroopDiag.VQDroopPIDDiagnostics   := VQDroop_PI.Diag;\n\n","LineInfoPersistence":"(string)80468261-eeb8-484c-b2ec-e7e9c2ccc617_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tVoltage w/Reactive Droop Function block \n|\tCalculate the reactive power setpoint based on a voltage droop curve with deadband region\n|\tA new reactive power setpoint will only be calculated when the voltage error differs from the previous droop calculation error by more than the hysteresis value\n*)\nFUNCTION_BLOCK fb_VQDroop\nVAR_INPUT\n\tVsp\t\t\t: REAL;    \t//[pu, Vbase], Voltage Droop setpoint\n\tVmeas\t\t: REAL;    \t//[pu, Vbase], Voltage measurement\n\tOutmin\t\t: REAL;    \t//[pu, Sbase], Minimum Droop Output\n\tOutmax\t\t: REAL;   \t//[pu, Sbase], Maximum Droop Output\n\tHyst\t\t: REAL;   \t//[pu, Vbase], Voltage reference hysteresis\n\tAbsDroop\t: REAL;  \t//[pu], Absorption Droop\n\tInjDroop\t: REAL; \t//[pu], Injection Droop\n\tDbd_Hi\t\t: REAL;\t\t//[pu, Vbase], Deadband region above the voltage setpoint (positive value)\n\tDbd_Lo\t\t: REAL;\t\t//[pu, Vbase], Deadband region below the voltage setpoint (must be positive value)\n    Gain_Kp\t\t: REAL;\t\t//[pu, VChange/MVA], Voltage-reactive power droop gain (pu Voltage/pu Reactive Power)\n\tQmeas       : REAL; \t//[pu, Sbase], Meter Reactive Power Feedback\n\t\nEND_VAR\nVAR\n\tVchange\t\t\t: REAL;\t\t//[pu, Vbase], Difference in voltage error between current cycle and when the droop calculation was last run\n\tVref\t\t\t: REAL;   \t//[pu, Vbase], Voltage reference (difference between the measured voltage and voltage setpoint)\n\tVrefLast\t\t: REAL;  \t//[pu, Vbase], Vref when the last droop calculation was run\n\tDroop\t\t\t: REAL;   \t//[pu, Sbase], Droop curve output (reactive power setpoint)\n\tDroopCalc\t\t: BOOL;   \t//Flag Calculate New Droop Value\n\tVOffset\t\t\t: REAL; \t//[pu, Vbase],Voltage offset for V w/Reactive Droop  calculation\n\tVQDroop_PI\t\t: fb_PI;\t//VQDroop PI Block\n\tOutDb           : BOOL;\t\t//Variable to track vref value outside hyst & deadband\nEND_VAR\nVAR_OUTPUT\t\n\tOut\t\t\t\t: REAL;\t\t//[pu, Sbase], Reactive power setpoint calculated as a function of the voltage droop curve\n\tVQDroopOffset\t: REAL;\t\t//[pu, Vbase],Voltage offset for V w/Reactive Droop  calculation\n\tVQDroopDiag     : TBE_PPC.dt_VQPIDroopDiagnostics;\nEND_VAR\n\nVAR_TEMP\n\tVsp_Offset\t\t: REAL;\t\t//[pu, Vbase], temp Vsp offset value \nEND_VAR\n\n","LineInfoPersistence":"(string)80468261-eeb8-484c-b2ec-e7e9c2ccc617_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)121","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}