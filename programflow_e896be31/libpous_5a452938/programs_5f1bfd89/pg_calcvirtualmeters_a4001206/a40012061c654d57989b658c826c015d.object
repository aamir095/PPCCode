{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a4001206-1c65-4d57-989b-658c826c015d","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_CalcVirtualMeters","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)5f1bfd89-e8d6-40b1-b151-6e2cd03e690f"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//PV and BESS Feeder level virtual meter calculation\n\n//Reset values that are calculated by summation\nVirtualMeterFbk.PVFeederMeterFbk.Sts_P := 0;\nVirtualMeterFbk.PVFeederMeterFbk.Sts_Q := 0;\nVirtualMeterFbk.BESSFeederMeterFbk.Sts_P := 0;\nVirtualMeterFbk.BESSFeederMeterFbk.Sts_Q := 0;\nVirtualMeterFbk.PVFeederMeterFbk.Sts_flt := TRUE;\nVirtualMeterFbk.BESSFeederMeterFbk.Sts_flt := TRUE;\nVirtualMeterFbk.POIFeederMeterFbk.Sts_flt := TRUE;\n\n//Loop through MV/Feeder meters to calculate PV/BESS virtual meter feedback (P and Q only)\nFOR i := 0 TO SiteConstants.NumMVMeters BY 1 DO\n\tIF i > 0 AND MVMeterCfg[i].MeterType = TBE_PPC.enum_MeterType.PV THEN\n\t\tIF NOT MVMeterFbk[i].Sts_flt THEN\n\t\t\t//MV Meter is not faulted - feedback values are good to use\n\t\t\tVirtualMeterFbk.PVFeederMeterFbk.Sts_flt := FALSE;\n\t\t\tVirtualMeterFbk.PVFeederMeterFbk.Sts_P := VirtualMeterFbk.PVFeederMeterFbk.Sts_P + MVMeterFbk[i].Sts_P; \n\t\t\tVirtualMeterFbk.PVFeederMeterFbk.Sts_Q := VirtualMeterFbk.PVFeederMeterFbk.Sts_Q + MVMeterFbk[i].Sts_Q; \n\t\tELSE\n\t\t\t//MV Meter is faulted - Mark PV MV Virtual Meter Feedback as invalid\n\t\t\tVirtualMeterFbk.PVFeederMeterFbk.Sts_flt := TRUE;\n\t\tEND_IF\n\tELSIF i > 0 AND MVMeterCfg[i].MeterType = TBE_PPC.enum_MeterType.BESS THEN\n\t\tIF NOT MVMeterFbk[i].Sts_flt THEN\n\t\t\t//MV Meter is not faulted - feedback values are good to use\n\t\t\tVirtualMeterFbk.BESSFeederMeterFbk.Sts_flt := FALSE;\n\t\t\tVirtualMeterFbk.BESSFeederMeterFbk.Sts_P := VirtualMeterFbk.BESSFeederMeterFbk.Sts_P + MVMeterFbk[i].Sts_P; \n\t\t\tVirtualMeterFbk.BESSFeederMeterFbk.Sts_Q := VirtualMeterFbk.BESSFeederMeterFbk.Sts_Q + MVMeterFbk[i].Sts_Q; \n\t\tELSE\n\t\t\t//MV Meter is faulted - Mark PV MV Virtual Meter Feedback as invalid\n\t\t\tVirtualMeterFbk.BESSFeederMeterFbk.Sts_flt := TRUE;\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n//POI Feeder level virtual meter calculation\nIF NOT VirtualMeterFbk.PVFeederMeterFbk.Sts_flt AND NOT VirtualMeterFbk.BESSFeederMeterFbk.Sts_flt THEN\n\t//Virtual PV and BESS feeder level meters are in good health - calculate virtual POI feeder meter\n\tVirtualMeterFbk.POIFeederMeterFbk.Sts_P := VirtualMeterFbk.PVFeederMeterFbk.Sts_P + VirtualMeterFbk.BESSFeederMeterFbk.Sts_P;\n\tVirtualMeterFbk.POIFeederMeterFbk.Sts_Q := VirtualMeterFbk.PVFeederMeterFbk.Sts_Q + VirtualMeterFbk.BESSFeederMeterFbk.Sts_Q;\n\tVirtualMeterFbk.POIFeederMeterFbk.Sts_flt := FALSE;\nELSE\n\tVirtualMeterFbk.POIFeederMeterFbk.Sts_flt := TRUE;\nEND_IF\n\n//Inverter level virtual meter calculation\n\n//Reset values that are calculated by summation\nVirtualMeterFbk.PVInvMeterFbk.Sts_P := 0;\nVirtualMeterFbk.PVInvMeterFbk.Sts_Q := 0;\nVirtualMeterFbk.BESSInvMeterFbk.Sts_P := 0;\nVirtualMeterFbk.BESSInvMeterFbk.Sts_Q := 0;\n\n//Loop through MV/Feeder meters to calculate PV/BESS virtual meter feedback (P and Q only)\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 AND NOT InvFbk[i].Sts_Offline THEN\n\t\tVirtualMeterFbk.PVInvMeterFbk.Sts_P := VirtualMeterFbk.PVInvMeterFbk.Sts_P + (InvFbk[i].Sts_P * UTypeCfg[InvCfg[i].UnitTypeID].Snom / 1000.0 / PlantCfg.Sbase);\n\t\tVirtualMeterFbk.PVInvMeterFbk.Sts_Q := VirtualMeterFbk.PVInvMeterFbk.Sts_Q + (InvFbk[i].Sts_Q * UTypeCfg[InvCfg[i].UnitTypeID].Snom / 1000.0 / PlantCfg.Sbase);\n\t\tPVInvOnlineCount := PVInvOnlineCount + 1; \n\tEND_IF\nEND_FOR\n\t\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 AND NOT EMSFbk[i].Sts_Offline THEN\n\t\tVirtualMeterFbk.BESSInvMeterFbk.Sts_P := VirtualMeterFbk.BESSInvMeterFbk.Sts_P + (EMSFbk[i].Sts_P * UTypeCfg[EMSCfg[i].UnitTypeID].Snom / 1000.0 / PlantCfg.Sbase);\n\t\tVirtualMeterFbk.BESSInvMeterFbk.Sts_Q := VirtualMeterFbk.BESSInvMeterFbk.Sts_Q + (EMSFbk[i].Sts_Q * UTypeCfg[EMSCfg[i].UnitTypeID].Snom / 1000.0 / PlantCfg.Sbase);\n\t\tEMSOnlineCount := EMSOnlineCount + 1; \n\tEND_IF\nEND_FOR\n\n//Calculate Inverter/EMS availability percentage\nIF PVInvOnlineCount > 0 AND SiteConstants.NumInvs > 0 THEN\n\tInvAvailPct := PVInvOnlineCount / SiteConstants.NumInvs;\nELSE\n\tInvAvailPct := 0; \nEND_IF\ntmpNumEMS := SiteConstants.NumEMS;\nIF EMSOnlineCount > 0 AND tmpNumEMS > 0 THEN\n\tEMSAvailPct := EMSOnlineCount / tmpNumEMS;\nELSE\n\tEMSAvailPct := 0; \nEND_IF\n\nVirtualMeterFbk.PVInvMeterFbk.Sts_flt := NOT(InvAvailPct > UnitAvailThresh);\nVirtualMeterFbk.BESSInvMeterFbk.Sts_flt := NOT(EMSAvailPct > UnitAvailThresh); \n\nUnitAvailPct := (InvAvailPct * (PlantCfg.Sbase_PV / PlantCfg.Sbase)) + (EMSAvailPct * (PlantCfg.Sbase_BESS / PlantCfg.Sbase));\n\n//POI Inverter/Unit level virtual meter calculation\nIF UnitAvailPct > UnitAvailThresh THEN\n\t//Virtual PV and BESS feeder level meters are in good health - calculate virtual POI feeder meter\n\tVirtualMeterFbk.POIInvMeterFbk.Sts_P := VirtualMeterFbk.PVInvMeterFbk.Sts_P + VirtualMeterFbk.BESSInvMeterFbk.Sts_P;\n\tVirtualMeterFbk.POIInvMeterFbk.Sts_Q := VirtualMeterFbk.PVInvMeterFbk.Sts_Q + VirtualMeterFbk.BESSInvMeterFbk.Sts_Q;\n\tVirtualMeterFbk.POIInvMeterFbk.Sts_flt := FALSE;\nELSE\n\tVirtualMeterFbk.POIInvMeterFbk.Sts_flt := TRUE; \nEND_IF","LineInfoPersistence":"(string)a4001206-1c65-4d57-989b-658c826c015d_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tCalculate Virtual Meters Program\n|\tCalculate 'virtual' meters based on feeder-level feedback and inverter/EMS-level feedback\n|\tVirtual meter feedback may be used for control as a fallback strategy in the event of the primary/secondary HV/POI meters being in poor health\n*)\nPROGRAM pg_CalcVirtualMeters\nVAR_INPUT\n\tInvFbk\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk; \t\t\t//Array of inverter feedback values\n\tEMSFbk\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\t\t\t\t//Array of EMS/BESS feedback values\n\tMVMeterFbk\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\t\t//Array of MV Meter feedback values\n\tMVMeterCfg\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\t\t//Array of MV Meter configuration structs\n\tPlantCfg\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t\t\t//Plant configuration struct\n\tUTypeCfg\t: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\t//Array of unit type configuration structures\n\tInvCfg\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\t\t\t//Array of PV Inverter configuration structures\n\tEMSCfg\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg;\t\t\t//Array of EMS configuration structures\nEND_VAR\nVAR_OUTPUT\n\tVirtualMeterFbk\t: dt_VirtualMeters; \t\t\t\t\t\t\t\t\t\t\t//Structure of virtual meter feedback\nEND_VAR\nVAR\n\ti\t\t\t\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\n\tInvAvailPct\t\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[pu], Percentage of inverters that are online/communicating\n\tEMSAvailPct\t\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[pu], Percentage of EMS units that are online/communicating\n\tUnitAvailPct\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[pu], Percentage of PV Inverters and EMS units that are online/communicating\n\tUnitAvailThresh\t\t\t\t\t: REAL := 0.95;\t\t\t\t\t\t\t\t\t//[pu], Minimum unit availability percentage required to calculate virtual POI inverter meter\n\ttmpNumEMS\t\t\t\t\t\t: UINT; \nEND_VAR\nVAR_TEMP\n\tPVInvOnlineCount\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t//Number of PV Inverters online\n\tEMSOnlineCount\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t//Number of EMS units online\nEND_VAR","LineInfoPersistence":"(string)a4001206-1c65-4d57-989b-658c826c015d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)177","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}