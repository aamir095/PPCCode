{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)e1ebc222-5283-4617-b2b7-8ab077861781","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCtrl_Hitachi","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Copy common command structure first\nINV_OUT := INV_IN;\nInvCmds := InvCmds_IN;\n\n// Hitachi Remote / Local Mode Command\nIF InvCmds_IN.RemoteReq THEN\n \tInvCmds.Remote := 1;\t\t\t// OpModInterface: Remote\nELSE\n    InvCmds.Remote := 0;\t\t\t// OpModInterface: Local\nEND_IF;\n\n\n// Remote trigger on change only, after startup delay\nIF InvCmds.Remote <> RemoteCmdPrev THEN\n     InvCmds.RemoteTrigger := TRUE;\nELSE\n     InvCmds.RemoteTrigger := FALSE;\nEND_IF\n\n// ------------------------------------------------------------\n// Hitachi Start / Stop / Disconnect Command\n// ------------------------------------------------------------\n// Common convention from fb_InvCtrl:\n//      InvCmds_IN.EStopReq = TRUE  -> emergency stop / disconnect request\n//      InvCmds_IN.StartReq = TRUE  -> run request\n//      InvCmds_IN.StartReq = FALSE -> stop request\n//\n// Hitachi DERCmd.ctlVal:\n//      0 = No Command\n//      1 = Run\n//      2 = Stop\n//      3 = Disconnect\n\nIF InvCmds_IN.EStopReq THEN\n    InvCmds.Start := InvEStopCmd;     // Disconnect command\nELSIF InvCmds_IN.StartReq THEN\n    InvCmds.Start := InvStartCmd;      // Run command\nELSE\n    InvCmds.Start := InvStopCmd;     // Stop command\nEND_IF;\n\n//Start / Stop Retry Supervision\nStartStopRetry(En := UnitTypeCfg.StartStopRetryEn, StartReq := InvCmds.StartReq, InvFbk := InvFbk, StartCmdVal := InvStartCmd, StopCmdVal := InvStopCmd, HMICmds := HMICmds,StartConfirmT := UnitTypeCfg.InvStartConfirmT, StopConfirmT := UnitTypeCfg.InvStopConfirmT, MaxCmdRetries := UnitTypeCfg.MaxCmdRetries);\n\n// Start trigger logic\nIF InvCmds.Start <> StartCmdPrev OR StartStopRetry.CmdRetryPulse THEN\n     InvCmds.StartTrigger := TRUE;\nELSE\n      InvCmds.StartTrigger := FALSE;\nEND_IF;\n\n// Hitachi Active/Reactive Power Command\nInvCmds.PCmd := InvCmds_IN.PCmd;\nInvCmds.QCmd := InvCmds_IN.QCmd;\n\n// Hitachi Reset Commands\n// The provided Hitachi guide notes automatic reset behavior:\n//      - after an error, unit attempts automatic reset after 3 minutes\n//      - after three failed reset attempts, unit enters locked state\n//\n\nInvCmds.Reset1Trigger := InvCmds_IN.Reset1Trigger;\nInvCmds.Reset2Trigger := InvCmds_IN.Reset2Trigger;\n\n\n// Disable unused command styles\nInvCmds.InvOpModeTrigger := FALSE;\n\n// Hitachi does not use SGRE ActivityInd command style for basic operation.\n// StartTrigger, PTrigger, QTrigger, and RemoteTrigger are used instead.\nInvCmds.ActivityIndTrigger := FALSE;\n\n//Heartbeat Counter - Comment if not used\n// Self-resetting 1 second timer-> Update Heartbeat value every second\nHeartbeatTmr(IN := NOT HeartbeatTmr.Q, PT := T#1S);\n\n// Increment heartbeat on the 1 second pulse\nIF HeartbeatValue >= 999 THEN\n    HeartbeatValue := 0;\nELSE\n    HeartbeatValue := HeartbeatValue + 1;\nEND_IF;\n\n// Move heartbeat value to command structure\nInvCmds.Heartbeat := HeartbeatValue;\n// One-scan pulse every 1 second\nInvCmds.HeartbeatTrigger := HeartbeatTmr.Q;\n\n\n// Diagnostics\nInvDiagnostics(RunCmd := InvCmds.Start = 1, RunSts := InvFbk.Sts_Running, PSp := InvCmds.PCmd, QSp := InvCmds.QCmd, PFbk := InvFbk.Sts_P, QFbk := InvFbk.Sts_Q, Diag => INV_OUT.Diag);\n\n\n// Store previous values\nRemoteCmdPrev := InvCmds.Remote;\nStartCmdPrev  := InvCmds.Start;\n","LineInfoPersistence":"(string)e1ebc222-5283-4617-b2b7-8ab077861781_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_InvCtrl_Hitachi\nVAR_INPUT\n    INV_IN              : TBE_PPC.dt_InvDevice;      // Incoming instance of inverter device\n    InvCmds_IN          : TBE_PPC.dt_DeviceCmds;     // Common command from fb_InvCtrl\n    InvFbk              : TBE_PPC.dt_DeviceFbk;      // Inverter feedback\n\tUnitTypeCfg\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//Unit type configuration\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\nEND_VAR\n\nVAR_OUTPUT\n    INV_OUT             : TBE_PPC.dt_InvDevice;      // Outgoing instance of inverter device\n    InvCmds             : TBE_PPC.dt_DeviceCmds;     // Final Hitachi-specific command structure\nEND_VAR\n\nVAR\n    // Previous values for change-based triggers\n    RemoteCmdPrev       : INT;                       // Previous remote/local mode command\n    StartCmdPrev        : INT;                       // Previous DERCmd command\n  \tHeartbeatTmr\t\t: TON;                       // Hearbeat Timer \n\tHeartbeatValue\t\t: INT;\t\t\t\t\t\t//  Heartbeat Counter\n    // Optional diagnostics\n    InvDiagnostics      : TBE_PPC.fb_InvDiag;        // Inverter diagnostics FB\n\t\n\tInvStopCmd\t\t\t: INT := 0; \t\t\t\t\t//Inverter Stop Command\n\tInvStartCmd\t\t\t: INT := 1;\t\t\t\t\t\t//Inverter Start Command\n\tInvEStopCmd\t\t\t: INT := 3;\t\t\t\t\t\t//Inverter Estop Command\n\t//Inverter Start/Stop Retry\n\tStartStopRetry \t\t: TBE_PPC.fb_InvStartStopRetry;\t\t //Start/stop retry supervision FB\nEND_VAR","LineInfoPersistence":"(string)e1ebc222-5283-4617-b2b7-8ab077861781_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)302","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}