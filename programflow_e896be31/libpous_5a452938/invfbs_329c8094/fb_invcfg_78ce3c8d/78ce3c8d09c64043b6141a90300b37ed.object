{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)78ce3c8d-09c6-4043-b614-1a90300b37ed","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)pU := inv_in.Cfg_Type; //Select type of inverter\n\n//Check to make sure Cfg_Type is set to nonzero value and set to 1 if it is 0. \nIF pU = 0 THEN\n\tpU := 1;\nEND_IF\n\n//Update analog and boolean command trigger outputs based on timers that are called in the unit type control function block\ninv_in.CFG_CmdDelayPT := Units.Types[pU].CFG_CmdDelayPT;\ninv_in.CMD_Update := Units.Types[pU].CMD_Update;\ninv_in.CMD_BoolTrigger := Units.Types[pU].CMD_BoolTrigger;\n\n//Update P and Q commands based on the unit-type P/Q commands (which are set in the unit type control function block)\ninv_in.CMD_P :=\tUnits.Types[pU].CMD_P;\ninv_in.CMD_Q :=\tUnits.Types[pU].CMD_Q;\n\n//Write to the output variable\ninv_out := inv_in;","LineInfoPersistence":"(string)78ce3c8d-09c6-4043-b614-1a90300b37ed_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tInverter Configuration Function Block\n|\tThe main purpose of this FB is to move values from the unit types GVL into the inverter instance\n|\tFor example, configuration values, P/Q commands, and periodic trigger values that are determined on the unit type level will be moved out and into the inverter instance\n*)\nFUNCTION_BLOCK fb_InvCfg\nVAR_INPUT\n\tINV_IN:TBE_PPC.dt_InvDevice;\nEND_VAR\nVAR_OUTPUT\n\tINV_OUT:TBE_PPC.dt_InvDevice;\nEND_VAR\nVAR\n\tpU:DINT;\nEND_VAR","LineInfoPersistence":"(string)78ce3c8d-09c6-4043-b614-1a90300b37ed_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)47","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}