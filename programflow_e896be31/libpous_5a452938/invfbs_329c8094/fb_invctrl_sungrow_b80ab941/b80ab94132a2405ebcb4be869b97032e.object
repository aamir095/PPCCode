{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b80ab941-32a2-405e-bcb4-be869b97032e","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCtrl_Sungrow","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move Entire Structure\nINV_OUT := INV_IN;\n\n//Call startup timer -> Startup timer will prevent P/Q/Start triggers within the first 10s of controller runtime\nStartupTmr(IN := TRUE, PT := T#10S);\n// Copy common command structure first\nInvCmds := InvCmds_IN;\n\n\nIF InvCmds_IN.EStopReq THEN\n    InvCmds.EStop := InvStopCmd;       // 0xCE = Remote EStop\n    InvCmds.Start := 0;\nELSE\n    InvCmds.EStop := 0;         // Not EStopped\n    InvCmds.Remote := 3;        // Enable remote mode\n    IF InvCmds_IN.StartReq THEN\n        InvCmds.Start := InvStartCmd;   // 0xCF = Power On\n    ELSE\n        InvCmds.Start := InvStopCmd;   // 0xCE = Power Off\n    END_IF\nEND_IF\n\n// Sungrow reactive power control mode QMode = 162 enables Q control mode.\nIF INV_IN.STS_QAuto THEN\n    InvCmds.QMode := 162;\nELSE\n    InvCmds.QMode := 0;\nEND_IF\n\n\n//Start / Stop Retry Supervision\nStartStopRetry(En := UnitTypeCfg.StartStopRetryEn, StartReq := InvCmds.StartReq, InvFbk := InvFbk, StartCmdVal := InvStartCmd, StopCmdVal := InvStopCmd, HMICmds := HMICmds,StartConfirmT := UnitTypeCfg.InvStartConfirmT, StopConfirmT := UnitTypeCfg.InvStopConfirmT, MaxCmdRetries := UnitTypeCfg.MaxCmdRetries);\n\n//Trigger Using Out of StartStopRetry\nInvCmds.StartTrigger := InvCmds_IN.StartTrigger OR StartStopRetry.CmdRetryPulse;\n\n//Call PQ Trigger Function Block\nPQTriggerLogic(P_Cmd := InvCmds.PCmd,\n\t\t\t\tQ_Cmd := InvCmds.QCmd,\n\t\t\t\tP_Threshold := PThresh,\n\t\t\t\tQ_Threshold := QThresh,\n\t\t\t\tWriteEnable := TRUE,\n\t\t\t\tMinTimeBetweenWrites := inv_in.CFG_CmdDelayPT,\n\t\t\t\tMaxTimeBetweenWrites := TMax,\n\t\t\t\tPeriodicPauseTime := TPause);\n\n\nIF inv_in.STS_PAuto THEN\n\tInvCmds.PTrigger := PQTriggerLogic.WriteP;\nELSIF ((InvCmds_PSp_Prev <> (InvCmds_IN.PCmd) AND StartupTmr.Q)) THEN\n\tInvCmds.PTrigger := TRUE;\nELSE\n\tInvCmds.PTrigger := FALSE;\nEND_IF\n\nIF inv_in.STS_QAuto THEN\n\tInvCmds.QTrigger := PQTriggerLogic.WriteQ;\nELSIF ((HMI_QSp_Prev <> HMICmds.QSp ) AND StartupTmr.Q) THEN\n\tInvCmds.QTrigger := TRUE;\nELSE\n\tInvCmds.QTrigger := FALSE;\nEND_IF\n\n//Inverter Diagnostics Function Block\nInvDiagnostics(RunCmd := InvCmds.Start = InvStartCmd, RunSts := InvFbk.Sts_Running, PSp := InvCmds.PCmd, QSp := InvCmds.QCmd, PFbk := InvFbk.Sts_P, QFbk := InvFbk.Sts_Q, StartCmdFailAlm := StartStopRetry.StartCmdFailAlm, StopCmdFailAlm := StartStopRetry.StopCmdFailAlm,  Diag => INV_OUT.Diag);\n\nInvCmds_PSp_Prev := InvCmds_IN.PCmd;\nHMI_QSp_Prev:=HMICmds.QSp;\n\n","LineInfoPersistence":"(string)b80ab941-32a2-405e-bcb4-be869b97032e_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_InvCtrl_Sungrow\nVAR_INPUT\n\tINV_IN\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Incoming instance of the inverter device\n\tInvCmds_IN    \t\t: TBE_PPC.dt_DeviceCmds;            // Common command from fb_INV\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\n\tInvFbk\t\t\t\t: TBE_PPC.dt_DeviceFbk;\t\t\t\t//Inverter feedback\n\tUnitTypeCfg\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//Unit type configuration\n\t//PCtrlDiagnostics\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t//plant-level active power control diagnostics structure\n\t//FreqDiagnostics\t: TBE_PPC.dt_FreqDroopDiagnostics;\t//Frequency droop diagnostics - used to disable Inverter Limiting Logic + Inverter Ramp Rate Logic during frequency event\nEND_VAR\nVAR_OUTPUT\n\tINV_OUT\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Outgoing instance of the inverter device\n\tInvCmds\t\t        : TBE_PPC.dt_DeviceCmds; \t\t\t//Device commands structure - includes both P and Q Commands\nEND_VAR\nVAR\n\t\n\tStartupTmr\t\t\t: TON;\t\t\t\t\t\t\t\t//Timer to prevent modbus writes in the first 10s\n\tStart_Cmd_Prev\t\t: INT;\t\t\t\t\t\t\t\t//Previous value of HMI start command\n\tPCmd_Limited\t\t: REAL;\t\t\t\t\t\t\t\t//Output of InvLimitLogic function\n\tPQTriggerLogic\t\t: TBE_PPC.fb_PQTriggerLogic;\t\t//P/Q Modbus Trigger Function Block\n\tInvDiagnostics\t\t: TBE_PPC.fb_InvDiag;\t\t\t\t//Inverter diagnostics function block\n\tInvCmds_PSp_Prev\t: REAL;\t\t\t\t\t\t\t\t//Previous value of Active power setpoint\n\tHMI_QSp_Prev\t\t: REAL;\t\t\t\t\t\t\t\t//Previous value of Reactive power setpoint\n\t\n\t//Configuration parameters for PQ Trigger Logic FB\n\tPThresh\t\t\t\t: REAL := 0.001;\t\t\t\t\t//0.1% threshold for triggering a P write\n\tQThresh\t\t\t\t: REAL := 0.001;\t\t\t\t\t//0.1% threshold for triggering a Q write\n\tTMax\t\t\t\t: TIME := T#1s;\t\t\t\t\t\t//Maximum time between P or Q writes\n\tTPause\t\t\t\t: TIME := T#2S;\t\t\t\t\t\t//Pause in triggers every 2s\n\t//Inverter Start/Stop Retry\n\tStartStopRetry \t\t: TBE_PPC.fb_InvStartStopRetry;\t\t //Start/stop retry supervision FB\n\t\n\tInvStartCmd\t\t\t: INT := 207;\t\t\t\t\t\t//Inverter Start Command\n\tInvStopCmd\t\t\t: INT := 206; \t\t\t\t\t\t//Inverter Stop Command\n\t\nEND_VAR","LineInfoPersistence":"(string)b80ab941-32a2-405e-bcb4-be869b97032e_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)516","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}