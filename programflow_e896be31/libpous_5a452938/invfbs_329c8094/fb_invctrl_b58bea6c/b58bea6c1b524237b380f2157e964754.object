{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b58bea6c-1b52-4237-b380-f2157e964754","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n//Call startup timer -> Startup timer will prevent P/Q/Start triggers within the first 10s of controller runtime\nStartupTmr(IN := TRUE, PT := T#10S);\n\n//Determine unit type of inverter and set to 1 if it is not defined\nIF UnitCfg <> 0 THEN\n\tInv_In.Cfg_Type := UnitCfg;\t//Move unit cfg identifier to Inv_In structure\nELSE\n\tUnitCfg := 1; \t\t\t\t//Use UnitCfg value of 1 if unit type cfg is not configured (fallback)\nEND_IF\n\n//Call inverter configuration FB\nINV_CFG(INV_IN:=INV_IN);\nINV_IN := INV_CFG.INV_OUT;\n\n//Inverter limiting logic - Limit the active power command to the inverter to the inverter active power feedback + offset value. Offset value is dynamic based on plant-level active power error (larger error = larger offset)\nTBE_PPC.fn_InvLimitLogic(En := (UnitTypeCfg.InvLimLogicCtrlEn AND NOT FreqDiagnostics.FreqDroopActive), PCmdPlant := inv_in.CMD_P, PlantPIDError := PCtrlDiagnostics.PIDDiagnostics.Error, InvFbk := InvFbk.Sts_P, InvLim_x := UnitTypeCfg.InvLim_x, InvLim_y := UnitTypeCfg.InvLim_y, PCmdInv => PCmd_Limited); \n\n//Inverter ramp logic - Limit the ramp rate of the inverter setpoint based on the plant-level active power error (larger error = faster ramp rate)\nInvRampCtrl(En := (UnitTypeCfg.InvRampRateCtrlEn AND NOT FreqDiagnostics.FreqDroopActive), PCmd_In := PCmd_Limited, PlantPIDError := PCtrlDiagnostics.PIDDiagnostics.Error, PlantPIDDbd := PlantCfg.ActivePwrCfg.PPIDOvshtDbd1, RampRate_x := UnitTypeCfg.RampRate_x, RampRate_y := UnitTypeCfg.RampRate_y, TaskTime := UDINT_TO_REAL(PPC.TaskTime)); \n\nPPC_PSp :=\tInvRampCtrl.PCmd_Out;\nHMI_PSp :=\tHMICmds.PSp; \nPPC_QSp :=\tinv_in.CMD_Q;\nHMI_QSp :=\tHMICmds.QSp; \n\n//Auto Manual Logic\nIF NOT inv_in.STS_PAuto AND HMICmds.PAutoEn THEN\n\tPAUTO :=TRUE;\nELSIF inv_in.STS_PAuto AND NOT HMICmds.PAutoEn THEN\n\tPAuto :=FALSE;\nEND_IF\ninv_in.STS_PAuto := PAuto;\n\nIF NOT inv_in.STS_QAuto AND HMICmds.QAutoEn THEN\n\tQAUTO :=TRUE;\nELSIF inv_in.STS_QAuto AND NOT HMICmds.QAutoEn THEN\n\tQAuto :=FALSE;\nEND_IF\ninv_in.STS_QAuto := QAuto;\n\n\n\n//Determing Operating State\nIF HMICmds.Estop THEN\n\t//Estop is active, set inverter to STOP mode\n\tInvCmds.StartReq := FALSE;       //Stop Command Request\n\tInvCmds.EStopReq := TRUE;\t\t// EStop Request\nELSIF Inv_In.STS_PAuto OR Inv_In.STS_QAuto THEN\n\t//Inverter is in auto mode -> use plant running mode status to determine Start/Stop Commands\n\tInvCmds.StartReq  := FALSE;\n\tInvCmds.RemoteReq := TRUE; \t\t//Remote Request\t\t\n\tIF OpModeSts.Running THEN\n\t\t//Set inverter to start\n\t\tInvCmds.StartReq := TRUE;\n\tELSIF PCtrlDiagnostics.PPID_SP < 0.0001 THEN\n\t\t//OpModeSts is NOT running and PID Setpoint is ~0 -> Pass stop command to inverters\n\t\tInvCmds.StartReq  := FALSE;\n\tEND_IF\n\t\nELSE\n\t//Inverter is in manual mode -> use HMI Inputs\n\t//InvCmds.StartReq  := FALSE;\n\tInvCmds.EStopReq := FALSE;\t\n\tInvCmds.RemoteReq := TRUE; \t\t//Remote Request\t\t\n\tIF NOT HMICmds.Run THEN\n\t\t//Set inverter to stop\n\t\tInvCmds.StartReq := FALSE; \t//Power Off\n\tELSIF HMICmds.Run THEN\n\t\t//Set inverter to start\n\t\tInvCmds.StartReq := TRUE;\t//Power On\n\tEND_IF\nEND_IF\n\n\n\n//Issue start trigger when inverter is in auto or when a new command is received. Don't allow any triggers for the first 10s of operation\nIF StartupTmr.Q AND (InvCmds.StartReq <> StartReq_Prev) THEN\n\t//Start command has changed and startup timer is complete, issue 1-shot start trigger\n\tInvCmds.StartTrigger := TRUE;\nELSIF (PAuto OR QAuto) THEN\n\t//Inverter is in auto, Send start trigger, issue 1-shot start trigger\n\tInvCmds.StartTrigger := TRUE;\t\nELSE\n\tInvCmds.StartTrigger := FALSE;\nEND_IF\n\n//Determine P/Q setpoints based on auto/manual control mode\nIF inv_in.STS_PAuto THEN\n\tInvCmds.PCmd := PPC_PSp;\t//Inverter in auto mode - Use PPC setpoint\nELSIF StartupTmr.Q THEN\n\tInvCmds.PCmd := HMI_PSp;\t//Inverter is in manual mode and startup timer is complete - Use HMI setpoint\nEND_IF\n\nIF inv_in.STS_QAuto THEN\n\tInvCmds.QCmd := PPC_QSp;\t//Inverter in auto mode - Use PPC setpoint\nELSIF StartupTmr.Q THEN\n\tInvCmds.QCmd := HMI_QSp;\t//Inverter is in manual mode and startup timer is complete - Use HMI setpoint\nEND_IF\n\n\t\t\t\t\n//Determine P/Q Triggers based on auto/manual control mode\nIF inv_in.STS_PAuto THEN\n\tIF inv_in.CMD_Update THEN\n\t\tInvCmds.PTrigger := TRUE;\n\tELSE\n\t\tInvCmds.PTrigger := FALSE;\n\tEND_IF\nELSIF ((HMI_PSp_Prev <> HMI_PSp) OR inv_in.CMD_Update) AND StartupTmr.Q  THEN\n\tInvCmds.PTrigger := TRUE;\nELSE\n\tInvCmds.PTrigger := FALSE;\nEND_IF\n\nIF inv_in.STS_QAuto  THEN\n\tIF inv_in.CMD_Update THEN\n\t\tInvCmds.QTrigger := TRUE;\n\tELSE\n\t\tInvCmds.QTrigger := FALSE;\n\tEND_IF\nELSIF ((HMI_QSp_Prev <> HMI_QSp) OR inv_in.CMD_Update) AND StartupTmr.Q  THEN\n\tInvCmds.QTrigger := TRUE;\nELSE\n\tInvCmds.QTrigger := FALSE;\nEND_IF\n\n\n\n//Set previous values\nStartReq_Prev\t:= InvCmds.StartReq;\nStart_Cmd_Prev := InvCmds.Start;\nHMI_PSp_Prev := HMICmds.PSp;\nHMI_QSp_Prev := HMICmds.QSp;\n\n//Move Entire Structure\nINV_OUT:=INV_IN;\n","LineInfoPersistence":"(string)b58bea6c-1b52-4237-b380-f2157e964754_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK fb_InvCtrl\nVAR_INPUT\n\tINV_IN\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Incoming instance of the inverter device\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\n\tOpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts;\t\t\t//Op Mode Status\n\tInvFbk\t\t\t\t: TBE_PPC.dt_DeviceFbk;\t\t\t\t//Inverter feedback\n\tUnitTypeCfg\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//Unit type configuration\n\tPCtrlDiagnostics\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t//plant-level active power control diagnostics structure\n\tFreqDiagnostics\t\t: TBE_PPC.dt_FreqDroopDiagnostics;\t//Frequency droop diagnostics - used to disable Inverter Limiting Logic + Inverter Ramp Rate Logic during frequency event\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t//Plant configuration structure\n\tUnitCfg\t\t\t\t: DINT;\t\t\t\t\t\t\t\t//Unit configuration identifier \nEND_VAR\nVAR_OUTPUT\n\tINV_OUT\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Outgoing instance of the inverter device\n\tInvCmds\t\t        : TBE_PPC.dt_DeviceCmds; \t\t\t//Device commands structure - includes both P and Q Commands\nEND_VAR\nVAR\n\tpU\t\t\t        : DINT; \t\t\t\t\t\t\t//Unit Pointer\n\tINV_CFG        \t\t: fb_InvCfg;\t\t\t\t\t\t//Inverter configuration function block\n\tPAuto        \t\t: BOOL;\t\t\t\t\t\t\t\t//P Auto Status of Inverter (True = Auto)\n\tQAuto        \t\t: BOOL;\t\t\t\t\t\t\t\t//Q Auto Status of Inverter (True = Auto)\n\tPPC_PSp       \t \t: REAL; \t\t\t\t\t\t\t//Active Power Set point from PPC\n\tHMI_PSp        \t\t: REAL; \t\t\t\t\t\t\t//Active Power Set Point from SCADA\n\tPPC_QSp        \t\t: REAL; \t\t\t\t\t\t\t//Reactive Power Set point from PPC\n\tHMI_QSp        \t\t: REAL; \t\t\t\t\t\t\t//Reactive Power Set Point from SCADA\n\tStartupTmr\t\t\t: TON;\t\t\t\t\t\t\t\t//Timer to prevent modbus writes in the first 10s\n\tStart_Cmd_Prev\t\t: INT;\t\t\t\t\t\t\t\t//Previous value of HMI start command\n\tHMI_PSp_Prev\t\t: REAL;\t\t\t\t\t\t\t\t//Previous value of HMI active power setpoint\n\tHMI_QSp_Prev\t\t: REAL;\t\t\t\t\t\t\t\t//Previous value of HMI reactive power setpoint\n\tInvRampCtrl\t\t\t: TBE_PPC.fb_InvRLim; \t\t\t\t//Inverter ramp rate function block\n\tPCmd_Limited\t\t: REAL;\t\t\t\t\t\t\t\t//Output of InvLimitLogic function\n\tStartReq_Prev\t\t: BOOL;\t\t\t\t\t\t\t\t//Previous StartReq for trigger logic\n\t\nEND_VAR","LineInfoPersistence":"(string)b58bea6c-1b52-4237-b380-f2157e964754_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)467","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}