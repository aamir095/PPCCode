{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8ff0f302-6381-4e13-a268-b9f52f55bf11","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCtrl_SGRE","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Copy common command structure first\nInvCmds := InvCmds_IN;\n\n\n//Call startup timer -> Startup timer will prevent P/Q/Start triggers within the first 10s of controller runtime\nStartupTmr(IN := TRUE, PT := T#10S);\n//Add time delay after comms are restored\nCommRestDly(IN := NOT InvFbk.Sts_Offline, PT := T#30S);\n\nIF InvCmds_IN.Reset1Trigger THEN\n    // Reset command: bits 0-2 = 000\n    InvCmds.CmdWord.0 := 0;\n    InvCmds.CmdWord.1 := 0;\n    InvCmds.CmdWord.2 := 0;\n\nELSIF InvCmds_IN.StartReq AND NOT InvFbk.Sts_Running THEN\n    // Run command: bits 0-2 = 010\n    InvCmds.CmdWord.0 := 0;\n    InvCmds.CmdWord.1 := 1;\n    InvCmds.CmdWord.2 := 0;\n\nELSIF (NOT InvCmds_IN.StartReq) AND NOT InvFbk.Sts_Stopped THEN\n    // Stop command: bits 0-2 = 001\n    InvCmds.CmdWord.0 := 1;\n    InvCmds.CmdWord.1 := 0;\n    InvCmds.CmdWord.2 := 0;\n\nELSE\n    // Blank command: bits 0-2 = 111\n    InvCmds.CmdWord.0 := 1;\n    InvCmds.CmdWord.1 := 1;\n    InvCmds.CmdWord.2 := 1;\nEND_IF\n\n// SGRE-specific command word bits\nInvCmds.CmdWord.4 := NightModeEn;     // Q at night / STATCOM mode\nInvCmds.CmdWord.8 := 1;               // Active Power Reduction Control enabled\nInvCmds.CmdWord.12 := 1;              // Reactive power control mode\n\n\n//Rising edge of reset command -> start latch timer\nRstStrt(CLK := HMICmds.Reset);\nrst_flag S= RstStrt.Q; //Set the value of rst_flag to TRUE once the Reset Start timer is complete (flag will be reset at end of FB)\nResetTmr(IN := rst_flag, PT := T#5S);\nIF ResetTmr.ET <> T#0S AND NOT ResetTmr.Q THEN\n\ttmp_ResetCmd := TRUE;\nELSE \n\ttmp_ResetCmd := FALSE;\nEND_IF\n\n\n//Update counter/watchdog value -> Set the client activity indicator/watchdog to the server activity indicator\nInvCmds.ClientActivityInd := InvFbk.Sts_ServerActivityInd;\n\n//Updating inverter command triggers\nIF StartupTmr.Q AND CommRestDly.Q THEN\n\tIF inv_in.CMD_Update THEN\t\n\t\tInvCmds.ActivityIndTrigger := TRUE; \n\t\t//Set tmp_ResetCmd to false since reset command has been issued\n\t\ttmp_ResetCmd := FALSE;\n\tELSE\n\t\tInvCmds.ActivityIndTrigger := FALSE; \t\n\tEND_IF\nEND_IF\n\n\n//P Commands\nIF StartupTmr.Q THEN\n\tIF inv_in.STS_PAuto THEN\t\t\t\n\t\tIF inv_in.CMD_Update THEN\n\t\t\tInvCmds.PCmd := InvCmds_IN.PCmd; \n\t\tEND_IF\n\tELSE \n\t\t//Inverter is in manual mode\n\t\tIF InvCmds.PCmd <> HMICmds.PSp THEN\n\t\t\tInvCmds.PCmd := HMICmds.PSp;\t\n\t\tEND_IF\n\tEND_IF\n\t\n\t//Q Commands\n\tIF inv_in.STS_QAuto THEN\t\t\t\n\t\tIF inv_in.CMD_Update THEN\t\n\t\t\tInvCmds.QCmd := InvCmds_IN.QCmd; \t\n\t\tEND_IF\n\tELSE \n\t\tIF InvCmds.QCmd <> HMICmds.QSp THEN\n\t\t\tInvCmds.QCmd := HMICmds.QSp ;\n\t\tEND_IF\n\tEND_IF\nEND_IF\n\n//Inverter Diagnostics Function Block\nInvDiagnostics(RunCmd := tmp_RunCmd, RunSts := InvFbk.Sts_Running, PSp := InvCmds.PCmd, QSp := InvCmds.QCmd, PFbk := InvFbk.Sts_P, QFbk := InvFbk.Sts_Q, Diag => INV_OUT.Diag);\n\n//Reset the reset flag to FALSE once the reset timer is complete\nrst_flag R= ResetTmr.Q;\n\nINV_OUT:=INV_IN;\n","LineInfoPersistence":"(string)8ff0f302-6381-4e13-a268-b9f52f55bf11_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tInverter function block for Siemens Gamesa (SGRE) Inverters\n|\tThis function block will do the following: \n|\t\tDetermine inverter-level commands based on plant-level P/Q commands and plant-level operating modes. \n|\t\tAdjust the inverter-level active power command based on inverter-level limiting logic and inverter-level ramp logic\n|\t\tDetermine the value of the MB TCP Register Triggers, which dictate when commands will be written to the inverter - ie some triggers may be periodic vs. 1-shot depending on operating mode and inverter specifications\n|\tFor SGRE inverters, all registers will be written at the same time and use the ActivityIndTrigger to be triggered (in meth_WriteInvCmds). \n|\tAdditionally, the SGRE inverters need to be sent a client (PPC) activity indicator that matches the value of the server (Inverter) activity indicator that the PPC reads from the Inverter. \n*)\nFUNCTION_BLOCK fb_InvCtrl_SGRE\nVAR_INPUT\n\tINV_IN\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Incoming instance of the inverter device\n\tInvCmds_IN    \t\t : TBE_PPC.dt_DeviceCmds;        // Common command from fb_INV\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\n\tInvFbk\t\t\t\t: TBE_PPC.dt_DeviceFbk;\t\t\t\t//Inverter feedback\n\tUnitTypeCfg\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//Unit type configuration\n\t//PCtrlDiagnostics\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t//plant-level active power control diagnostics structure\n\t//FreqDiagnostics\t\t: TBE_PPC.dt_FreqDroopDiagnostics;\t//Frequency droop diagnostics - used to disable Inverter Limiting Logic + Inverter Ramp Rate Logic during frequency event\n\tNightModeEn\t\t\t: BOOL;\t\t\t\t\t\t\t\t//True = enable night/STATCOM mode, False = enable MPPT mode\nEND_VAR\nVAR_OUTPUT\n\tINV_OUT\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Outgoing instance of inverter device\n\tInvCmds\t\t        : TBE_PPC.dt_DeviceCmds; \t\t\t//Device commands structure - includes both P and Q Commands\n\t\nEND_VAR\nVAR\n\tPCmd_Limited\t\t: REAL;\t\t\t\t\t\t\t\t//Output of InvLimitLogic function\n\ttmp_RunCmd\t\t\t: BOOL;\t\t\t\t\t\t\t\t//Temporary run or start/stop command\n\tStartupTmr\t\t\t: TON;\t\t\t\t\t\t\t\t//Timer to prevent modbus writes in the first 10s\n\tCommRestDly\t\t\t: TON;\t\t\t\t\t\t\t\t//10s time delay after comms are restored\n\tResetTmr\t\t\t: TON;\t\t\t\t\t\t\t\t//5s hold for reset command\n\tRstStrt\t\t\t\t: r_trig;\t\t\t\t\t\t\t//Trigger for reset command\n\ttmp_ResetCmd\t\t: BOOL;\t\t\t\t\t\t\t\t//Temporary reset command\n\trst_flag\t\t\t: BOOL;\t\t\t\t\t\t\t\t//Reset flag\n\tInvDiagnostics\t\t: TBE_PPC.fb_InvDiag;\t\t\t\t//Inverter diagnostics function block\nEND_VAR","LineInfoPersistence":"(string)8ff0f302-6381-4e13-a268-b9f52f55bf11_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)339","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}