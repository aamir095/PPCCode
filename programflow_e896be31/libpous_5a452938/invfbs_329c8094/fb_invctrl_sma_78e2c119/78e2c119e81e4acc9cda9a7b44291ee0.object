{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)78e2c119-e81e-4acc-9cda-9a7b44291ee0","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)fb_InvCtrl_SMA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)329c8094-4af7-4071-b54d-8b1e7c9a7bab"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)INV_OUT:=INV_IN;\n\n// Copy common command structure first\nInvCmds := InvCmds_IN;\n\n// SMA operating mode command\nIF InvCmds_IN.EStopReq THEN\n    InvCmds.InvOpMode := InvOpModeStop;\n\nELSIF InvCmds_IN.StartReq  THEN\n    InvCmds.InvOpMode := InvOpModeRun;\n\nELSE\n    InvCmds.InvOpMode := InvOpModeStop;\nEND_IF\n\n//Start / Stop Retry Supervision\nStartStopRetry(En := UnitTypeCfg.StartStopRetryEn, StartReq := InvCmds.StartReq, InvFbk := InvFbk, StartCmdVal := InvOpModeRun, StopCmdVal := InvOpModeStop, HMICmds := HMICmds,StartConfirmT := UnitTypeCfg.InvStartConfirmT, StopConfirmT := UnitTypeCfg.InvStopConfirmT, MaxCmdRetries := UnitTypeCfg.MaxCmdRetries);\n\n// SMA op mode trigger: trigger only on command change\nIF InvCmds.InvOpMode <> OpModeCmdPrev OR StartStopRetry.CmdRetryPulse THEN\n    InvCmds.InvOpModeTrigger := TRUE;\nELSE\n    InvCmds.InvOpModeTrigger := FALSE;\nEND_IF\n\n// SMA reset commands\nInvCmds.Reset1 := 26;        // SMA Error Clear / Acknowledge\nInvCmds.Reset2 := 21121;     // SMA Pro Error Clear / Acknowledge All\n\nInvCmds.Reset1Trigger := InvCmds_IN.Reset1Trigger;\nInvCmds.Reset2Trigger := InvCmds_IN.Reset2Trigger;\n\n\n//Inverter Diagnostics Function Block\nInvDiagnostics(RunCmd := InvCmds.InvOpMode = InvOpModeRun, RunSts := InvFbk.Sts_Running, PSp := InvCmds.PCmd, QSp := InvCmds.QCmd, PFbk := InvFbk.Sts_P, QFbk := InvFbk.Sts_Q, Diag => INV_OUT.Diag);\n\n\n//Set Op Mode Cmd Previous to current \nOpModeCmdPrev := InvCmds.InvOpMode;\n","LineInfoPersistence":"(string)78e2c119-e81e-4acc-9cda-9a7b44291ee0_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tSMA Inverter Control Function Block\n|\tThis FB will determine the 5 commands that are written from the Plant Controller to the SMA Inverter:\n|\tActive Power Setpoint, Reactive Power Setpoint, Operating Mode Command (Start/Stop), Error Clear and Error Clear Pro\n\n|\tFor SMA inverters there are 5 registers that are written and will be triggered independently of each other. \n*)\n\nFUNCTION_BLOCK fb_InvCtrl_SMA\nVAR_INPUT\n\tINV_IN\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Incoming instance of the inverter device\n\tInvCmds_IN    \t\t : TBE_PPC.dt_DeviceCmds;        // Common command from fb_INV\n\tHMICmds\t\t        : TBE_PPC.dt_DeviceHMIInputs;\t\t//Device level commands from HMI\n\t//OpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts;\t\t\t//Op Mode Status\n\tInvFbk\t\t\t\t: TBE_PPC.dt_DeviceFbk;\t\t\t\t//Inverter feedback\n\tUnitTypeCfg\t\t\t: TBE_PPC.dt_UnitTypeCfg;\t\t\t//Unit type configuration\n\t//PCtrlDiagnostics\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t//plant-level active power control diagnostics structure\n\t//FreqDiagnostics\t\t: TBE_PPC.dt_FreqDroopDiagnostics;\t//Frequency droop diagnostics - used to disable Inverter Limiting Logic + Inverter Ramp Rate Logic during frequency event\n\t\nEND_VAR\nVAR_OUTPUT\n\tINV_OUT\t\t        : TBE_PPC.dt_InvDevice;\t\t\t\t//Outgoing instance of inverter device\n\tInvCmds\t\t        : TBE_PPC.dt_DeviceCmds;\t\t\t//Device commands structure - includes both P and Q Commands\nEND_VAR\nVAR\n\tInvOpModeStop\t\t: INT := 381;\t\t\t\t\t\t//Inverter Op Mode Command to Stop\n\tInvOpModeRun\t\t: INT := 309; \t\t\t\t\t\t//Inverter Op Mode Command to Run\n\tOpModeCmdPrev\t\t: INT; \t\t\t\t\t\t\t\t//Previous value of op mode command (needed to trigger on change only)\n\tPCmd_Limited\t\t: REAL;\t\t\t\t\t\t\t\t//Output of InvLimitLogic function\n\tInvDiagnostics\t\t: TBE_PPC.fb_InvDiag;\t\t\t\t//Inverter diagnostics function block\n\t//Inverter Start/Stop Retry\n\tStartStopRetry \t\t: TBE_PPC.fb_InvStartStopRetry;\t\t //Start/stop retry supervision FB\nEND_VAR","LineInfoPersistence":"(string)78e2c119-e81e-4acc-9cda-9a7b44291ee0_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)280","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}