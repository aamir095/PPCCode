{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)7bca1fd3-21eb-4659-adbe-9e6b653ddbca","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)SCADA_GVL","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)564ed8c7-7876-45b7-a328-9fcec0ffa824"}]}}}}]},"TypeGuid":"(Guid)ffbfa93a-b94d-45fc-a329-229860183b1d","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"ffbfa93a","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tSCADA GVL\n|\tContains Inputs/Outputs from SCADA System\n|\tGVL will serve as OPC UA server\n|\tPPC will read/write from/to GVL in read inputs/write outputs program only\n*)\n{attribute 'qualified_only'}\nVAR_GLOBAL\n\t//Inputs from HMI to PPC\n\tPlantHMIInputs \t\t\t: TBE_PPC.dt_PlantHMIInputs;   \t\t\t\t\t\t\t\t\t\t\t//Structure of Setpoints/Mode Commands from HMI to PPC\n\tDeviceHMIInputs\t\t\t: ARRAY [0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs;   \t//Array of structures of device setpoints/mode commands from HMI to PPC\n\tEMSHMIInputs\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceHMIInputs;\t\t\t//EMS level HMI commands\n\tCapBankHMIInputs\t\t: ARRAY [0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankHMIInputs; \t//Array of structures of capacitor bank commands from HMI to PPC\n\tRedundancyHMIInputs\t\t: TBE_PPC.dt_RedundancyHMIInputs;\t\t\t\t\t\t\t\t\t\t//Structure of redundancy-related HMI Inputs\n\t\n\t\n\t\n\t//Outputs from PPC to HMI\n\tPlantAlarms   \t\t\t: TBE_PPC.dt_PlantAlarms;   \t\t\t\t\t\t\t\t\t\t\t//Structure of plant alarms\n\tHVMeterFbk_scaled\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; \t\t\t//HV Meter Feedback, scaled for SCADA/Ignition\n\tMVMeterFbk_scaled\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; \t\t\t//MV Meter Feedback, scaled for SCADA/Ignition\n\tMeterFbk_scaled\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//Meter Feedback used for POI control, scaled for SCADA/Ignition\n\tMeterFbk_PV\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//Meter feedback used for PV closed loop control\n\tMeterFbk_BESS\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t\t\t\t//Meter feedback used for BESS closed loop control\n\tRedundancySts\t\t\t: ARRAY[1..2] OF TBE_PPC.dt_RedundancyDiagnostics; \t\t\t\t\t\t//Array of redundancy diagnostics, Index 1 = RTAC1, Index 2 = RTAC2\n\tPlantRemoteInputs1\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t\t\t\t//Structure of plant inputs from remote source 1\n\tPlantRemoteInputs2\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t\t\t\t//Structure of plant inputs from remote source 2\n\tPlantCurtailmentInputs\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t\t\t\t//Structure of plant inputs from remote curtailment source\n\tPlantDiagnostics\t\t: dt_PPCDiagnostics;\t\t\t\t\t\t\t\t\t\t\t\t\t//Structure of plant diagnostics\n\tInvDeviceDiagnostics\t: ARRAY [0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDeviceDiag;\t\t\t//Array of inverter diagnostic structures\n\tEMSDeviceDiagnostics\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_EMSDeviceDiag;\t\t\t//Array of EMS diagnostic structures\n\tTestDiagnostics\t\t\t: TBE_PPC.dt_TestDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Test Diagnostics Structure\n\tMetStationFbk\t\t\t: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\t//Array of met station feedback structures\n\t\n\t//Virtual Meters\n\tVirtualMeters\t\t\t: dt_VirtualMeters; \t\t\t\t\t\t\t\t\t\t\t\t\t//Structure of virtual meters\n\t\n\t//Watchdog\n\tCtrlWatchdog\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Watchdog timer, for redundant controller comms\n\t\n\t//testing\n\tPTriggerCounter\t\t\t: UINT;\n\tQTriggerCounter\t\t\t: UINT;\n\n\tOP5600ConnectionSts\t\t: BOOL;\n\t\nEND_VAR","LineInfoPersistence":"(string)7bca1fd3-21eb-4659-adbe-9e6b653ddbca_Decl_LineIds"}}}},"NetVarProperties":null,"ParameterList":"(bool)False","AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","ffbfa93a":"{ffbfa93a-b94d-45fc-a329-229860183b1d}","string":"System.String"}}},"FormatVersion":"1.0"}