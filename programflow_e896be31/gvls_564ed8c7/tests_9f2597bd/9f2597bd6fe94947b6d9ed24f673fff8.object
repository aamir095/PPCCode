{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)9f2597bd-6fe9-4947-b6d9-ed24f673fff8","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)TESTS","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)564ed8c7-7876-45b7-a328-9fcec0ffa824"}]}}}}]},"TypeGuid":"(Guid)ffbfa93a-b94d-45fc-a329-229860183b1d","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"ffbfa93a","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)VAR_GLOBAL\n\tDebug\t\t\t: BOOL :=TRUE;\n\tSimulation\t\t: BOOL :=FALSE;             //Simulate plant operation\n\tTestTimeTotal\t: TIME;\n\tFreqEn\t\t\t: BOOL;    \t\t\t\t\t//Enable frequency test\n\tFreqRampUp\t\t: REAL :=1.0;              \t//Frequency Test Ramp Up Rate\n\tFreqRampDwn\t\t: REAL :=1.0;           \t//Frequency Test Ramp Down Rate\n\tFreqTrgt\t\t: REAL :=65.0;         \t\t//Frequency Test Target\n\tFreqStart\t\t: REAL :=60.0;    \t\t\t//Frequency Test Start Value\n\tFreqTimeMax\t\t: TIME :=T#20M;     \t\t//Frequency Test Max Time\n\ttmrFreq\t\t\t: TON;               \t\t//Frequency Test Timer On\n\t// TestTime: ARRAY[1..PlantCfg.TEST_SIZE] OF TIME;\n\t// TestRun:  ARRAY [1..PlantCfg.TEST_SIZE] OF BOOL; // if yes test is running               \n\t//  TestRes:  ARRAY[1..PlantCfg.TEST_SIZE] OF STRING(255);\n\t//  TestEn :  ARRAY [1..PlantCfg.TEST_SIZE] OF BOOL;  // enable/disable individual tests from HMI\n\tShutOffTime\t\t: TIME :=T#10S;\n\tStartUpTime\t\t: TIME :=T#10S;\n\tTestDelay\t\t: TIME :=T#10S;\n\tCmdTime\t\t\t: TIME :=T#10S; \t\t\t// send commands to units  \n\tPerr\t\t\t: REAL :=0.005;\n\tQerr\t\t\t: REAL :=0.005;\n\tPbr\t\t\t\t: REAL;            \t\t\t//Active power\n\tQbr\t\t\t\t: REAL;            \t\t\t//Reactive power \n\tFreq\t\t\t: REAL;          \t\t\t//Frequency\n\tVreg\t\t\t: REAL :=345;               //Voltage\n\tUnderFreqEn\t\t: BOOL;       \t\t\t\t//Enable Under Frequency Event Test\n\tUnderFreqData\t: ARRAY[1..5000] OF REAL;\n\tOverFreqEn\t\t: BOOL;          \t\t\t//Enable Over Frequency Event Test\n\tOverFreqData\t: ARRAY[1..9000] OF REAL;\nEND_VAR","LineInfoPersistence":"(string)9f2597bd-6fe9-4947-b6d9-ed24f673fff8_Decl_LineIds"}}}},"NetVarProperties":null,"ParameterList":"(bool)False","AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","ffbfa93a":"{ffbfa93a-b94d-45fc-a329-229860183b1d}","string":"System.String"}}},"FormatVersion":"1.0"}