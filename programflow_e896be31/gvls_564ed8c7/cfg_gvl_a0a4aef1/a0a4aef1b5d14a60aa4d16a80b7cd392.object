{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a0a4aef1-b5d1-4a60-aa4d-16a80b7cd392","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)Cfg_GVL","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)564ed8c7-7876-45b7-a328-9fcec0ffa824"}]}}}}]},"TypeGuid":"(Guid)ffbfa93a-b94d-45fc-a329-229860183b1d","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"ffbfa93a","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tPlant Config GVL\n|\tContains all config variables for site\n|\tEntire GVL uses retained memory\n*)\n{attribute 'qualified_only'}\nVAR_GLOBAL RETAIN\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t\t\t\t\t\t\t\t\t\t\t//Plant level configuration structure\n\tPlantCfg_Eng\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t//Plant level configuration structure (in engineering units)\n\tCapBankCfg\t\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Capacitor bank configuration structure (in core units)\n\tCapBankCfg_Eng\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Capacitor bank configuration structure (in engineering units)\n\tCapBankNumOfOper\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t\t\t\t\t\t//The operation counts of each cap bank\n\tUnitTypeCfg   \t\t: ARRAY [0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;   \t//Array of structures for unit type configuration\n\tDeviceCfg\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg; \t\t\t\t//Array of device configuration structures\n\tEMSDeviceCfg\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg; \t\t\t\t//Array of device configuration structures\n\tHVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\t\t\t//Array of HV meter configuration structures\n\tMVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\t\t\t//Array of MV meter configuration structures\n\tRedundancyCfg\t\t: TBE_PPC.dt_RedundancyCfg;\t\t\t\t\t\t\t\t\t\t\t\t//Structure of redundancy configuration tags\n\tCfgComplete\t\t\t: BOOL; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Boolean variable to determine if initial/default configuration variables have been set\n\tEnableSELHMICtrl\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Boolean variable to enable/disable SEL HMI cntl\nEND_VAR","LineInfoPersistence":"(string)a0a4aef1-b5d1-4a60-aa4d-16a80b7cd392_Decl_LineIds"}}}},"NetVarProperties":null,"ParameterList":"(bool)False","AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","ffbfa93a":"{ffbfa93a-b94d-45fc-a329-229860183b1d}","string":"System.String"}}},"FormatVersion":"1.0"}