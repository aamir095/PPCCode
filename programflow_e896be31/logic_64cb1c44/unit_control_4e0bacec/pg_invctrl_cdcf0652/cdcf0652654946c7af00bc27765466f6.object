{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)cdcf0652-6549-46c7-af00-bc27765466f6","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_InvCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)4e0bacec-9225-47ef-9241-d96e28cf202d"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through all EMS units and call Ctrl FB for each one\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\t//Iterate through all inverters and call the appropriate function block based on the InvFB type and case statement below\n\tIF i >= 1 THEN\n\t\t//Common Inverter Control\n\t\tUx_InvCtrl[i](Inv_In := PV_Inv.U1_PV_INV[i],  HMICmds := InvHMICmds[i], OpModeSts := OpModeSts, InvFbk := InvFbk[i], UnitTypeCfg := UnitTypeCfg[InvDeviceCfg[i].UnitTypeID], PlantCfg := PlantCfg, PCtrlDiagnostics := PCtrlDiagnostics, FreqDiagnostics := PSpDiagnostics.FreqDiag_POI, UnitCfg := InvDeviceCfg[i].UnitTypeID, Inv_Out => PV_Inv.U1_PV_INV[i], InvCmds => InvCmds[i]);\n\t\tCASE UnitTypeCfg[InvDeviceCfg[i].UnitTypeID].InvFB OF\n\t\t\tTBE_PPC.enum_InvFBType.Sungrow: \n\t\t\t\t//Sungrow inverter type\n\t\t\t\tUx_InvCtrl_SG[i](Inv_In := PV_Inv.U1_PV_INV[i], HMICmds:= InvHMICmds[i], InvFbk := InvFbk[i],InvCmds_IN := InvCmds[i],UnitTypeCfg := UnitTypeCfg[i], Inv_Out => PV_Inv.U1_PV_INV[i], InvCmds => InvCmds[i]);\n\t\t\tTBE_PPC.enum_InvFBType.SMA:\n\t\t\t\t//SMA Inverter Type\n\t\t\t\tUx_InvCtrl_SMA[i](Inv_In := PV_Inv.U1_PV_INV[i], HMICmds:= InvHMICmds[i], InvFbk := InvFbk[i],InvCmds_IN := InvCmds[i], UnitTypeCfg := UnitTypeCfg[i], Inv_Out => PV_Inv.U1_PV_INV[i], InvCmds => InvCmds[i]);\n\t\t\tTBE_PPC.enum_InvFBType.SGRE:\n\t\t\t\t//SGRE Inverter Type\n\t\t\t\tUx_InvCtrl_SGRE[i](Inv_In := PV_Inv.U1_PV_INV[i], HMICmds:= InvHMICmds[i], InvFbk := InvFbk[i],InvCmds_IN := InvCmds[i], UnitTypeCfg := UnitTypeCfg[i], NightModeEn := FALSE, Inv_Out => PV_Inv.U1_PV_INV[i], InvCmds => InvCmds[i]);\n\t\t\tTBE_PPC.enum_InvFBType.Hitachi:\n\t\t\t\t//Hitachi inverter type\n\t\t\t\tUx_InvCtrl_HITACHI[i](Inv_In := PV_Inv.U1_PV_INV[i],  HMICmds:= InvHMICmds[i], InvFbk := InvFbk[i],InvCmds_IN := InvCmds[i], UnitTypeCfg := UnitTypeCfg[i], Inv_Out => PV_Inv.U1_PV_INV[i], InvCmds => InvCmds[i]);\n\t\t\tTBE_PPC.enum_InvFBType.Other: \n\t\t\t\t//Other Inverter Type - Call custom inverter function block here\t\n\t\tEND_CASE\n\t\t\n\t\t//Update status\n\t\tInvSts[i] := U1_PV_Inv[i]; \n\tEND_IF\nEND_FOR\n\n//Call EMS control function block\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i >= 1 THEN\n\t\tuX_EMSCtrl[i](EMS_in := EMS_GVL.U1_EMS[i], Plant_EMS_PCmd := EMS_PCmd, Plant_EMS_QCmd := EMS_QCmd, EMSUnitType := UnitTypeCfg[EMSDeviceCfg[i].UnitTypeID], HMICmds := EMSHMICmds[i], EMSCmds => EMSCmds[i], EMS_out => EMS_GVL.U1_EMS[i]); \n\t\t//Update status\n\t\tEMSSts[i] := EMS_GVL.U1_EMS[i];\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)cdcf0652-6549-46c7-af00-bc27765466f6_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tInverter Unit Control Program\n|\tLoops through all Inverter units and calls Inverter Control FB\n*)\nPROGRAM pg_InvCtrl\nVAR_INPUT\n\tEMS_PCmd\t\t\t: REAL;\n\tEMS_QCmd\t\t\t: REAL;\n\tInvHMICmds\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs; \t\t//HMI Commands for Inv modules\n\tEMSHMICmds\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceHMIInputs;\t\t\t//HMI Commands for EMS modules\n\tOpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts;\t\t\t\t\t\t\t\t\t\t\t\t//Op Mode Status\n\tInvFbk\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk; \t\t\t\t//Array of inverter feedback structures\n\tUnitTypeCfg\t\t\t: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\t\t//Array of unit type configurations\n\tInvDeviceCfg\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\t\t\t\t//Array of device configurations\n\tEMSDeviceCfg\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg;\t\t\t\t//Array of EMS device configurations\n\tPCtrlDiagnostics\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Active power control (plant-level) diagnostics structure\n\tPSpDiagnostics\t\t: TBE_PPC.dt_PSpDiagnostics;\t\t\t\t\t\t\t\t\t\t\t//Active power setpoint diagnostics\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t//Plant configuration structure\nEND_VAR\nVAR_OUTPUT\n\tInvCmds\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds; \t\t\t//Inv Commands for Inv Modules\n\tInvSts\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice; \n\tEMSCmds\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCmds;\n\tEMSSts\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\nEND_VAR\nVAR\n\tUx_InvCtrl\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF fb_InvCtrl;\t\t\t\t\t\t//Array of  Inv Control for all Inverter type common functions- keep it\n\tUx_InvCtrl_SG\t\t: ARRAY[0..SiteConstants.NumInvs] OF fb_InvCtrl_Sungrow;\t\t\t\t//Array of Inv Control function blocks for Sungrow Inverters - Keep if used, delete if not used\n\tUx_InvCtrl_SMA\t\t: ARRAY[0..SiteConstants.NumInvs] OF fb_InvCtrl_SMA;\t\t\t\t\t//Array of Inv Control function blocks for SMA Inverters - Keep if used, delete if not used\n\tUx_InvCtrl_SGRE\t\t: ARRAY[0..SiteConstants.NumInvs] OF fb_InvCtrl_SGRE;\t\t\t\t\t//Array of Inv Control function blocks for SGRE Inverters - Keep if used, delete if not used\n\tUx_InvCtrl_HITACHI\t: ARRAY[0..SiteConstants.NumInvs] OF fb_InvCtrl_Hitachi;\t\t\t\t//Array of Inv Control function blocks for SGRE Inverters - Keep if used, delete if not used\n\tUx_EMSCtrl\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF fb_EMSCtrl;\t\t\t\t\t\t\t//EMS control function blocks\n\ti\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\nEND_VAR","LineInfoPersistence":"(string)cdcf0652-6549-46c7-af00-bc27765466f6_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)125","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}