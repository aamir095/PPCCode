{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)93d412c0-3b31-41d9-987c-bccecb03be53","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1_Tests","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)f97f0f5c-0bf0-4734-90bf-2317448f50f8"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over all inputs from pre-test to post-test variable (Only a few inputs will be modified within this program\n\nPPCInputs_PostTest := PPCInputs_PreTest;\n\n//Commented for now - not currently in use\n//PTest(En:=_En,OutStart:=_Start,Trgt:=_Trgt,MaxError:=0.1,PV:= PPCInputs_PreTest.MeterFbk.STS_P,TMax:=T#60S,THold:=T#30S,RampUprate:=0.0,RampDwnRate:=0.0);\n\n//Frequency Test\nIF PPCInputs_PreTest.PlantHMIInputs.ActivePwr.FreqTestEn THEN\n\tFreqTestActive := TRUE;\nEND_IF\nFreqTestSp := PPCInputs_PreTest.PlantHMIInputs.ActivePwr.FreqTestSp_Hz;\nFreqTestTime := REAL_TO_TIME(PPCInputs_PreTest.PlantHMIInputs.ActivePwr.FreqTestTime_sec);\ntmrFreq(In := FreqTestActive, PT := FreqTestTime); \nIF tmrFreq.Q THEN\n\tFreqTestActive := FALSE; \nEND_IF\n\nIF FreqTestActive THEN\n\t//Manipulate the frequency feedback value (Use test SP instead of feedback value\n\tPPCInputs_PostTest.MeterFbk.Sts_Freq := FreqTestSp;  \t//No need to scaling, FreqTestSp is scaled in condition HMI Inputs\n\tPPCInputs_PreTest.MeterFbk.Sts_Freq := FreqTestSp;  \t//PreTest value also updated as auto tests will overwrite the post test values\nEND_IF\n\n//Calculate frequency output during test\nIF NOT FreqTestActive THEN\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestSp_Hz := 60.0;               //Fall Back to Nomainal Frequency when FreqTestActive is FALSE\n\tFTestPerr:=pg_U1_PV_PCtrl.rlim1.Out - PPCInputs_PreTest.MeterFbk.STS_P;\t//Calculate P Error\n\tFTestdev:=FreqTestSp-1.0;\t//Frequency deviation, pu\n\t//Calculate droop output\n\tIF FTestdev > PlantCfg.FreqCfg.FDbd1 THEN\t//High frequecy\n\t\tFTestout:= -(FTestdev - PlantCfg.FreqCfg.fdbd1)*PlantCfg.FreqCfg.Ddn;\t\n\tELSIF FTestdev < PlantCfg.FreqCfg.fdbd2 THEN\t//Low frequency\n\t\tFTestout:= -(FTestdev - PlantCfg.FreqCfg.fdbd2)*PlantCfg.FreqCfg.Dup;\t\n\tELSE\t//Frequency is within range\n\t\tFTestout:=0;\n\tEND_IF; \n\n\t//Frequency droop with error\n\tIF FTestout < 0.0 AND FTestPerr > 0.0 THEN\n\t\tFTestout:=FTestout - FTestPerr;\n\tEND_IF;\t\n\n\t//Frequency droop with error\n\tIF FTestout > 0.0 AND FTestPerr < 0.0 THEN\n\t\tFTestout:=FTestout + FTestPerr;\n\tEND_IF;\t\n\tFTestout:=FTestout+pg_U1_PV_PCtrl.rlim1.Out;\n\tIF FTestout < PlantCfg.ActivePwrCfg.Pmin_POI THEN FTestout:=PlantCfg.ActivePwrCfg.Pmin_POI; END_IF;\t//Limit droop to -1.0 pu\n\tIF FTestout > PlantCfg.ActivePwrCfg.Pmax_POI THEN FTestout:=PlantCfg.ActivePwrCfg.Pmax_POI; END_IF;\t\t//Limit droop to 1.0 pu\n\t\nEND_IF;\n\n//Output Diagnostics\nTestDiag.FreqTestActive := FreqTestActive; \n\n\n//Voltage Test\nIF PPCInputs_PreTest.PlantHMIInputs.TestInputs.VoltageTestEn THEN\n\tVTestActive := TRUE;\nEND_IF\n\nVTestTmr(In := VTestActive, PT := REAL_TO_TIME(PPCInputs_PreTest.PlantHMIInputs.TestInputs.VoltageTestTime)); \nIF VTestTmr.Q THEN\n\tVTestActive := FALSE; \nEND_IF\n\nIF VTestActive THEN\n\t//Manipulate the voltage feedback value (Use test SP instead of feedback value)\n\tPPCInputs_PostTest.MeterFbk.Sts_Vreg := PPCInputs_PreTest.PlantHMIInputs.TestInputs.VoltageTestSp;  //No need to scaling, VoltageTestSp is scaled in condition HMI Inputs\n\tPPCInputs_PreTest.MeterFbk.Sts_Vreg := PPCInputs_PreTest.PlantHMIInputs.TestInputs.VoltageTestSp;\t//PreTest values also updated as auto tests will overwrite the PostTest values\n\tPPCInputs_PostTest.MeterFbk.Sts_VLLAvg := PPCInputs_PostTest.MeterFbk.Sts_Vreg;\nEND_IF\n\nTestDiag.VoltageTestActive := VTestActive; \n\n//Auto Test Section\nCASE PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestNum OF\n\t//Active Power Related Tests\n\t1: \n\t\tAutoTest01(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr); \n\t2: \n\t\tAutoTest02(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr); \n\t3: \n\t\tAutoTest03(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr); \n\t4: \n\t\tAutoTest04(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, FbkIn := PPCInputs_PreTest.MeterFbk, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, FbkOut => PPCInputs_PostTest.MeterFbk); \n\t\t\n\t//Reactive Power Related Tests\n\t10: \n\t\tAutoTest10(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t11: \n\t\tAutoTest11(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t12: \n\t\tAutoTest12(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t13: \n\t\tAutoTest13(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t14: \n\t\tAutoTest14(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, PCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, QCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, PCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr, QCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t15: \n\t\tAutoTest15(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, PCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, QCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, PCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr, QCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t16: \n\t\tAutoTest16(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, CmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, CmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr); \n\t20: \n\t\tAutoTest20(En := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestsEn, Start := PPCInputs_PreTest.PlantHMIInputs.TestInputs.TestStart, PCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ActivePwr, QCmdsIn := PPCInputs_PreTest.PlantHMIInputs.ReactivePwr, FbkIn := PPCInputs_PreTest.MeterFbk, PlantCfg := PlantCfg, Diag => TestDiag.AutoTestDiagnostics, PCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ActivePwr, QCmdsOut => PPCInputs_PostTest.PlantHMIInputs.ReactivePwr, FbkOut => PPCInputs_PostTest.MeterFbk); \n\t\tFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\t\t\tIF i > 0 THEN\n\t\t\t\tPPCInputs_PostTest.CapBankHMIInputs[i].AutoEn := AutoTest20.CapBankCmds.AutoEn;\n\t\t\tEND_IF\n\t\tEND_FOR\n\t//Invalid Test ID Selected\n\tELSE\n\t\tTestDiag.AutoTestDiagnostics.TestID := 0;\n\t\tTestDiag.AutoTestDiagnostics.TestInProgress := FALSE;\n\t\tTestDiag.AutoTestDiagnostics.TestPctComplete := 0;\n\t\tTestDiag.AutoTestDiagnostics.TestStepStr := 'Invalid Test ID Selection'; \nEND_CASE","LineInfoPersistence":"(string)93d412c0-3b31-41d9-987c-bccecb03be53_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM pg_U1_Tests\n\nVAR_INPUT\n\tPPCInputs_PreTest\t: dt_PPCInputs; \t\t\t\t//PPC Inputs, prior to test values being applied\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t//Plant configuration struct\nEND_VAR\nVAR_OUTPUT\n\tPPCInputs_PostTest\t: dt_PPCInputs; \t\t\t\t//PPC Inputs, after test values have been applied\n\tTestDiag\t\t\t: TBE_PPC.dt_TestDiagnostics; \t//Test Diagnostics structure\nEND_VAR\n\nVAR CONSTANT\n\tSIZE:UINT:=100;\nEND_VAR\nVAR\n\ttmrFreq\t\t\t: TON;\t\t\t\t//Frequency Test Timer\n\tPTest\t\t\t: TBE_PPC.fb_Test;\n\t_En\t\t\t\t: BOOL;\n\t_Start\t\t\t: REAL;\n\t_Trgt\t\t\t: REAL;\n\tFTestdev\t\t: REAL;\t//Frequency Test Deviation\n\tFTestPerr\t\t: REAL;\t//Frequency test Active Power Error\n\tFTestout\t\t: REAL;\t//Frequency Test Calculated Output\n\t\n\tFreqTestActive\t: BOOL;\t\t//Frequency test is active\n\tFreqTestSp\t\t: REAL;\t\t//[pu], Frequency test setpoint\n\tFreqTestTime\t: TIME;\t\t//[ms], Frequency test time, in ms\n\t\n\tVTestActive\t\t: BOOL;\t\t//Voltage test is active\n\tVTestTmr\t\t: TON;\t\t//Timer for voltage test\n\t\n\t\n\t//Auto Test FBs\n\tAutoTest01\t\t: TBE_PPC.fb_AutoTest01_PClosedLoopCtrl;\t\t//Function block for auto test 1\n\tAutoTest02\t\t: TBE_PPC.fb_AutoTest02_PRampRateCtrl;\t\t\t//Function block for auto test 2\n\tAutoTest03\t\t: TBE_PPC.fb_AutoTest03_PCtrlTest_5_8;\t\t\t//Function block for auto test 3\n\tAutoTest04\t\t: TBE_PPC.fb_AutoTest04_PFRTest_5_9;\t\t\t//Function block for auto test 4\n\tAutoTest10\t\t: TBE_PPC.fb_AutoTest10_QCtrl;\t\t\t\t\t//Function block for auto test 10\n\tAutoTest11\t\t: TBE_PPC.fb_AutoTest11_VCtrl_VNom;\t\t\t//Function block for auto test 11\n\tAutoTest12\t\t: TBE_PPC.fb_AutoTest12_VCtrl_VSp;\t\t\t\t//Function block for auto test 12\n\tAutoTest13\t\t: TBE_PPC.fb_AutoTest13_PFCtrl;\t\t\t\t//Function block for auto test 13\n\tAutoTest14\t\t: TBE_PPC.fb_AutoTest14_QCapability_5_6;\t\t//Function block for auto test 14\n\tAutoTest15\t\t: TBE_PPC.fb_AutoTest15_QStep_5_7;\t\t\t\t//Function block for auto test 15\n\tAutoTest16\t\t: TBE_PPC.fb_AutoTest16_VStepTest_5_11_6;\t\t//Function block for auto test 16\n\tAutoTest20\t\t: TBE_PPC.fb_AutoTest20_ERCOTPart3;\t\t\t//ERCOT Part 3 Test\n\t\n\ti\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t//Indexing var\nEND_VAR","LineInfoPersistence":"(string)93d412c0-3b31-41d9-987c-bccecb03be53_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)231","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}