{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)0f92a372-4c59-478b-a670-29350342ae48","ParentGuid":"(Guid)b6cb46ab-0f2f-4e56-b20e-95f65d521ac4","Name":"(string)meth_CalcMaxInvFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\tmaxInvFbk := MAX(MaxInvFbk, InvFbk[i].Sts_P);\n\tEND_IF\nEND_FOR\nmeth_CalcMaxInvFbk := maxInvFbk; ","LineInfoPersistence":"(string)0f92a372-4c59-478b-a670-29350342ae48_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCalculate maximum inverter real power feedback value from all inverters\nMETHOD meth_CalcMaxInvFbk : REAL\nVAR_INPUT\n\t///Array of feedback values from inverters\n\tInvFbk: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\t///temp variable to store the max inverter fbk, scaled to pu\n\tmaxInvFbk: REAL := 0;\nEND_VAR\n","LineInfoPersistence":"(string)0f92a372-4c59-478b-a670-29350342ae48_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}