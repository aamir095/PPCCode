{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)0548ac71-816b-4d4b-82d4-dfdf65e52796","ParentGuid":"(Guid)c3d016a1-e085-41be-a52d-d382bc40b5e9","Name":"(string)meth_CalcBESSLimits","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//If all EMS modules are at low SOC, then the EMS cannot discharge\n//If all EMS modules are at high SOC, then the EMS cannot charge\n\nIF PlantEMSSts.NumEMSMinSOC = SiteConstants.NumEMS THEN\n\t//All EMS modules at low SOC - Discharge not allowed, set Max to 0\n\tPMax := 0;\nELSE\n\tPMax := PMax_Default;\nEND_IF\n\nIF PlantEMSSts.NumEMSMaxSOC = SiteConstants.NumEMS THEN\n\t//All EMS modules at high SOC - Chage not allowed, set Min to 0\n\tPMin := 0;\nELSE\n\tPMin := PMin_Default;\nEND_IF\n\n//BESS Anti-Windup\nIF AWUEn THEN\n\tPMax := MIN(PMax, MaxDischCap + AWUBuffer);\n\tPMin := MAX(PMin, -MaxDischCap - AWUBuffer);\nEND_IF","LineInfoPersistence":"(string)0548ac71-816b-4d4b-82d4-dfdf65e52796_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tMethod to calculate BESS active power command limits based on SOC and other inputs\n///|\tThis block will also handle BESS Anti-Windup, which takes into account the Max Charge/Discharge capability of all EMS modules\nMETHOD meth_CalcBESSLimits\nVAR_INPUT\n\t///[pu], Default minimum BESS active power command\n\tPMin_Default: REAL;\n\t///[pu], Default maximum BESS active power command\n\tPMax_Default: REAL;\n\t///Structure of plant-level EMS diagnostics\n\tPlantEMSSts: TBE_PPC.dt_PlantEMSDiagnostics;\n\t///True = BESS Anti-Windup enabled\n\tAWUEn: BOOL;\n\t///Maximum charging capacity amongst all EMS modules\n\tMaxChrgCap: REAL;\n\t///Maximum discharging capacity amongst all EMS modules\n\tMaxDischCap: REAL;\n\t///Anti-windup buffer\n\tAWUBuffer: REAL;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Minimum BESS active power command\n\tPMin: REAL;\n\t///[pu], Maximum BESS active power command\n\tPMax: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)0548ac71-816b-4d4b-82d4-dfdf65e52796_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}