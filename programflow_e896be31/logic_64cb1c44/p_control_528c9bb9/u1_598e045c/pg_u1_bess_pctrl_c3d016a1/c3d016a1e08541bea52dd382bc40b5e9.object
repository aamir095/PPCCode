False"}},"AreElementsSpaceOptimized":"(bool)True"}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM pg_U1_BESS_PCtrl\nVAR_INPUT\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t//Plant Cfg Struct\n\tMeterFbk_BESS\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t//[pu], Meter feedback from BESS meter\n\tMeterFbk_POI\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t//[pu], Meter feedback at POI (combination of PV and BESS)\n\tInputsFromAuxCtl\t: TBE_PPC.dt_PCtlAuxOutputs; \t\t\t\t\t\t\t\t//Inputs from PCtlAux\n\tOpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t\t\t\t\t\t//Operation mode status\n\tRedundancySts\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t\t//Redundancy status structure of local controller\n\tPlantAlarms\t\t\t: TBE_PPC.dt_PlantAlarms;\t\t\t\t\t\t\t\t\t//Plant alarms struct\n\tRemoteCtrlInputs\t: TBE_PPC.dt_RemoteCtrlInputs;\t\t\t\t\t\t\t\t//Inputs from remote controller\n\tPlantEMSSts\t\t\t: TBE_PPC.dt_PlantEMSDiagnostics;\t\t\t\t\t\t\t//Structure of plant-level EMS diagnostics\n\tEMSFbk\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\t\t//Array of BESS feedback structures\n\tPSp_Diagnostics\t\t: TBE_PPC.dt_PSpDiagnostics;\t\t\t\t\t\t\t\t\t//Diagnostics structure\n\tPSp_BESS\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//BESS active power setpoint\n\tPSp_POI\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//POI active power setpoint\nEND_VAR\nVAR_OUTPUT\n\tBESS_PCmd\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//[pu], Plant-Level BESS active power command\n\tDiagnostics\t\t\t: TBE_PPC.dt_PCtrlDiagnostics;\t\t\t\t\t\t\t\t//Real power control diagnostics structure\nEND_VAR\nVAR\n\tBESS_PI\t\t\t\t: fb_PI; \t\t\t\t\t\t\t\t\t\t\t//BESS Proportional-Integral controller function block\nEND_VAR","LineInfoPersistence":"(string)c3d016a1-e085-41be-a52d-d382bc40b5e9_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)504","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"Ch