{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)cd33b35a-2f5d-4b8d-aed0-183c77e5d3ed","ParentGuid":"(Guid)8659e8e7-25d1-4a92-abad-61dae3150475","Name":"(string)meth_ConditionPSpPOI","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//If plant is PVS Co-Located, POI Setpoint will be the sum of PV and BESS setpoints\nIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated THEN\n\t//Calculated PSp_POI_MW as sum of BESS and PV active power setpoints\n\t//Limit PSp_POI to POI limits\n\tIF (PSp_BESS_In + PSp_PV_In) > PlantCfg.ActivePwrCfg.PMax_POI THEN\n\t\tPSp_POI := PlantCfg.ActivePwrCfg.PMax_POI;\n\tELSIF (PSp_BESS_In + PSp_PV_In) < PlantCfg.ActivePwrCfg.PMin_POI THEN\n\t\tPSp_POI := PlantCfg.ActivePwrCfg.PMin_POI * PlantCfg.Sbase;\n\tEND_IF\n\t\n\t//Pass through PV/BESS Setpoints\n\tPSp_PV := PSp_PV_In;\n\tPSp_BESS := PSp_BESS_In;\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Hybrid THEN\n\t//Plant is PVS Hybrid\n\tPSp_POI := PSp_POI_In;\n\t\n\t//Set PSp_PV to max active power -> This setpoint will be used when BESS is in POI Control (and PV should produce max power)\n\tIF InputsFromAuxCtl.ClosedLoopPerm_PV AND OpModeSts.PClosedLoopCtrl_PV THEN\n\t\t//Set PV Setpoint to Max PV capability\n\t\tPSp_PV := PlantCfg.ActivePwrCfg.PMax_PV;\n\tELSE\n\t\t//Set PV Setpoint to PV-Specific Setpoint\n\t\tPSp_PV := PSp_PV_In;\n\tEND_IF\t\t\n\t\n\t//Determine BESS Setpoint based on if charge priority is enabled\n\tIF HMICmds.BESSChrgPriorityEn THEN\n\t\t//Charge priority is enabled -> Set BESS setpoint to negative of PV Meter Fbk (BESS should try to consume all of PV production). Convert PV Meter Fbk from pu Sbase_PV to pu Sbase_BESS\n\t\tIF PlantCfg.BESSCfg.GridChrgEn THEN\n\t\t\tPSp_BESS := -1.0 * MeterFbk_PV.Sts_P;\n\t\tELSE\n\t\t\t//Grid charging not enabled - add offset to the PV Meter Fbk to avoid grid charging during transient events\n\t\t\tPSp_BESS := (-1.0 * MeterFbk_PV.Sts_P) + PlantCfg.BESSCfg.ChrgPriorityOffset;\n\t\tEND_IF\n\tELSIF InputsFromAuxCtl.ClosedLoopPerm_BESS AND OpModeSts.PClosedLoopCtrl_BESS THEN\n\t\t//BESS is in closed loop control - use PI Setpoint\n\t\tPSp_BESS := PSp_POI_In;\n\tELSIF (NOT InputsFromAuxCtl.ClosedLoopPerm_BESS) OR (NOT OpModeSts.PClosedLoopCtrl_BESS) THEN\n\t\t//BESS is in manual/open loop control - use BESS-specific setpoint\n\t\tPSP_BESS := PSp_BESS_In;\n\tELSE\n\t\t//Else condition - set BESS setpoint to 0\n\t\tPSp_BESS := 0; \n\tEND_IF\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PV THEN\n\t//Plant is PV - POI setpoint will always be used, and Sbase = Sbase_PV\n\tPSp_POI := PSP_POI_In;\n\tPSp_PV := 0;\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.StorageOnly THEN\n\t//Plant is Storage only - POI setpoint will always be used, and Sbase = Sbase_BESS\n\tPSp_POI := PSP_POI_In; \n\tPSp_BESS := 0;\nEND_IF","LineInfoPersistence":"(string)cd33b35a-2f5d-4b8d-aed0-183c77e5d3ed_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition PSp POI so that it is scaled to Sbase_PV and Sbase_BESS\n///|\tAlso apply limiting logic to PSp_POI based on POI configuration values\nMETHOD meth_ConditionPSpPOI\nVAR_INPUT\n\t///[pu], POI Setpoint\n\tPSp_POI_In: REAL;\n\t///[pu], BESS active power setpoint\n\tPSp_BESS_In: REAL;\n\t///[pu], PV active power setpoint\n\tPSp_PV_In: REAL;\n\t///Plant configuration struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///[pu], Commands from HMI\n\tHMICmds: TBE_PPC.dt_ActivePwrHMIInputs;\n\t///[pu], PV meter feedback\n\tMeterFbk_PV: TBE_PPC.dt_MeterFbk;\n\t///Inputs from PCtlAux\n\tInputsFromAuxCtl: TBE_PPC.dt_PCtlAuxOutputs;\n\t///Op Mode Status\n\tOpModeSts: TBE_PPC.dt_UnitOpModeSts;\nEND_VAR\nVAR_OUTPUT\n\t///[pu]\n\tPSp_PV: REAL;\n\t///[pu]\n\tPSp_BESS: REAL;\n\t///[pu]\n\tPSp_POI: REAL;\nEND_VAR\nVAR\n\t///[MW], POI setpoint, calculated as sum of BESS + PV setpoints\n\tPSp_POI_MW: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)cd33b35a-2f5d-4b8d-aed0-183c77e5d3ed_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}