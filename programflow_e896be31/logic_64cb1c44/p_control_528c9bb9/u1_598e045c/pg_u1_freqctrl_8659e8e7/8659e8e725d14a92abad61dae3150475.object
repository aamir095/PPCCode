Value":{"InnerList":{"@Type":"[]","@Value":[{"@Type":"b3e42b54","@Value":{"X":"(int)51","Y":"(int)16","IsJoint":"(bool)False","Flags":"(int)0"}},{"@Type":"b3e42b54","@Value":{"X":"(int)50","Y":"(int)16","IsJoint":"(bool)False","Flags":"(int)0"}}]}}}},{"@Key":{"@Type":"93c117eb","@Value":{"ConnectionId":"(long)1218","StartPoint":{"@Type":"b3e42b54","@Value":{"X":"(int)79","Y":"(int)45","IsJoint":"(bool)False","Flags":"(int)0"}},"Unroutable":"(bool)False","CorrespondingPageId":null,"Locked":"(bool)False"}},"@Value":{"@Type":"584effbc","@Value":{"InnerList":{"@Type":"[]","@Value":[{"@Type":"b3e42b54","@Value":{"X":"(int)79","Y":"(int)45","IsJoint":"(bool)False","Flags":"(int)68"}},{"@Type":"b3e42b54","@Value":{"X":"(int)80","Y":"(int)45","IsJoint":"(bool)True","Flags":"(int)23"}},{"@Type":"b3e42b54","@Value":{"X":"(int)80","Y":"(int)43","IsJoint":"(bool)True","Flags":"(int)30"}},{"@Type":"b3e42b54","@Value":{"X":"(int)80","Y":"(int)42","IsJoint":"(bool)False","Flags":"(int)12"}},{"@Type":"b3e42b54","@Value":{"X":"(int)82","Y":"(int)42","IsJoint":"(bool)False","Flags":"(int)65"}}]}}}}]}}},"AutoSizeCanvas":"(bool)True","CanvasWidth":"(int)185","CanvasHeight":"(int)125","EditorConfiguration":{"@Type":"4f1e43e3","@Value":{"HideNamespaces":"(bool)False"}},"AreElementsSpaceOptimized":"(bool)True"}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRamp rate control, frequency control, and setpoint limiting function block\n|\tApply ramp rate control to PV and BESS setpoints\n|\tApply any necessary frequency-related active power setpoint adjustments to PV and BESS setpoints\n|\tCalculate POI setpoint as sum of PV + BESS setpoints and limit as necessary\n*)\nPROGRAM pg_U1_FreqCtrl\nVAR_INPUT\n\tOpModeSts\t\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t//Operation mode status\n\tInputsFromAuxCtl\t\t: TBE_PPC.dt_PCtlAuxOutputs; \t\t\t//Inputs from PCtlAux\n\tPlantCfg\t\t\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t//Plant configuration struct\n\tMeterFbk_BESS\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t//[pu], Meter feedback from BESS meter\n\tMeterFbk_PV\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t//[pu], Meter feedback from PV meter\n\tMeterFbk_POI\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t//[pu], Meter feedback at POI (combination of PV and BESS)\n\tRedundancySts\t\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t//Redundancy status structure of local controller\n\tHSL\t\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t//[pu], High sustainable limit of plant\n\tHSL_PV\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t//[pu], High sustainable limit (PV Only)\n\tPlantEMSSts\t\t\t\t: TBE_PPC.dt_PlantEMSDiagnostics;\t\t//Structure of plant-level EMS diagnostics\n\tHMICmds\t\t\t\t\t: TBE_PPC.dt_ActivePwrHMIInputs;\t\t//Plant HMI inputs\n\tRem1Cmds\t\t\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t//Remote inputs from remote source 1\n\tRem2Cmds\t\t\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t//Remote inputs from remote source 2\nEND_VAR\nVAR_OUTPUT\n\tPsp_PV\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t//Active power setpoint for PV\n\tPSp_BESS\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t//Active power setpoint for BESS\n\tPSp_POI\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t//Active power setpoint for POI in units pu on Sbase_PV (calculated as combination of PV + BESS setpoints)\n\tPSp_Diagnostics\t\t\t: TBE_PPC.dt_PSpDiagnostics;\t\t\t//Active power setpoint diagnostics structure - includes setpoints pre/post-ramp block and frequency diagnostics\nEND_VAR\nVAR\n\tRampCtrl_POI\t: TBE_PPC.fb_R_LIM;\t\t\t//Ramp rate control block for POI setpoint\n\tRampCtrl_PV\t\t: TBE_PPC.fb_R_LIM;\t\t\t//Ramp rate control block for PV setpoint\n\tRampCtrl_BESS\t: TBE_PPC.fb_R_LIM;\t\t\t//Ramp rate control block for BESS setpoint\n\tFreqCtrl_POI\t: TBE_PPC.fb_F_CTL;\t\t\t//Frequency control function block for POI setpoint\n\tFreqCtrl_PV\t\t: TBE_PPC.fb_F_CTL;\t\t\t//Frequency control function block for PV setpoint\n\tFreqCtrl_EMS\t: TBE_PPC.fb_F_CTL_EMS;\t\t//Frequency control function block for BESS\n\tRampSEL_POI\t\t: TBE_PPC.fb_PRampRateSelect;\t//Ramp rate selection block for POI ramp rate\n\tRampSEL_PV\t\t: TBE_PPC.fb_PRampRateSelect;\t//Ramp rate selection block for PV ramp rate\n\tRampSEL_BESS\t: TBE_PPC.fb_PRampRateSelect;\t//Ramp rate selection block for EMS/BESS ramp rate\n\tFFR_Ctrl_POI\t: TBE_PPC.fb_FFR_CTL;\t\t\t//FFR control function block for POI \n\tFFR_Ctrl_PV\t\t: TBE_PPC.fb_FFR_CTL;\t\t\t//FFR control function block for PV \n\tFFR_Ctrl_EMS\t: TBE_PPC.fb_FFR_CTL_EMS;\t\t//FFR control function block for EMS\nEND_VAR","LineInfoPersistence":"(string)8659e8e7-25d1-4a92-abad-61dae3150475_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)1329","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","233bc97c":"{233bc97c-69fe-4d29-b40e-a9a9b854044e}","24449d48":"{24449d48-c96a-49c4-b9d1-a4ea34aedce3}","32d3375e":"{32d3375e-c010-41e2-9e43-b2fbf4f2b374}","3487d131":"{3487d131-7fd4-48ac-9e99-9e275c3b8ff8}","4b8bcc79":"{4b8bcc79-5980-4868-b49e-005a8148859b}","4f1e43e3":"{4f1e43e3-0667-4421-ad70-d7adf37c167a}","584effbc":"{584effbc-813e-443a-bf78-ad9c8d49db41}","5ae2e111":"{5ae2e111-ecff-4a21-b647-2d4da63f8db7}","5c3476a8":"{5c3476a8-05c5-430e-861c-9cfa51d68ca8}","65582d84":"{65582d84-cf18-4ca0-be59-bf5a3d00b8f8}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","72f2b13f":"{72f2b13f-5349-4a8a-bbe6-2bccf3f42179}","77f43dfe":"{77f43dfe-ca6a-4869-828f-7609d8ed6ea6}","88453c7d":"{88453c7d-d652-4a27-a1b0-a1953be49a5c}","8d9e2b78":"{8d9e2b78-3efe-4fe4-8160-f3a7381ddd8f}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","93c117eb":"{93c117eb-0884-403b-b01e-28b89f47e041}","9e94943e":"{9e94943e-4951-4da7-a4e2-1f1bb71a6228}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","b3e42b54":"{b3e42b54-b8f2-45d3-825d-747f82f244a0}","bool":"System.Boolean