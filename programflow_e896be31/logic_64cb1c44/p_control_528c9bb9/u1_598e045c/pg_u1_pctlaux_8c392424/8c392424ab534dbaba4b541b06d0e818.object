{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8c392424-ab53-4dba-ba4b-541b06d0e818","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1_PCTLAux","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)598e045c-d9a2-4c0f-a9a5-8eebea3ffda3"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine active power POI setpoint to use based on operating mode and curtailment inputs\nPSp_POI_temp := TBE_PPC.fn_PSetpointSelect(OpStnSetp := HMICmds.PSp_POI, RemSetp1 := RemoteCmds1.PSp_POI, RemSetp2 := RemoteCmds2.PSp_POI, CurtailLim := CurtailmentCmds.PSp_POI, CmdMode := OpModeSts.PCmdMode_POI, CurtailFlag := CurtailmentCmds.CurtailmentFlag_POI, CurtailEn := PlantCfg.ActivePwrCfg.PRemCurtailEn_POI);\n\n//Two separate PV and BESS setpoints will be used for co-located\n//Determine which active power setpoint to use based on operating mode and curtailment inputs\nPSp_PV_temp := TBE_PPC.fn_PSetpointSelect(OpStnSetp := HMICmds.PSp_PV, RemSetp1 := RemoteCmds1.PSp_PV, RemSetp2 := RemoteCmds2.PSp_PV, CurtailLim := CurtailmentCmds.PSp_PV, CmdMode := OpModeSts.PCmdMode_PV, CurtailFlag := CurtailmentCmds.CurtailmentFlag_PV, CurtailEn := PlantCfg.ActivePwrCfg.PRemCurtailEn_PV);\n\n//Determine which BESS active power setpoint to used - Curtailment not relevant for BESS, so limit set to 1 and Enable/Flag inputs set to False\nPSp_BESS_temp := TBE_PPC.fn_PSetpointSelect(OpStnSetp := HMICmds.PSp_BESS, RemSetp1 := RemoteCmds1.PSp_BESS, RemSetp2 := RemoteCmds2.PSp_BESS, CurtailLim := CurtailmentCmds.PSp_BESS, CmdMode := OpModeSts.PCmdMode_BESS, CurtailFlag := CurtailmentCmds.CurtailmentFlag_BESS, CurtailEn := PlantCfg.ActivePwrCfg.PRemCurtailEn_BESS);\n\n\n//Check tmpPsp against limits\nIF PSp_POI_temp<PlantCfg.ActivePwrCfg.Pmin_POI THEN\n\tPSp_POI_temp:=PlantCfg.ActivePwrCfg.Pmin_POI;\nELSIF PSp_POI_temp>PlantCfg.ActivePwrCfg.Pmax_POI THEN\n\tPSp_POI_temp:=PlantCfg.ActivePwrCfg.Pmax_POI;\nEND_IF\n\nIF PSp_PV_temp<PlantCfg.ActivePwrCfg.Pmin_PV THEN\n\tPSp_PV_temp:=PlantCfg.ActivePwrCfg.Pmin_PV;\nELSIF PSp_PV_temp>PlantCfg.ActivePwrCfg.Pmax_PV THEN\n\tPSp_PV_temp:=PlantCfg.ActivePwrCfg.Pmax_PV;\nEND_IF\n\nIF PSp_BESS_temp < PlantCfg.BESSCfg.PMin THEN\n\tPSp_BESS_temp := PlantCfg.BESSCfg.PMin;\nELSIF PSp_BESS_temp > PlantCfg.BessCfg.PMax THEN\n\tPSp_BESS_temp := PlantCfg.BESSCfg.PMax;\nEND_IF\n\n//Determine closed loop permissive for PV and BESS controllers\nIF PCtrl_Aux_Outputs.BESS_POI_Ctrl AND RedundancySts.Sts_CtrlActive AND MeterFbk.Sts_MeterMode >= 1 AND (PlantEMSSts.NumEMSinPAuto >= 1) THEN\n\t//BESS in POI Control, POI meter feedback is valid, and at least 1 EMS in auto -> allow BESS closed loop control\n\tPCtrl_Aux_Outputs.ClosedLoopPerm_BESS := TRUE;\nELSIF RedundancySts.Sts_CtrlActive AND MeterFbk_BESS.Sts_MeterMode >= 1 AND (PlantEMSSts.NumEMSinPAuto >= 1) THEN\n\t//BESS is not in POI control, BESS meter feedback is valid, and at least 1 EMS is in auto -> allow BESS closed loop control\n\tPCtrl_Aux_Outputs.ClosedLoopPerm_BESS := TRUE;\nELSE\n\t//Not all conditions are met for BESS closed loop control\n\tPCtrl_Aux_outputs.ClosedLoopPerm_BESS := FALSE;\nEND_IF\n\nIF PCtrl_Aux_Outputs.PV_POI_Ctrl AND RedundancySts.Sts_CtrlActive AND MeterFbk.Sts_MeterMode >= 1 THEN\n\t//PV is in POI Control, meter feedback is value, and at least 1 EMS is in auto\n\tPCtrl_Aux_Outputs.ClosedLoopPerm_PV := TRUE;\nELSIF RedundancySts.Sts_CtrlActive AND MeterFbk_PV.Sts_MeterMode >= 1 THEN\n\t//PV is not in POI Control, PV meter feedback is valid -> allow BESS closed loop control\n\tPCtrl_Aux_Outputs.ClosedLoopPerm_PV := TRUE;\nELSE\n\tPCtrl_Aux_Outputs.ClosedLoopPerm_PV := FALSE;\nEND_IF\n\n//Determine permissive value for BESS to be in POI Control\nIF (BESSPCmd > 0 AND PlantEMSSts.NumEMSMinSOC = SiteConstants.NumEMS) OR (BESSPCmd < 0 AND PlantEMSSts.NumEMSMaxSOC = SiteConstants.NumEMS) OR (PlantEMSSts.NumEMSRunning = 0) OR (HMICmds.BESSChrgPriorityEn) OR (NOT PlantCfg.BESSCfg.BESSPOICtrlEn) THEN\n\t//Conditions are not met for BESS to be in POI Control - Set permissive to FALSE\n\tBESSPOICtrl_Perm := FALSE;\nELSE\n\t//Conditions are met for BESS to be in POI Control - Set permissive to TRUE\n\tBESSPOICtrl_Perm := TRUE;\nEND_IF\n\n//Determine if PV or BESS is in POI Control\nIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PV THEN\n\t//Plant is PV Only - PV will be in POI Control\n\tPCtrl_Aux_Outputs.PV_POI_Ctrl := TRUE;\n\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.StorageOnly THEN\n\t//Plant is Storage/BESS only - BESS will be in POI Control\n\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := TRUE;\nELSIF HMICmds.BESSChrgPriorityEn THEN\n\tIF PCtrl_Aux_Outputs.ClosedLoopPerm_PV AND OpModeSts.PClosedLoopCtrl_PV THEN\n\t\t//BESS Charge Priority is enabled and PV is operating in closed loop control -> Disable BESS POI Control and enable PV POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := TRUE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\n\tELSE\n\t\t//BESS Charge Priority is enabled, but PV is not operating inc losed loop control -> Disable BESS POI Control and PV POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\n\tEND_IF\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated AND((PSp_BESS_temp + PSp_PV_Temp) < PlantCfg.HOL) THEN\n\t\t//Plant is co-located and combined PV+BESS setpoint is less than HOL - neither PV nor BESS will be in POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\nELSIF BESSPOICtrl_Perm THEN\n\tIF PCtrl_Aux_Outputs.ClosedLoopPerm_BESS AND OpModeSts.PClosedLoopCtrl_BESS THEN\n\t\t//Plant is co-located OR hybrid, conditions are met for BESS to be in POI Control, and BESS PID is in closed-loop control -> enable BESS POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := TRUE;\n\tELSIF (PCtrl_Aux_Outputs.ClosedLoopPerm_PV AND OpModeSts.PClosedLoopCtrl_PV) THEN\n\t\t//BESS PID is not in closed-loop control and PV is in closed loop control -> enable PV POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := TRUE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\n\tELSE\n\t\t//BESS and PV are not in closed-loop control and plant is co-located -> neither PV nor BESS will be in POI Control\n\t\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\t\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\n\tEND_IF\nELSIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Hybrid AND OpModeSts.PClosedLoopCtrl_PV THEN\n\t//All other scenarios for hybrid plant -> PV will be responsible for POI Control\n\tPCtrl_Aux_Outputs.PV_POI_Ctrl := TRUE;\n\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\nELSE \n\t//All other scenarios for Co-Located plant -> Neither PV nor BESS will be in POI Control\n\tPCtrl_Aux_Outputs.PV_POI_Ctrl := FALSE;\n\tPCtrl_Aux_Outputs.BESS_POI_Ctrl := FALSE;\nEND_IF\n\n//Compensate PV/BESS active power setpoints when in open-loop control\n(*\nIF (PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated OR PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Hybrid) AND NOT (PCtrl_Aux_Outputs.ClosedLoopPerm_BESS AND OpModeSts.PClosedLoopCtrl) THEN\n\t//BESS is in open-loop control -> compensave active power setpoint based on Sbase and Sbase_BESS\n\tPSp_BESS_temp := PSp_BESS_temp * (PlantCfg.Sbase / PlantCfg.Sbase_BESS); \nEND_IF\nIF (PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated OR PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Hybrid) AND NOT (PCtrl_Aux_Outputs.ClosedLoopPerm_PV AND OpModeSts.PClosedLoopCtrl) THEN\n\t//BESS is in open-loop control -> compensave active power setpoint based on Sbase and Sbase_BESS\n\tPSp_PV_temp := PSp_PV_temp * (PlantCfg.Sbase / PlantCfg.Sbase_PV); \nEND_IF\n*)\n\n//If plant is not running, set P setpoint to 0\nIF NOT OpModeSts.Running THEN\n\tPSp_PV_temp := 0; \n\tPSp_BESS_temp := 0;\n\tPSp_POI_temp := 0; \nEND_IF\n\n//Enable/Disable ramp rate block - ramp rate is enabled when redundant controller is active and disabled for other site-specific scenarios (ie CAISO AGC SP is active)\n//Update this section as necessary if other conditions require the active power setpoint to step instead of ramp\nPCtrl_Aux_Outputs.RampRateEn_POI := (RedundancySts.Sts_CtrlActive);\nPCtrl_Aux_Outputs.RampRateEn_PV := (RedundancySts.Sts_CtrlActive);\nPCtrl_Aux_Outputs.RampRateEn_BESS := (RedundancySts.Sts_CtrlActive);\n\n//Move PSp_temp to output structure\nPCtrl_Aux_Outputs.Psp_POI := PSp_POI_temp; \nPCtrl_Aux_Outputs.Psp_PV := PSp_PV_temp; \nPCtrl_Aux_Outputs.Psp_BESS := PSp_BESS_temp; \nPCtrl_Aux_Outputs.Pref := PSp_POI_temp; \n\n//Active power high/low gain control\nIF MeterFbk.Sts_P > (PlantCfg.ActivePwrCfg.PIDTuning.LoGainLmt + PlantCfg.ActivePwrCfg.PIDTuning.LoGainDb) THEN\n\tPCtrl_Aux_Outputs.Kpg_PV := PlantCfg.ActivePwrCfg.PIDTuning.KpHi;\n\tPCtrl_Aux_Outputs.Kig_PV := PlantCfg.ActivePwrCfg.PIDTuning.KiHi;\t\n\tPCtrl_Aux_Outputs.Kpg_BESS := PlantCfg.BESSCfg.PIDTuning.KpHi;\t\n\tPCtrl_Aux_Outputs.Kig_BESS := PlantCfg.BESSCfg.PIDTuning.KiHi;\nELSIF MeterFbk.Sts_P < PlantCfg.ActivePwrCfg.PIDTuning.LoGainLmt  THEN\n\tPCtrl_Aux_Outputs.Kpg_PV := PlantCfg.ActivePwrCfg.PIDTuning.KpLo;\n\tPCtrl_Aux_Outputs.Kig_PV := PlantCfg.ActivePwrCfg.PIDTuning.KiLo;\n\tPCtrl_Aux_Outputs.Kpg_BESS := PlantCfg.BESSCfg.PIDTuning.KpLo;\t\n\tPCtrl_Aux_Outputs.Kig_BESS := PlantCfg.BESSCfg.PIDTuning.KiLo;\nEND_IF\n\n//Set PMin for active power PI control\n//PMin prevents PI control from commanding less than reference\nPmin:=pg_U1_PV_PCtrl.PV_PI.SP;\nIF Pmin>=1.0 THEN\n\tPmin:=0.95;\t\n\tELSIF Pmin<=0.0 THEN\n\tPmin:=PlantCfg.ActivePwrCfg.Pmin_POI;\t\nEND_IF\n//Frequency Droop Enable\nPCtrl_Aux_Outputs.FreqDroopEn_PV := OpModeSts.PClosedLoopCtrl_PV AND PlantCfg.FreqCfg.FreqCtrlEn_PV AND (OpModeSts.State = 1);\nPCtrl_Aux_Outputs.FreqDroopEn_BESS := OpModeSts.PClosedLoopCtrl_BESS AND PlantCfg.FreqCfg.FreqCtrlEn_BESS AND (OpModeSts.State = 1);\n\n//Freeze Rate Limiter Output from Raising\nPCtrl_Aux_Outputs.PRampUpFrz := PCtrl_Aux_Outputs.Pref > 1.0 AND MeterFbk.STS_P < 0.1;\n\n//Freeze Rate Limiter Output from Lowering\n PCtrl_Aux_Outputs.PRampDnFrz := FALSE;\n ","LineInfoPersistence":"(string)8c392424-ab53-4dba-ba4b-541b06d0e818_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tReal power auxiliary control\n|\tPurpose: \tDetermine the real power setpoints based on operating mode (Oper, Remote, Schedule, etc.). \n|\t\t\t\tCheck setpoint against configured site limits for real power. \n|\t\t\t\tVerify that plant is running w/ appropriate feedback before passing setpoint on to PCtl. \n|\t\t\t\tDetermine gains for Closed loop controller. \n|\t\t\t\tDetermine if frequency droop should be enabled/disabled. \n*)\nPROGRAM pg_U1_PCTLAux\nVAR_INPUT\n\tOpModeSts\t\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t\t\t\t\t\t//Operating mode status structure\n\tHMICmds\t\t\t\t\t: TBE_PPC.dt_ActivePwrHMIInputs; \t\t\t\t\t\t\t//[pu], Commands from HMI\n\tRemoteCmds1\t\t\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t//[pu], Commands from remote source 1\n\tRemoteCmds2\t\t\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t//[pu], Commands from remote source 2\n\tCurtailmentCmds\t\t\t: TBE_PPC.dt_PlantRemoteInputs;\t\t\t\t\t\t\t\t//[pu], Commands from remote curtailment source\n\tScheduleCmds\t\t\t: TBE_PPC.dt_ActivePwrHMIInputs;\t\t\t\t\t\t\t//[pu], Commands FROM scheduler\n\tMeterFbk\t\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t\t\t\t\t\t\t\t//[pu], Meter feedback\n\tMeterFbk_BESS\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t//[pu], BESS meter feedback\n\tMeterFbk_PV\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t\t\t\t\t\t\t\t//[pu], PV meter feedback\n\tPlantCfg\t\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t\t\t\t\t\t\t\t//plant config struct\n\tPlantEMSSts\t\t\t\t: TBE_PPC.dt_PlantEMSDiagnostics;\t\t\t\t\t\t\t//Plant-level EMS Status/Diagnostics structure\n\tBESSFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\t\t//BESS/EMS feedback\n\tRedundancySts\t\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t\t//Redundancy status structure of local controller\n\tBESSPCmd\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//[pu], BESS active power command (from previous cycle) - used to determine if BESS is commanded to charge or discharge\nEND_VAR\nVAR_OUTPUT\n\tPCtrl_Aux_Outputs\t\t: TBE_PPC.dt_PCtlAuxOutputs; \t\t\t\t\t\t\t\t//Real Power auxiliary control output structure\nEND_VAR\nVAR\n    RTRIGP \t\t\t\t\t: R_TRIG;\n    FTRIGP \t\t\t\t\t: F_TRIG;\n\tPmin\t\t\t\t\t: REAL;\n\tPSp_POI_temp\t\t\t: REAL;\t\t\t\t\t\t//POI Real power setpoint, temporary (for use in this program only)\t\n\tPSp_PV_temp\t\t\t\t: REAL;\t\t\t\t\t\t//PV Real power setpoint, temporary (for use in this program only)\t\n\tPsp_BESS_temp\t\t\t: REAL;\t\t\t\t\t\t//BESS active power setpoint, temporary (for use in this program only)\n\t\n\tBESSPOICtrl_Perm\t\t: BOOL;\t\t\t\t\t\t//True = conditions are met for BESS to be in POI Control, False = conditions are not met for BESS to be in POI Control\nEND_VAR","LineInfoPersistence":"(string)8c392424-ab53-4dba-ba4b-541b06d0e818_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)264","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}