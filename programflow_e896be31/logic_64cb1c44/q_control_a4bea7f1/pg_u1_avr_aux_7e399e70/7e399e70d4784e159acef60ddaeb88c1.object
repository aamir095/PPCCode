{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)7e399e70-d478-4e15-9ace-f60ddaeb88c1","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1_AVR_Aux","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)a4bea7f1-dcbe-4a94-98db-c0eb88f66500"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine PF, Q, and V Setpoints from SCADA or Remote source\nIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.OpStation THEN\n\t//Operator Mode - used setpoints from HMI/SCADA\n\ttmpPFsp := HMICmds.PFSp;\n\ttmpQsp := HMICmds.QSp;\n\ttmpVsp := HMICmds.VSp;\n\ttmpQmd := HMICmds.OpMode;\nELSIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.Remote1 THEN\n\t//Remote Mode - use setpoints from remote source\n\ttmpPFsp := RemoteCmds1.PFSp;\n\ttmpQsp := RemoteCmds1.QSp;\n\ttmpVsp := RemoteCmds1.VSp;\n\ttmpQmd := RemoteCmds1.QOpMode;\nELSIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.Remote2 THEN\n\t//Remote Mode - use setpoints from remote source\n\ttmpPFsp := RemoteCmds2.PFSp;\n\ttmpQsp := RemoteCmds2.QSp;\n\ttmpVsp := RemoteCmds2.VSp;\n\ttmpQmd := RemoteCmds2.QOpMode;\nELSIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.Scheduler THEN\n\ttmpPFsp := ScheduleCmds.PFSp;\n\ttmpQsp := ScheduleCmds.QSp;\n\ttmpVsp := ScheduleCmds.VSp;\n\ttmpQmd := ScheduleCmds.OpMode;\nEND_IF\n\n//Check temporary setpoints against limits - if outside of limits, used previous setpoint\nIF (tmpPFsp < -1.0 OR tmpPFsp >1.0 OR (tmpPFsp > PlantCfg.PFCfg.PFmin AND tmpPFsp < PlantCfg.PFCfg.PFmax)) THEN\n\ttmpPFsp:=QCtrl_Aux_Outputs.PFsp;\nEND_IF\ntmpQsp := fn_LimCheckWithReject(Val := tmpQsp, DefVal := QCtrl_Aux_Outputs.Qsp, MinVal := PlantCfg.ReactivePwrCfg.Qmin, MaxVal := PlantCfg.ReactivePwrCfg.Qmax);\ntmpVsp := fn_LimCheckWithReject(Val := tmpVsp, DefVal := QCtrl_Aux_Outputs.Vsp, MinVal := PlantCfg.VoltageCfg.VMin, MaxVal := PlantCfg.VoltageCfg.VMax);\n\n//Calculate the Q limits to maintain power factor limits\nQHiLim_PF := TBE_PPC.fn_PF_Q(PlantCfg.PFCfg.PFmax, MeterFbk.STS_P);    \t//Q high limit to maintain power factor\nQLoLim_PF := TBE_PPC.fn_PF_Q(PlantCfg.PFCfg.PFmin, MeterFbk.STS_P);     \t//Q low limit to maintain power factor\n\n// Q to manual - track Q output\nFTRIGQ(CLK := OpModeSts.QClosedLoopCtrl);               //Set FTrigQ on falling edge of Cfng.QAuto\nIF RTRIGQ.Q AND .RtacOnline THEN\n\ttmpQsp := pg_U1_AVR.PI_Q.Out;           \t\t\t//Set the Qref to the PI output for bumpless transfer\nEND_IF;                \n\n// Q to auto - track Q, V and PF setpoints\nRTRIGQ(CLK := OpModeSts.QClosedLoopCtrl);               //Set RTrigQ on rising edge of Cfng.QAuto\n//Cfng.QAuto one shot. Set reference values to measured values for bumpless transfer\nIF RTRIGQ.Q AND .RtacOnline THEN \n\ttmpQsp := MeterFbk.STS_Q; \n\ttmpVsp := MeterFbk.Sts_Vreg; \n\ttmpPFsp := MeterFbk.Sts_PF; \nEND_IF;\n\n//Assign SP to ref values\ntmpVref:=tmpVsp;\ntmpQref:=tmpQsp;\ntmpPFref:=tmpPFsp;\n\n//Control mode interlocks - Determine which modes are allowable. Interlock value of TRUE means that mode is available. \nVIntlk := OpModeSts.QClosedLoopCtrl AND tmpQmd <> PlantCfg.AVR_VLM AND OpModeSts.VAndPFCtrlEn;\nPFIntlk := OpModeSts.QClosedLoopCtrl AND tmpQmd <> PlantCfg.AVR_VLM AND OpModeSts.VAndPFCtrlEn;\nQIntlk := tmpQmd <> PlantCfg.AVR_VLM;\n\n//Reactive power mode selection\nIF tmpQmd = PlantCfg.AVR_V AND PlantCfg.VoltageCfg.VCntrlEn AND VIntlk THEN\n\t//Enable voltage control\n\ttmpQmd := PlantCfg.AVR_V;           \nELSIF tmpQmd = PlantCfg.AVR_PF AND PlantCfg.PFCfg.PFCntrlEn AND PFIntlk THEN\n\t//Enable PF control\n\ttmpQmd := PlantCfg.AVR_PF;       \nELSIF NOT OpModeSts.QClosedLoopCtrl OR (tmpQmd = PlantCfg.AVR_Q AND PlantCfg.ReactivePwrCfg.QCntrlEn AND QIntlk) THEN\n\t//Enable reactive power control\n\ttmpQmd := PlantCfg.AVR_Q;       \nELSE\n\ttmpQmd := PlantCfg.AVR_Q;\t//Fallback - select Q control mode   \nEND_IF\n\n(************Voltage Droop Calculation***************************)\n//Move voltage absorption/injection droop values to an internal variable and check to ensure the droop values are > minimum allowed\nVAbsDroop:=PlantCfg.VoltageCfg.VAbsDroop;\nVInjDroop:=PlantCfg.VoltageCfg.VInjDroop;\n\n//Check Droop against Minimum\nIF VAbsDroop < PlantCfg.VoltageCfg.VDroopMin THEN\n\tVAbsDroop:=PlantCfg.VoltageCfg.VDroopMin; \nEND_IF;\nIF VInjDroop < PlantCfg.VoltageCfg.VDroopMin THEN\n\tVInjDroop:=PlantCfg.VoltageCfg.VDroopMin; \nEND_IF;\n\nIF tmpQmd=PlantCfg.AVR_V AND NOT PlantCfg.VoltageCfg.RefFlag THEN\n\t//Calculate the Voltage Droop setpoint ramp rates\n\tDroopRef:=MeterFbk.Sts_Vreg-tmpVref;\n\tIF DroopRef<=0 THEN\n\t\tDroopUpLim := ABS(VInjDroop*100);\n\t\tDroopDnLim := ABS(VInjDroop*100);\n\tELSE\n\t\tDroopUpLim := ABS(VAbsDroop*100);\n\t\tDroopDnLim := ABS(VAbsDroop*100);\n\tEND_IF\n\t\n\tDroopRLIMpv := TBE_PPC.fn_VoltageLmtCalc(Vref := MeterFbk.Sts_Vreg, VDBHigh := PlantCfg.VoltageCfg.VDBHigh, VDBLow := PlantCfg.VoltageCfg.VDBLow, Qref := tmpQref, Qmax := PlantCfg.ReactivePwrCfg.Qmax, Qmin := PlantCfg.ReactivePwrCfg.Qmin, AbsDroop := VAbsDroop, InjDroop := VAbsDroop);\n\tDroopRlim(En := DroopRLIMEn, Auto := TRUE, SP := tmpVref, PV := DroopRLIMpv, UpLim := DroopUpLim, DnLim := DroopDnLim, TaskTime := UDINT_TO_REAL(PPC.TaskTime));\n\tDroopRLIMEn:=TRUE;\n\tIF PlantCfg.VoltageCfg.VQDroopEn THEN\n\t\t//Voltage w/Reactive Droop funciton call -if Gain_Kp = 0 then it would act like standard VDroop function\n\t\tVQDroop(Vsp:=DroopRlim.Out, Qmeas := MeterFbk.Sts_Q,  Vmeas:=MeterFbk.Sts_Vreg, Outmin:=PlantCfg.ReactivePwrCfg.Qmin, Outmax:=PlantCfg.ReactivePwrCfg.Qmax, Hyst:=PlantCfg.VoltageCfg.VDroopHyst, AbsDroop:=VAbsDroop,InjDroop:=VInjDroop, Dbd_Hi := PlantCfg.VoltageCfg.VDbHigh, Dbd_Lo := PlantCfg.VoltageCfg.VDbLow);\n\t\ttmpQref:= VQDroop.Out;\n\t\ttmpVQDroopActive := TRUE;\n\tELSE\n\t\t//Voltage droop function call -> Filtering moved to Condition Meter Fbk, Vreg value (filtered) will be used in the voltage droop FB call\n\t\tVDroop(Vsp:=DroopRlim.Out, Vmeas:=MeterFbk.Sts_Vreg, Outmin:=PlantCfg.ReactivePwrCfg.Qmin, Outmax:=PlantCfg.ReactivePwrCfg.Qmax, Hyst:=PlantCfg.VoltageCfg.VDroopHyst, AbsDroop:=VAbsDroop,InjDroop:=VInjDroop, Dbd_Hi := PlantCfg.VoltageCfg.VDbHigh, Dbd_Lo := PlantCfg.VoltageCfg.VDbLow, Out => QDroop);\n\t\ttmpQref:=QDroop;\n\t\ttmpVQDroopActive := FALSE;\t\n\tEND_IF\n\nELSE\n\t(*Droop control is not enabled, clear droop values,VQDroop Status*)\n\tQDroop := 0.0;\n\tDroopRLIMEn := FALSE;\n\ttmpVQDroopActive := FALSE;\t\nEND_IF\n//************ END Voltage Droop Calculation ***********************\n\n//************ Power Factor Control Mode *************************\n//If in power factor mode, set Qref\nIF tmpQmd = PlantCfg.AVR_PF AND OpModeSts.State = 1 THEN\n\tPF_QSp := TBE_PPC.fn_PF_Q(tmpPFref, MeterFbk.Sts_P);       //Calculate QSp from PF sp\n\ttmpQref := PF_QSp;                         \t\t\t\t\t//Update CMD.Qref with PF Sp\nEND_IF\n\n//********** END Power Factor Control Mode *********************\n\n//Set the Qhigh and Qlow limits\nIF (tmpQmd=PlantCfg.AVR_PF) OR PlantCfg.PFCfg.PFEnvEn THEN\n\tQHiLim := LIMIT(0, QHiLim_PF, PlantCfg.ReactivePwrCfg.Qmax);\n\tQLoLim := LIMIT(PlantCfg.ReactivePwrCfg.QMin, QLoLim_PF, 0); \nELSE\n\tQHiLim := PlantCfg.ReactivePwrCfg.Qmax;\n\tQLoLim := PlantCfg.ReactivePwrCfg.Qmin;\nEND_IF\n\n//Set the Q process variable for the PI loop\nQCtrl_Aux_Outputs.QPI_QPV := MeterFbk.Sts_Q;\n\n//Set the V process variable for the PI loop\nQCtrl_Aux_Outputs.QPI_VPV := MeterFbk.Sts_Q;\n\n//Reactive power HI/Lo gain control\nIF MeterFbk.Sts_Q<PlantCfg.ReactivePwrCfg.PIDTuning.LoGainLmt THEN\n\tQCtrl_Aux_Outputs.Kpq := PlantCfg.ReactivePwrCfg.PIDTuning.KpLo;\n\tQCtrl_Aux_Outputs.Kiq := PlantCfg.ReactivePwrCfg.PIDTuning.KiLo;\nELSIF MeterFbk.Sts_Q>(PlantCfg.ReactivePwrCfg.PIDTuning.LoGainLmt + PlantCfg.ReactivePwrCfg.PIDTuning.LoGainDb) THEN\n\tQCtrl_Aux_Outputs.Kpq := PlantCfg.ReactivePwrCfg.PIDTuning.KpHi;\n\tQCtrl_Aux_Outputs.Kiq := PlantCfg.ReactivePwrCfg.PIDTuning.KiHi;     \nEND_IF\n\n//PF setpoint tracking\nIF OpModeSts.QClosedLoopCtrl AND tmpQmd<>PlantCfg.AVR_PF AND .RtacOnline OR OpModeSts.State=0 THEN\n\ttmpPFsp := MeterFbk.Sts_PF;\n\tQCtrl_Aux_Outputs.PFTrackSp := tmpPFsp;\nEND_IF\n\n//Q setpoint tracking\nIF OpModeSts.QClosedLoopCtrl AND tmpQmd <> PlantCfg.AVR_Q AND .RtacOnline OR OpModeSts.State=0 THEN\n\ttmpQsp := MeterFbk.Sts_Q;\n\tQCtrl_Aux_Outputs.QTrackSp := MeterFbk.Sts_Q * PlantCfg.Sbase;\nEND_IF\n\n//V setpoint tracking - For voltage droop mode, back-calculate the voltage setpoint that would align with the current reactive power setpoint\nIF .RtacOnline AND NOT PlantCfg.VoltageCfg.RefFlag AND tmpQmd <> PlantCfg.AVR_V AND (PlantAlarms.HVRT OR PlantAlarms.LVRT) THEN\n\t//Current mode is not voltage control and there is a VRT event -> Set VSp to existing VSp\n\tQCtrl_Aux_Outputs.VTrackSp := HMICmds.VSp * PlantCfg.VoltageCfg.Vbase; \nELSIF .RtacOnline AND NOT PlantCfg.VoltageCfg.RefFlag AND tmpQmd <> PlantCfg.AVR_V THEN\n\t//Current mode is not voltage control -> Calculate the voltage setpoint based on QFbk, VFbk and voltage droop curve to allow for bumpless transfer\n\ttmpVsp := TBE_PPC.fn_VoltageLmtCalc(Vref := MeterFbk.Sts_Vreg, Qref := tmpQref, VDBHigh := PlantCfg.VoltageCfg.VDBHigh, VDBLow := PlantCfg.VoltageCfg.VDBLow, Qmax := PlantCfg.ReactivePwrCfg.Qmax, Qmin := PlantCfg.ReactivePwrCfg.Qmin, AbsDroop := PlantCfg.VoltageCfg.VAbsDroop, InjDroop := PlantCfg.VoltageCfg.VAbsDroop);\n\ttmpVsp := fn_LimCheckWithReject(Val := tmpVsp, DefVal := QCtrl_Aux_Outputs.Vsp, MinVal := PlantCfg.VoltageCfg.VMin, MaxVal := PlantCfg.VoltageCfg.VMax);\n\tQCtrl_Aux_Outputs.VTrackSp := tmpVsp * PlantCfg.VoltageCfg.Vbase;\nELSIF .RtacOnline AND PlantCfg.VoltageCfg.RefFlag AND tmpQmd <> PlantCfg.AVR_V THEN\n\t//Ref Flag is True (this mode is typically not used)\n\ttmpVsp := MeterFbk.Sts_Vreg;\n\tQCtrl_Aux_Outputs.VTrackSp := MeterFbk.Sts_Vreg * PlantCfg.VoltageCfg.Vbase;      \nELSE\n\t//Else statement to catch any other scenarios\n\tQCtrl_Aux_Outputs.VTrackSp := tmpVsp * PlantCfg.VoltageCfg.Vbase;\nEND_IF\n\n//Set QRef to 0 if volt var is not enabled\nIF NOT OpModeSts.VoltVarEn THEN\n\ttmpQref:=0.0;\nEND_IF\n\n//Compare QRef to limits\nIF tmpQref < QLoLim THEN\n\ttmpQref := QLoLim;\nELSIF tmpQref > QHiLim THEN\n\ttmpQref := QHiLim;\nEND_IF\n\n//Call Q Limit Calculation Function to determine Q Setpoint Limits based on site reactive power capability or CURL points (for ERCOT sites)\nTBE_PPC.fn_QLimCalc(PFbk := MeterFbk.Sts_P, \n\t\t\t\t\t\tQMaxDefault := PlantCfg.ReactivePwrCfg.Qmax, \n\t\t\t\t\t\tQMinDefault := PlantCfg.ReactivePwrCfg.Qmin, \n\t\t\t\t\t\tUseCURLData := PlantCfg.ReactivePwrCfg.UseCURLData, \n\t\t\t\t\t\txVals := PlantCfg.ReactivePwrCfg.CURL_xVals, \n\t\t\t\t\t\tQMaxVals := PlantCfg.ReactivePwrCfg.CURL_QMaxVals,\n\t\t\t\t\t\tQminVals := PlantCfg.ReactivePwrCfg.CURL_QMinVals, \n\t\t\t\t\t\tQMax => tmpQMax, \n\t\t\t\t\t\tQmin => tmpQMin, \n\t\t\t\t\t\tDiag => QCtrl_Aux_Outputs.QLimCalcDiag);\n\t\t\t\t\t\t\n//Limit reactive power setpoint based on calculated limit\nIF tmpQref < tmpQMin THEN\n\ttmpQref := tmpQMin;\nELSIF tmpQref > tmpQMax THEN\n\ttmpQref := tmpQMax;            \nEND_IF\n\n//Assign tmpXXRef values to tags\nQCtrl_Aux_Outputs.PFref := tmpPFref;\nQCtrl_Aux_Outputs.PFsp := tmpPFsp;\nQCtrl_Aux_Outputs.Qref := tmpQref; \nQCtrl_Aux_Outputs.Qsp := tmpQsp;\nQCtrl_Aux_Outputs.Vref := tmpVref;\nQCtrl_Aux_Outputs.Vsp := tmpVsp;\nQCtrl_Aux_Outputs.OpMode := tmpQmd; \nQCtrl_Aux_Outputs.QDroop := QDroop; \n//Voltage w/Reactive Droop Diag Mapping\nQCtrl_Aux_Outputs.VQDroopActive := tmpVQDroopActive;\nQCtrl_Aux_Outputs.VQDroopOffset := VQDroop.VQDroopOffset;    //[v]\nQCtrl_Aux_Outputs.VQPIDroopDiag := VQDroop.VQDroopDiag;      //Mapping Entire Diag (Output from VQDroop Function)\n\n","LineInfoPersistence":"(string)7e399e70-d478-4e15-9ace-f60ddaeb88c1_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tReactive power auxiliary control\n|\tPurpose: \tDetermine the reactive power setpoints based on operating mode (Oper, Remote, Schedule, etc.). \n|\t\t\t\tCheck setpoint against configured site limits for reactive power. \n|\t\t\t\tRun auxiliary control functions such as voltage droop, etc. to obtain reactive power setpoint for AVR control\n|\t\t\t\tDetermine gains for Closed loop controller. \n*)\nPROGRAM pg_U1_AVR_Aux\nVAR_INPUT\n\tOpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t\t\t\t\t\t\t\t//Operating mode status structure\n\tHMICmds\t\t\t\t: TBE_PPC.dt_ReactivePwrHMIInputs; \t\t\t\t\t\t\t\t\t//[pu], Commands from HMI\n\tRemoteCmds1\t\t\t: TBE_PPC.dt_PlantRemoteInputs; \t\t\t\t\t\t\t\t\t//[pu], Commands from remote source 1\n\tRemoteCmds2\t\t\t: TBE_PPC.dt_PlantRemoteInputs; \t\t\t\t\t\t\t\t\t//[pu], Commands from remote source 2\n\tScheduleCmds\t\t: TBE_PPC.dt_ReactivePwrHMIInputs;\t\t\t\t\t\t\t\t\t//[pu], Commands from scheduler\n\tMeterFbk\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t\t\t\t\t\t\t\t\t\t//[pu], Meter Feedback\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t\t\t\t\t\t\t\t\t\t//Plant configuration struct\n\tHVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\t\t//HV Meter Config array\n\tMVMeterCfg\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\t\t//HV Meter Config array\n\tHVMeterFbk\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\t\t//HV Meter Feedback\n\tMVMeterFbk\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\t\t//MV Meter Feedback\n\tPlantAlarms\t\t\t: TBE_PPC.dt_PlantAlarms;\t\t\t\t\t\t\t\t\t\t\t//Plant Alarms Structure\n\tLDCSts\t\t\t\t: TBE_PPC.dt_LDCSts; \n\tQCapInj\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Calculated plant reactive power injection capacity\n\tQCapAbs\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Calculated plant reactive power absorption capacity \nEND_VAR\nVAR_OUTPUT\n\tQCtrl_Aux_Outputs\t: TBE_PPC.dt_AVRCtlAuxOutputs; \t\t\t\t\t\t\t\t\t\t//Output structure from AVR Auxiliary control program\nEND_VAR\nVAR\n\tRTRIGQ \t\t\t\t: R_TRIG;             \t\t//Rising Edge\n\tFTRIGQ \t\t\t\t: F_TRIG; \t\t\t\t\t//Falling Edge\n\tDroopRLIM\t\t\t: TBE_PPC.FB_R_LIM;  \t\t//Droop setpoint rate limiter\n\tDroopUpLim\t\t\t: REAL;          \t\t\t//Droop setpoint ramp up limit\n\tDroopDnLim\t\t\t: REAL;          \t\t\t//Droop setpoint ramp down limit\n\tDroopRef\t\t\t: REAL;                  \t//Droop reference value\n\tDroopRLIMpv\t\t\t: REAL;       \t\t\t\t//PV For Droop sp RLIM                \n\tDroopRLIMEn\t\t\t: BOOL;     \t\t\t\t//Enable Droop RLIM\n\tQLoLim\t\t\t\t: REAL :=0;              \t//Reactive Power Low Limit\n\tQHiLim\t\t\t\t: REAL:=0;               \t//Reactive Power High Limit\n\tQLoLim_PF\t\t\t: REAL:=0;     \t\t\t\t//Reactive Power Low Limit To Maintain Power Factor Limits\n\tQHiLim_PF\t\t\t: REAL:=0;       \t\t\t//Reactive Power High Limit To Maintain Power Factor Limits\n\tPFIntlk\t\t\t\t: BOOL;    \t\t\t\t\t//Power Factor Control Interlock\n\tQIntlk\t\t\t\t: BOOL;      \t\t\t\t//Reactive power control interlock\n\tVIntlk\t\t\t\t: BOOL;      \t\t\t\t//Voltage control interlock\n\tPF_QSp\t\t\t\t: REAL;   \t\t\t\t\t//Reactive power setpoint derived from power faactor sp\n\ttmpPFref\t\t\t: REAL;                \t\t//Temp PF ref\n\ttmpPFsp\t\t\t\t: REAL; \t\t\t\t\t//Temp PF sp\n\ttmpQref\t\t\t\t: REAL;  \t\t\t\t\t//Temp Q ref\n\ttmpQsp\t\t\t\t: REAL;   \t\t\t\t\t//Temp Q sp\n\ttmpVref\t\t\t\t: REAL;  \t\t\t\t\t//Temp V ref\n\ttmpVsp\t\t\t\t: REAL;   \t\t\t\t\t//Temp V sp\n\ttmpQmd \t\t\t\t: UINT; \t\t\t\t\t//Temp Q mode command\n\tQDroop\t\t\t\t: REAL;\t\t\t\t\t\t//Output of voltage droop calculation\n\tVAbsDroop\t\t\t: REAL;         \t\t\t//Voltage Absorbtion Droop \n\tVInjDroop\t\t\t: REAL;        \t\t\t\t//Voltage Injection Droop\n\tVDroop\t\t\t\t: TBE_PPC.fb_VDroop;\t\t//Instance of voltage droop function block - to calculated Q Setpoint based on voltage feedback and voltage droop curve\n\ttmpQMax\t\t\t\t: REAL;\t\t\t\t\t\t//Q max value as calculated by the QLimCalc function\n\ttmpQMin\t\t\t\t: REAL;\t\t\t\t\t\t//Q min value as calculated by the QLimCalc function\n\ttmpVQDroopActive\t: BOOL;\t\t\t\t\t\t//Temp to hold V w/Reactive Droop Function Active/Inactive\n\tVQDroop\t\t\t\t: fb_VQDroop;\t\t\t\t//Instance of voltage w/Reactive droop function block - to calculated Q Setpoint based on voltage feedback and voltage droop curve\nEND_VAR","LineInfoPersistence":"(string)7e399e70-d478-4e15-9ace-f60ddaeb88c1_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)398","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}