{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)aec53f68-3a91-4b73-9fa7-46bd8f42ab3b","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_RedundancyInputsSwitch","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)952de500-f348-4619-9664-e0cb54559071"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine which input structure should be used based on IP Alias Active tag\nIF RedundancySts_Local.Sts_CtrlActive THEN\n\t//IP Alias is active, use local inputs\n\tPPCInputs := PPCInputs_Local;\nELSIF RedundancySts_Local.Sts_CommsGood AND RedundancySts_Local.Sts_RemoteCtrlActive THEN\n\t//RTAC <-> RTAC Comms is good and remote controller is active - Use inputs from remote controller\n\tmeth_ReadInputsFromRemoteCtrl(); \nELSE\n\t//Neither controller is active -> ues local inputs\n\tPPCInputs := PPCInputs_Local; \nEND_IF\n\n//Map the remote outputs structure to the PPCInputs structure\nPPCInputs.RemoteCtrlInputs := PPCInputs_Remote.RemoteCtrlInputs;\n\n//Add Redundancy Status to PPC Inputs -> This will reflect the local redundancy status\nPPCInputs.RedundancySts_Local := RedundancySts_Local; \n\n//Update local Cfg tags to match remote Cfg tags if local PPC is passive\nIF (NOT RedundancySts_Local.Sts_CtrlActive) AND PPCInputs_Remote.RedundancySts_Local.Sts_CtrlActive AND PlantCfg_Eng_Remote.Sbase <> 0 THEN\n\t//IP Alias is not active and RTAC<->RTAC comms is good, update local cfg tags to match remote - Only PlantCfg_Eng will be updated\n\tCfg_GVL.PlantCfg_Eng.ActivePwrCfg := PlantCfg_Eng_Remote.ActivePwrCfg;\n\tCfg_GVL.PlantCfg_Eng.FreqCfg := PlantCfg_Eng_Remote.FreqCfg;\n\tCfg_GVL.PlantCfg_Eng.ReactivePwrCfg := PlantCfg_Eng_Remote.ReactivePwrCfg;\n\tCfg_GVL.PlantCfg_Eng.VoltageCfg := PlantCfg_Eng_Remote.VoltageCfg;\n\tCfg_GVL.PlantCfg_Eng.PFCfg := PlantCfg_Eng_Remote.PFCfg;\n\tCfg_GVL.PlantCfg_Eng.BESSCfg := PlantCfg_Eng_Remote.BESSCfg;\n\tCfg_GVL.CapBankCfg_Eng := CapBankCfg_Remote;\n\tCfg_GVL.CapBankNumOfOper := CapBankNumOper_Remote; \n\tCfg_GVL.PlantCfg_Eng.VoltageCfg := PlantCfg_Eng_Remote.VoltageCfg;\n\tCfg_GVL.PlantCfg_Eng.FFRCfg := PlantCfg_Eng_Remote.FFRCfg;\n\t\nEND_IF","LineInfoPersistence":"(string)aec53f68-3a91-4b73-9fa7-46bd8f42ab3b_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRedundancy Inputs Switch Program\n|\tThis program will pass out the inputs/cfg from the Active PPC if the local PPC is Passive. \n|\tOtherwise, when the local PPC is Active, it will pass out the inputs/cfg read from external devices\n*)\nPROGRAM pg_RedundancyInputsSwitch\nVAR_INPUT\n\tPPCInputs_Local\t\t\t: dt_PPCInputs;\t\t\t\t\t\t\t\t\t\t//PPC Inputs read from external devices\n\tPPCInputs_Remote\t\t: dt_PPCInputs;\t\t\t\t\t\t\t\t\t\t//PPC Inputs read from the remote PPC\n\tPlantCfg_Eng_Remote\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t//Plant config structure read from remote PPC\n\tRedundancySts_Local\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t//Redundancy status structure of local controller\n\tCfg\t\t\t\t\t\t: TBE_PPC.dt_RedundancyCfg; \t\t\t\t\t\t//Redundancy configuration structure\n\tCapBankCfg_Remote\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t//Cap Bank configuration struct from remote PPC\n\tCapBankNumOper_Remote\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t//Array of number of cap bank operations, from remote PPC\nEND_VAR\nVAR_OUTPUT\n\tPPCInputs\t\t\t\t: dt_PPCInputs;\t\t\t\t\t\t\t\t\t\t//PPC Inputs to be used by core logic\nEND_VAR\nVAR\n\ti\t\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\nEND_VAR","LineInfoPersistence":"(string)aec53f68-3a91-4b73-9fa7-46bd8f42ab3b_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)83","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}