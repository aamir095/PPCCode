respondingPageId":null,"Locked":"(bool)False"}},"@Value":{"@Type":"584effbc","@Value":{"InnerList":{"@Type":"[]","@Value":[{"@Type":"b3e42b54","@Value":{"X":"(int)13","Y":"(int)8","IsJoint":"(bool)False","Flags":"(int)68"}},{"@Type":"b3e42b54","@Value":{"X":"(int)18","Y":"(int)8","IsJoint":"(bool)False","Flags":"(int)65"}}]}}}},{"@Key":{"@Type":"93c117eb","@Value":{"ConnectionId":"(long)35","StartPoint":{"@Type":"b3e42b54","@Value":{"X":"(int)13","Y":"(int)9","IsJoint":"(bool)False","Flags":"(int)0"}},"Unroutable":"(bool)False","CorrespondingPageId":null,"Locked":"(bool)False"}},"@Value":{"@Type":"584effbc","@Value":{"InnerList":{"@Type":"[]","@Value":[{"@Type":"b3e42b54","@Value":{"X":"(int)13","Y":"(int)9","IsJoint":"(bool)False","Flags":"(int)68"}},{"@Type":"b3e42b54","@Value":{"X":"(int)18","Y":"(int)9","IsJoint":"(bool)False","Flags":"(int)65"}}]}}}},{"@Key":{"@Type":"93c117eb","@Value":{"ConnectionId":"(long)36","StartPoint":{"@Type":"b3e42b54","@Value":{"X":"(int)33","Y":"(int)8","IsJoint":"(bool)False","Flags":"(int)0"}},"Unroutable":"(bool)False","CorrespondingPageId":null,"Locked":"(bool)False"}},"@Value":{"@Type":"584effbc","@Value":{"InnerList":{"@Type":"[]","@Value":[{"@Type":"b3e42b54","@Value":{"X":"(int)33","Y":"(int)8","IsJoint":"(bool)False","Flags":"(int)68"}},{"@Type":"b3e42b54","@Value":{"X":"(int)38","Y":"(int)8","IsJoint":"(bool)False","Flags":"(int)65"}}]}}}}]}}},"AutoSizeCanvas":"(bool)True","CanvasWidth":"(int)65","CanvasHeight":"(int)12","EditorConfiguration":{"@Type":"4f1e43e3","@Value":{"HideNamespaces":"(bool)False"}},"AreElementsSpaceOptimized":"(bool)True"}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRedundancy Logic Program\n|\tThis program contains two instances of the SEL function block to generate an IP Alias based on Redundancy Logic\n|\tTwo instances of the function block are present, but only the one that matches the SN of the RTAC will run (which allows for the same logic to run on both RTACs)\n|\tRefer to the IP Alias Library Documentation (from SEL) for more details on how the function blocks work\n*)\nPROGRAM pg_RedundancyLogic\nVAR_INPUT\n\tRedundancyCfg\t\t: TBE_PPC.dt_RedundancyCfg; \t\t\t//Redundancy configuration structure\n\tHMIInputs_Local\t\t: TBE_PPC.dt_RedundancyHMIInputs;\t\t//Redundancy HMI Inputs from local controller\n\tPlantCfg_Remote\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t//PPC config structure read from remote PPC\n\tPPCInputs_Remote\t: dt_PPCInputs;\t\t\t\t\t\t\t//PPC Inputs from remote controller\nEND_VAR\nVAR_OUTPUT\n\tRedundancySts\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t//Redundancy status structure\nEND_VAR\nVAR\n\tPortCtrlRTAC1\t\t: fb_InterfaceControl;\t\t\t\t\t//Interface check, tied to SN of RTAC1\n\tPortCtrlRTAC2\t\t: fb_InterfaceControl;\t\t\t\t\t//Interface check, tied to SN of RTAC2\n\tStartupTmr1\t\t\t: fb_10sStartupTimer;\t\t\t\t\t//10s startup timer - will disable redundancy upon startup\n\tStartupTmr2\t\t\t: fb_10sStartupTimer;\t\t\t\t\t//10s startup timer - will disable redundancy upon startup\n\tRedundancyCheck1\t: fb_RedundancyCheck;\t\t\t\t\t//Redundancy check function block for RTAC1\n\tRedundancyCheck2\t: fb_RedundancyCheck;\t\t\t\t\t//Redundancy check function block for RTAC2\nEND_VAR","LineInfoPersistence":"(string)12bc438c-eeef-4663-b9df-49c6e380651d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)95","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","233bc97c":"{233bc97c-69fe-4d29-b40e-a9a9b854044e}","24449d48":"{24449d48-c96a-49c4-b9d1-a4ea34aedce3}","32d3375e":"{32d3375e-c010-41e2-9e43-b2fbf4f2b374}","4b8bcc79":"{4b8bcc79-5980-4868-b49e-005a8148859b}","4f1e43e3":"{4f1e43e3-0667-4421-ad70-d7adf37c167a}","584effbc":"{584effbc-813e-443a-bf78-ad9c8d49db41}","5ae2e111":"{5ae2e111-ecff-4a2