ype":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCombine diagnostics from TBE and SEL redundancy blocks into one diagnostics output\nMETHOD meth_CombineDiagnostics\nVAR_INPUT\n\tTBERedundancySts: TBE_PPC.dt_RedundancyDiagnostics;\n\tSELRedundancySts: TBE_PPC.dt_RedundancyDiagnostics;\nEND_VAR\nVAR_OUTPUT\n\tRedundancySts: TBE_PPC.dt_RedundancyDiagnostics;\nEND_VAR\n","LineInfoPersistence":"(string)71083151-eb46-4607-9693-99ea26262816_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}