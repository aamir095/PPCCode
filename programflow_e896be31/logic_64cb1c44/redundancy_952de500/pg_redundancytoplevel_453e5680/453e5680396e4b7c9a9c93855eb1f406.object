lisation":"(string)PROGRAM pg_RedundancyTopLevel\nVAR_INPUT\n\tPPCInputs_Local\t\t: dt_PPCInputs; \t\t\t\t\t\t\t\t\t\t\t//PPC inputs, from local controller\n\tPPCInputs_Remote\t: dt_PPCInputs;\t\t\t\t\t\t\t\t\t\t\t\t//PPC inputs, from remote controller\n\tPlantCfg_Remote\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t//PPC Configuration structure, from remote controller\n\tCapBankCfg_Remote\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t//Cap Bank configuration struct from remote PPC\n\tCapBankNumOper_Remote\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t//Array of number of cap bank operations, from remote PPC\nEND_VAR\nVAR_OUTPUT\n\tPPCInputs\t\t\t: dt_PPCInputs;\t\t\t\t\t\t\t\t\t\t\t\t//PPC inputs, to be used in core logic\n\tRedundancyDiagnostics\t: ARRAY[1..2] OF TBE_PPC.dt_RedundancyDiagnostics; \t\t//Array of redundancy diagnostics\nEND_VAR","LineInfoPersistence":"(string)453e5680-396e-4b7c-9a9c-93855eb1f406_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)129","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","233bc97c":"{233bc97c-69fe-4d29-b40e-a9a9b854044e}","24449d48":"{24449d48-c96a-49c4-b9d1-a4ea34aedce3}","32d3375e":"{32d3375e-c010-41e2-9e43-b2fbf4f2b374}","4b8bcc79":"{4b8bcc79-5980-4868-b49e-005a8148859b}","4f1e43e3":"{4f1e43e3-0667-4421-ad70-d7adf37c167a}","584effbc":"{584effbc-813e-443a-bf78-ad9c8d49db41}","5ae2e111":"{5ae2e111-ecff-4a21-b647-2d4da63f8db7}","5c3476a8":"{5c3476a8-05c5-430e-861c-9cfa51d68ca8}","65582d84":"{65582d84-cf18-4ca0-be59-bf5a3d00b8f8}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","72f2b13f":"{72f2b13f-5349-4a8a-bbe6-2bccf3f42179}","77f43dfe":"{77f43dfe-ca6a-4869-828f-7609d8ed6ea6}","88453c7d":"{88453c7d-d652-4a27-a1b0-a1953be49a5c}","8d9e2b78":"{8d9e2b78-3efe-4fe4-8160-f3a7381ddd8f}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","93c117eb":"{93c117eb-088