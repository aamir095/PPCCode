{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)9ce4dfff-787e-416d-b42f-80db322c3a20","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_RedundancyDiagnostics","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)952de500-f348-4619-9664-e0cb54559071"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Copy redundancy diagnostics structure into output variable\nDiag_Local := Diag_Local_In; \n\nIF Diag_Local.Sts_CtrlActive AND NOT IPAliasActivePrev THEN\n\t//Controller has transitioned to active\n\tTActiveStart := SysTimeCore.SysTimeGetMs(); \nELSIF (NOT Diag_Local.Sts_CtrlActive AND IPAliasActivePrev) OR (TActiveStart = 0 AND TPassiveStart = 0) THEN\n\tTPassiveStart := SysTimeCore.SysTimeGetMs();\nEND_IF\nIPAliasActivePrev := Diag_Local.Sts_CtrlActive;\n\n//Determine time spent as active controller\nIF Diag_Local.Sts_CtrlActive THEN\n\tIF TActiveStart > SysTimeCore.SysTimeGetMS() THEN\n\t\t//Recalculate start time\n\t\tTActiveStart := SysTimeCore.SysTimeGetMs(); \n\tEND_IF\n\tDiag_Local.Sts_TimeActive := (SysTimeCore.SysTimeGetMs() - TActiveStart) / 1000;\t\t//Convert from ms to sec \n\tDiag_Local.Sts_TimePassive := 0;  \nELSE\n\tIF TPassiveStart > SysTimeCore.SysTimeGetMs() THEN\n\t\t//Recalculate start time\n\t\tTPassiveStart := SysTimeCore.SysTimeGetMs(); \n\tEND_IF\n\tDiag_Local.Sts_TimePassive := (SysTimeCore.SysTimeGetMs() - TPassiveStart) / 1000; \t//Convert from ms to sec\n\tDiag_Local.Sts_TimeActive := 0;  \nEND_IF\n\n//Determine if Remote Controller is online via watchdog timer\nWatchdogTON(IN := (RemoteCtrlInputs.Watchdog = WatchdogCountPrev), PT := Cfg.CommStatusTimeout);\nWatchdogCountPrev := RemoteCtrlInputs.Watchdog;\n\nIF NOT WatchdogTON.Q THEN\n\t//RTAC/RTAC comms are good - move active status of remote controller to local diagnostics struct\n\tDiag_Local.Sts_RemoteCtrlActive := Diag_Remote_In.Sts_CtrlActive;\nELSE\n\t//RTAC/RTAC comms are bad -> Set active status of remote controller to FALSE since it is unknown\n\tDiag_Local.Sts_RemoteCtrlActive := FALSE;\nEND_IF\n\n//Move remote diagnostics to local variable\n//Diag_Remote := Remote_To_Local_NGVL.RedundancyDiag;\n\n//Adjust remote status if watchdog timer fails\n(*\nIF Diag_Local.Alm_RemoteControllerWatchdogTimeout THEN\n\tDiag_Remote.Sts_CtrlActive := FALSE;\n\tDiag_Remote.Sts_EthCommsGood := FALSE;\n\tDiag_Remote.Sts_NGVLCommsGood := FALSE;\n\tDiag_Remote.STS_Enabled := FALSE;\n\tDiag_Remote.Sts_IPAliasActive := FALSE;\n\tDiag_Remote.Sts_TimeActive := 0;\n\tDiag_Remote.Sts_TimePassive := 0;\nEND_IF\n*)\n\n//Determine if both controllers are 'Active'\n//Diag_Local.Alm_BothControllersActive := (Diag_Local.Sts_CtrlActive AND Diag_Remote.Sts_CtrlActive); \n\n//Determine if both controllers are 'Passive'\n//Diag_Local.Alm_NeitherControllerActive := (NOT Diag_Local.Sts_CtrlActive AND NOT Diag_Remote.Sts_CtrlActive);\n\n//Update SN and IP address of local controller\nDiag_Local.Sts_SN := SystemTags.Serial_Number.strVal; \nIF Cfg.SN_RTAC1 = SystemTags.Serial_Number.strVal THEN\n\tDiag_Local.Sts_IP := Cfg.IP_RTAC1;\nELSIF Cfg.SN_RTAC2 = SystemTags.Serial_Number.strVal THEN\n\tDiag_Local.Sts_IP := Cfg.IP_RTAC2;\nEND_IF\n\n//Determine if controllers have the same Project ID\nget_project_ID(project_ID := Diag_Local.Sts_ProjectID);\n//Diag_Local.Alm_ProjectIDMismatch := (Diag_Remote.Sts_ProjectID <> Diag_Local.Sts_ProjectID) AND (NOT Diag_Local.Alm_RemoteControllerWatchdogTimeout);\n\n//Determine if controllers have the same plant-level P/Q Outputs\n\n\n//Determine if the out of sync alarm needs to be set - \n//Diag_Local.Alm_ProjectsOutOfSync := Diag_Local.Alm_OutputsMismatch OR Diag_Local.Alm_ProjectIDMismatch;\n\n//Generate output array of Diagnostics structures\nIF Cfg.SN_RTAC1 = SystemTags.Serial_Number.strVal THEN\n\t//RTAC1\n\tRedundancyDiagnostics[1] := Diag_Local;\n\tRedundancyDiagnostics[2] := Diag_Remote_In; \nELSIF Cfg.SN_RTAC2 = SystemTags.Serial_Number.strVal THEN\n\t//RTAC2\n\tRedundancyDiagnostics[1] := Diag_Remote_In;\n\tRedundancyDiagnostics[2] := Diag_Local;\nEND_IF\n\n//Output local diagnostics structure\nDiag_Local_Out := Diag_Local;\n","LineInfoPersistence":"(string)9ce4dfff-787e-416d-b42f-80db322c3a20_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRedundancy Diagnostics Program\n|\tDetermine diagnostic values related to PPC Redundancy\n*)\nPROGRAM pg_RedundancyDiagnostics\nVAR_INPUT\n\tRemoteCtrlInputs\t: TBE_PPC.dt_RemoteCtrlInputs;\t\t\t//Inputs from remote controller\n\tDiag_Local_In\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t//Redundancy status structure\n\tDiag_Remote_In\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t//Redundancy status structure from remote controller\n\tCfg\t\t\t\t\t: TBE_PPC.dt_RedundancyCfg; \t\t\t//Redundancy configuration structure\nEND_VAR\nVAR_OUTPUT\n\tRedundancyDiagnostics\t: ARRAY[1..2] OF TBE_PPC.dt_RedundancyDiagnostics; \t\t//Array of redundancy diagnostics, index 1 = RTAC1, index 2 = RTAC2\n\tDiag_Local_Out\t\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t//Local controller redundancy diagnostics\nEND_VAR\nVAR\n\tWatchdogCountPrev\t: UINT;\t\t\t\t\t\t\t\t\t//Previous value of watchdog counter from remote controller\n\tWatchdogTON\t\t\t: TON;\t\t\t\t\t\t\t\t\t//Timer for watchdog counter\n\tIPAliasActivePrev\t: BOOL;\t\t\t\t\t\t\t\t\t//Previous value of IP Alias Active\n\tTActiveStart\t\t: UDINT;\t\t\t\t\t\t\t\t//Time at which controller transitions to active\n\tTPassiveStart\t\t: UDINT;\t\t\t\t\t\t\t\t//Time at which controller transitions to passive\n\tDiag_Local\t\t\t: TBE_PPC.dt_RedundancyDiagnostics; \t//Structure of redundancy related diagnostics for local controller\n\tDiag_Remote\t\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t//Structure of redundancy related diagnostics from remote controller\nEND_VAR","LineInfoPersistence":"(string)9ce4dfff-787e-416d-b42f-80db322c3a20_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)155","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}