{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)96258d24-29d1-43c9-955f-e2df00e7a703","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1_CapBankLogic","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)1a10d204-4ed5-4f63-825d-b9404e205dd0"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF SiteConstants.NumCapBanks = 0 THEN\n\tRETURN;\nEND_IF\n\n// Map in open/closed status for each cap bank using loop. \nFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO\n\t//Determine Status\n\tCapbank[i].STS_Clsd := CapBankSts[i].Closed;\n\tCapbank[i].STS_Opnd := CapBankSts[i].Open;\n\t\n\t//Determine Auto/Manual Enable\n\tIF CapBankHMIInputs[i].AutoEn THEN\n\t\tCapbank[i].HMI_AutoEn := TRUE;\n\t\tCapbank[i].HMI_ManEn := FALSE;\n\t\tCapBankDiag[i].Auto := TRUE;\n\tELSE\n\t\tCapbank[i].HMI_ManEn := TRUE;\n\t\tCapbank[i].HMI_AutoEn := FALSE;\n\t\tCapBankDiag[i].Auto := FALSE;\n\tEND_IF\n\t\n\t//Determine Permissive\n\tIF Capbank[i].STS_Opnd AND CapBankSts[i].CloseAvail THEN\n\t\t//switch is open and close is available -> set permissive to true\n\t\tCapbank[i].Close_Permissive := TRUE;\n\t\tCapbank[i].Open_Permissive := FALSE;\n\t\tCapBankDiag[i].ClosePerm := TRUE;\n\t\tCapBankDiag[i].OpenPerm := FALSE;\n\tELSIF Capbank[i].STS_Clsd AND CapBankSts[i].OpenAvail THEN\n\t\t//switch is closed and open is available -> set permissive to true\n\t\tCapbank[i].Open_Permissive := TRUE;\n\t\tCapbank[i].Close_Permissive := FALSE;\n\t\tCapBankDiag[i].OpenPerm := TRUE;\n\t\tCapBankDiag[i].ClosePerm := FALSE;\n\tELSE\n\t\tCapbank[i].Open_Permissive := FALSE;\n\t\tCapbank[i].Close_Permissive := FALSE;\n\t\tCapBankDiag[i].OpenPerm := FALSE;\n\t\tCapBankDiag[i].ClosePerm := FALSE;\n\tEND_IF\n\t\n\t//Source of Q measurement\n\tCASE capbankcfg.QMeasSrc OF\n\t\tTBE_PPC.enum_QSource.HVMeter:\n\t\t\ttmp_QFbk := MeterFbk.Sts_Q;\n\t\tTBE_PPC.enum_QSource.MVMeter:\n\t\t\ttmp_QFbk := CapBankSts[i].Q;\n\t\tTBE_PPC.enum_QSource.InvSum:\n\t\t\ttmp_QFbk := 0;\n\t\t\tFOR k := 0 TO SiteConstants.NumInvs BY 1 DO\n\t\t\t\ttmp_QFbk := tmp_QFbk + InvQFbk[k].Sts_Q;\n\t\t\tEND_FOR\n\t\tELSE\n\t\t\ttmp_QFbk := MeterFbk.Sts_Q;\n\tEND_CASE\n\t\n\t//system is not in operation when feedback is not over threshold for all cap banks and not in the middle of any open/close operation\n\tNotInOperation := TRUE;\n\tNotInOperation := NotInOperation \n\t\t\t\t\tAND NOT CapBankDiag[i].InCloseOperation\n\t\t\t\t\tAND NOT CapBankDiag[i].InOpenOperation \n\t\t\t\t\tAND tmp_QFbk <= CapBankCfg.CapCloseThresh[i] \n\t\t\t\t\tAND tmp_QFbk >= CapBankCfg.CapOpenThresh[i];\n\t\t\t\t\t\n\t//clear the trial count when cap banks are not in operation\n\tIF NOT(tmp_QFbk > CapBankCfg.CapCloseThresh[i]) OR Capbank[i].STS_Clsd THEN\n\t\tCapbank[i].Close_Trial := 0;\t\n\tEND_IF\n\tIF NOT(tmp_QFbk < CapBankCfg.CapOpenThresh[i]) OR Capbank[i].STS_Opnd THEN\n\t\tCapbank[i].Open_Trial := 0;\t\n\tEND_IF\n\t\n\t//operation order selection, default mode is number of operations\n\tCASE CapBankOperMode OF\n\t\tTBE_PPC.enum_CapOperMode.StagedMode: \n\t\t\tStagedMode := TRUE;\n\t\t\tNumOperMode := FALSE;\n\t\tTBE_PPC.enum_CapOperMode.NumOperMode:\n\t\t\tStagedMode := FALSE;\n\t\t\tNumOperMode := TRUE;\n\t\tELSE\n\t\t\tStagedMode := FALSE;\n\t\t\tNumOperMode := TRUE;\n\tEND_CASE\nEND_FOR\n\n//In staged mode, close order is specified by user from HMI. \nIF StagedMode AND NotInOperation THEN\n   //initialize the close order array and HMIInputOrder array for the sorting in next step\n\tFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tCloseOrder[i] := i;\n\t\tHMIInputOrder[i] := CapBankHMIInputs[i].CloseOrder;\n\tEND_FOR\n\t//sort the capbank index by user's input of close order (min to max), CloseOrder[1] is the index of cap bank with min close order input from HMI\n\tFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tIF i < SiteConstants.NumCapBanks THEN \n\t\t\tFOR j := 1 TO SiteConstants.NumCapBanks - i DO\n\t\t\t\tIF HMIInputOrder[j] > HMIInputOrder[j+1] THEN\n\t\t\t\t\ttemp := HMIInputOrder[j];\n\t\t\t\t\tHMIInputOrder[j] := HMIInputOrder[j+1];\n\t\t\t\t\tHMIInputOrder[j+1] := temp;\n\t\t\t\t\t\n\t\t\t\t\ttempIndex := CloseOrder[j];\n\t\t\t\t\tCloseOrder[j] := CloseOrder[j+1];\n\t\t\t\t\tCloseOrder[j+1] := tempIndex; \n\t\t\t\tEND_IF\n\t\t\tEND_FOR\n\t\tEND_IF\n\tEND_FOR\nEND_IF\n\n//In NumOperMode, sort the cap bank index by the number of operations from min to max, close the one with min operation number\nIF NumOperMode AND NotInOperation THEN\n\t//initialize the close order array and NumOperSts array for the sorting in next step\n\tFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tCloseOrder[i] := i;\n\t\tNumOperSts[i] := NumOfOper[i];\n\tEND_FOR\n\t//sort the capbank index by number of close operations (min to max), CloseOrder[1] is the index of cap bank with min operation count\n\tFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tIF i < SiteConstants.NumCapBanks THEN \n\t\t\tFOR j := 1 TO SiteConstants.NumCapBanks - i DO\n\t\t\t\tIF NumOperSts[j] > NumOperSts[j+1] THEN\n\t\t\t\t\ttemp := NumOperSts[j];\n\t\t\t\t\tNumOperSts[j] := NumOperSts[j+1];\n\t\t\t\t\tNumOperSts[j+1] := temp;\n\t\t\t\t\t\n\t\t\t\t\ttempIndex := CloseOrder[j];\n\t\t\t\t\tCloseOrder[j] := CloseOrder[j+1];\n\t\t\t\t\tCloseOrder[j+1] := tempIndex; \n\t\t\t\tEND_IF\n\t\t\tEND_FOR\n\t\tEND_IF\n\tEND_FOR\nEND_IF\n\n//Cap bank close logic\nFOR i := 1 TO SiteConstants.NumCapBanks BY 1 DO \n\t//Get the index and do the condition check for close operation based on the close order\n\tIF i = 1 THEN\n\t\tindex := CloseOrder[i];\n\t\tPreBanksCheckedForClose[index] := TRUE;\n\tELSIF i <= SiteConstants.NumCapBanks THEN\n\t\tindex := CloseOrder[i];\n\t\tAllPreviousClsd[index] := TRUE;\n\t\tFOR m := 1 TO i - 1 BY 1 DO\n\t\t\tpreviousIndex := CloseOrder[i-m]; \n\t\t\tAllPreviousClsd[index] := AllPreviousClsd[index] AND //allow current bank to be closed when previous banks:\n\t\t\t\t\t\t\t(Capbank[previousIndex].HMI_ManEn // have manual mode enabled\n\t\t\t\t\t\t\tOR NOT Capbank[previousIndex].Close_Permissive //or they are not permissive to be operated\n\t\t\t\t\t\t\tOR Capbank[previousIndex].STS_Clsd //or they are already closed\n\t\t\t\t\t\t\tOR (Capbank[previousIndex].Close_Trial = CapbankCfg.OperAttempt AND NOT Capbank[previousIndex].STS_Clsd)); //or they are not closed but had enough trials defined by OperAttempt.\n\t\tEND_FOR\n\t\tPreBanksCheckedForClose[index] := AllPreviousClsd[index];\n\tEND_IF\n\t\n\t//Log the current close order to diagostic structure\n\tCapBankDiag[i].CloseOrder := index;\n\t\n\t//The condition to allow cb to be closed in auto mode. Need to follow close order. Advance to next cap bank when the bank is successfully closed or had been tried for \"OperAttempt\" times\n\tAutoCloseCondition[index] := tmp_QFbk > CapBankCfg.CapCloseThresh[index] \n\t\t\t\t\t\t\t\tAND Capbank[index].Close_Permissive \n\t\t\t\t\t\t\t\tAND PreBanksCheckedForClose[index]\n\t\t\t\t\t\t\t\tAND Capbank[index].HMI_AutoEn\n\t\t\t\t\t\t\t\tAND NOT Capbank[index].STS_Clsd \n\t\t\t\t\t\t\t\tAND Capbank[index].Close_Trial < CapbankCfg.OperAttempt;\n\t\n\t//the condition to allow cb to be closed in manual mode, in manual mode there is no restriction from the close order\n\tManualCloseCondition[index] := Capbank[index].Close_Permissive \n\t\t\t\t\t\t\t\t\tAND Capbank[index].HMI_ManEn\n\t\t\t\t\t\t\t\t\tAND CapBankHMIInputs[index].CmdCloseManual\n\t\t\t\t\t\t\t\t\tAND NOT Capbank[index].STS_Clsd;\n\t\t\t\t\t\t\t\t\t\n\tRtrigManualClose[index](CLK := ManualCloseCondition[index]);\n\t\n\t//when condition is true use below timers to close cap bank\t\t\t\t\t\t\t\t\n\tCloseThreshTmr[index](In := NOT SwitchCloseDelayTmr[index].q AND AutoCloseCondition[index], PT := CapBankCfg.ThreshWaitTime);\n\tCloseCmdTmr[index](IN := CloseThreshTmr[index].Q OR RtrigManualClose[index].Q, PT := CapBankCfg.OpTime);\n\tSwitchCloseDelayTmr[index](IN := CloseThreshTmr[index].Q, PT := CapBankCfg.SuspendTime + CapBankCfg.OpTime);\n\tCapBankCmds[index].Close := CloseCmdTmr[index].q AND (AutoCloseCondition[index] OR ManualCloseCondition[index]);\n\t\n\t//Increment trial counts when operation is over (only in the auto mode)\n\tFtrigClose[index](CLK := SwitchCloseDelayTmr[index].q);\n\tIF AutoCloseCondition[index] AND FtrigClose[index].Q THEN\n\t\tCapbank[index].Close_Trial := Capbank[index].Close_Trial + 1;\n\tEND_IF\n\t\n\t//Update diagnose status\n\tCapBankDiag[index].InCloseOperation := CloseThreshTmr[index].IN OR SwitchCloseDelayTmr[index].Q;\n\tCapBankDiag[index].CloseWaitTmrActive := CloseThreshTmr[index].IN AND NOT SwitchCloseDelayTmr[index].Q; \n\tCapBankDiag[index].CloseCmdIssued := Capbank[index].Close_Trial = 0 AND CloseCmdTmr[index].q;\n\tCapBankDiag[index].CloseCmdIssuedTwice := Capbank[index].Close_Trial = 1 AND CloseCmdTmr[index].q; \n\tCapBankDiag[index].Closed := CapBankSts[index].Closed;\n\tCapBankDiag[index].AllowCloseInAuto := AutoCloseCondition[index];\n\tCapBankDiag[index].AllowCloseInManual := ManualCloseCondition[index];\n\tCapBankDiag[index].CloseTrial := Capbank[index].Close_Trial;\n\tCapBankDiag[index].CloseFailed := Capbank[index].Close_Trial = 1 AND NOT Capbank[index].STS_Clsd;\n\tCapBankDiag[index].CloseFailedTwice := Capbank[index].Close_Trial = 2 AND NOT Capbank[index].STS_Clsd;\nEND_FOR\n\n//Cap bank open logic\nFOR j := SiteConstants.NumCapBanks TO 1 BY -1 DO\n\t//Get the index and do the condition check for open operation based on backward traversal of close order \n\tIF j = SiteConstants.NumCapBanks THEN\n\t\tindex := CloseOrder[j];\n\t\tPreBanksCheckedForOpen[index] := TRUE;\n\tELSIF j >= 1 THEN\n\t\tindex := CloseOrder[j];\n\t\tAllPreviousOpnd[index] := TRUE;\n\t\tFOR m := 1 TO SiteConstants.NumCapBanks - j BY 1 DO\n\t\t\tpreviousIndex := CloseOrder[j+m];\n\t\t\tAllPreviousOpnd[index] := AllPreviousOpnd[index] AND //allow current bank to be opened when previous banks:\n\t\t\t\t\t\t\t\t\t(Capbank[previousIndex].HMI_ManEn // have manual mode enabled\n\t\t\t\t\t\t\t\t\tOR NOT Capbank[previousIndex].Open_Permissive //or they are not permissive to be operated\n\t\t\t\t\t\t\t\t\tOR Capbank[previousIndex].STS_Opnd //or they are already opened\n\t\t\t\t\t\t\t\t\tOR (Capbank[previousIndex].Open_Trial = CapbankCfg.OperAttempt AND NOT Capbank[previousIndex].STS_Opnd)); //or they are not opened but had been tried OperAttempt times\n\t\tEND_FOR\n\t\tPreBanksCheckedForOpen[index] := AllPreviousOpnd[index];\n\tEND_IF\n\t\n\t//Log the current close order to diagnostic structure\n\tCapBankDiag[i].CloseOrder := index;\n\t\n\t//The condition to allow cb to be opened in auto mode. Need to follow reversed close order. Advance to next cap bank when the bank is successfully opened or had been tried \"OperAttempt\" times\n\tAutoOpenCondition[index] := tmp_QFbk < CapBankCfg.CapOpenThresh[index] \n\t\t\t\t\t\t\t\tAND Capbank[index].Open_Permissive \n\t\t\t\t\t\t\t\tAND PreBanksCheckedForOpen[index]\n\t\t\t\t\t\t\t\tAND Capbank[index].HMI_AutoEn \n\t\t\t\t\t\t\t\tAND NOT Capbank[index].STS_Opnd  \n\t\t\t\t\t\t\t\tAND Capbank[index].Open_Trial < CapbankCfg.OperAttempt;\n\t\n\t//the condition to allow cb to be opened in manual mode, in manual mode there is no restriction from close order\n\tManualOpenCondition[index] := Capbank[index].Open_Permissive \n\t\t\t\t\t\t\t\tAND Capbank[index].HMI_ManEn\n\t\t\t\t\t\t\t\tAND CapBankHMIInputs[index].CmdOpenManual\n\t\t\t\t\t\t\t\tAND NOT Capbank[index].STS_Opnd;\n\t\t\t\t\t\t\t\t\n\tRtrigManualOpen[index](CLK := ManualOpenCondition[index]);\n\t\t\t\t\t\t\t\t\n\t//when condition is true use below timers to open cap bank\t\n\tOpenThreshTmr[index](In := NOT SwitchOpenDelayTmr[index].q AND AutoOpenCondition[index], PT := CapBankCfg.ThreshWaitTime);\n\tOpenCmdTmr[index](IN := OpenThreshTmr[index].Q OR RtrigManualOpen[index].Q, PT := CapBankCfg.OpTime);\n\tSwitchOpenDelayTmr[index](IN := OpenThreshTmr[index].Q, PT := CapBankCfg.SuspendTime + CapBankCfg.OpTime);\n\tCapBankCmds[index].Open := OpenCmdTmr[index].q AND (AutoOpenCondition[index] OR ManualOpenCondition[index]);\n\t\n\t//Increment trial counts when operation is over (only in the auto mode)\n\tFtrigOpen[index](CLK := SwitchOpenDelayTmr[index].q);\n\tIF AutoOpenCondition[index] AND FtrigOpen[index].Q THEN\n\t\tCapbank[index].Open_Trial := Capbank[index].Open_Trial + 1;\n\tEND_IF\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\n\t//when cap bank is opened, update the operation counts retained variable \n\tRtrigOpen[index](CLK := Capbank[index].STS_Opnd);\n\tIF RtrigOpen[index].Q THEN\n\t\tNumOfOper[index] := NumOfOper[index] + 1;\n\tEND_IF\n\t\n\t//Update diagnose status\n\tCapBankDiag[index].InOpenOperation := OpenThreshTmr[index].IN OR SwitchOpenDelayTmr[index].Q;\n\tCapBankDiag[index].OpenWaitTmrActive := OpenThreshTmr[index].IN AND NOT SwitchOpenDelayTmr[index].q; \n\tCapBankDiag[index].OpenCmdIssued := Capbank[index].Open_Trial = 0 AND OpenCmdTmr[index].q;\n\tCapBankDiag[index].OpenCmdIssuedTwice := Capbank[index].Open_Trial = 1 AND OpenCmdTmr[index].q; \n\tCapBankDiag[index].Closed := CapBankSts[index].Closed;\n\tCapBankDiag[index].AllowOpenInAuto := AutoOpenCondition[index];\n\tCapBankDiag[index].AllowOpenInManual := ManualOpenCondition[index];\n\tCapBankDiag[index].OpenTrial := Capbank[index].Open_Trial;\n\tCapBankDiag[index].OpenFailed := Capbank[index].Open_Trial = 1 AND NOT Capbank[index].STS_Opnd;\n\tCapBankDiag[index].OpenFailedTwice := Capbank[index].Open_Trial = 2 AND NOT Capbank[index].STS_Opnd;\nEND_FOR","LineInfoPersistence":"(string)96258d24-29d1-43c9-955f-e2df00e7a703_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tCap Bank Logic Program\n*)\nPROGRAM pg_U1_CapBankLogic\nVAR_INPUT\n\tCapBankSts\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankFbk;\t\t\t//Cap bank status structure\n\tCapBankHMIInputs\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankHMIInputs; \t//Cap bank inputs from HMI\n\tCapBankOperMode\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Choose between stage mode (1) or number of operation (2) mode\n\tMeterFbk\t\t\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t\t\t\t\t\t\t\t\t\t\t//Meter feedback\n\tCapBankCfg\t\t\t\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Capacitor bank configuration structure\n\tInvQFbk\t\t\t\t        : ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\t\t\t\t//[pu] The total production of Q from all inverters\t\t\t\t\t\t\t\t\nEND_VAR\nVAR_OUTPUT\n\tCapBankCmds\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankCmds;\t\t//Cap bank commands structure\n\tCapBankDiag\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankSts;\t\t\t//Cap bank status structure\nEND_VAR\nVAR_IN_OUT\n\tNumOfOper\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t\t\t\t\t\t//The operation counts of each cap bank. Should be defined as a retained GVL.\nEND_VAR\nVAR\n\ti,j,k,m\t\t\t\t\t\t: UINT;\t\t//Indexing variable\n\tSwitchCloseDelayTmr\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TOF; \t\t\t\t\t\t\t//Delay timer to disable fast switching of capacitor bank (Open -> Close Transition)\n\tSwitchOpenDelayTmr\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TOF; \t\t\t\t\t\t\t//Delay timer to disable fast switching of capacitor bank (Closed -> Open Transition)\n\tOpenThreshTmr\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TON;\t\t\t\t\t\t\t//Timer used to verify that the open requirements are met for xx amount of time before issuing an open cmd\n\tCloseThreshTmr\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TON;\t\t\t\t\t\t\t//Timer used to verify that the close requierments are met for xx amount of time before issuing a close cmd\n\tCloseCmdTmr\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TOF;\t\t\t\t\t\t\t//Command timer to hold close commands for specified duration\n\tOpenCmdTmr\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF TOF;\t\t\t\t\t\t\t//Command timer to hold open commands for specified duration\n\n\ttmp_QFbk\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//[pu], local variable for the Q feedback\n\tStagedMode \t\t\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//TRUE = Staged mode is selected\n\tNumOperMode\t\t\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//TRUE = Number of operation mode is selected\n\tCapbank\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF dt_CapBankCtrl;\t\t\t\t//Local structure to store and organize local variables\t\t\t\t\t\t\n\tNumOperSts\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF REAL; \t\t\t\t\t\t\t//local copy of operation counts, used for sorting\n\tHMIInputOrder\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF REAL; \t\t\t\t\t\t\t//local copy of HMI Input Order, used for sorting\n\tTemp\t\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Temp variable used in sorting\n\tTempIndex\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Temp variable used in sorting\n\tCurrentBankCloseAllowed\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//TRUE = current cap bank is allowed to be closed\n\tCurrentBankOpenAllowed\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//TRUE = current cap bank is allowed to be opened\n\tRtrigOpen\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF R_TRIG;\t\t\t\t\t\t//Rising edge of Cap bank opening\n\tRtrigManualClose \t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF R_TRIG;\t\t\t\t\t\t//Rising edge of manual close condition is met\n\tRtrigManualOpen\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF R_TRIG;\t\t\t\t\t\t//Rising edge of manual open condition is met\n\tFtrigClose \t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF F_TRIG;\t\t\t\t\t\t//Falling edge of close delay timer expires\n\tFtrigOpen \t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF F_TRIG;\t\t\t\t\t\t//Falling edge of open delay timer expires\n\tIndex\t\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Index of cap bank being operated\n\tPreviousIndex \t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Index of the previous cap bank being operated\t\n\tAutoCloseCondition\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = CLOSE condition is met for current cap bank in auto mode\n\tManualCloseCondition\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = CLOSE condition is met for current cap bank in manual mode\n\tAutoOpenCondition\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = OPEN condition is met for current cap bank in auto mode\n\tManualOpenCondition\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = OPEN condition is met for current cap bank in manual mode\n\tCloseOrder\t\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t\t\t\t\t\t//The order of cap bank at index will be closed. \n\tNotInOperation\t\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//TRUE = No operation (open/close) is being conducted for any of the cap bank in the system\n\tAllPreviousOpnd \t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = All previous cap bank are opened or had been tried to be opened for twice\n\tAllPreviousClsd \t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = All previous cap bank are closed or had been tried to be closed for twice\n\tPreBanksCheckedForClose\t \t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = ALL previous cap bank are checked and satisfies the condition for current cap bank to be closed\n\tPreBanksCheckedForOpen\t \t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t\t\t\t\t\t\t//TRUE = ALL previous cap bank are checked and satisfies the condition for current cap bank to be opened\nEND_VAR","LineInfoPersistence":"(string)96258d24-29d1-43c9-955f-e2df00e7a703_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)429","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}