{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b03527d0-127d-4336-b11a-57668a0b8829","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_VoltageSchedule","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)65b7bcbe-fc37-48cf-8c43-0b23c2923fd1"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Move entire structure\nPlantHMIInputs_pu   := PlantHMIInputs;\nLastVoltageSP \t\t:= PlantHMIInputs_pu.ReactivePwr.VSp;\n\n// Set voltage schedule from HMI\n// Enumeration of 1,2,3,4 or 5 for custom schedule\nCurVoltageSch_enum := PlantHMIInputs_pu.ReactivePwr.VScheduleID;    // HMI input\ni := CurVoltageSch_enum;                                             // Voltage schedule index\n\nEN := PlantCfg.VoltageCfg.VSchEn AND PlantHMIInputs_pu.ReactivePwr.VScheduleEn AND QCtrl_Aux_Outputs.OpMode = 1 AND i>0 AND i = PlantCfg.VSchCfg[i].ID AND (System_Time_Control_POU.Time_Source_Ident = 'IRIG_B' OR System_Time_Control_POU.Time_Source_Ident = 'NTP');\n\nIF EN THEN\n    // Determine active time slot\n    IF ((iDateTime[3] >= PlantCfg.VSchCfg[i].TimeSlot[1].StartHR) AND (iDateTime[3] < PlantCfg.VSchCfg[i].TimeSlot[2].StartHR)) THEN\n        TimeSlot := 1;\n    ELSIF ((iDateTime[3] >= PlantCfg.VSchCfg[i].TimeSlot[2].StartHR) AND (iDateTime[3] < PlantCfg.VSchCfg[i].TimeSlot[3].StartHR)) THEN\n        TimeSlot := 2;\n    ELSIF ((iDateTime[3] >= PlantCfg.VSchCfg[i].TimeSlot[3].StartHR) AND (iDateTime[3] < PlantCfg.VSchCfg[i].TimeSlot[4].StartHR)) THEN\n        TimeSlot := 3;\n    ELSIF ((iDateTime[3] >= PlantCfg.VSchCfg[i].TimeSlot[5].StartHR) AND (iDateTime[3] <= 23)) THEN\n        TimeSlot := 4;\n    END_IF\n\n    // Set voltage schedule setpoint based on active time slot\n    IF TimeSlot = 1 THEN\n        CurSchedule_VSp := PlantCfg.VSchCfg[i].VSp_kV[1];\n    ELSIF TimeSlot = 2 THEN\n        CurSchedule_VSp := PlantCfg.VSchCfg[i].VSp_kV[2];\n    ELSIF TimeSlot = 3 THEN\n        CurSchedule_VSp := PlantCfg.VSchCfg[i].VSp_kV[3];\n    ELSIF TimeSlot = 4 THEN\n        CurSchedule_VSp := PlantCfg.VSchCfg[i].VSp_kV[4];\n    ELSE\n        CurSchedule_VSp := LastVoltageSP;\n    END_IF\n\t//Check Vsp within Limits\n\tCurSchedule_VSp := fn_LimCheckWithReject(Val := CurSchedule_VSp, DefVal :=CurSchedule_VSp, MinVal := PlantCfg.VoltageCfg.VMin, MaxVal := PlantCfg.VoltageCfg.VMax);\n    // Map active voltage schedule setpoint\n    PlantHMIInputs_pu.ReactivePwr.VSp := CurSchedule_VSp;\n\n    // Voltage setpoint tracking during voltage schedule mode\n    SCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := CurSchedule_VSp * PlantCfg.VoltageCfg.Vbase;\nEND_IF\n\n// Map diagnostics\nIF NOT PlantHMIInputs_pu.ReactivePwr.VScheduleEn THEN\n    VoltageSchState := TBE_PPC.enum_VoltageSchState.Passive;\nELSIF ((System_Time_Control_POU.Time_Source_Ident <> 'IRIG_B') AND (System_Time_Control_POU.Time_Source_Ident <> 'NTP')) OR (i <> PlantCfg.VSchCfg[i].ID) THEN\n    VoltageSchState := TBE_PPC.enum_VoltageSchState.Fault;\nELSIF PlantHMIInputs_pu.ReactivePwr.VScheduleEn AND (QCtrl_Aux_Outputs.OpMode <> 1) THEN\n    VoltageSchState := TBE_PPC.enum_VoltageSchState.Standby;\nELSIF EN THEN\n    VoltageSchState := TBE_PPC.enum_VoltageSchState.Active;\nELSE\n    VoltageSchState := TBE_PPC.enum_VoltageSchState.Fault;\nEND_IF\n\nDiagVoltageSch.ActiveScheID    := CurVoltageSch_enum;\nDiagVoltageSch.VoltageSchState := VoltageSchState;\nDiagVoltageSch.CurTimeSlot     := TimeSlot;\nDiagVoltageSch.CurVoltageSP    := CurSchedule_VSp * PlantCfg.VoltageCfg.Vbase;\nDiagVoltageSch.CurTimeHR       := iDateTime[3];\nDiagVoltageSch.HMIScheEn       := PlantHMIInputs_pu.ReactivePwr.VScheduleEn;\nDiagVoltageSch.ValidTimeSource := (System_Time_Control_POU.Time_Source_Ident = 'IRIG_B') OR (System_Time_Control_POU.Time_Source_Ident = 'NTP');","LineInfoPersistence":"(string)b03527d0-127d-4336-b11a-57668a0b8829_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM pg_VoltageSchedule\nVAR_INPUT\n    PlantCfg          : TBE_PPC.dt_PlantCfg;                // Plant configuration structure\n    QCtrl_Aux_Outputs : TBE_PPC.dt_AVRCtlAuxOutputs;        // Output structure from AVR auxiliary control program\n\tPlantHMIInputs\t  : TBE_PPC.dt_PlantHMIInputs;          // [pu], Conditioned plant HMI input structure\nEND_VAR\n\nVAR_OUTPUT\n\tPlantHMIInputs_pu : TBE_PPC.dt_PlantHMIInputs;          // [pu], Conditioned plant HMI input structure\n    DiagVoltageSch    : TBE_PPC.dt_VSchDiagnostics;         // Voltage schedule diagnostics structure\nEND_VAR\n(*\nVAR_IN_OUT\n    PlantHMIInputs_pu : TBE_PPC.dt_PlantHMIInputs;          // [pu], Conditioned plant HMI input structure\nEND_VAR*)\n\nVAR\n    EN                 : BOOL;                              // Internal enable command for voltage scheduling\n    CurVoltageSch_enum : UINT;                              // Active voltage schedule ID\n    VoltageSchState    : TBE_PPC.enum_VoltageSchState;      // Current voltage schedule state/status\n    i                  : UINT;                              // Voltage schedule loop index\n    CurSchedule_VSp    : REAL;                              // [kV], Active schedule voltage setpoint\n    TimeSlot           : UINT;                              // Active voltage schedule time slot index\n    LastVoltageSP      : REAL;                              // [kV], Previous HMI voltage setpoint\nEND_VAR","LineInfoPersistence":"(string)b03527d0-127d-4336-b11a-57668a0b8829_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)120","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}