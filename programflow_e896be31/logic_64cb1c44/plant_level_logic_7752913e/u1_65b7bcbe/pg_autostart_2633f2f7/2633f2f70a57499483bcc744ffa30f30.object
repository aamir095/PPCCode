{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)2633f2f7-0a57-4994-83bc-c744ffa30f30","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_AutoStart","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)True","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)65b7bcbe-fc37-48cf-8c43-0b23c2923fd1"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Start auto-start delay timer\nAutoStartWaitTON(IN := (PlantCfg.AutoStartEn AND PlantHMICmds_In.AutoStartPermissive)); \n\n//Determine AutoStart state\nIF PlantCfg.AutoStartEn AND PlantHMICmds_In.AutoStartPermissive AND (NOT AutoStartTrigger OR AutoStartStarted) THEN\n\tAutoStartStarted := TRUE;\n\tIF AutoStartWaitTON.Q AND MeterFbk.Sts_MeterMode > 0 THEN\n\t\t//AutoStart wait timer has completed -> AutoStart process is active\n\t\tDiag.Sts := TBE_PPC.enum_AutoStartSts.Active; \n\t\t\n\t\t//Start AutoStart Active TON\n\t\tAutoStartActiveTON(IN := TRUE); \n\t\t\n\t\t//Transition P/Q to closed loop mode and set setpoints to retained values\n\t\tPlantHMICmds_In.ActivePwr.ClosedLoopCtrlEn := Retained_GVL.PClosedLoopCtrlEn;\n\t\tPlantHMICmds_In.ReactivePwr.ClosedLoopCtrlEn := Retained_GVL.QClosedLoopCtrlEn;\n\t\tPlantHMICmds_In.ActivePwr.CmdMode := Retained_GVL.PCmdMode;\n\t\tPlantHMICmds_In.ReactivePwr.CmdMode := Retained_GVL.QCmdMode;\n\t\tPlantHMICmds_In.ActivePwr.PSp := Retained_GVL.PSp;\n\t\tPlantHMICmds_In.ReactivePwr.OpMode := Retained_GVL.QOpMode;\n\t\tPlantHMICmds_In.ReactivePwr.QSp := Retained_GVL.QSp;\n\t\tPlantHMICmds_In.ReactivePwr.VSp := Retained_GVL.VSp;\n\t\tPlantHMICmds_In.ReactivePwr.PFSp := Retained_GVL.PFSp;\n\t\t\n\t\t//Once P/Q are in auto mode, set all inverters to auto mode\n\t\tIF OpModeSts.PClosedLoopCtrl AND OpModeSts.QClosedLoopCtrl THEN\n\t\t\tFOR i := 1 TO SiteConstants.NumInvs BY 1 DO\n\t\t\t\tInvHMICmds_In[i].PAutoEn := TRUE;\n\t\t\t\tInvHMICmds_Out[i].QAutoEn := TRUE;\n\t\t\tEND_FOR\n\t\t\t//AutoStart is completed -> set diagnostics status and transition to normal operation\n\t\t\tDiag.Sts_AutoStartComplete := TRUE; \n\t\t\tAutoStartStarted := FALSE;\n\t\tELSIF AutoStartActiveTON.Q THEN\n\t\t\t//Plant failed to transition to P/Q closed loop control -> Set Error Flag and transition to default operating mode\n\t\t\tDiag.Err_ClosedLoopTransitionFailed := TRUE; \n\t\t\tAutoStartStarted := FALSE;\n\t\tEND_IF\n\tELSIF AutoStartWaitTON.Q THEN\n\t\t//AutoStart wait timer has completed but meter feedback is invalid -> Transition to default operating mode\n\t\tDiag.Err_NoMeterFbk := TRUE;\n\t\tAutoStartStarted := FALSE;\n\tELSE\n\t\t//AutoStart wait timer has not yet completed\n\t\tDiag.Sts := TBE_PPC.enum_AutoStartSts.WaitCheckSts;\n\tEND_IF\nELSIF NOT PlantCfg.AutoStartEn THEN\n\t//Auto Start Not Enabled\n\tDiag.Sts := TBE_PPC.enum_AutoStartSts.Disabled;\n\tAutoStartStarted := FALSE;\nELSIF PlantCfg.AutoStartEn AND NOT PlantHMICmds_In.AutoStartPermissive THEN\n\t//Auto Start Enabled, but permissive removed\n\tDiag.Sts := TBE_PPC.enum_AutoStartSts.PermissiveRemoved;\n\tAutoStartStarted := FALSE;\nELSIF AutoStartWaitTON.Q THEN\n\t//Auto start wait timer has elapsed, but conditions were not met for Auto Start\n\tDiag.Sts := TBE_PPC.enum_AutoStartSts.NotActive;\n\tAutoStartStarted := FALSE;\nELSE\n\t//Auto Start is not active\n\tDiag.Sts := TBE_PPC.enum_AutoStartSts.NotActive;\nEND_IF\n\n//Move incoming Inverter/Plant HMI commands to outputs\nPlantHMICmds_Out := PlantHMICmds_In;\nInvHMICmds_Out := InvHMICmds_In; \n\nAutoStartTrigger := TRUE; \t\t//Set trigger flag to true -> this will allow auto-start to start only on initial startup, and not during normal operation","LineInfoPersistence":"(string)2633f2f7-0a57-4994-83bc-c744ffa30f30_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tAuto Start Program\n|\tPPC will Auto-Start under certain conditions after a power cycle\n|\tConditions: Auto Start must be enabled, Auto Start permissive from SCADA must remain True, Meter comms is good\n|\tActions: Auto-Start will transition P/Q controllers to closed loop control mode and use the last known setpoints and Q op mode. Once controllers have transitioned to closed loop, all inverters will be transitioned to Auto\n*)\nPROGRAM pg_AutoStart\nVAR_INPUT\n\tPlantHMICmds_In\t\t: TBE_PPC.dt_PlantHMIInputs;\t\t\t\t\t\t\t\t\t\t\t//Plant HMI Commands (incoming from SCADA)\n\tPlantCfg\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t\t\t\t\t\t\t\t\t\t\t//Plant configuration struct\n\tInvHMICmds_In\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs; \t\t//HMI Commands for Inv modules (incoming from SCADA)\n\tMeterFbk\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t\t\t\t\t\t\t\t\t\t\t//[pu], Meter feedback\n\tOpModeSts\t\t\t: TBE_PPC.dt_UnitOpModeSts; \t\t\t\t\t\t\t\t\t\t\t//Operating mode status structure\nEND_VAR\nVAR_OUTPUT\n\tPlantHMICmds_Out\t: TBE_PPC.dt_PlantHMIInputs;\t\t\t\t\t\t\t\t\t\t\t//Plant HMI Commands (outgoing to core logic)\n\tInvHMICmds_Out\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs; \t\t//HMI Commands for Inv modules (outgoing to inverter logic)\n\tDiag\t\t\t\t: TBE_PPC.dt_AutoStartDiagnostics;\t\t\t\t\t\t\t\t\t\t\t\t//Auto-Start Diagnostics Structure\nEND_VAR\nVAR\n\tAutoStartTrigger\t: BOOL := FALSE;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Trigger variable to start auto start (on rising edge only)\t\n\tAutoStartWaitTON\t: TON := (PT := T#60S); \t\t\t\t\t\t\t\t\t\t\t\t//AutoStart Delay Timer\t\t\n\tAutoStartActiveTON\t: TON := (PT := T#1S);\t\t\t\t\t\t\t\t\t\t\t\t\t//AutoStart active timer (allows AutoStart to cancel if plant does not transition to closed loop control\n\tAutoStartStarted\t: BOOL := FALSE;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Auto Start started flag\n\ti\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\t\t\t\t\t\t\t\t\t\nEND_VAR","LineInfoPersistence":"(string)2633f2f7-0a57-4994-83bc-c744ffa30f30_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)133","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}