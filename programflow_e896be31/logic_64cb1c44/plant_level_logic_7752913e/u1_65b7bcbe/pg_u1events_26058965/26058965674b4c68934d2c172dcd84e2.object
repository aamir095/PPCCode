{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)26058965-674b-4c68-934d-2c172dcd84e2","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1Events","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)65b7bcbe-fc37-48cf-8c43-0b23c2923fd1"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Call startup tmr - startup tmr will prevent events from being triggered within 10s of controller starting\nStartupTmr(IN := TRUE, PT := T#10S);\n\n\t\n//Plant-Level\n\n//Active Power\nPlantEventsTmp.POIPSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.POIPSpChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Psp_POI);\nPlantEventsTmp.POICmdModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.POICmdModeChange, SrcVal := TO_REAL(PPCDiag.OpModeSts.PCmdMode_POI));\nPlantEventsTmp.PVPSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PVPSpChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Psp_PV);\nPlantEventsTmp.PVCmdModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PVCmdModeChange, SrcVal := TO_REAL(PPCDiag.OpModeSts.PCmdMode_PV));\nPlantEventsTmp.EMSPSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.EMSPSpChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Psp_BESS);\nPlantEventsTmp.EMSCmdModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.EMSCmdModeChange, SrcVal := TO_REAL(PPCDiag.OpModeSts.PCmdMode_BESS));\n\nPlantEventsTmp.POIMeterModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.POIMeterModeChange, SrcVal := TO_REAL(POIMeterFbk.Sts_MeterMode));\nIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated THEN\n\tPlantEventsTmp.PVMeterModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PVMeterModeChange, SrcVal := TO_REAL(PVMeterFbk.Sts_MeterMode));\n\tPlantEventsTmp.BESSMeterModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.BESSMeterModeChange, SrcVal := TO_REAL(BESSMeterFbk.Sts_MeterMode));\nEND_IF\n\n// make sure that threshold is minimum of 20MW, otherwise 10% of rated power in [pu]\nIF (0.1 * PlantCfg.SBase) > P_DEVIATION_THRESHOLD_MW THEN\n\tPDeviationThreshold := 0.1;\nELSE\n\tPDeviationThreshold := P_DEVIATION_THRESHOLD_MW / PlantCfg.Sbase;\nEND_IF\n\nPDeviationEventDetection(\tEN:= TRUE, \n\t\t\t\t\t\t\tSourceValue:= POIMeterFbk.Sts_P, \n\t\t\t\t\t\t\tThreshold:= PDeviationThreshold, \n\t\t\t\t\t\t\tMonitorTime:= P_DEVIATION_MONITOR_TIME, \n\t\t\t\t\t\t\tSampleTime:= P_DEVIATION_SAMPLE_TIME, \n\t\t\t\t\t\t\tDeviationEvent=> PlantEventsTmp.PDeviationEvent, \n\t\t\t\t\t\t\tCfgError=> );\n\n//Active Power Configuration\nPlantEventsTmp.PPIDPChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PPIDPChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Kpg_PV);\nPlantEventsTmp.PPIDIChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PPIDIChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Kig_PV);\n\n//BESS/EMS Active Power Configuration\nPlantEventsTmp.EMSPIDPChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.EMSPIDPChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Kpg_BESS);\nPlantEventsTmp.EMSPIDIChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.EMSPIDIChange, SrcVal := PPCDiag.PCtrl_Aux_Outputs.Kig_BESS);\n\n//Frequency Configuration\nPlantEventsTmp.FDbd1Change := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.FDbd1Change, SrcVal := PlantCfg.FreqCfg.FDbd1);\nPlantEventsTmp.FDbd2Change := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.FDbd2Change, SrcVal := PlantCfg.FreqCfg.FDbd2);\nPlantEventsTmp.FreqDDnChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.FreqDDnChange, SrcVal := PlantCfg.FreqCfg.DDn);\nPlantEventsTmp.FreqDUpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.FreqDUpChange, SrcVal := PlantCfg.FreqCfg.DUp);\n\n//Reactive Power\nIF PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_Q THEN\n\tPlantEventsTmp.QSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.QSpChange, SrcVal := PPCDiag.QCtrl_Aux_Outputs.Qsp);\n\tPlantEventsTmp.VSpChange.Event := FALSE;\n\tPlantEventsTmp.PFSpChange.Event := FALSE;\nELSIF PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_PF THEN\n\tPlantEventsTmp.QSpChange.Event := FALSE;\n\tPlantEventsTmp.VSpChange.Event := FALSE;\n\tPlantEventsTmp.PFSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.PFSpChange, SrcVal := PPCDiag.QCtrl_Aux_Outputs.PFsp);\nELSIF PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_V THEN\n\tPlantEventsTmp.QSpChange.Event := FALSE;\n\tPlantEventsTmp.VSpChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VSpChange, SrcVal := PPCDiag.QCtrl_Aux_Outputs.Vsp);\n\tPlantEventsTmp.PFSpChange.Event := FALSE;\nEND_IF\nPlantEventsTmp.QCmdModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.QCmdModeChange, SrcVal := TO_REAL(PPCDiag.OpModeSts.QCmdMode));\nPlantEventsTmp.QOpModeChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.QOpModeChange, SrcVal := TO_REAL(PPCDiag.QCtrl_Aux_Outputs.OpMode));\n\n//Reactive Power Configuration\nPlantEventsTmp.QPIDPChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.QPIDPChange, SrcVal := PPCDiag.QCtrl_Aux_Outputs.Kpq);\nPlantEventsTmp.QPIDIChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.QPIDIChange, SrcVal := PPCDiag.QCtrl_Aux_Outputs.Kiq);\nPlantEventsTmp.VAbsDroopChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VAbsDroopChange, SrcVal := PlantCfg.VoltageCfg.VAbsDroop);\nPlantEventsTmp.VInjDroopChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VInjDroopChange, SrcVal := PlantCfg.VoltageCfg.VInjDroop);\nPlantEventsTmp.VDroopHystChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VDroopHystChange, SrcVal := PlantCfg.VoltageCfg.VDroopHyst);\nPlantEventsTmp.VDbdLowChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VDbdLowChange, SrcVal := PlantCfg.VoltageCfg.VDbLow);\nPlantEventsTmp.VDbdHighChange := TBE_PPC.fn_EventTrigger(Event := PlantEventsTmp.VDbdHighChange, SrcVal := PlantCfg.VoltageCfg.VDbHigh);\n\n//Misc. \nPlantEventsTmp.TimeScrChange := System_Time_Control_POU.Time_Source_Ident <> TimeSrcPrev; \nIF PlantEventsTmp.TimeScrChange THEN\n\tTimeSrcPrev_2 := TimeSrcPrev; \nEND_IF\nTimeSrcPrev := System_Time_Control_POU.Time_Source_Ident; \n\nIF StartupTmr.Q THEN\n\t//Move temp structure to output\n\tPlantEvents := PlantEventsTmp;\nEND_IF","LineInfoPersistence":"(string)26058965-674b-4c68-934d-2c172dcd84e2_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tEvents Program - This program will capture various plant-level events/alarms for logging in the RTAC SOE\n|\tFor comparing analog values, the current value used by the controller will be compared to the .CurVal in the Plant Events structure to detect a change. The .PrevVal will then be updated to the.CurVal and the .CurVal will be updated to the value used by the controller\n*)\nPROGRAM pg_U1Events\nVAR_INPUT\n\tPlantCfg\t\t\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t//Structure of plant configuration - Engineering units will be used for event collection so that current/previous values will be displayed in eng. units\n\tPOIMeterFbk\t\t\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t//POI meter feedback\n\tPVMeterFbk\t\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t//PV meter feedback\n\tBESSMeterFbk\t\t\t\t: TBE_PPC.dt_MeterFbk;\t\t\t//BESS meter feedback\n\tHVMeterFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; \n\tMVMeterFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; \n\tEMSFbk\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\tInvFbk\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\tMetStationFbk\t\t\t\t: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\tPPCDiag\t\t\t\t\t\t: dt_PPCDiagnostics; \t\t\t//PPC Diagnostics Structure\nEND_VAR             \t\t\nVAR_OUTPUT          \t\t\n\tPlantEvents\t\t\t\t\t: TBE_PPC.dt_PlantEvents; \t\t//Structure of plant events\nEND_VAR\nVAR\n\tStartupTmr\t\t\t\t\t: TON;\t\t\t\t\t\t\t//Startup timer used to prevent events from being triggered in the first 10s of run-time to prevent nuisance comm alarms when controller is starting up\n\tPlantEventsTmp\t\t\t\t: TBE_PPC.dt_PlantEvents;\t\t//Temporary structure of plant events\n\ttmp \t\t\t\t\t\t: STRING;\n\tx\t\t\t\t\t\t\t: STRING;\n\tTimeSrcPrev\t\t\t\t\t: STRING(255);\t\t\t\t\t//Time source string - Used to determine if time source has changed\n\tTimeSrcPrev_2\t\t\t\t: STRING(255);\t\t\t\t\t//Time source string - Used for logging event in Tag Processor (time source from previous cycle)\n\t\n\tPDeviationEventDetection\t: TBE_PPC.fb_TimedDeviationEvent;\n\tPDeviationThreshold\t\t\t: REAL;\nEND_VAR\nVAR CONSTANT\n\tP_DEVIATION_MONITOR_TIME\t: TIME := T#4S;\n\tP_DEVIATION_SAMPLE_TIME\t\t: TIME := T#100MS;\n\tP_DEVIATION_THRESHOLD_MW\t: REAL := 20.0;\nEND_VAR","LineInfoPersistence":"(string)26058965-674b-4c68-934d-2c172dcd84e2_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)160","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}