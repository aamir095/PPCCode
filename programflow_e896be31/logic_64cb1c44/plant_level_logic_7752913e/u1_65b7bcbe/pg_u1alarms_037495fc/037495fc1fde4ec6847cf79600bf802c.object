{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)037495fc-1fde-4ec6-847c-f79600bf802c","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_U1Alarms","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)65b7bcbe-fc37-48cf-8c43-0b23c2923fd1"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Alarm Logic\n\n//Assign Meter Indexes as 1/2 or 0 depending on how many meters are enabled\nIF SiteConstants.NumHVMeters >= 2 THEN\n\tHVMeterIndex1 := 1;\n\tHVMeterIndex2 := 2; \nELSIF SiteConstants.NumHVMeters >= 1 THEN\n\tHVMeterIndex1 := 1;\n\tHVMeterIndex2 := 0;\nELSE\n\tHVMeterIndex1 := 0;\n\tHVMeterIndex2 := 0;\nEND_IF\nIF SiteConstants.NumMVMeters >= 2 THEN\n\tMVMeterIndex1 := 1;\n\tMVMeterIndex2 := 2; \nELSIF SiteConstants.NumMVMeters >= 1 THEN\n\tMVMeterIndex1 := 1;\n\tMVMeterIndex2 := 0;\nELSE\n\tMVMeterIndex1 := 0;\n\tMVMeterIndex1 := 0;\nEND_IF\n\n//Measurement/Feedback Alarms\nPFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.PFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.PFbk.Lo,\n\tCfg_HiLmt := AlmCfg.PFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.PFbk.HiHi,\n\tIn := MeterFbk.Sts_P,\n\tLoLo => PlantAlarms.PFbk.LoLo,\n\tLo => PlantAlarms.PFbk.Lo,\n\tHi => PlantAlarms.PFbk.Hi,\n\tHiHi => PlantAlarms.PFbk.HiHi);\n\t\nQFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.QFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.QFbk.Lo,\n\tCfg_HiLmt := AlmCfg.QFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.QFbk.HiHi,\n\tIn := MeterFbk.Sts_Q,\n\tLoLo => PlantAlarms.QFbk.LoLo,\n\tLo => PlantAlarms.QFbk.Lo,\n\tHi => PlantAlarms.QFbk.Hi,\n\tHiHi => PlantAlarms.QFbk.HiHi);\n\nVLLAvgFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VLLAvgFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VLLAvgFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VLLAvgFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VLLAvgFbk.HiHi,\n\tIn := MeterFbk.Sts_VLLAvg,\n\tLoLo => PlantAlarms.VLLAvgFbk.LoLo,\n\tLo => PlantAlarms.VLLAvgFbk.Lo,\n\tHi => PlantAlarms.VLLAvgFbk.Hi,\n\tHiHi => PlantAlarms.VLLAvgFbk.HiHi);\n\nVABFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VABFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VABFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VABFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VABFbk.HiHi,\n\tIn := MeterFbk.Sts_VAB,\n\tLoLo => PlantAlarms.VABFbk.LoLo,\n\tLo => PlantAlarms.VABFbk.Lo,\n\tHi => PlantAlarms.VABFbk.Hi,\n\tHiHi => PlantAlarms.VABFbk.HiHi);\n\nVBCFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VBCFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VBCFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VBCFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VBCFbk.HiHi,\n\tIn := MeterFbk.Sts_VBC,\n\tLoLo => PlantAlarms.VBCFbk.LoLo,\n\tLo => PlantAlarms.VBCFbk.Lo,\n\tHi => PlantAlarms.VBCFbk.Hi,\n\tHiHi => PlantAlarms.VBCFbk.HiHi);\n\nVCAFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VCAFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VCAFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VCAFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VCAFbk.HiHi,\n\tIn := MeterFbk.Sts_VCA,\n\tLoLo => PlantAlarms.VCAFbk.LoLo,\n\tLo => PlantAlarms.VCAFbk.Lo,\n\tHi => PlantAlarms.VCAFbk.Hi,\n\tHiHi => PlantAlarms.VCAFbk.HiHi);\n\nVANFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VANFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VANFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VANFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VANFbk.HiHi,\n\tIn := MeterFbk.Sts_VAN,\n\tLoLo => PlantAlarms.VANFbk.LoLo,\n\tLo => PlantAlarms.VANFbk.Lo,\n\tHi => PlantAlarms.VANFbk.Hi,\n\tHiHi => PlantAlarms.VANFbk.HiHi);\n\nVBNFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VBNFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VBNFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VBNFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VBNFbk.HiHi,\n\tIn := MeterFbk.Sts_VBN,\n\tLoLo => PlantAlarms.VBNFbk.LoLo,\n\tLo => PlantAlarms.VBNFbk.Lo,\n\tHi => PlantAlarms.VBNFbk.Hi,\n\tHiHi => PlantAlarms.VBNFbk.HiHi);\n\nVCNFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VCNFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.VCNFbk.Lo,\n\tCfg_HiLmt := AlmCfg.VCNFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.VCNFbk.HiHi,\n\tIn := MeterFbk.Sts_VCN,\n\tLoLo => PlantAlarms.VCNFbk.LoLo,\n\tLo => PlantAlarms.VCNFbk.Lo,\n\tHi => PlantAlarms.VCNFbk.Hi,\n\tHiHi => PlantAlarms.VCNFbk.HiHi);\n\n//PF Feedback Alarms - two separate FBs will be used (one for PF < 0 and one for PF >= 0). \n//PF Lo/LoLo will be set when PF is negative\n//PF Hi/HiHi will be set when PF is positive\nPFFbkAlm_Neg(En := (MeterFbk.Sts_PF < 0),\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PFFbk.Lo,\n\tCfg_HiHiLmt := AlmCfg.PFFbk.LoLo,\n\tIn := MeterFbk.Sts_PF,\n\tHi => PlantAlarms.PFFbk.Lo,\n\tHiHi => PlantAlarms.PFFbk.LoLo);\n\t\nPFFbkAlm_Pos(En := (MeterFbk.Sts_PF >= 0),\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.PFFbk.HiHi,\n\tCfg_LoLmt := AlmCfg.PFFbk.Hi,\n\tIn := MeterFbk.Sts_PF,\n\tLo => PlantAlarms.PFFbk.Hi,\n\tLoLo => PlantAlarms.PFFbk.HiHi);\n\nFreqFbkAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.FreqFbk.LoLo,\n\tCfg_LoLmt := AlmCfg.FreqFbk.Lo,\n\tCfg_HiLmt := AlmCfg.FreqFbk.Hi,\n\tCfg_HiHiLmt := AlmCfg.FreqFbk.HiHi,\n\tIn := MeterFbk.Sts_Freq,\n\tLoLo => PlantAlarms.FreqFbk.LoLo,\n\tLo => PlantAlarms.FreqFbk.Lo,\n\tHi => PlantAlarms.FreqFbk.Hi,\n\tHiHi => PlantAlarms.FreqFbk.HiHi);\n\nVLLAvgFbk_MVAlm(En := TRUE,\n\tCfg_LoLoTime := AlmCfg.ThreshTime, \n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoLoLmt := AlmCfg.VLLAvgFbk_MV.LoLo,\n\tCfg_LoLmt := AlmCfg.VLLAvgFbk_MV.Lo,\n\tCfg_HiLmt := AlmCfg.VLLAvgFbk_MV.Hi,\n\tCfg_HiHiLmt := AlmCfg.VLLAvgFbk_MV.HiHi,\n\tIn := MVMeterFbk[MVMeterIndex1].Sts_VLLAvg,\n\tLoLo => PlantAlarms.VLLAvgFbk_MV.LoLo,\n\tLo => PlantAlarms.VLLAvgFbk_MV.Lo,\n\tHi => PlantAlarms.VLLAvgFbk_MV.Hi,\n\tHiHi => PlantAlarms.VLLAvgFbk_MV.HiHi);\n\n//Measurement Deviation Alarms - Enabled when there are 2 HV meters only\nPMeasDevAlm(En := SiteConstants.NumHVMeters >= 2,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PMeasDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PMeasDev.HiHi,\n\tIn := (ABS(HVMeterFbk[HVMeterIndex1].Sts_P - HVMeterFbk[HVMeterIndex2].Sts_P)),\n\tHi => PlantAlarms.PMeasDev.Hi,\n\tHiHi => PlantAlarms.PMeasDev.HiHi);\nQMeasDevAlm(En := SiteConstants.NumHVMeters >= 2,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.QMeasDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.QMeasDev.HiHi,\n\tIn := (ABS(HVMeterFbk[HVMeterIndex1].Sts_Q - HVMeterFbk[HVMeterIndex2].Sts_Q)),\n\tHi => PlantAlarms.QMeasDev.Hi,\n\tHiHi => PlantAlarms.QMeasDev.HiHi);\n\t\nVLLAvgMeasDevAlm(En := SiteConstants.NumHVMeters >= 2,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.VLLAvgMeasDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.VLLAvgMeasDev.HiHi,\n\tIn := (ABS(HVMeterFbk[HVMeterIndex1].Sts_VLLAvg - HVMeterFbk[HVMeterIndex2].Sts_VLLAvg)),\n\tHi => PlantAlarms.VLLAvgMeasDev.Hi,\n\tHiHi => PlantAlarms.VLLAvgMeasDev.HiHi);\n\t\nPFMeasDevAlm(En := SiteConstants.NumHVMeters >= 2,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PFMeasDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PFMeasDev.HiHi,\n\tIn := (ABS(HVMeterFbk[HVMeterIndex1].Sts_PF - HVMeterFbk[HVMeterIndex2].Sts_PF)),\n\tHi => PlantAlarms.PFMeasDev.Hi,\n\tHiHi => PlantAlarms.PFMeasDev.HiHi);\n\t\nFreqMeasDevAlm(En := SiteConstants.NumHVMeters >= 2,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.FreqMeasDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.FreqMeasDev.HiHi,\n\tIn := (ABS(HVMeterFbk[HVMeterIndex1].Sts_Freq - HVMeterFbk[HVMeterIndex2].Sts_Freq)),\n\tHi => PlantAlarms.FreqMeasDev.Hi,\n\tHiHi => PlantAlarms.FreqMeasDev.HiHi);\n\n//Setpoint vs. Feedback Deviation Alarms\nPSpPOIDevAlm(En := ((PPCDiag.OpModeSts.PClosedLoopCtrl_PV OR PPCDiag.OpModeSts.PClosedLoopCtrl_BESS) AND PlantCfg.PlantType <> TBE_PPC.enum_PlantType.PVS_Colocated),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PSpPOIDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PSpPOIDev.HiHi,\n\tIn := (ABS(PPCDiag.PSp_Diagnostics.PSp_POI_PostCond - MeterFbk.Sts_P)),\n\tHi => PlantAlarms.PSpPOIDev.Hi,\n\tHiHi => PlantAlarms.PSpPOIDev.HiHi);\n\nPSpPVDevAlm(En := ((PPCDiag.OpModeSts.PClosedLoopCtrl_PV OR PPCDiag.OpModeSts.PClosedLoopCtrl_BESS) AND PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PSpPVDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PSpPVDev.HiHi,\n\tIn := (ABS(PPCDiag.PSp_Diagnostics.PSp_PV_PostCond - MeterFbk.Sts_P)),\n\tHi => PlantAlarms.PSpPVDev.Hi,\n\tHiHi => PlantAlarms.PSpPVDev.HiHi);\n\nPSpBESSDevAlm(En := ((PPCDiag.OpModeSts.PClosedLoopCtrl_PV OR PPCDiag.OpModeSts.PClosedLoopCtrl_BESS) AND PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PSpBESSDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PSpBESSDev.HiHi,\n\tIn := (ABS(PPCDiag.PSp_Diagnostics.PSp_BESS_PostCond - MeterFbk.Sts_P)),\n\tHi => PlantAlarms.PSpBESSDev.Hi,\n\tHiHi => PlantAlarms.PSpBESSDev.HiHi);\n\t\nQSpDevAlm(En := (PPCDiag.OpModeSts.QClosedLoopCtrl AND PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_Q),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.QSpDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.QSpDev.HiHi,\n\tIn := (ABS(PPCDiag.QCtrl_Aux_Outputs.Qsp - MeterFbk.Sts_Q)),\n\tHi => PlantAlarms.QSpDev.Hi,\n\tHiHi => PlantAlarms.QSpDev.HiHi);\n\t\nVSpDevAlm(En := (PPCDiag.OpModeSts.QClosedLoopCtrl AND PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_V),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.VSpDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.VSpDev.HiHi,\n\tIn := (ABS(PPCDiag.QCtrl_Aux_Outputs.Vsp - MeterFbk.Sts_VLLAvg)),\n\tHi => PlantAlarms.VSpDev.Hi,\n\tHiHi => PlantAlarms.VSpDev.HiHi);\n\t\nPFSpDevAlm(En := (PPCDiag.OpModeSts.QClosedLoopCtrl AND PPCDiag.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_PF),\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.PFSpDev.Hi,\n\tCfg_HiHiLmt := AlmCfg.PFSpDev.HiHi,\n\tIn := (ABS(PPCDiag.QCtrl_Aux_Outputs.PFsp - MeterFbk.Sts_PF)),\n\tHi => PlantAlarms.PFSpDev.Hi,\n\tHiHi => PlantAlarms.PFSpDev.HiHi);\n\n//Ride Through Alarms\n//Set the high frequency ride through ALM\nIF MeterFbk.Sts_Freq > AlmCfg.HFRT AND MeterFbk.Sts_MeterMode > 0 AND MeterFbk.Sts_MeterMode < 100 THEN\n\tPlantAlarms.HFRT := TRUE;\t\nELSIF MeterFbk.Sts_Freq <= (AlmCfg.HFRT - AlmCfg.FRT_Hyst) THEN\n\tPlantAlarms.HFRT := FALSE;\t\nELSE\n\tPlantAlarms.HFRT := FALSE;\nEND_IF\n\n//Set the low frequency ride through ALM\nIF MeterFbk.Sts_Freq < AlmCfg.LFRT AND MeterFbk.Sts_MeterMode > 0 AND MeterFbk.Sts_MeterMode < 100 THEN\n\tPlantAlarms.LFRT := TRUE;\t\nELSIF MeterFbk.Sts_Freq >= (AlmCfg.LFRT + AlmCfg.FRT_Hyst) THEN\n\tPlantAlarms.LFRT := FALSE;\t\nELSE\t\n\tPlantAlarms.LFRT := FALSE;\nEND_IF\n\n//Set the high voltage ride through ALM\nIF MeterFbk.Sts_Vreg > AlmCfg.HVRT AND MeterFbk.Sts_MeterMode > 0 AND MeterFbk.Sts_MeterMode < 100 THEN\n\tPlantAlarms.HVRT := TRUE;\t\nELSIF MeterFbk.Sts_Vreg <= (AlmCfg.HVRT - AlmCfg.VRT_Hyst) THEN\n\tPlantAlarms.HVRT := FALSE;\nELSE\n\tPlantAlarms.HVRT := FALSE;\nEND_IF\n\n//Set the low voltage ride through ALM\nIF MeterFbk.Sts_Vreg < AlmCfg.LVRT AND MeterFbk.Sts_MeterMode > 0 AND MeterFbk.Sts_MeterMode < 100 THEN\n\tPlantAlarms.LVRT := TRUE;\t\nELSIF MeterFbk.Sts_Vreg >= (AlmCfg.LVRT + AlmCfg.VRT_Hyst) THEN\n\tPlantAlarms.LVRT := FALSE;\t\nELSE\n\tPlantAlarms.LVRT := FALSE;\nEND_IF\n\n//Boolean Alarms\nPlantAlarms.PlantStopped := PPCDiag.OpModeSts.Stopped;\nPlantAlarms.POpenLoop_PV := NOT PPCDiag.OpModeSts.PClosedLoopCtrl_PV;\nPlantAlarms.POpenLoop_BESS := NOT PPCDiag.OpModeSts.PClosedLoopCtrl_BESS;\nPlantAlarms.FreqCtrlDisabled_PV := NOT PPCDiag.PCtrl_Aux_Outputs.FreqDroopEn_PV;\nPlantAlarms.FreqCtrlDisabled_BESS := NOT PPCDiag.PCtrl_Aux_Outputs.FreqDroopEn_BESS;\nPlantAlarms.PVFreqCtrlActive := PPCDiag.PSp_Diagnostics.FreqDiag_PV.FreqDroopActive;\nPlantAlarms.EMSFreqCtrlActive := PPCDiag.PSp_Diagnostics.FreqDiag_BESS.FreqDroopActive;\nPlantAlarms.POIFreqCtrlActive := PPCDiag.PSp_Diagnostics.FreqDiag_POI.FreqDroopActive;\nPlantAlarms.QOpenLoop := NOT PPCDiag.OpModeSts.QClosedLoopCtrl;\nPlantAlarms.VoltVarDisabled := NOT PPCDiag.OpModeSts.VoltVarEn;\nPlantAlarms.PPIDOutputIsNaN := NOT Fun_IsValidReal(PPCDiag.PV_PCtrlDiagnostics.PPID_CV); \nPlantAlarms.EMSPIDOutputIsNaN := NOT Fun_IsValidReal(PPCDiag.BESS_PCtrlDiagnostics.PPID_CV); \nPlantAlarms.QPIDOutputIsNaN := NOT Fun_IsValidReal(PPCDiag.QCtrlDiagnostics.QPID_CV);\n\n//Redundancy Related Alarms - Some alarms are only enabled when comms to remote controller is valid and SN is configured correctly\nIF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC1 THEN\n\t//RTAC1 - Use first index of redundancy diagnostics array\n\tPlantAlarms.Redundancy_RemoteControllerWatchdogTimeout := NOT RedundancyDiagnostics[1].Sts_CommsGood;\n\tPlantAlarms.Redundancy_CfgAlarm := FALSE;\nELSIF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC2 THEN\n\t//RTAC2 - Use second index of redundancy diagnostics array\n\tPlantAlarms.Redundancy_RemoteControllerWatchdogTimeout := NOT RedundancyDiagnostics[2].Sts_CommsGood;\n\tPlantAlarms.Redundancy_CfgAlarm := FALSE;\nELSE\n\t//Serial number of controller does not match configured SN of RTAC1 or RTAC2 - set RedundancyCfg Alarm to TRUE\n\tPlantAlarms.Redundancy_CfgAlarm := TRUE;\n\tPlantAlarms.Redundancy_RemoteControllerWatchdogTimeout := FALSE;\nEND_IF\n\nIF (NOT PlantAlarms.Redundancy_RemoteControllerWatchdogTimeout) AND (NOT PlantAlarms.Redundancy_CfgAlarm) THEN\n\tPlantAlarms.Redundancy_BothControllersActive := RedundancyDiagnostics[1].Sts_CtrlActive AND RedundancyDiagnostics[2].Sts_CtrlActive;\n\tPlantAlarms.Redundancy_NeitherControllerActive := (NOT RedundancyDiagnostics[1].Sts_CtrlActive) AND (NOT RedundancyDiagnostics[2].Sts_CtrlActive);\n\n\t//Determine if plant-level outputs of Local and Remote Controller Differ\n\tRedundancyPVPCmdMismatch(En := RedundancyCfg.En,\n\t\tCfg_HiTime := RedundancyCfg.OutputsMismatchThreshTime,\n\t\tCfg_HiLmt := RedundancyCfg.OutputsMismatchDiffThresh,\n\t\tIn := (ABS(RemoteCtrlTrackingInputs.PCmd_PV - PPCDiag.PV_PCtrlDiagnostics.PPID_CV)));\n\tRedundancyBESSPCmdMismatch(En := RedundancyCfg.En,\n\t\tCfg_HiTime := RedundancyCfg.OutputsMismatchThreshTime,\n\t\tCfg_HiLmt := RedundancyCfg.OutputsMismatchDiffThresh,\n\t\tIn := (ABS(RemoteCtrlTrackingInputs.PCmd_BESS - PPCDiag.BESS_PCtrlDiagnostics.PPID_CV)));\n\tRedundancyQCmdMismatch(En := RedundancyCfg.En,\n\t\tCfg_HiTime := RedundancyCfg.OutputsMismatchThreshTime,\n\t\tCfg_HiLmt := RedundancyCfg.OutputsMismatchDiffThresh,\n\t\tIn := (ABS(RemoteCtrlTrackingInputs.QCmd - PPCDiag.QCtrlDiagnostics.QPID_CV)));\n\t\t\n\tPlantAlarms.Redundancy_OutputsMismatch := RedundancyPVPCmdMismatch.Hi OR RedundancyBESSPCmdMismatch.Hi OR RedundancyQCmdMismatch.Hi;\n\n\tPlantAlarms.Redundancy_ProjectIDMismatch := RedundancyDiagnostics[1].Sts_ProjectID <> RedundancyDiagnostics[2].Sts_ProjectID;\n\tPlantAlarms.Redundancy_ProjectsOutOfSync := PlantAlarms.Redundancy_OutputsMismatch OR PlantAlarms.Redundancy_ProjectIDMismatch;\nELSE\n\tPlantAlarms.Redundancy_BothControllersActive := FALSE;\n\tPlantAlarms.Redundancy_NeitherControllerActive := FALSE;\n\tPlantAlarms.Redundancy_OutputsMismatch := FALSE;\n\tPlantAlarms.Redundancy_ProjectIDMismatch := FALSE;\n\tPlantAlarms.Redundancy_ProjectsOutOfSync := FALSE;\n\t//\nEND_IF\n\n//Voltage Deviation Alarms\n//Calculate average Phase/Neutral voltage from all 3 phase voltages\nVxNAvg := (MeterFbk.Sts_VAN + MeterFbk.Sts_VBN + MeterFbk.Sts_VCN) / 3.0;\n\nVANPhaseDeviationAlm(En := VxNAvg > 0,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_LoLoTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.VPhaseNeutralDeviation.Hi,\n\tCfg_HiHiLmt := AlmCfg.VPhaseNeutralDeviation.HiHi,\n\tCfg_LoLmt := AlmCfg.VPhaseNeutralDeviation.Lo,\n\tCfg_LoLoLmt := AlmCfg.VPhaseNeutralDeviation.LoLo,\n\tIn := (MeterFbk.Sts_VAN - VxNAvg),\n\tHi => PlantAlarms.VANPhaseDeviation.Hi,\n\tHiHi => PlantAlarms.VANPhaseDeviation.HiHi,\n\tLo => PlantAlarms.VANPhaseDeviation.Lo,\n\tLoLo => PlantAlarms.VANPhaseDeviation.LoLo);\nVBNPhaseDeviationAlm(En := VxNAvg > 0,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_LoLoTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.VPhaseNeutralDeviation.Hi,\n\tCfg_HiHiLmt := AlmCfg.VPhaseNeutralDeviation.HiHi,\n\tCfg_LoLmt := AlmCfg.VPhaseNeutralDeviation.Lo,\n\tCfg_LoLoLmt := AlmCfg.VPhaseNeutralDeviation.LoLo,\n\tIn := (MeterFbk.Sts_VBN - VxNAvg),\n\tHi => PlantAlarms.VBNPhaseDeviation.Hi,\n\tHiHi => PlantAlarms.VBNPhaseDeviation.HiHi,\n\tLo => PlantAlarms.VBNPhaseDeviation.Lo,\n\tLoLo => PlantAlarms.VBNPhaseDeviation.LoLo);\nVCNPhaseDeviationAlm(En := VxNAvg > 0,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_HiHiTime := AlmCfg.ThreshTime,\n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_LoLoTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.VPhaseNeutralDeviation.Hi,\n\tCfg_HiHiLmt := AlmCfg.VPhaseNeutralDeviation.HiHi,\n\tCfg_LoLmt := AlmCfg.VPhaseNeutralDeviation.Lo,\n\tCfg_LoLoLmt := AlmCfg.VPhaseNeutralDeviation.LoLo,\n\tIn := (MeterFbk.Sts_VCN - VxNAvg),\n\tHi => PlantAlarms.VCNPhaseDeviation.Hi,\n\tHiHi => PlantAlarms.VCNPhaseDeviation.HiHi,\n\tLo => PlantAlarms.VCNPhaseDeviation.Lo,\n\tLoLo => PlantAlarms.VCNPhaseDeviation.LoLo);\n\t\n\n//Communication Alarms\n//Meter Comms\nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 AND i <= 10 THEN\n\t\tPlantAlarms.HVMeterCommsLoss[i] := HVMeterFbk[i].Sts_flt;\n\tEND_IF\nEND_FOR\n\nFOR i := 0 TO SiteConstants.NumMVMeters BY 1 DO\n\tIF i > 0 AND i <= 10 THEN\n\t\tPlantAlarms.MVMeterCommsLoss[i] := MVMeterFbk[i].Sts_flt;\n\tEND_IF\nEND_FOR\n\n//Inverter Alarms\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 AND i <= 100 THEN\n\t\tPlantAlarms.InvCommsLoss[i] := InvFbk[i].Sts_Offline;\n\t\tPlantAlarms.InvCtrlAlarms[i] := InvSts[i].Diag;\n\tEND_IF\nEND_FOR\n\n//EMS Comms\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 AND i <= 10 THEN\n\t\tPlantAlarms.EMSCommsLoss[i] := EMSFbk[i].Sts_Offline;\n\tEND_IF\nEND_FOR\n\n//Redundant remote controller comms alarm\nIF RedundancyCfg.En THEN\n\tPlantAlarms.RemoteCtrlCommsLoss := PlantAlarms.Redundancy_RemoteControllerWatchdogTimeout;\nELSE\n\tPlantAlarms.RemoteCtrlCommsLoss := FALSE;\nEND_IF\n\n//Met Station Comms\nFOR i := 0 TO SiteConstants.NumMetStations BY 1 DO\n\tIF i > 0 AND i <= 20 THEN\n\t\tPlantAlarms.MetCommsLoss[i] := MetStationFbk[i].Offline;\n\tEND_IF\nEND_FOR\n\n//Auxiliary Device Comms Alarms -> Add as necessary\n\n//SEL Hardware Related Alarms\n//CPU Burden Alarms\nPlantAlarms.CPUBurdenHi := PPCDiag.SysTags.CPU_Burden_Percent_5_Second_Average > REAL_TO_DINT(AlmCfg.CPUBurden.Hi);\nPlantAlarms.CPUBurdenHiHi := PPCDiag.SysTags.CPU_Burden_Percent_5_Second_Average > REAL_TO_DINT(AlmCfg.CPUBurden.HiHi);\n\n//Supply Voltage Alarms\nPrimarySupplyVoltageAlm(\n\tEn := TRUE,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.SupplyVoltage.Hi,\n\tCfg_LoLmt := AlmCfg.SupplyVoltage.Lo,\n\tIn := PPCDiag.SysTags.Supply_Voltage_Pos_Neg,\n\tHi => PlantAlarms.PrimarySupplyVoltageHigh,\n\tLo => PlantAlarms.PrimarySupplyVoltageLow);\nBackupSupplyVoltageAlm(\n\tEn := TRUE,\n\tCfg_HiTime := AlmCfg.ThreshTime,\n\tCfg_LoTime := AlmCfg.ThreshTime,\n\tCfg_HiLmt := AlmCfg.SupplyVoltage.Hi,\n\tCfg_LoLmt := AlmCfg.SupplyVoltage.Lo,\n\tIn := PPCDiag.SysTags.Supply_Voltage_Pos_Neg_B,\n\tHi => PlantAlarms.BackupSupplyVoltageHigh,\n\tLo => PlantAlarms.BackupSupplyVoltageLow);\n\t\n\nSysWatchdogExpired_TP(IN := (PPCDiag.SysTags.System_Watchdog_Expired <> ''), PT := T#60S, Q => PlantAlarms.SysWatchdogExpired);\nSysHardwareFailure_TP(IN := (PPCDiag.SysTags.System_Hardware_Failure <> ''), PT := T#60S, Q => PlantAlarms.SysHardwareFailure);\nRTACSettingsChange(IN := PPCDiag.SysTags.Settings_Change, PT := T#60S, Q => PlantAlarms.RTACSettingsChange);\nRTACPowerCycle(IN := PPCDiag.SysTags.Power_Up, PT := T#60S, Q => PlantAlarms.RTACPowerCycle);\n\n//PPC Out of NTP/IRIG Time Sync\nPlantAlarms.PPCTimeSourceCommLoss  := (System_Time_Control_POU.Time_Source_Ident <> 'IRIG_B') AND (System_Time_Control_POU.Time_Source_Ident <> 'NTP');","LineInfoPersistence":"(string)037495fc-1fde-4ec6-847c-f79600bf802c_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tDetermine status of plant alarms\n*)\n\nPROGRAM pg_U1Alarms\nVAR_INPUT\n\tPlantCfg\t\t\t\t\t: TBE_PPC.dt_PlantCfg; \t\t\t//Structure of plant configuration\n\tMeterFbk\t\t\t\t\t: TBE_PPC.dt_MeterFbk; \t\t\t//Meter Feedback\n\tHVMeterFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; \n\tMVMeterFbk\t\t\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; \n\tInvFbk\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\tEMSFbk\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\tMetStationFbk\t\t\t\t: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\tRedundancyDiagnostics\t\t: ARRAY[1..2] OF TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t//Array of redundancy diagnostics, index 1 = RTAC1, index 2 = RTAC2\n\tRemoteCtrlTrackingInputs\t: TBE_PPC.dt_RemoteCtrlInputs;\n\tRedundancyCfg\t\t\t\t: TBE_PPC.dt_RedundancyCfg;\t\t\t\t\t\t\t\t\t\t\t\t//Redundancy Cfg Struct\n\tPPCDiag\t\t\t\t\t\t: dt_PPCDiagnostics; \n\tAlmCfg\t\t\t\t\t\t: TBE_PPC.dt_AlmCfg;\n\tInvSts\t\t\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\nEND_VAR\nVAR_OUTPUT\n\tPlantAlarms\t\t\t\t\t: TBE_PPC.dt_PlantAlarms; \t\t//Structure of plant alarms\nEND_VAR\nVAR\n\t//Feedback Alarms\n\tPFbkAlm\t\t\t\t: TBE_PPC.fb_Alarm; \t\t//Active power feedback alarm\n\tQFbkAlm\t\t\t\t: TBE_PPC.fb_Alarm; \t\t//Reactive power feedback alarm\n\tVLLAvgFbkAlm\t\t: TBE_PPC.fb_Alarm; \t\t//Average Line-Line voltage feedback alarm\n\tVABFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase A/B Voltage feedback alarm\n\tVBCFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase B/C Voltage feedback alarm\n\tVCAFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase C/A Voltage feedback alarm\n\tVANFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase A/N Voltage feedback alarm\n\tVBNFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase B/N Voltage feedback alarm\n\tVCNFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Phase C/N feedback alarm\n\tPFFbkAlm_Neg\t\t: TBE_PPC.fb_Alarm; \t\t//Power Factor feedback alarm for PF < 0\n\tPFFbkAlm_Pos\t\t: TBE_PPC.fb_Alarm; \t\t//Power Factor feedback alarm for PF >= 0\n\tFreqFbkAlm\t\t\t: TBE_PPC.fb_Alarm; \t\t//Frequency feedback alarm\n\tVLLAvgFbk_MVAlm\t\t: TBE_PPC.fb_Alarm;\t\t//Medium Voltage feedback alarm\n\t\n\t//Measurement Deviation Alarms\n\tPMeasDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Active power measurement deviation Alarm\n\tQMeasDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Reactive power measurement deviation Alarm\n\tVLLAvgMeasDevAlm\t: TBE_PPC.fb_Alarm;\t//Average Line-Line Voltage measurement deviation Alarm\n\tPFMeasDevAlm\t\t: TBE_PPC.fb_Alarm;\t//Power Factor measurement deviation Alarm\n\tFreqMeasDevAlm\t\t: TBE_PPC.fb_Alarm;\t//Frequency measurement deviation Alarm\n\t\n\t//Setpoint/Feedback Deviation Alarms\n\tPSpPOIDevAlm\t\t: TBE_PPC.fb_Alarm;\t//Active Power POI Setpoint/Fbk Deviation Alarm (non co-located plants only)\n\tPSpPVDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Active Power PV Setpoint/Fbk Deviation Alarm (co-located plants only)\n\tPSpBESSDevAlm\t\t: TBE_PPC.fb_Alarm;\t//Active Power BESS Setpoint/Fbk Deviation Alarm (co-located plants only)\n\tQSpDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Reactive Power Setpoint/Fbk Deviation Alarm\n\tVSpDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Voltage Setpoint/Fbk Deviation Alarm\n\tPFSpDevAlm\t\t\t: TBE_PPC.fb_Alarm;\t//Power Factor Setpoint/Fbk Deviation Alarm\n\t\n\t//Redundancy Outputs Mismatch Alarms\n\tRedundancyPVPCmdMismatch\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining if the PV P Command of local and remote controller differ by > threshold (redundant controllers only)\n\tRedundancyBESSPCmdMismatch\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining if the BESS P Command of local and remote controller differ by > threshold (redundant controllers only)\n\tRedundancyQCmdMismatch\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining if the Q Command of local and remote controller differ by > threshold (redundant controllers only)\n\t\n\t//SEL Hardware Related Alarms\n\tPrimarySupplyVoltageAlm\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining if primary supply voltage is high/low\n\tBackupSupplyVoltageAlm\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining if backup supply voltage is high/low\n\tSysWatchdogExpired_TP\t\t: TP;\t\t\t\t\t//Pulse timer to hold a system watchdog expired alarm for 60s after it occurs\n\tSysHardwareFailure_TP\t\t: TP;\t\t\t\t\t//Pulse timer to hold a system hardware failure alarm for 60s after it occurs\t\t\t\t\n\tRTACSettingsChange\t\t\t: TP;\t\t\t\t\t//Pulse timer to hold an RTAC settings change alarm for 60s after it occurs\n\tRTACPowerCycle\t\t\t\t: TP;\t\t\t\t\t//Pulse timer to hold an RTAC Power Cycle alarm for 60s after it occurs \n\t\n\t//Voltage phase deviation alarms\n\tVANPhaseDeviationAlm\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining voltage phase deviation for Phase A/N\n\tVBNPhaseDeviationAlm\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining voltage phase deviation for Phase B/N\n\tVCNPhaseDeviationAlm\t\t: TBE_PPC.fb_Alarm;\t//Alarm FB for determining voltage phase deviation for Phase C/N\n\tVxNAvg\t\t\t\t\t\t: REAL;\t\t\t\t\t//Average Phase/Neutral voltage\n\t\n\ti\t\t\t\t: UINT;\t\t\t\t\t\t\t//Indexing variable\n\t\n\tHVMeterIndex1\t: INT;\t\t//Index used to access HV Meter 1\n\tHVMeterIndex2\t: INT;\t\t//Index used to access HV Meter 2\n\tMVMeterIndex1\t: INT;\t\t//Index used to access MV Meter 1\n\tMVMeterIndex2\t: INT;\t\t//Index used to access MV Meter 2\n\t\n\ttmp\t\t\t\t: BOOL;\nEND_VAR","LineInfoPersistence":"(string)037495fc-1fde-4ec6-847c-f79600bf802c_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)735","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}