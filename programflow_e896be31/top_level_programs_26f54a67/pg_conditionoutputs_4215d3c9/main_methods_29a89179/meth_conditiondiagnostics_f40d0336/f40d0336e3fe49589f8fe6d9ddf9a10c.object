{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)f40d0336-e3fe-4958-9f8f-e6d9ddf9a10c","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_ConditionDiagnostics","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)29a89179-c273-4926-be83-19b0cf1ef8ed"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire array of EMS/Inv status structure\nInvSts_scaled := InvSts_pu;\nEMSSts_scaled := EMSSts_pu; \n\n//Move over entire diagnostics structure and then scale values as necessary\nDiagnostics_scaled := Diagnostics_pu; \n\n//Real Power Auxiliary Control Diagnostics\nDiagnostics_scaled.PCtrl_Aux_Outputs.Psp_PV := Diagnostics_pu.PCtrl_Aux_Outputs.Psp_PV * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PCtrl_Aux_Outputs.Psp_BESS := Diagnostics_pu.PCtrl_Aux_Outputs.Psp_BESS * PlantCfg.Sbase; \t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PCtrl_Aux_Outputs.Psp_POI := Diagnostics_pu.PCtrl_Aux_Outputs.Psp_POI * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\n//Reactive Power Auxiliary Control Diagnostics\nDiagnostics_scaled.QCtrl_Aux_Outputs.Vsp := Diagnostics_pu.QCtrl_Aux_Outputs.Vsp * PlantCfg.VoltageCfg.Vbase; \t\t\t\t\t\t//Multiply pu value by V base to get kV \nDiagnostics_scaled.QCtrl_Aux_Outputs.Qsp := Diagnostics_pu.QCtrl_Aux_Outputs.Qsp * PlantCfg.Sbase;\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get Mvar\nDiagnostics_scaled.QCtrl_Aux_Outputs.VQDroopOffset := Diagnostics_pu.QCtrl_Aux_Outputs.VQDroopOffset * PlantCfg.VoltageCfg.Vbase;   //Multiply pu value by V base to get kV \nDiagnostics_scaled.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_SP := Diagnostics_pu.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_SP * PlantCfg.VoltageCfg.Vbase;   //Multiply pu value by V base to get kV \nDiagnostics_scaled.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_PV := Diagnostics_pu.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_PV * PlantCfg.VoltageCfg.Vbase;   //Multiply pu value by V base to get kV \nDiagnostics_scaled.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_CV := Diagnostics_pu.QCtrl_Aux_Outputs.VQPIDroopDiag.VQDroopPID_CV * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MVAR\n\n//Op Mode Status - No scaling necessary\n\n//Real Power Control Diagnostics\n//Scale PID diagnostics using Sbase_PV or Sbase depending on if PV is in POI Control\nDiagnostics_scaled.PV_PCtrlDiagnostics.PIDDiagnostics.IOut := Diagnostics_pu.PV_PCtrlDiagnostics.PIDDiagnostics.IOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PV_PCtrlDiagnostics.PIDDiagnostics.POut := Diagnostics_pu.PV_PCtrlDiagnostics.PIDDiagnostics.POut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PV_PCtrlDiagnostics.PIDDiagnostics.Error := Diagnostics_pu.PV_PCtrlDiagnostics.PIDDiagnostics.Error * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PV_PCtrlDiagnostics.PIDDiagnostics.MinOut := Diagnostics_pu.PV_PCtrlDiagnostics.PIDDiagnostics.MinOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PV_PCtrlDiagnostics.PIDDiagnostics.MaxOut := Diagnostics_pu.PV_PCtrlDiagnostics.PIDDiagnostics.MaxOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.PV_PCtrlDiagnostics.PPID_SP := Diagnostics_pu.PV_PCtrlDiagnostics.PPID_SP * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW \nDiagnostics_scaled.PV_PCtrlDiagnostics.PPID_PV := Diagnostics_pu.PV_PCtrlDiagnostics.PPID_PV * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW \nDiagnostics_scaled.PV_PCtrlDiagnostics.PPID_CV := Diagnostics_pu.PV_PCtrlDiagnostics.PPID_CV * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\n//BESS Active Power Control Diagnostics\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PIDDiagnostics.IOut := Diagnostics_pu.BESS_PCtrlDiagnostics.PIDDiagnostics.IOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PIDDiagnostics.POut := Diagnostics_pu.BESS_PCtrlDiagnostics.PIDDiagnostics.POut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PIDDiagnostics.Error := Diagnostics_pu.BESS_PCtrlDiagnostics.PIDDiagnostics.Error * PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PIDDiagnostics.MinOut := Diagnostics_pu.BESS_PCtrlDiagnostics.PIDDiagnostics.MinOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PIDDiagnostics.MaxOut := Diagnostics_pu.BESS_PCtrlDiagnostics.PIDDiagnostics.MaxOut * PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nDiagnostics_scaled.BESS_PCtrlDiagnostics.PPID_SP := Diagnostics_pu.BESS_PCtrlDiagnostics.PPID_SP * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW \nDiagnostics_scaled.BESS_PCtrlDiagnostics.PPID_PV := Diagnostics_pu.BESS_PCtrlDiagnostics.PPID_PV * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW \nDiagnostics_scaled.BESS_PCtrlDiagnostics.PPID_CV := Diagnostics_pu.BESS_PCtrlDiagnostics.PPID_CV * PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\n\n//Active Power Setpoint Diagnostics\nDiagnostics_scaled.PSp_Diagnostics.PSp_PV_PreRamp := Diagnostics_pu.PSp_Diagnostics.PSp_PV_PreRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_PV_PostRamp := Diagnostics_pu.PSp_Diagnostics.PSp_PV_PostRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_PV_PostCond := Diagnostics_pu.PSp_Diagnostics.PSp_PV_PostCond * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_BESS_PreRamp := Diagnostics_pu.PSp_Diagnostics.PSp_BESS_PreRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_BESS_PostRamp := Diagnostics_pu.PSp_Diagnostics.PSp_BESS_PostRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_BESS_PostCond := Diagnostics_pu.PSp_Diagnostics.PSp_BESS_PostCond * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_POI_PreRamp := Diagnostics_pu.PSp_Diagnostics.PSp_POI_PreRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_POI_PostRamp := Diagnostics_pu.PSp_Diagnostics.PSp_POI_PostRamp * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.PSp_POI_PostCond := Diagnostics_pu.PSp_Diagnostics.PSp_POI_PostCond * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_PV.FreqDeviation := Diagnostics_pu.PSp_Diagnostics.FreqDiag_PV.FreqDeviation * PlantCfg.FreqCfg.FreqBase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_PV.PErr := Diagnostics_pu.PSp_Diagnostics.FreqDiag_PV.PErr * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_PV.FreqDroopOutput := Diagnostics_pu.PSp_Diagnostics.FreqDiag_PV.FreqDroopOutput * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_BESS.FreqDeviation := Diagnostics_pu.PSp_Diagnostics.FreqDiag_BESS.FreqDeviation * PlantCfg.FreqCfg.FreqBase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_BESS.PErr := Diagnostics_pu.PSp_Diagnostics.FreqDiag_BESS.PErr * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_BESS.FreqDroopOutput := Diagnostics_pu.PSp_Diagnostics.FreqDiag_BESS.FreqDroopOutput * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_POI.FreqDeviation := Diagnostics_pu.PSp_Diagnostics.FreqDiag_POI.FreqDeviation * PlantCfg.FreqCfg.FreqBase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_POI.PErr := Diagnostics_pu.PSp_Diagnostics.FreqDiag_POI.PErr * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FreqDiag_POI.FreqDroopOutput := Diagnostics_pu.PSp_Diagnostics.FreqDiag_POI.FreqDroopOutput * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FFRDiag_POI.FFROutput     := Diagnostics_pu.PSp_Diagnostics.FFRDiag_POI.FFROutput * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FFRDiag_PV.FFROutput     := Diagnostics_pu.PSp_Diagnostics.FFRDiag_PV.FFROutput * PlantCfg.Sbase;\nDiagnostics_scaled.PSp_Diagnostics.FFRDiag_BESS.FFROutput     := Diagnostics_pu.PSp_Diagnostics.FFRDiag_BESS.FFROutput * PlantCfg.Sbase;\n\n\n\n//Ramp Rate Selection Block Diagnostics\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_POI.UpLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_POI.UpLim * PlantCfg.Sbase * 60.0; \t//pu/s to MW/min\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_POI.DnLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_POI.DnLim * PlantCfg.Sbase * 60.0; \t//pu/s to MW/min\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_PV.UpLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_PV.UpLim * PlantCfg.Sbase * 60.0; \t\t//pu/s to MW/min\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_PV.DnLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_PV.DnLim * PlantCfg.Sbase * 60.0; \t\t//pu/s to MW/min\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_BESS.UpLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_BESS.UpLim * PlantCfg.Sbase * 60.0; \t//pu/s to MW/min\nDiagnostics_scaled.PSp_Diagnostics.RampRateSelect_BESS.DnLim := Diagnostics_pu.PSp_Diagnostics.RampRateSelect_BESS.DnLim * PlantCfg.Sbase * 60.0; \t//pu/s to MW/min\nDiagnostics_scaled.QCtrlDiagnostics.RampRateSelect.UpLim := Diagnostics_pu.QCtrlDiagnostics.RampRateSelect.UpLim * PlantCfg.Sbase * 60.0;\t\t\t//pu/s to MVAr/min\nDiagnostics_scaled.QCtrlDiagnostics.RampRateSelect.DnLim := Diagnostics_pu.QCtrlDiagnostics.RampRateSelect.DnLim * PlantCfg.Sbase * 60.0;\t\t\t//pu/s to MVAr/min\n\n//Reactive Power Control Diagnostics\nDiagnostics_scaled.QCtrlDiagnostics.QPID_CV := Diagnostics_pu.QCtrlDiagnostics.QPID_CV * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get Mvar \nDiagnostics_scaled.QCtrlDiagnostics.QPID_PV := Diagnostics_pu.QCtrlDiagnostics.QPID_PV * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get Mvar \nDiagnostics_scaled.QCtrlDiagnostics.QPID_SP := Diagnostics_pu.QCtrlDiagnostics.QPID_SP * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get Mvar \n                                                                 \n//Determine inverter diagnostics\nmeth_CalcPlantLevelInvDiagnostics(UnitTypeCfg := UnitTypeCfg, InvCfg := InvCfg, InvFbk_pu := PPCInputs_pu.InvFbk, InvSts := InvSts_pu, PlantCfg := PlantCfg, InvDiag => Diagnostics_scaled.PlantInvDiagnostics); \n\n//EMS Plant-Level Diagnostics (move over values from PPC Inputs)\nDiagnostics_scaled.PlantEMSDiagnostics.Total_ChargeCap := PPCInputs_pu.PlantEMSSts.Total_ChargeCap * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEMSDiagnostics.Total_DischCap := PPCInputs_pu.PlantEMSSts.Total_DischCap * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEMSDiagnostics.Total_GrossMW := PPCInputs_pu.PlantEMSSts.Total_GrossMW * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEMSDiagnostics.Total_GrossMVAR := PPCInputs_pu.PlantEMSSts.Total_GrossMVAR * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEMSDiagnostics.Total_QCapAbs := PPCInputs_pu.PlantEMSSts.Total_QCapAbs * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEMSDiagnostics.Total_QCapInj := PPCInputs_pu.PlantEMSSts.Total_QCapInj * PlantCfg.Sbase;\n\n//HSL\nDiagnostics_scaled.HSL := PPCInputs_pu.HSL * PlantCfg.Sbase;    \t\t\t\t\t\t\t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get scaled HSL   \n\n//Calculate Plant Power Potential (based on Irradiance)\nDiagnostics_scaled.ActivePwrPotentialOutput := LIMIT(0, (Diagnostics_scaled.MetAvgFbk.POA_Irr_TC / PlantCfg.MetStationCfg.MaxIrr) * PlantCfg.Sbase, PlantCfgEng.HOL); \n\n//Capacitor Bank Diagmostics - No scaling necessary\n\n//Calculate met station average feedback values\nmeth_CalcMetAvg(MetFbk_scaled := MetFbk_scaled, MetCfg := PlantCfg.MetStationCfg, MetFbk_Avg => Diagnostics_scaled.MetAvgFbk); \n\n//Plant Events - Cfg values will be tracked in Eng. units, so scale analog setpoints only\nDiagnostics_scaled.PlantEvents := Diagnostics_pu.PlantEvents;\nDiagnostics_scaled.PlantEvents.POIPSpChange.CurVal := Diagnostics_pu.PlantEvents.POIPSpChange.CurVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.POIPSpChange.PrevVal := Diagnostics_pu.PlantEvents.POIPSpChange.PrevVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.PVPSpChange.CurVal := Diagnostics_pu.PlantEvents.PVPSpChange.CurVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.PVPSpChange.PrevVal := Diagnostics_pu.PlantEvents.PVPSpChange.PrevVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.EMSPSpChange.CurVal := Diagnostics_pu.PlantEvents.EMSPSpChange.CurVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.EMSPSpChange.PrevVal := Diagnostics_pu.PlantEvents.EMSPSpChange.PrevVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.QSpChange.CurVal := Diagnostics_pu.PlantEvents.QSpChange.CurVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.QSpChange.PrevVal := Diagnostics_pu.PlantEvents.QSpChange.PrevVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.VSpChange.CurVal := Diagnostics_pu.PlantEvents.VSpChange.CurVal * PlantCfg.VoltageCfg.Vbase;\nDiagnostics_scaled.PlantEvents.VSpChange.PrevVal := Diagnostics_pu.PlantEvents.VSpChange.PrevVal * PlantCfg.VoltageCfg.Vbase;\nDiagnostics_scaled.PlantEvents.PDeviationEvent.CurVal := Diagnostics_pu.PlantEvents.PDeviationEvent.CurVal * PlantCfg.Sbase;\nDiagnostics_scaled.PlantEvents.PDeviationEvent.CurVal := Diagnostics_pu.PlantEvents.PDeviationEvent.PrevVal * PlantCfg.Sbase;\n","LineInfoPersistence":"(string)f40d0336-e3fe-4958-9f8f-e6d9ddf9a10c_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition Diagnostics Program\n///|\tCondition diagnostic outputs from core logic from pu to engineering units for SCADA/Ignition\nMETHOD meth_ConditionDiagnostics\nVAR_INPUT\n\t///[pu], Diagnostics in pu, from core logic\n\tDiagnostics_pu: dt_PPCDiagnostics;\n\t///Plant configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Plant configuration structure (in engineering units)\n\tPlantCfgEng: TBE_PPC.dt_PlantCfg;\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\t///Inverter configuration\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\n\t///Array of feedback information from all met stations (scaled to eng. units)\n\tMetFbk_scaled: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\t///[pu], PPC Inputs, scaled to percent unit\n\tPPCInputs_pu: dt_PPCInputs;\n\t///Inverter status structure\n\tInvSts_pu: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\n\t///EMS status structure\n\tEMSSts_pu: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\nEND_VAR\nVAR_OUTPUT\n\t///Diagnostics, scaled to engineering units for SCADA/Ignition\n\tDiagnostics_scaled: dt_PPCDiagnostics;\n\t///Inverter status structure\n\tInvSts_scaled: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\n\t///EMS status structure\n\tEMSSts_scaled: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\nEND_VAR\n","LineInfoPersistence":"(string)f40d0336-e3fe-4958-9f8f-e6d9ddf9a10c_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}