{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)0ebdb00a-d1ca-46b2-8617-9c1dfca9a616","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_ConditionMeterFbkForSCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)29a89179-c273-4926-be83-19b0cf1ef8ed"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//HVMeterFbk_scaled\nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move all values to scaled structure\n\t\tHVMeterFbk_scaled[i] := HVMeterFbk_pu[i];\n\t\t\n\t\t//Scale/condition values as necessary - For now, only P, Q, V, and Frequency will be scaled. Current values will pass through as-is since they don't get converted to pu\n\t\tHVMeterFbk_scaled[i].STS_P := HVMeterFbk_pu[i].STS_P * PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tHVMeterFbk_scaled[i].STS_Q := HVMeterFbk_pu[i].STS_Q * PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Multiply pu value by Sbase to get MVAr\n\t\tHVMeterFbk_scaled[i].Sts_P_Comp := HVMeterFbk_pu[i].Sts_P_Comp * PlantCfg.Sbase;\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tHVMeterFbk_scaled[i].Sts_P_UC := HVMeterFbk_pu[i].Sts_P_UC * PlantCfg.Sbase;\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tHVMeterFbk_scaled[i].Sts_Q_Comp := HVMeterFbk_pu[i].Sts_Q_Comp * PlantCfg.Sbase;\t\t\t\t\t//Multiply pu value by Sbase to get MVAr\n\t\tHVMeterFbk_scaled[i].Sts_Q_UC := HVMeterFbk_pu[i].Sts_Q_UC * PlantCfg.Sbase;\t\t\t\t\t\t//Multiply pu value by Sbase to get MVAr\n\t\tHVMeterFbk_scaled[i].STS_Freq := HVMeterFbk_pu[i].STS_Freq * PlantCfg.FreqCfg.FreqBase; \t\t\t//Multiply pu value by Freq Base to get Hz\n\t\tHVMeterFbk_scaled[i].STS_VLLAvg := HVMeterFbk_pu[i].STS_VLLAvg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Voltage Base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_Vreg := HVMeterFbk_pu[i].Sts_Vreg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Voltage Base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VAB := HVMeterFbk_pu[i].Sts_VAB * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VBC := HVMeterFbk_pu[i].Sts_VBC * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VCA := HVMeterFbk_pu[i].Sts_VCA * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VAN := HVMeterFbk_pu[i].Sts_VAN * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VBN := HVMeterFbk_pu[i].Sts_VBN * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\tHVMeterFbk_scaled[i].Sts_VCN := HVMeterFbk_pu[i].Sts_VCN * PlantCfg.VoltageCfg.Vbase;\t\t\t\t//Multiply pu value by Voltage base to get kV\n\t\t\n\t\t//Scale raw/unfiltered values as well\n\t\tHVMeterFbk_scaled[i].Sts_P_raw := HVMeterFbk_pu[i].Sts_P_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tHVMeterFbk_scaled[i].Sts_Vreg_raw := HVMeterFbk_pu[i].Sts_Vreg_raw * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Voltage Base to get kV\n\t\tHVMeterFbk_scaled[i].STS_Q_raw := HVMeterFbk_pu[i].STS_Q_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tHVMeterFbk_scaled[i].STS_Freq_raw := HVMeterFbk_pu[i].STS_Freq_raw * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\n\tEND_IF\nEND_FOR\n\n//MVMeterFbk_scaled\nFOR i := 0 TO SiteConstants.NumMVMeters BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move all values to scaled structure\n\t\tMVMeterFbk_scaled[i] := MVMeterFbk_pu[i];\n\t\t\n\t\t//Scale/condition values as necessary - For now, only P, Q, V, and Frequency will be scaled. Current values will pass through as-is since they don't get converted to pu\n\t\tMVMeterFbk_scaled[i].STS_P := MVMeterFbk_pu[i].STS_P * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].STS_Q := MVMeterFbk_pu[i].STS_Q * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].Sts_P_Comp := MVMeterFbk_pu[i].Sts_P_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].Sts_P_UC := MVMeterFbk_pu[i].Sts_P_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].Sts_Q_Comp := MVMeterFbk_pu[i].Sts_Q_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MVAr\n\t\tMVMeterFbk_scaled[i].Sts_Q_UC := MVMeterFbk_pu[i].Sts_Q_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MVAr\n\t\tMVMeterFbk_scaled[i].STS_Freq := MVMeterFbk_pu[i].STS_Freq * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\n\t\tMVMeterFbk_scaled[i].STS_VAB := MVMeterFbk_pu[i].STS_VAB * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].STS_VBC := MVMeterFbk_pu[i].STS_VBC * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].STS_VCA := MVMeterFbk_pu[i].STS_VCA * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].Sts_VAN := MVMeterFbk_pu[i].Sts_VAN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].Sts_VBN := MVMeterFbk_pu[i].Sts_VBN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].Sts_VCN := MVMeterFbk_pu[i].Sts_VCN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\n\t\tMVMeterFbk_scaled[i].STS_VLLAvg := MVMeterFbk_pu[i].STS_VLLAvg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Freq Base to get Hz\n\t\t\n\t\t//Scale raw/unfiltered values as well\n\t\tMVMeterFbk_scaled[i].Sts_P_raw := MVMeterFbk_scaled[i].Sts_P_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].Sts_Vreg_raw := MVMeterFbk_scaled[i].Sts_Vreg_raw * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Voltage Base to get kV\n\t\tMVMeterFbk_scaled[i].STS_Q_raw := MVMeterFbk_scaled[i].STS_Q_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\n\t\tMVMeterFbk_scaled[i].STS_Freq_raw := MVMeterFbk_scaled[i].STS_Freq_raw * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\n\tEND_IF\nEND_FOR\n\n//MeterFbk_scaled\n//Move all values to scaled structure\nMeterFbk_scaled := MeterFbk_pu;\n\t\n//Scale/condition values as necessary - For now, only P, Q, V, and Frequency will be scaled. Current values will pass through as-is since they don't get converted to pu\nMeterFbk_scaled.STS_P := MeterFbk_pu.STS_P * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.STS_Q := MeterFbk_pu.STS_Q * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.Sts_P_Comp := MeterFbk_pu.Sts_P_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.Sts_P_UC := MeterFbk_pu.Sts_P_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.Sts_Q_Comp := MeterFbk_pu.Sts_Q_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_scaled.Sts_Q_UC := MeterFbk_pu.Sts_Q_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_scaled.STS_Freq := MeterFbk_pu.STS_Freq * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_scaled.STS_VAB := MeterFbk_pu.STS_VAB * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.STS_VBC := MeterFbk_pu.STS_VBC * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.STS_VCA := MeterFbk_pu.STS_VCA * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.Sts_VAN := MeterFbk_pu.Sts_VAN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.Sts_VBN := MeterFbk_pu.Sts_VBN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.Sts_VCN := MeterFbk_pu.Sts_VCN * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage base to get kV\nMeterFbk_scaled.STS_VLLAvg := MeterFbk_pu.STS_VLLAvg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_scaled.Sts_Vreg := MeterFbk_scaled.Sts_Vreg * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage Base to get kV\nMeterFbk_scaled.Sts_P_raw := MeterFbk_scaled.Sts_P_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.Sts_Vreg_raw := MeterFbk_scaled.Sts_Vreg_raw * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage Base to get kV\nMeterFbk_scaled.STS_Q_raw := MeterFbk_scaled.STS_Q_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_scaled.STS_Freq_raw := MeterFbk_scaled.STS_Freq_raw * PlantCfg.FreqCfg.FreqBase; \t\t\t//Multiply pu value by Freq Base to get Hz\n\n//PV Meter Fbk\n//Move all values to scaled structure\nMeterFbk_PV_scaled := MeterFbk_pu;\n\t\n//Scale/condition values as necessary - For now, only P, Q, V, and Frequency will be scaled. Current values will pass through as-is since they don't get converted to pu\nMeterFbk_PV_scaled.STS_P := MeterFbk_PV_pu.STS_P * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.STS_Q := MeterFbk_PV_pu.STS_Q * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.Sts_P_Comp := MeterFbk_PV_pu.Sts_P_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.Sts_P_UC := MeterFbk_PV_pu.Sts_P_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.Sts_Q_Comp := MeterFbk_PV_pu.Sts_Q_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_PV_scaled.Sts_Q_UC := MeterFbk_PV_pu.Sts_Q_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_PV_scaled.STS_Freq := MeterFbk_PV_pu.STS_Freq * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_PV_scaled.STS_VAB := MeterFbk_PV_pu.STS_VAB * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_PV_scaled.STS_VBC := MeterFbk_PV_pu.STS_VBC * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_PV_scaled.STS_VCA := MeterFbk_PV_pu.STS_VCA * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_PV_scaled.STS_VLLAvg := MeterFbk_PV_pu.STS_VLLAvg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_PV_scaled.Sts_P_raw := MeterFbk_PV_scaled.Sts_P_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.Sts_Vreg_raw := MeterFbk_PV_scaled.Sts_Vreg_raw * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage Base to get kV\nMeterFbk_PV_scaled.STS_Q_raw := MeterFbk_PV_scaled.STS_Q_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_PV_scaled.STS_Freq_raw := MeterFbk_PV_scaled.STS_Freq_raw * PlantCfg.FreqCfg.FreqBase; \t\t\t//Multiply pu value by Freq Base to get Hz\n\n//BESS Meter Fbk\n//Move all values to scaled structure\nMeterFbk_BESS_scaled := MeterFbk_BESS_pu;\n\t\n//Scale/condition values as necessary - For now, only P, Q, V, and Frequency will be scaled. Current values will pass through as-is since they don't get converted to pu\nMeterFbk_BESS_scaled.STS_P := MeterFbk_BESS_pu.STS_P * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.STS_Q := MeterFbk_BESS_pu.STS_Q * PlantCfg.Sbase; \t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.Sts_P_Comp := MeterFbk_BESS_pu.Sts_P_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.Sts_P_UC := MeterFbk_BESS_pu.Sts_P_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.Sts_Q_Comp := MeterFbk_BESS_pu.Sts_Q_Comp * PlantCfg.Sbase;\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_BESS_scaled.Sts_Q_UC := MeterFbk_BESS_pu.Sts_Q_UC * PlantCfg.Sbase;\t\t\t\t//Multiply pu value by Sbase to get MVAr\nMeterFbk_BESS_scaled.STS_Freq := MeterFbk_BESS_pu.STS_Freq * PlantCfg.FreqCfg.FreqBase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_BESS_scaled.STS_VAB := MeterFbk_BESS_pu.STS_VAB * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_BESS_scaled.STS_VBC := MeterFbk_BESS_pu.STS_VBC * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_BESS_scaled.STS_VCA := MeterFbk_BESS_pu.STS_VCA * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_BESS_scaled.STS_VLLAvg := MeterFbk_BESS_pu.STS_VLLAvg * PlantCfg.VoltageCfg.Vbase; \t\t//Multiply pu value by Freq Base to get Hz\nMeterFbk_BESS_scaled.Sts_P_raw := MeterFbk_BESS_scaled.Sts_P_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.Sts_Vreg_raw := MeterFbk_BESS_scaled.Sts_Vreg_raw * PlantCfg.VoltageCfg.Vbase; \t\t\t//Multiply pu value by Voltage Base to get kV\nMeterFbk_BESS_scaled.STS_Q_raw := MeterFbk_BESS_scaled.STS_Q_raw * PlantCfg.Sbase; \t\t\t\t\t\t\t//Multiply pu value by Sbase to get MW\nMeterFbk_BESS_scaled.STS_Freq_raw := MeterFbk_BESS_scaled.STS_Freq_raw * PlantCfg.FreqCfg.FreqBase; \t\t\t//Multiply pu value by Freq Base to get Hz\n\n//Condition VirtualMeterFbk_scaled. Meter Feedback\n//Move everything from pu to scaled structs\nVirtualMeterFbk_scaled := VirtualMeterFbk_pu; \n\n//Scale values as necessary\nVirtualMeterFbk_scaled.PVFeederMeterFbk.Sts_P := VirtualMeterFbk_pu.PVFeederMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.PVFeederMeterFbk.Sts_Q := VirtualMeterFbk_pu.PVFeederMeterFbk.Sts_Q * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.BESSFeederMeterFbk.Sts_P := VirtualMeterFbk_pu.BESSFeederMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.BESSFeederMeterFbk.Sts_Q := VirtualMeterFbk_pu.BESSFeederMeterFbk.Sts_Q * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.POIFeederMeterFbk.Sts_P := VirtualMeterFbk_pu.POIFeederMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.POIFeederMeterFbk.Sts_Q := VirtualMeterFbk_pu.POIFeederMeterFbk.Sts_Q * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.PVInvMeterFbk.Sts_P := VirtualMeterFbk_pu.PVInvMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.PVInvMeterFbk.Sts_Q := VirtualMeterFbk_pu.PVInvMeterFbk.Sts_Q * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.BESSInvMeterFbk.Sts_P := VirtualMeterFbk_pu.BESSInvMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.BESSInvMeterFbk.Sts_Q := VirtualMeterFbk_pu.BESSInvMeterFbk.Sts_Q * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.POIInvMeterFbk.Sts_P := VirtualMeterFbk_pu.POIInvMeterFbk.Sts_P * PlantCfg.Sbase;\nVirtualMeterFbk_scaled.POIInvMeterFbk.Sts_Q := VirtualMeterFbk_pu.POIInvMeterFbk.Sts_Q * PlantCfg.Sbase;\n","LineInfoPersistence":"(string)0ebdb00a-d1ca-46b2-8617-9c1dfca9a616_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition meter feedback for SCADA\n///|\tConvert meter feedback from percent-unit to engineering units for SCADA\nMETHOD meth_ConditionMeterFbkForSCADA\nVAR_INPUT\n\t///[pu], Meter feedback, scaled to pu\n\tHVMeterFbk_pu: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///[pu], Meter feedback, scaled to pu\n\tMVMeterFbk_pu: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///[pu], Meter feedback, scaled to pu, Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_pu: TBE_PPC.dt_MeterFbk;\n\t///[pu], PV Meter feedback, scaled to pu, Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_PV_pu: TBE_PPC.dt_MeterFbk;\n\t///[pu], BESS Meter feedback, scaled to pu, Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_BESS_pu: TBE_PPC.dt_MeterFbk;\n\t///Plant configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Array of HV meter configuration structures\n\tHVMeterCfg: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///Array of HV meter configuration structures\n\tMVMeterCfg: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///VirtualMeterFbk_scaled. Meter Struct\n\tVirtualMeterFbk_pu: dt_VirtualMeters;\nEND_VAR\nVAR_OUTPUT\n\t///Meter feedback, scaled to engineering units for SCADA/Ignition\n\tHVMeterFbk_scaled: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///Meter feedback, scaled to engineering units for SCADA/Ignition\n\tMVMeterFbk_scaled: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///Meter feedback, scaled TO engineering units FOR SCADA/Ignition, Meter Feedback TO be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_scaled: TBE_PPC.dt_MeterFbk;\n\t///PV Meter feedback, scaled to engineering units for SCADA/Ignition, Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_PV_scaled: TBE_PPC.dt_MeterFbk;\n\t///BESS Meter feedback, scaled to engineering units for SCADA/Ignition, Meter Feedback to be used in core logic (source may vary depending on active meter mode)\n\tMeterFbk_BESS_scaled: TBE_PPC.dt_MeterFbk;\n\t///VirtualMeterFbk_scaled. Meter Struct, scaled to engineering units\n\tVirtualMeterFbk_scaled: dt_VirtualMeters;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)0ebdb00a-d1ca-46b2-8617-9c1dfca9a616_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}