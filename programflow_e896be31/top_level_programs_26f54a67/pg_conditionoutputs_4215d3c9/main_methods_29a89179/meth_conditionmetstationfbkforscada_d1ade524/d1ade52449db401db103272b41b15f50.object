{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d1ade524-49db-401d-b103-272b41b15f50","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_ConditionMetStationFbkForSCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)29a89179-c273-4926-be83-19b0cf1ef8ed"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumMetStations BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over all data\n\t\tMetStationFbk_scaled[i] := MetStationFbk_pu[i]; \n\t\tMetStationFbk_scaled[i].POA_Irr_TC := MetStationFbk_pu[i].POA_Irr_TC * MetStationCfg.MaxIrr; \n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)d1ade524-49db-401d-b103-272b41b15f50_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition met station feedback for SCADA or utility mapping\nMETHOD meth_ConditionMetStationFbkForSCADA\nVAR_INPUT\n\t///Met station feedback values, in percentage units\n\tMetStationFbk_pu: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\t///Met station configuration structure\n\tMetStationCfg: TBE_PPC.dt_MetStationCfg;\nEND_VAR\nVAR_OUTPUT\n\t///Met station feedback values, scaled for SCADA/utility\n\tMetStationFbk_scaled: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\n\t///Temporary value for conditioned irradiance\n\tIrr_Temp: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)d1ade524-49db-401d-b103-272b41b15f50_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}