{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)1cb1a657-e47b-4fc2-afc0-63067b75da37","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_ConditionInvOutputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)29a89179-c273-4926-be83-19b0cf1ef8ed"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Scale inverter outputs for inverter modbus registers\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over entire structure\n\t\tInvCmds_scaled[i] := InvCmds_pu[i]; \n\t\tInvCmds_scaled[i].PCmd := InvCmds_pu[i].PCmd * UnitTypeCfg[InvCfg[i].UnitTypeID].PCmd_fromPu;\t//pu to Modbus Units\n\t\tInvCmds_scaled[i].QCmd := InvCmds_pu[i].QCmd * UnitTypeCfg[InvCfg[i].UnitTypeID].QCmd_fromPu;\t//pu to Modbus Units\n\tEND_IF\nEND_FOR\n\n//Scale inverter outputs for SCADA\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over entire structure\n\t\tInvCmds_scaledForSCADA[i] := InvCmds_pu[i]; \n\t\t\n\t\t//Scale/Condition values as necessary -> Modify based on inverter modbus register scaling. \n\t\tInvCmds_scaledForSCADA[i].PCmd := InvCmds_pu[i].PCmd * UnitTypeCfg[InvCfg[i].UnitTypeID].Snom;\t\t//pu to kW\n\t\tInvCmds_scaledForSCADA[i].QCmd := InvCmds_pu[i].QCmd * UnitTypeCfg[InvCfg[i].UnitTypeID].Snom;\t\t//pu to kW\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)1cb1a657-e47b-4fc2-afc0-63067b75da37_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_ConditionInvOutputs\nVAR_INPUT\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\n\t///[pu], Array of inverter commands from core logic\n\tInvCmds_pu: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds;\nEND_VAR\nVAR_OUTPUT\n\t///EMS Commands scaled for SCADA\n\tInvCmds_scaledForSCADA: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds;\n\t///Array of inverter commands, scaled for modbus registers\n\tInvCmds_scaled: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)1cb1a657-e47b-4fc2-afc0-63067b75da37_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}