{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)0db9fe2b-d2d9-4635-9419-494a50a1a444","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_CalcMetAvg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)fe97cef2-2ad6-45b6-9543-a97ae5a99f91"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through all met stations and calculate average value\nFOR i := 0 TO SiteConstants.NumMetStations BY 1 DO\n\tIF i > 0 THEN\n\t\tIF NOT MetFbk_scaled[i].Offline THEN\n\t\t\tIF MetFbk_scaled[i].POA_Irr > MetCfg.POA_lim[0] AND MetFbk_scaled[i].POA_Irr < MetCfg.POA_lim[1] THEN\n\t\t\t\tPOA_Sum := POA_Sum + MetFbk_scaled[i].POA_Irr;\n\t\t\t\tPOA_n := POA_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].POA_Irr_TC > MetCfg.POA_lim[0] AND MetFbk_scaled[i].POA_Irr_TC < MetCfg.POA_lim[1] THEN\n\t\t\t\tPOA_TC_Sum := POA_TC_Sum + MetFbk_scaled[i].POA_Irr_TC;\n\t\t\t\tPOA_TC_n := POA_TC_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].GHI > MetCfg.GHI_lim[0] AND MetFbk_scaled[i].GHI < MetCfg.GHI_lim[1] THEN\n\t\t\t\tGHI_Sum := GHI_Sum + MetFbk_scaled[i].GHI;\n\t\t\t\tGHI_n := GHI_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].DirectIrr > MetCfg.DirectIrr_lim[0] AND MetFbk_scaled[i].DirectIrr < MetCfg.DirectIrr_lim[1] THEN\n\t\t\t\tDirectIrr_Sum := DirectIrr_Sum + MetFbk_scaled[i].DirectIrr;\n\t\t\t\tDirectIrr_n := DirectIrr_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].BOMTempAvg > MetCfg.Temp_lim[0] AND MetFbk_scaled[i].BOMTempAvg < MetCfg.Temp_lim[1] THEN\n\t\t\t\tBOMTemp_Sum := BOMTemp_Sum + MetFbk_scaled[i].BOMTempAvg;\n\t\t\t\tBOMTemp_n := BOMTemp_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].AmbTemp > MetCfg.Temp_lim[0] AND MetFbk_scaled[i].AmbTemp < MetCfg.Temp_lim[1] THEN\n\t\t\t\tAmbTemp_Sum := AmbTemp_Sum + MetFbk_scaled[i].AmbTemp;\n\t\t\t\tAmbTemp_n := AmbTemp_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].WindSpd > MetCfg.WindSpd_lim[0] AND MetFbk_scaled[i].WindSpd < MetCfg.WindSpd_lim[1] THEN\n\t\t\t\tWindSpd_Sum := WindSpd_Sum + MetFbk_scaled[i].WindSpd;\n\t\t\t\tWindSpd_n := WindSpd_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].WindDir > MetCfg.WindDir_lim[0] AND MetFbk_scaled[i].WindDir < MetCfg.WindDir_lim[1] THEN\n\t\t\t\tWindDir_Sum := WindDir_Sum + MetFbk_scaled[i].WindDir;\n\t\t\t\tWindDir_n := WindDir_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].RH > MetCfg.RH_lim[0] AND MetFbk_scaled[i].RH < MetCfg.RH_lim[1] THEN\n\t\t\t\tRH_Sum := RH_Sum + MetFbk_scaled[i].RH;\n\t\t\t\tRH_n := RH_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].Pressure > MetCfg.Pressure_lim[0] AND MetFbk_scaled[i].Pressure < MetCfg.Pressure_lim[1] THEN\n\t\t\t\tPressure_Sum := Pressure_Sum + MetFbk_scaled[i].Pressure;\n\t\t\t\tPressure_n := Pressure_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].Precip > MetCfg.Precip_lim[0] AND MetFbk_scaled[i].Precip < MetCfg.Precip_lim[1] THEN\n\t\t\t\tPrecip_Sum := Precip_Sum + MetFbk_scaled[i].Precip;\n\t\t\t\tPrecip_n := Precip_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].SolarPosElevation > MetCfg.Angle_lim[0] AND MetFbk_scaled[i].SolarPosElevation < MetCfg.Angle_lim[1] THEN\n\t\t\t\tSolarPosElevation_Sum := SolarPosElevation_Sum + MetFbk_scaled[i].SolarPosElevation;\n\t\t\t\tSolarPosElevation_n := SolarPosElevation_n + 1;\n\t\t\tEND_IF\n\t\t\tIF MetFbk_scaled[i].SolarPosAzimuth > MetCfg.Angle_lim[0] AND MetFbk_scaled[i].SolarPosAzimuth < MetCfg.Angle_lim[1] THEN\n\t\t\t\tSolarPosAzimuth_Sum := SolarPosAzimuth_Sum + MetFbk_scaled[i].SolarPosAzimuth;\n\t\t\t\tSolarPosAzimuth_n := SolarPosAzimuth_n + 1;\n\t\t\tEND_IF\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n//Calculate average values\nMetFbk_Avg.POA_Irr := TBE_PPC.fn_AvgCalcWith0Check(Sum := POA_Sum, n := POA_n); \nMetFbk_Avg.POA_Irr_TC := TBE_PPC.fn_AvgCalcWith0Check(Sum := POA_TC_Sum, n := POA_TC_n); \nMetFbk_Avg.GHI := TBE_PPC.fn_AvgCalcWith0Check(Sum := GHI_Sum, n := GHI_n); \nMetFbk_Avg.DirectIrr := TBE_PPC.fn_AvgCalcWith0Check(Sum := DirectIrr_Sum, n := DirectIrr_n); \nMetFbk_Avg.BOMTempAvg := TBE_PPC.fn_AvgCalcWith0Check(Sum := BOMTemp_Sum, n := BOMTemp_n); \nMetFbk_Avg.AmbTemp := TBE_PPC.fn_AvgCalcWith0Check(Sum := AmbTemp_Sum, n := AmbTemp_n); \nMetFbk_Avg.WindSpd := TBE_PPC.fn_AvgCalcWith0Check(Sum := WindSpd_Sum, n := WindSpd_n); \nMetFbk_Avg.WindDir := TBE_PPC.fn_AvgCalcWith0Check(Sum := WindDir_Sum, n := WindDir_n); \nMetFbk_Avg.RH := TBE_PPC.fn_AvgCalcWith0Check(Sum := RH_Sum, n := RH_n); \nMetFbk_Avg.Pressure := TBE_PPC.fn_AvgCalcWith0Check(Sum := Pressure_Sum, n := Pressure_n); \nMetFbk_Avg.Precip := TBE_PPC.fn_AvgCalcWith0Check(Sum := Precip_Sum, n := Precip_n); \nMetFbk_Avg.SolarPosElevation := TBE_PPC.fn_AvgCalcWith0Check(Sum := SolarPosElevation_Sum, n := SolarPosElevation_n); \nMetFbk_Avg.SolarPosAzimuth := TBE_PPC.fn_AvgCalcWith0Check(Sum := SolarPosAzimuth_Sum, n := SolarPosAzimuth_n); ","LineInfoPersistence":"(string)0db9fe2b-d2d9-4635-9419-494a50a1a444_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCalculation met station average values\nMETHOD meth_CalcMetAvg\nVAR_INPUT\n\t///Array of feedback information from all met stations (scaled to eng. units)\n\tMetFbk_scaled: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\t///Met station cfg \n\tMetCfg: TBE_PPC.dt_MetStationCfg;\nEND_VAR\nVAR_OUTPUT\n\t///Met station average feedback (scaled to eng. units)\n\tMetFbk_Avg: TBE_PPC.dt_MetStationFbk;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\n\t///Sum value for calculating average\n\tPOA_Sum: REAL;\n\t///Counter value for calculating average\n\tPOA_n: REAL;\n\t///Sum value for calculating average\n\tPOA_TC_Sum: REAL;\n\t///Counter value for calculating average\n\tPOA_TC_n: REAL;\n\t///Sum value for calculating average\n\tGHI_Sum: REAL;\n\t///Counter value for calculating average\n\tGHI_n: REAL;\n\t///Sum value for calculating average\n\tDirectIrr_Sum: REAL;\n\t///Counter value for calculating average\n\tDirectIrr_n: REAL;\n\t///Sum value for calculating average\n\tBOMTemp_Sum: REAL;\n\t///Counter value for calculating average\n\tBOMTemp_n: REAL;\n\t///Sum value for calculating average\n\tAmbTemp_Sum: REAL;\n\t///Counter value for calculating average\n\tAmbTemp_n: REAL;\n\t///Sum value for calculating average\n\tWindSpd_Sum: REAL;\n\t///Counter value for calculating average\n\tWindSpd_n: REAL;\n\t///Sum value for calculating average\n\tWindDir_Sum: REAL;\n\t///Counter value for calculating average\n\tWindDir_n: REAL;\n\t///Sum value for calculating average\n\tRH_Sum: REAL;\n\t///Counter value for calculating average\n\tRH_n: REAL;\n\t///Sum value for calculating average\n\tPressure_Sum: REAL;\n\t///Counter value for calculating average\n\tPressure_n: REAL;\n\t///Sum value for calculating average\n\tPrecip_Sum: REAL;\n\t///Counter value for calculating average\n\tPrecip_n: REAL;\n\t///Sum value for calculating average\n\tSolarPosElevation_Sum: REAL;\n\t///Counter value for calculating average\n\tSolarPosElevation_n: REAL;\n\t///Sum value for calculating average\n\tSolarPosAzimuth_Sum: REAL;\n\t///Counter value for calculating average\n\tSolarPosAzimuth_n: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)0db9fe2b-d2d9-4635-9419-494a50a1a444_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}