{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)652ca7a4-c592-4c16-8180-e0a19a6b33b4","ParentGuid":"(Guid)4215d3c9-0bac-4e74-b09e-7b030facd1be","Name":"(string)meth_CalcPlantLevelInvDiagnostics","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)fe97cef2-2ad6-45b6-9543-a97ae5a99f91"}]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n//Count units in different states for diagnostics\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i >= 1 THEN\n\t\t//Determine number of generating/not generating inverters\n\t\tIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND PPCInputs_pu.InvFbk[i].Sts_P > InvGeneratingThreshold THEN \n\t\t\t//Inverter is online and active power feedback is above generating threshold\n\t\t\ttmpTotalPVInv_Generating := tmpTotalPVInv_Generating + 1;\n\t\tELSIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND (PPCInputs_pu.InvFbk[i].Sts_Stopped OR PPCInputs_pu.InvFbk[i].Sts_P < InvGeneratingThreshold) THEN\n\t\t\t//Inverter is online, but is stopped or active power production is below generating threshold\n\t\t\ttmpTotalPVInv_NotGenerating := tmpTotalPVInv_NotGenerating + 1;\n\t\tELSE\n\t\t\t//Inverter is offline -> add 1 to unknown count\n\t\t\ttmpTotalPVInv_Unknown:=tmpTotalPVInv_Unknown+1; \n\t\tEND_IF\n\t\t\n\t\t//Determine number of faulted/ready inverters\n\t\tIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND PPCInputs_pu.InvFbk[i].Sts_Faulted THEN\n\t\t\t//Inverter is online, but faulted -> add 1 to faulted count\n\t\t\ttmpTotalPVInv_Faulted := tmpTotalPVInv_Faulted + 1;\n\t\tELSIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline THEN\n\t\t\t//Inverter is online and not faulted -> add 1 to ready count and add capacity to available generating capacity\n\t\t\ttmpTotalPVInv_Ready := tmpTotalPVInv_Ready + 1;\n\t\t\ttmpTotal_AvailGenCap := tmpTotal_AvailGenCap + (UnitTypeCfg[InvCfg[i].UnitTypeID].Snom * kWToMW);  \n\t\tEND_IF\n\t\t\n\t\t//Calculate gross MW and MVars\n\t\tIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline THEN\n\t\t\ttmpTotal_GrossMW := tmpTotal_GrossMW + (PPCInputs_pu.InvFbk[i].Sts_P * UnitTypeCfg[InvCfg[i].UnitTypeID].Snom * kWToMW);\n\t\t\ttmpTotal_GrossMVAR := tmpTotal_GrossMVAR + (PPCInputs_pu.InvFbk[i].Sts_Q * UnitTypeCfg[InvCfg[i].UnitTypeID].Snom * kWToMW);\n\t\tEND_IF\n\t\t\n\t\t//Calculate available reactive power absorption/injection capacity. Logic is based on Qnom and inverter running status. Modify as necessary if Inverter reports dynamic available reactive power absorption/injection capability. \n\t\tIF UnitTypeCfg[InvCfg[i].UnitTypeID].NumModules > 1 THEN\n\t\t\t//Calculate available injection/absorption capacity depending on module status\n\t\t\tIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND PPCInputs_pu.InvFbk[i].Sts_Running AND PPCInputs_pu.InvFbk[i].Sts_Module1Running AND PPCInputs_pu.InvFbk[i].Sts_Module2Running THEN\n\t\t\t\t//Inverter is online, running, and both modules are running\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\tELSIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND PPCInputs_pu.InvFbk[i].Sts_Running AND (PPCInputs_pu.InvFbk[i].Sts_Module1Running OR PPCInputs_pu.InvFbk[i].Sts_Module2Running) THEN\n\t\t\t\t//Inverter is online, running, and at least one module is running (Logic assumes equal distribution of reactive power capability between modules)\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr / 2);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr / 2);\n\t\t\tEND_IF\n\t\tELSE\n\t\t\t//Inverter only has one module -> calculate injection/absorption capacity depending on inverter running status\n\t\t\tIF NOT PPCInputs_pu.InvFbk[i].Sts_Offline AND PPCInputs_pu.InvFbk[i].Sts_Running THEN\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\tEND_IF\n\t\tEND_IF\n\t\t\n\t\t//Determine min/max frequency and temperature values\n\t\tIF NOT InvFbk_pu[i].Sts_Offline THEN\n\t\t\t//Only perform comparison if the inverter is online\n\t\t\tIF InvFbk_pu[i].Sts_Freq > tmpMaxInvFreq THEN tmpMaxInvFreq := InvFbk_pu[i].Sts_Freq; END_IF\n\t\t\tIF InvFbk_pu[i].Sts_Freq < tmpMinInvFreq THEN tmpMinInvFreq := InvFbk_pu[i].Sts_Freq; END_IF\n\t\t\tIF InvFbk_pu[i].Sts_CabTemp > tmpMaxInvCabTemp THEN tmpMaxInvCabTemp := InvFbk_pu[i].Sts_CabTemp; END_IF\n\t\t\tIF InvFbk_pu[i].Sts_CabTemp < tmpMinInvCabTemp THEN tmpMinInvCabTemp := InvFbk_pu[i].Sts_CabTemp; END_IF\n\t\t\tIF InvFbk_pu[i].Sts_IntTemp > tmpMaxInvIntTemp THEN tmpMaxInvIntTemp := InvFbk_pu[i].Sts_IntTemp; END_IF\n\t\t\tIF InvFbk_pu[i].Sts_IntTemp < tmpMinInvIntTemp THEN tmpMinInvIntTemp := InvFbk_pu[i].Sts_IntTemp; END_IF\n\t\tEND_IF\n\t\t\n\t\t//Determine counts of inverters in P/Q Auto/Manual -> This is based on desired mode only, and not inverter online status/feedback\n\t\tIF InvSts[i].Sts_Pauto THEN\n\t\t\ttmpNumInvs_PAuto := tmpNumInvs_PAuto + 1;\n\t\tELSE\n\t\t\ttmpNumInvs_PManual := tmpNumInvs_PManual + 1;\n\t\tEND_IF\n\t\t\n\t\tIF InvSts[i].Sts_Qauto THEN\n\t\t\ttmpNumInvs_QAuto := tmpNumInvs_QAuto + 1;\n\t\tELSE\n\t\t\ttmpNumInvs_QManual := tmpNumInvs_QManual + 1;\n\t\tEND_IF\n\t\t\n\t\tInvDiag.NumInvs_PAuto := tmpNumInvs_PAuto;\n\t\tInvDiag.NumInvs_PManual := tmpNumInvs_PManual;\n\t\tInvDiag.NumInvs_QAuto := tmpNumInvs_QAuto;\n\t\tInvDiag.NumInvs_QManual := tmpNumInvs_QManual;\n\tEND_IF\nEND_FOR\n\n//Move inverter diagnostic counts/values to output structure\nInvDiag.TotalPVInv_Generating\t\t:= tmpTotalPVInv_Generating;        \t//Set Diagnostic total number of PV inverters generating\nInvDiag.TotalPVInv_NotGenerating\t:= tmpTotalPVInv_NotGenerating;     \t//Set Diagnostic total number of PV inverters not generating\nInvDiag.TotalPVInv_Unknown\t\t\t:= tmpTotalPVInv_Unknown;            \t//Set Diagnostic total number of PV inverters Unknown - Comm Loss\nInvDiag.TotalPVInv_Faulted\t\t\t:= tmpTotalPVInv_Faulted;           \t//Set Diagnostic total number of PV inverters faulted\nInvDiag.TotalPVInv_Ready\t\t\t:= tmpTotalPVInv_Ready;              \t//Set Diagnostic total number of PV inverters ready to generate\nInvDiag.Total_GrossMW\t\t\t\t:= tmpTotal_GrossMW;                \t//Set Diagnostic total Calculated PV inverter MW\nInvDiag.Total_GrossMVAR\t\t\t\t:= tmpTotal_GrossMVAR; \t\t\t\t\t//Set Diagnostic total calculated PV inverters MVar\nInvDiag.Total_AvailGenCap\t\t\t:= LIMIT(0, 100.0 * tmpTotal_AvailGenCap / PlantCfg.SBase, 100);\t\t\t\t//Set Diagnostic total available PV inverters generating capacity\nInvDiag.Total_QCapAbs\t\t\t\t:= tmpTotal_QCapAbs;\t\t\t\t\t//Set Diagnostic total available PV inverters reactive power absorption capacity\nInvDiag.Total_QCapInj\t\t\t\t:= tmpTotal_QCapInj;\t\t\t\t\t//Set Diagnostic total available PV inverters reactive power injection capacity\n\n//Move min/max values to output structure\nInvDiag.MinInvFreq\t\t\t\t\t:= tmpMinInvFreq;\t\nInvDiag.MaxInvFreq\t\t\t\t\t:= tmpMaxInvFreq;\t\nInvDiag.MinInvCabTemp\t\t\t\t:= tmpMinInvCabTemp;\t\nInvDiag.MaxInvCabTemp\t\t\t\t:= tmpMaxInvCabTemp;\t\nInvDiag.MinInvIntTemp\t\t\t\t:= tmpMinInvIntTemp;\t\nInvDiag.MaxInvIntTemp\t\t\t\t:= tmpMaxInvIntTemp;\t\t\t\t\t","LineInfoPersistence":"(string)652ca7a4-c592-4c16-8180-e0a19a6b33b4_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCalculate plant-level inverter diagnostics and output as plant inverter diagnostics structure\nMETHOD meth_CalcPlantLevelInvDiagnostics\nVAR_INPUT\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\t///Inverter configuration\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\n\t///Array of inverter feedback values\n\tInvFbk_pu: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\t///Inverter status\n\tInvSts: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\n\t///Plant config struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///Structure of plant-level inverter diagnostics\n\tInvDiag: TBE_PPC.dt_PlantInvDiagnostics;\nEND_VAR\nVAR\n\t///temporary Diagnostic total number of PV inverters generating\n\ttmpTotalPVInv_Generating: INT;\n\t///temporary Diagnostic total number of PV inverters not generating\n\ttmpTotalPVInv_NotGenerating: INT;\n\t///temporary Diagnostic total number OF PV inverters Unknown - Comm Loss\n\ttmpTotalPVInv_Unknown: INT;\n\t///temporary Diagnostic total number of PV inverters faulted\n\ttmpTotalPVInv_Faulted: INT;\n\t///temporary Diagnostic total number of PV inverters ready to generate\n\ttmpTotalPVInv_Ready: INT;\n\t///temporary Diagnostic total Calculated MV inverter MW\n\ttmpTotal_GrossMW: REAL;\n\t///temporary Diagnostic total calculated MVAR inverter MAVR\t\n\ttmpTotal_GrossMVAR: REAL;\n\t///temporary Diagnostic total available inverter generating capacity in MW\n\ttmpTotal_AvailGenCap: REAL;\n\t///temporary Diagnostic total reactive power absorption capacity\n\ttmpTotal_QCapAbs: REAL;\n\t///temporary Diagnostic total reactive power injection capacity\n\ttmpTotal_QCapInj: REAL;\n\t///temporary number of inverters in P Auto\n\ttmpNumInvs_PAuto: INT;\n\t///temporary number of inverters in P Manual\n\ttmpNumInvs_PManual: INT;\n\t///temporary number of inverters in Q Auto\n\ttmpNumInvs_QAuto: INT;\n\t///temporary number of inverters in Q Manual\n\ttmpNumInvs_QManual: INT;\n\t///Indexing Variable\n\ti: UINT;\n\t///[pu], active power threshold above which inverter is considered to be 'generating'\n\tInvGeneratingThreshold: REAL := 0.01;\n\t///Conversion factor from kW to MW\n\tkWToMW: REAL := 0.001;\n\t///Conversion factor from kVAr to MVAr\n\tkVArToMVAr: REAL := 0.001;\n\t///temporary value for minimum inverter frequency\n\ttmpMinInvFreq: REAL := 999;\n\t///temporary value for maximum inverter frequency\n\ttmpMaxInvFreq: REAL := -999;\n\t///temporary value for min inverter cabinet temp\n\ttmpMinInvCabTemp: REAL := 999;\n\t///temporary value for maximum inverter cabinet temp\n\ttmpMaxInvCabTemp: REAL := -999;\n\t///temporary value for minimum inverter internal temp\n\ttmpMinInvIntTemp: REAL := 999;\n\t///temporary value for maximum inverter internal temp\n\ttmpMaxInvIntTemp: REAL := -999;\nEND_VAR\n","LineInfoPersistence":"(string)652ca7a4-c592-4c16-8180-e0a19a6b33b4_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}