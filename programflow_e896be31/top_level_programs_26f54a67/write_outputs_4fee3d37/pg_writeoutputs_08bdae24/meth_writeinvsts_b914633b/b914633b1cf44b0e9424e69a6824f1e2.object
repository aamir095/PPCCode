{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b914633b-1cf4-4b0e-9424-e69a6824f1e2","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WriteInvSts","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through all inverters and write to the SCADA_GVL\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\t//Alarm Values\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Alm_Comm := InvFbk_scaled[i].Sts_Offline; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Alm_Control := 0; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Alm_Offline := InvFbk_scaled[i].Sts_Offline; \n\t\t\n\t\t//Command values\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Cmd_Psp := InvCmds_scaled[i].PCmd; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Cmd_Qsp := InvCmds_scaled[i].QCmd;\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Cmd_Start := REAL_TO_INT(InvCmds_scaled[i].Start);\n\t\t\n\t\t//Status/Fbk values from device\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Pauto := InvSts[i].STS_PAuto;\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Qauto := InvSts[i].STS_QAuto;\n\t\t\n\t\t//Internal Status/Diagnostic Values\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_IA := InvFbk_scaled[i].Sts_Ia;\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_IB := InvFbk_scaled[i].Sts_IB;\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_IC := InvFbk_scaled[i].Sts_IC;\n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_P := InvFbk_scaled[i].Sts_P; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_PF := InvFbk_scaled[i].Sts_PF; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Q := InvFbk_scaled[i].Sts_Q; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_S := 0; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_VAB := InvFbk_scaled[i].Sts_VAB; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_VBC := InvFbk_scaled[i].Sts_VBC; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_VCA := InvFbk_scaled[i].Sts_VCA; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Freq := InvFbk_scaled[i].Sts_Freq; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Running := InvFbk_scaled[i].Sts_Running; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Stopped := InvFbk_scaled[i].Sts_Stopped; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_Flt := InvFbk_scaled[i].Sts_Faulted; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_OpMode := InvFbk_scaled[i].Sts_OpMode; \n\t\tSCADA_GVL.InvDeviceDiagnostics[i].Sts_RunMode := InvFbk_scaled[i].Sts_RunMode; \n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)b914633b-1cf4-4b0e-9424-e69a6824f1e2_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_WriteInvSts\nVAR_INPUT\n\t///Inverter feedbacks, scaled for SCADA\n\tInvFbk_scaled: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\t///Inverter status values, scaled for SCADA\n\tInvSts: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_InvDevice;\n\t///Inverter Commands, scaled for SCADA\n\tInvCmds_scaled: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)b914633b-1cf4-4b0e-9424-e69a6824f1e2_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}