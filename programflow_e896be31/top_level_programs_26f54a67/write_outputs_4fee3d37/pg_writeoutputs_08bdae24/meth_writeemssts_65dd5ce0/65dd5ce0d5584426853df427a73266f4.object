{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)65dd5ce0-d558-4426-853d-f427a73266f4","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WriteEMSSts","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through all EMSerters and write to the SCADA_GVL\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 THEN\n\t\t//Alarm Values\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Alm_Comm := 0; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Alm_Control := 0; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Alm_Offline := EMSFbk_scaled[i].Sts_Offline; \n\t\t\n\t\t//Command values\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Cmd_Psp := EMSCmds_scaled[i].PCmd; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Cmd_Qsp := EMSCmds_scaled[i].QCmd;\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Cmd_Start := REAL_TO_INT(EMSCmds_scaled[i].Start);\n\t\t\n\t\t//Status/Fbk values from device\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Pauto := EMSSts[i].STS_PAuto;\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Qauto := EMSSts[i].STS_QAuto;\n\t\t\n\t\t//Internal Status/Diagnostic Values\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_P := EMSFbk_scaled[i].Sts_P; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Q := EMSFbk_scaled[i].Sts_Q; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_SOC := EMSFbk_scaled[i].Sts_SOC; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_IA := EMSFbk_scaled[i].Sts_Ia;\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_IB := EMSFbk_scaled[i].Sts_IB;\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_IC := EMSFbk_scaled[i].Sts_IC;\n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_PF := EMSFbk_scaled[i].Sts_PF; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_S := 0; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_VAB := EMSFbk_scaled[i].Sts_VAB; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_VBC := EMSFbk_scaled[i].Sts_VBC; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_VCA := EMSFbk_scaled[i].Sts_VCA; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Freq := EMSFbk_scaled[i].Sts_Freq; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_PChrgCap := EMSFbk_scaled[i].Sts_PChrgCap; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_PDischCap := EMSFbk_scaled[i].Sts_PDischCap; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_MinSOCFlag := EMSFbk_scaled[i].Sts_MinSOCFlag; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_MaxSOCFlag := EMSFbk_scaled[i].Sts_MaxSOCFlag; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Running := EMSFbk_scaled[i].Sts_Running; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Stopped := EMSFbk_scaled[i].Sts_Stopped; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_Flt := EMSFbk_scaled[i].Sts_Faulted; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_OpMode := EMSFbk_scaled[i].Sts_OpMode; \n\t\tSCADA_GVL.EMSDeviceDiagnostics[i].Sts_RunMode := EMSFbk_scaled[i].Sts_RunMode; \n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)65dd5ce0-d558-4426-853d-f427a73266f4_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_WriteEMSSts\nVAR_INPUT\n\t///EMS feedbacks, scaled for SCADA\n\tEMSFbk_scaled: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\t///EMS status values, scaled for SCADA\n\tEMSSts: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_InvDevice;\n\t///EMS Commands, scaled for SCADA\n\tEMSCmds_scaled: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCmds;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)65dd5ce0-d558-4426-853d-f427a73266f4_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}