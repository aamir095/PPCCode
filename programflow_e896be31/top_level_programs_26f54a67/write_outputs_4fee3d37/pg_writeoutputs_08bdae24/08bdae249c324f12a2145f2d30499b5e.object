lue":{"TextBlobForSerialisation":"(string)PROGRAM pg_WriteOutputs\nVAR\n\tTest_Trigger\t\t\t: BOOL;\n\tRemoteOutputsTrigger\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Trigger bit for remote outputs\n\tAutoStartCompletePrev\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Previous value of Auto Start Complete flag\nEND_VAR\nVAR_INPUT\n\tPPCOutputs_scaled\t\t: dt_PPCOutputs; \t\t\t\t\t\t\t\t\t\t\t//PPC Outputs, scaled for writing to external devices\n\tPPCInputs_scaled\t\t: dt_PPCInputs; \t\t\t\t\t\t\t\t\t\t\t//PPC Inputs structure, passed onto SCADA/HMI\n\tInvCmds_scaledForSCADA\t: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCmds;\t//Inverter Commands, scaled for SCADA/HMI\n\tEMSCmds_scaledForSCADA\t: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCmds;\t//EMS Commands, scaled for SCADA/HMI\n\tRedundancyDiagnostics\t: ARRAY[1..2] OF TBE_PPC.dt_RedundancyDiagnostics;\t\t\t//Array of redundancy diagnostics, index 1 = RTAC1, index 2 = RTAC2\n\tTestDiagnostics\t\t\t: TBE_PPC.dt_TestDiagnostics;\t\t\t\t\t\t\t\t//Test diagnostics structure\nEND_VAR","LineInfoPersistence":"(string)08bdae24-9c32-4f12-a214-5f2d30499b5e_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)341","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","233bc97c":"{233bc97c-69fe-4d29-b40e-a9a9b854044e}","24449d48":"{24449d48-c96a-49c4-b9d1-a4ea34aedce3}","32d3375e":"{32d3375e-c010-41e2-9e43-b2fbf4f2b374}","4b8bcc79":"{4b8bcc79-5980-4868-b49e-005a8148859b}","4f1e43e3":"{4f1e43e3-0667-4421-ad70-d7adf37c167a}","584effbc":"{584effbc-813e-443a-bf78-ad9c8d49db41}","5ae2e111":"{5ae2e111-ecff-4a21-b647-2d4da63f8db7}","65582d84":"{65582d84-cf18-4ca0-be59-bf5a3d00b8f8}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","72f2b13f":"{72f2b13f-5349-4a8a-bbe6-2bccf3f42179}","77f43dfe":"{77f43dfe-ca6a-4869-828f-7609d8ed6ea6}","88453c7d":"{88453c7d-d652-4a27