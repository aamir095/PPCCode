{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)36463112-0bf6-4001-9531-525ad07118e7","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WritePlantSts","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move plant Status to SCADA GVL\n\n//HV Meter Feedbacks\nSCADA_GVL.HVMeterFbk_scaled := HVMeterFbk_scaled;\n\n//MV Meter Feedbacks\nSCADA_GVL.MVMeterFbk_scaled := MVMeterFbk_scaled; \n\n//Meter Feedback (Meter values used for control)\nSCADA_GVL.MeterFbk_scaled := MeterFbk_scaled; \nSCADA_GVL.MeterFbk_PV := MeterFbk_PV_scaled;\nSCADA_GVL.MeterFbk_BESS := MeterFbk_BESS_scaled;\n\n//Plant inputs from remote source\nSCADA_GVL.PlantRemoteInputs1\t:= PlantRemoteInputs1; \nSCADA_GVL.PlantRemoteInputs2\t:= PlantRemoteInputs2; \nSCADA_GVL.PlantCurtailmentInputs := PlantCurtailmentInputs; \n\n//Met Station Feedback\nSCADA_GVL.MetStationFbk := MetStationFbk; \n\n//Testing Only - write test points to MB Server\nTestPointsMap.PSp.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_POI_PreRamp * 100);\nTestPointsMap.Qsp.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Qsp * 100);\nTestPointsMap.Vsp.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Vsp * 10);\nTestPointsMap.PFSp.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.PFSp * 100);\nTestPointsMap.PPID_SP.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_SP * 100);\nTestPointsMap.PPID_PV.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_PV * 100);\nTestPointsMap.PPID_CV.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_CV * 100);\nTestPointsMap.QPID_SP.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_SP * 100);\nTestPointsMap.QPID_PV.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_PV * 100);\nTestPointsMap.QPID_CV.status.stVal := REAL_TO_DINT(SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_CV * 100);\nTestPointsMap.FreqSp.status.stVal := REAL_TO_DINT(SCADA_GVL.MeterFbk_scaled.Sts_Freq * 100); \nTestPointsMap.TestActive.status.stVal := BOOL_TO_DINT(SCADA_GVL.TestDiagnostics.AutoTestDiagnostics.TestInProgress); \nTestPointsMap.TestID.status.instMag := SCADA_GVL.TestDiagnostics.AutoTestDiagnostics.TestID;\n\nTestPointsMap.PSp.status.q.validity := good;\nTestPointsMap.Qsp.status.q.validity := good;\nTestPointsMap.Vsp.status.q.validity := good;\nTestPointsMap.PFSp.status.q.validity := good;\nTestPointsMap.PPID_SP.status.q.validity := good;\nTestPointsMap.PPID_PV.status.q.validity := good;\nTestPointsMap.PPID_CV.status.q.validity := good;\nTestPointsMap.PPID_SP.status.q.validity := good;\nTestPointsMap.PPID_PV.status.q.validity := good;\nTestPointsMap.PPID_CV.status.q.validity := good;\nTestPointsMap.FreqSp.status.q.validity := good;\nTestPointsMap.TestActive.status.q.validity := good;\nTestPointsMap.TestID.status.q.validity := good; ","LineInfoPersistence":"(string)36463112-0bf6-4001-9531-525ad07118e7_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_WritePlantSts\nVAR_INPUT\n\t///HV Meter Feedback, scaled for SCADA/Ignition\n\tHVMeterFbk_scaled: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///MV Meter Feedback, scaled for SCADA/Ignition\n\tMVMeterFbk_scaled: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///POM Meter Feedback, scaled for SCADA/Ignition\n\tMeterFbk_scaled: TBE_PPC.dt_MeterFbk;\n\t///PV Meter Feedback, scaled for SCADA/Ignition\n\tMeterFbk_PV_scaled: TBE_PPC.dt_MeterFbk;\n\t///BESS Meter Feedback, scaled for SCADA/Ignition\n\tMeterFbk_BESS_scaled: TBE_PPC.dt_MeterFbk;\n\t///Plant remote inputs from remote source 1\n\tPlantRemoteInputs1: TBE_PPC.dt_PlantRemoteInputs;\n\t///Plant remote inputs from remote source 2\n\tPlantRemoteInputs2: TBE_PPC.dt_PlantRemoteInputs;\n\t///Plant remote inputs\n\tPlantCurtailmentInputs: TBE_PPC.dt_PlantRemoteInputs;\n\t///Met Station Feedback Array\n\tMetStationFbk: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)36463112-0bf6-4001-9531-525ad07118e7_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}