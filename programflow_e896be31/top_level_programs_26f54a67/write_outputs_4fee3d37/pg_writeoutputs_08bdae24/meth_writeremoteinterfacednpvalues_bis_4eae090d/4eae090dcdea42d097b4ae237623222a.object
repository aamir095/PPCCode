nterfaceMap_DNP.Inv088Online.stVal := NOT PPCInputs_scaled.InvFbk[88].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv089Online.stVal := NOT PPCInputs_scaled.InvFbk[89].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv090Online.stVal := NOT PPCInputs_scaled.InvFbk[90].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv091Online.stVal := NOT PPCInputs_scaled.InvFbk[91].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv092Online.stVal := NOT PPCInputs_scaled.InvFbk[92].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv093Online.stVal := NOT PPCInputs_scaled.InvFbk[93].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv094Online.stVal := NOT PPCInputs_scaled.InvFbk[94].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv095Online.stVal := NOT PPCInputs_scaled.InvFbk[95].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv096Online.stVal := NOT PPCInputs_scaled.InvFbk[96].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv097Online.stVal := NOT PPCInputs_scaled.InvFbk[97].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv098Online.stVal := NOT PPCInputs_scaled.InvFbk[98].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv099Online.stVal := NOT PPCInputs_scaled.InvFbk[99].Sts_Offline;\n*)","LineInfoPersistence":"(string)4eae090d-cdea-42d0-97b4-ae237623222a_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_WriteRemoteInterfaceDNPValues_BIs\nVAR_INPUT\n\t///PPC Outputs, scaled for writing to external devices\n\tPPCOutputs_scaled: dt_PPCOutputs;\n\t///PPC Inputs structure, passed onto SCADA/HMI\n\tPPCInputs_scaled: dt_PPCInputs;\n\t///Plant configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Plant Configuration structure (in engineering units)\n\tPlantCfgEng: TBE_PPC.dt_PlantCfg;\n\t///PPC Inputs, scaled for writing to external devices\n\tMetStationFbk: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)4eae090d-cdea-42d0-97b4-ae237623222a_Decl_LineIds"}}}}}},"TypeI