{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)4eae090d-cdea-42d0-97b4-ae237623222a","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WriteRemoteInterfaceDNPValues_BIs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//General Plant Status Values\nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i = 1 THEN\n\t\tRemoteInterfaceMap_DNP.HVPM1CommsOk.stVal := NOT PPCInputs_scaled.HVMeterFbk[i].Sts_flt;\n\tELSIF i = 2 AND SiteConstants.NumHVMeters >= 2 THEN\n\t\tRemoteInterfaceMap_DNP.HVPM2CommsOk.stVal := NOT PPCInputs_scaled.HVMeterFbk[i].Sts_flt;\n\tEND_IF\nEND_FOR\nRemoteInterfaceMap_DNP.MeterFailoverActive.stVal := PPCInputs_scaled.MeterFbk.Sts_MeterMode <> 1;\nRemoteInterfaceMap_DNP.PlantRunningSts.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.Running;\n\n//Active Power Control Status\nRemoteInterfaceMap_DNP.PFREnabled.stVal := PPCOutputs_scaled.Diagnostics.PCtrl_Aux_Outputs.FreqDroopEn_PV;\nRemoteInterfaceMap_DNP.PCurtailFbk.stVal := PPCInputs_scaled.PlantCurtailmentInputs.CurtailmentFlag_POI;\nRemoteInterfaceMap_DNP.POpStnActive.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.PCmdMode_POI = 0;\nRemoteInterfaceMap_DNP.PRem1Active.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.PCmdMode_POI = 1;\nRemoteInterfaceMap_DNP.PRem2Active.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.PCmdMode_POI = 2;\nRemoteInterfaceMap_DNP.PRemCurtailActive.stVal := PPCInputs_scaled.PlantCurtailmentInputs.CurtailmentFlag_POI;\nRemoteInterfaceMap_DNP.GovernorBlocking.stVal := PPCOutputs_scaled.Diagnostics.PCtrl_Aux_Outputs.Psp_PV < PlantCfgEng.HOL;\n\n//Reactive Power Control Status\nRemoteInterfaceMap_DNP.AVRActive.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.QClosedLoopCtrl;\nRemoteInterfaceMap_DNP.VCtrlActive.stVal := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_V;\nRemoteInterfaceMap_DNP.PFCtrlActive.stVal := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_PF;\nRemoteInterfaceMap_DNP.QCtrlActive.stVal := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.OpMode = PlantCfg.AVR_Q;\nRemoteInterfaceMap_DNP.QOpStnActive.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.QCmdMode = 0;\nRemoteInterfaceMap_DNP.QRem1Active.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.QCmdMode = 1;\nRemoteInterfaceMap_DNP.QRem2Active.stVal := PPCOutputs_scaled.Diagnostics.OpModeSts.QCmdMode = 2;\n\n//Remote Source 1 Readback Values\nRemoteInterfaceMap_DNP.Rem1VCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs1.QOpMode = PlantCfg.AVR_V;\nRemoteInterfaceMap_DNP.Rem1PFCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs1.QOpMode = PlantCfg.AVR_PF;\nRemoteInterfaceMap_DNP.Rem1QCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs1.QOpMode = PlantCfg.AVR_Q;\nRemoteInterfaceMap_DNP.Rem1PClosedLoopCtrlEnFbk.stVal := RemoteInterfaceMap_DNP.Rem1PClosedLoopCtrlEn.status.stVal;\nRemoteInterfaceMap_DNP.Rem1QClosedLookCtrlEnFbk.stVal := RemoteInterfaceMap_DNP.Rem1QClosedLoopCtrlEn.status.stVal;\n\n//Remote Source 2 Readback Values\nRemoteInterfaceMap_DNP.Rem2VCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs2.QOpMode = PlantCfg.AVR_V;\nRemoteInterfaceMap_DNP.Rem2PFCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs2.QOpMode = PlantCfg.AVR_PF;\nRemoteInterfaceMap_DNP.Rem2QCtrlEnFbk.stVal := PPCInputs_scaled.PlantRemoteInputs2.QOpMode = PlantCfg.AVR_Q;\nRemoteInterfaceMap_DNP.Rem2PClosedLoopCtrlEnFbk.stVal := RemoteInterfaceMap_DNP.Rem2PClosedLoopCtrlEn.status.stVal;\nRemoteInterfaceMap_DNP.Rem2QClosedLookCtrlEnFbk.stVal := RemoteInterfaceMap_DNP.Rem2QClosedLoopCtrlEn.status.stVal;\n\n//Remote Curtailment Source Readback Values\nRemoteInterfaceMap_DNP.CurtailmentFlagFbk.stVal := PPCInputs_scaled.PlantCurtailmentInputs.CurtailmentFlag_POI;\nRemoteInterfaceMap_DNP.PVCurtailmentFlagFbk.stVal := PPCInputs_scaled.PlantCurtailmentInputs.CurtailmentFlag_PV;\nRemoteInterfaceMap_DNP.BESSCurtailmentFlagFbk.stVal := PPCInputs_scaled.PlantCurtailmentInputs.CurtailmentFlag_BESS;\n\n//Met station status values - comment as needed based on number of met stations\nRemoteInterfaceMap_DNP.Met001Online.stVal := NOT PPCInputs_scaled.MetStationFbk[1].Offline;\n(*\nRemoteInterfaceMap_DNP.Met002Online.stVal := NOT PPCInputs_scaled.MetStationFbk[2].Offline;\nRemoteInterfaceMap_DNP.Met003Online.stVal := NOT PPCInputs_scaled.MetStationFbk[3].Offline;\nRemoteInterfaceMap_DNP.Met004Online.stVal := NOT PPCInputs_scaled.MetStationFbk[4].Offline;\nRemoteInterfaceMap_DNP.Met005Online.stVal := NOT PPCInputs_scaled.MetStationFbk[5].Offline;\nRemoteInterfaceMap_DNP.Met006Online.stVal := NOT PPCInputs_scaled.MetStationFbk[6].Offline;\nRemoteInterfaceMap_DNP.Met007Online.stVal := NOT PPCInputs_scaled.MetStationFbk[7].Offline;\nRemoteInterfaceMap_DNP.Met008Online.stVal := NOT PPCInputs_scaled.MetStationFbk[8].Offline;\nRemoteInterfaceMap_DNP.Met009Online.stVal := NOT PPCInputs_scaled.MetStationFbk[9].Offline;\nRemoteInterfaceMap_DNP.Met010Online.stVal := NOT PPCInputs_scaled.MetStationFbk[10].Offline;\n*)\n\n\n//Inverter status values - comment as needed based on number of inverters\nRemoteInterfaceMap_DNP.Inv001Online.stVal := NOT PPCInputs_scaled.InvFbk[1].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv002Online.stVal := NOT PPCInputs_scaled.InvFbk[2].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv003Online.stVal := NOT PPCInputs_scaled.InvFbk[3].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv004Online.stVal := NOT PPCInputs_scaled.InvFbk[4].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv005Online.stVal := NOT PPCInputs_scaled.InvFbk[5].Sts_Offline;\n(*\nRemoteInterfaceMap_DNP.Inv006Online.stVal := NOT PPCInputs_scaled.InvFbk[6].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv007Online.stVal := NOT PPCInputs_scaled.InvFbk[7].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv008Online.stVal := NOT PPCInputs_scaled.InvFbk[8].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv009Online.stVal := NOT PPCInputs_scaled.InvFbk[9].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv010Online.stVal := NOT PPCInputs_scaled.InvFbk[10].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv011Online.stVal := NOT PPCInputs_scaled.InvFbk[11].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv012Online.stVal := NOT PPCInputs_scaled.InvFbk[12].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv013Online.stVal := NOT PPCInputs_scaled.InvFbk[13].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv014Online.stVal := NOT PPCInputs_scaled.InvFbk[14].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv015Online.stVal := NOT PPCInputs_scaled.InvFbk[15].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv016Online.stVal := NOT PPCInputs_scaled.InvFbk[16].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv017Online.stVal := NOT PPCInputs_scaled.InvFbk[17].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv018Online.stVal := NOT PPCInputs_scaled.InvFbk[18].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv019Online.stVal := NOT PPCInputs_scaled.InvFbk[19].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv020Online.stVal := NOT PPCInputs_scaled.InvFbk[20].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv021Online.stVal := NOT PPCInputs_scaled.InvFbk[21].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv022Online.stVal := NOT PPCInputs_scaled.InvFbk[22].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv023Online.stVal := NOT PPCInputs_scaled.InvFbk[23].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv024Online.stVal := NOT PPCInputs_scaled.InvFbk[24].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv025Online.stVal := NOT PPCInputs_scaled.InvFbk[25].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv026Online.stVal := NOT PPCInputs_scaled.InvFbk[26].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv027Online.stVal := NOT PPCInputs_scaled.InvFbk[27].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv028Online.stVal := NOT PPCInputs_scaled.InvFbk[28].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv029Online.stVal := NOT PPCInputs_scaled.InvFbk[29].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv030Online.stVal := NOT PPCInputs_scaled.InvFbk[30].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv031Online.stVal := NOT PPCInputs_scaled.InvFbk[31].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv032Online.stVal := NOT PPCInputs_scaled.InvFbk[32].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv033Online.stVal := NOT PPCInputs_scaled.InvFbk[33].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv034Online.stVal := NOT PPCInputs_scaled.InvFbk[34].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv035Online.stVal := NOT PPCInputs_scaled.InvFbk[35].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv036Online.stVal := NOT PPCInputs_scaled.InvFbk[36].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv037Online.stVal := NOT PPCInputs_scaled.InvFbk[37].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv038Online.stVal := NOT PPCInputs_scaled.InvFbk[38].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv039Online.stVal := NOT PPCInputs_scaled.InvFbk[39].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv040Online.stVal := NOT PPCInputs_scaled.InvFbk[40].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv041Online.stVal := NOT PPCInputs_scaled.InvFbk[41].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv042Online.stVal := NOT PPCInputs_scaled.InvFbk[42].Sts_Offline;\nRemoteInterfaceMap_DNP.Inv043Online.stVal := NOT PPCInputs_scaled.InvFbk[43].Sts_Offline;\nRemoteInter