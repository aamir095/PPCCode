{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a47cb3cc-3a51-405e-a75e-2f46b631cf0b","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_SPTracking","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Reactive power setpoint tracking\n//PF setpoint tracking\nIF OpModeSts.QClosedLoopCtrl AND QCtrlAuxOutputs.OpMode<>PlantCfg.AVR_PF AND .RtacOnline OR OpModeSts.State=0 THEN\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.PFSp := QCtrlAuxOutputs.PFTrackSp;           \nEND_IF\n//Q setpoint tracking\nIF OpModeSts.QClosedLoopCtrl AND QCtrlAuxOutputs.OpMode<>PlantCfg.AVR_Q AND .RtacOnline OR OpModeSts.State=0 THEN\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.QSp :=QCtrlAuxOutputs.QTrackSp;            \nEND_IF\n//V setpoint tracking\nIF .RtacOnline AND NOT PlantCfg.VoltageCfg.RefFlag AND QCtrlAuxOutputs.OpMode<>PlantCfg.AVR_V THEN\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := QCtrlAuxOutputs.VTrackSp;\nEND_IF\n\n//Active power remote mode setoint tracking\nIF PlantCfg.PlantType = TBE_PPC.enum_PlantType.PVS_Colocated THEN\n\tIF OpModeSts.PCmdMode_PV = TBE_PPC.enum_CmdMode.Remote1 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_PV := PlantRemoteInputs1.PSp_PV;\n\tELSIF OpModeSts.PCmdMode_PV = TBE_PPC.enum_CmdMode.Remote2 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_PV := PlantRemoteInputs2.PSp_PV;\n\tEND_IF\n\tIF OpModeSts.PCmdMode_BESS = TBE_PPC.enum_CmdMode.Remote1 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_BESS := PlantRemoteInputs1.PSp_BESS;\n\tELSIF OpModeSts.PCmdMode_BESS = TBE_PPC.enum_CmdMode.Remote2 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_BESS := PlantRemoteInputs2.PSp_BESS;\n\tEND_IF\nELSE\n\tIF OpModeSts.PCmdMode_POI = TBE_PPC.enum_CmdMode.Remote1 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_POI := PlantRemoteInputs1.PSp_POI;\n\tELSIF OpModeSts.PCmdMode_POI = TBE_PPC.enum_CmdMode.Remote2 THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_POI := PlantRemoteInputs2.PSp_POI;\n\tEND_IF\nEND_IF\n\n//Reactive power remote mode setpoint tracking\nIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.Remote1 THEN\n\tIF  QCtrlAuxOutputs.OpMode = PlantCfg.AVR_PF THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.PFSp := PlantRemoteInputs1.PFSp;\n\tELSIF QCtrlAuxOutputs.OpMode = PlantCfg.AVR_Q THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.QSp := PlantRemoteInputs1.QSp;\n\tELSIF QCtrlAuxOutputs.OpMode = PlantCfg.AVR_V THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := PlantRemoteInputs1.VSp;\n\tEND_IF\nELSIF OpModeSts.QCmdMode = TBE_PPC.enum_CmdMode.Remote2 THEN\n\tIF  QCtrlAuxOutputs.OpMode = PlantCfg.AVR_PF THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.PFSp := PlantRemoteInputs2.PFSp;\n\tELSIF QCtrlAuxOutputs.OpMode = PlantCfg.AVR_Q THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.QSp := PlantRemoteInputs2.QSp;\n\tELSIF QCtrlAuxOutputs.OpMode = PlantCfg.AVR_V THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := PlantRemoteInputs2.VSp;\n\tEND_IF\nEND_IF","LineInfoPersistence":"(string)a47cb3cc-3a51-405e-a75e-2f46b631cf0b_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tReactive power tracking method\n///|\tUpdate SCADA GVL with tracked reactive power setpoints depending on which reactive power mode is active\nMETHOD meth_SPTracking\nVAR_INPUT\n\t///Operating Mode Status of Plant \n\tOpModeSts: TBE_PPC.dt_UnitOpModeSts;\n\t///Outputs from AVR Control Auxiliary Block\n\tQCtrlAuxOutputs: TBE_PPC.dt_AVRCtlAuxOutputs;\n\t///Outputs from P Control Auxiliary Block\n\tPCtrlAuxOutputs: TBE_PPC.dt_PCtlAuxOutputs;\n\t///Plant configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Plant inputs from remote source 1\n\tPlantRemoteInputs1: TBE_PPC.dt_PlantRemoteInputs;\n\t///Plant inputs from remote source 2\n\tPlantRemoteInputs2: TBE_PPC.dt_PlantRemoteInputs;\nEND_VAR\n","LineInfoPersistence":"(string)a47cb3cc-3a51-405e-a75e-2f46b631cf0b_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}