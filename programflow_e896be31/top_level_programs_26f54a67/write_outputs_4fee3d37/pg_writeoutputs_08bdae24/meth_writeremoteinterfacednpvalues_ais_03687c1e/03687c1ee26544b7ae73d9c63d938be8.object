{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)03687c1e-e265-44b7-ae73-d9c63d938be8","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WriteRemoteInterfaceDNPValues_AIs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Write general plant status values\nIF RemoteInterfaceMap_DNP.PPCHeartbeat.instMag > HeartbeatMaxVal THEN\n\tRemoteInterfaceMap_DNP.PPCHeartbeat.instMag := 0;\nELSE\n\tRemoteInterfaceMap_DNP.PPCHeartbeat.instMag := RemoteInterfaceMap_DNP.PPCHeartbeat.instMag + 1;\nEND_IF\n\nRemoteInterfaceMap_DNP.HSL.instMag := PPCOutputs_scaled.Diagnostics.HSL;\nRemoteInterfaceMap_DNP.AvailGenCapacity.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.Total_AvailGenCap;\nRemoteInterfaceMap_DNP.ActivePwrPotentialOutput.instMag := PPCOutputs_scaled.Diagnostics.ActivePwrPotentialOutput; \n\n//Active Power Control Status\nRemoteInterfaceMap_DNP.PSpSts.instMag := PPCOutputs_scaled.Diagnostics.PCtrl_Aux_Outputs.Psp_PV;\nRemoteInterfaceMap_DNP.PSts.instMag := PPCInputs_scaled.MeterFbk.Sts_P;\nRemoteInterfaceMap_DNP.PRampRateUp.instMag := PlantCfgEng.ActivePwrCfg.PUpLim_POI;\nRemoteInterfaceMap_DNP.PRampRateDn.instMag := PlantCfgEng.ActivePwrCfg.PDnLim_POI;\nRemoteInterfaceMap_DNP.PFRDroopPct.instMag := 100.0 / PlantCfgEng.FreqCfg.DDn;\t\t//Converted from pu power/pu freq to Frequency Droop Percentage\nRemoteInterfaceMap_DNP.PFRDbd1.instMag := PlantCfgEng.FreqCfg.FDbd1;\nRemoteInterfaceMap_DNP.PFRDbd2.instMag := PlantCfgEng.FreqCfg.FDbd2;\n\n//Reactive Power Control Status\nRemoteInterfaceMap_DNP.QmdSts.instMag := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.OpMode;\nRemoteInterfaceMap_DNP.VSpSts.instMag := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.Vsp;\nRemoteInterfaceMap_DNP.PFSpSts.instMag := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.PFsp;\nRemoteInterfaceMap_DNP.QSpSts.instMag := PPCOutputs_scaled.Diagnostics.QCtrl_Aux_Outputs.Qsp;\nRemoteInterfaceMap_DNP.VLLAvgSts.instMag := PPCInputs_scaled.MeterFbk.Sts_VLLAvg;\nRemoteInterfaceMap_DNP.VABSts.instMag := PPCInputs_scaled.MeterFbk.Sts_VAB;\nRemoteInterfaceMap_DNP.VBCSts.instMag := PPCInputs_scaled.MeterFbk.Sts_VBC;\nRemoteInterfaceMap_DNP.VCASts.instMag := PPCInputs_scaled.MeterFbk.Sts_VCA;\nRemoteInterfaceMap_DNP.PFSts.instMag := PPCInputs_scaled.MeterFbk.Sts_PF;\nRemoteInterfaceMap_DNP.QSts.instMag := PPCInputs_scaled.MeterFbk.Sts_Q;\nRemoteInterfaceMap_DNP.QRampRateQmdUp.instMag := PlantCfgEng.ReactivePwrCfg.QRefUpLim;\nRemoteInterfaceMap_DNP.QRampRateQmdDn.instMag := PlantCfgEng.ReactivePwrCfg.QRefDnLim;\nRemoteInterfaceMap_DNP.QRampRateVmdUp.instMag := PlantCfgEng.VoltageCfg.Vrefuplim;\nRemoteInterfaceMap_DNP.QRampRateVmdDn.instMag := PlantCfgEng.VoltageCfg.Vrefdnlim;\n\n//Remote Source 1 Readback Values\nRemoteInterfaceMap_DNP.Rem1PspFbk.instMag := PPCInputs_scaled.PlantRemoteInputs1.PSp_PV;\nRemoteInterfaceMap_DNP.Rem1VspFbk.instMag := PPCInputs_scaled.PlantRemoteInputs1.VSp;\nRemoteInterfaceMap_DNP.Rem1PFSpFbk.instMag := PPCInputs_scaled.PlantRemoteInputs1.PFSp;\nRemoteInterfaceMap_DNP.Rem1QSpFbk.instMag := PPCInputs_scaled.PlantRemoteInputs1.QSp;\nRemoteInterfaceMap_DNP.Rem1QmdFbk.instMag := PPCInputs_scaled.PlantRemoteInputs1.QOpMode;\nRemoteInterfaceMap_DNP.Rem1HeartbeatFbk.instMag := RemoteInterfaceMap_DNP.Rem1Heartbeat.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PspPVFbk.instMag := RemoteInterfaceMap_DNP.Rem1PSpPV.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PSpBESSFbk.instMag := RemoteInterfaceMap_DNP.Rem1PSpBESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampUpRate_POIFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampUpRate_POI.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampDnRate_POIFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampDnRate_POI.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampUpRate_PVFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampUpRate_PV.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampDnRate_PVFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampDnRate_PV.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampUpRate_BESSFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampUpRate_BESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem1PRampDnRate_BESSFbk.instMag := RemoteInterfaceMap_DNP.Rem1PRampDnRate_BESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem1QRampUpRateFbk.instMag := RemoteInterfaceMap_DNP.Rem1QRampUpRate.status.instMag;\nRemoteInterfaceMap_DNP.Rem1QRampDnRateFbk.instMag := RemoteInterfaceMap_DNP.Rem1QRampDnRate.status.instMag;\nRemoteInterfaceMap_DNP.Rem1QRampUpRate_VmodeFbk.instMag := RemoteInterfaceMap_DNP.Rem1QRampUpRate_Vmode.status.instMag;\nRemoteInterfaceMap_DNP.Rem1QRampDnRate_VmodeFbk.instMag := RemoteInterfaceMap_DNP.Rem1QRampDnRate_Vmode.status.instMag;\n\n\n//Remote Source 2 Readback Values\nRemoteInterfaceMap_DNP.Rem2PspFbk.instMag := PPCInputs_scaled.PlantRemoteInputs2.PSp_PV;\nRemoteInterfaceMap_DNP.Rem2VspFbk.instMag := PPCInputs_scaled.PlantRemoteInputs2.VSp;\nRemoteInterfaceMap_DNP.Rem2PFSpFbk.instMag := PPCInputs_scaled.PlantRemoteInputs2.PFSp;\nRemoteInterfaceMap_DNP.Rem2QSpFbk.instMag := PPCInputs_scaled.PlantRemoteInputs2.QSp;\nRemoteInterfaceMap_DNP.Rem2QmdFbk.instMag := PPCInputs_scaled.PlantRemoteInputs2.QOpMode;\nRemoteInterfaceMap_DNP.Rem2HeartbeatFbk.instMag := RemoteInterfaceMap_DNP.Rem2Heartbeat.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PspPVFbk.instMag := RemoteInterfaceMap_DNP.Rem2PSpPV.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PSpBESSFbk.instMag := RemoteInterfaceMap_DNP.Rem2PSpBESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampUpRate_POIFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampUpRate_POI.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampDnRate_POIFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampDnRate_POI.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampUpRate_PVFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampUpRate_PV.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampDnRate_PVFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampDnRate_PV.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampUpRate_BESSFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampUpRate_BESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem2PRampDnRate_BESSFbk.instMag := RemoteInterfaceMap_DNP.Rem2PRampDnRate_BESS.status.instMag;\nRemoteInterfaceMap_DNP.Rem2QRampUpRateFbk.instMag := RemoteInterfaceMap_DNP.Rem2QRampUpRate.status.instMag;\nRemoteInterfaceMap_DNP.Rem2QRampDnRateFbk.instMag := RemoteInterfaceMap_DNP.Rem2QRampDnRate.status.instMag;\nRemoteInterfaceMap_DNP.Rem2QRampUpRate_VmodeFbk.instMag := RemoteInterfaceMap_DNP.Rem2QRampUpRate_Vmode.status.instMag;\nRemoteInterfaceMap_DNP.Rem2QRampDnRate_VmodeFbk.instMag := RemoteInterfaceMap_DNP.Rem2QRampDnRate_Vmode.status.instMag;\n\n//Remote Curtailment Source Readback Values\nRemoteInterfaceMap_DNP.RemCurtailPLimFbk.instMag := PPCInputs_scaled.PlantCurtailmentInputs.PSp_PV;\nRemoteInterfaceMap_DNP.RemCurtailHeartbeatFbk.instMag := RemoteInterfaceMap_DNP.RemCurtailHeartbeat.status.instMag;\nRemoteInterfaceMap_DNP.RemCurtailPVLimFbk.instMag := RemoteInterfaceMap_DNP.RemCurtailPVLim.status.instMag;\nRemoteInterfaceMap_DNP.RemCurtailBESSLimFbk.instMag := RemoteInterfaceMap_DNP.RemCurtailBESSLim.status.instMag;\n\n//Inverter Status Values\nRemoteInterfaceMap_DNP.TotalGrossMW.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.Total_GrossMW;\nRemoteInterfaceMap_DNP.TotalGrossMVAR.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.Total_GrossMVAR;\nRemoteInterfaceMap_DNP.NumInvsGenerating.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.TotalPVInv_Generating;\nRemoteInterfaceMap_DNP.NumInvsNotGenerating.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.TotalPVInv_NotGenerating;\nRemoteInterfaceMap_DNP.NumInvsUnknown.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.TotalPVInv_Unknown;\nRemoteInterfaceMap_DNP.NumInvsFaulted.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.TotalPVInv_Faulted;\nRemoteInterfaceMap_DNP.NumInvsReady.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.TotalPVInv_Ready;\nRemoteInterfaceMap_DNP.MaxInvFreq.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MaxInvFreq;\nRemoteInterfaceMap_DNP.MinInvFreq.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MinInvFreq;\nRemoteInterfaceMap_DNP.MaxInvIntTemp.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MaxInvIntTemp;\nRemoteInterfaceMap_DNP.MinInvIntTemp.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MinInvIntTemp;\nRemoteInterfaceMap_DNP.MaxInvCabTemp.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MaxInvCabTemp;\nRemoteInterfaceMap_DNP.MinInvCabTemp.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.MinInvCabTemp;\nRemoteInterfaceMap_DNP.TotalQAbsCapacity.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.Total_QCapAbs;\nRemoteInterfaceMap_DNP.TotalQInjCapacity.instMag := PPCOutputs_scaled.Diagnostics.PlantInvDiagnostics.Total_QCapInj;\n\n//Met station average values\nRemoteInterfaceMap_DNP.MetAvg_POAIrr_TC.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.POA_Irr_TC;\nRemoteInterfaceMap_DNP.MetAvg_POAIrr.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.POA_Irr;\nRemoteInterfaceMap_DNP.MetAvg_GHI.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.GHI;\nRemoteInterfaceMap_DNP.MetAvg_DirectIrr.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.DirectIrr;\nRemoteInterfaceMap_DNP.MetAvg_BackPanelTemp.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.BOMTempAvg;\nRemoteInterfaceMap_DNP.MetAvg_WindSpd.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.WindSpd;\nRemoteInterfaceMap_DNP.MetAvg_WindDir.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.WindDir;\nRemoteInterfaceMap_DNP.MetAvg_AmbTemp.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.AmbTemp;\nRemoteInterfaceMap_DNP.MetAvg_RH.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.RH;\nRemoteInterfaceMap_DNP.MetAvg_Pressure.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.Pressure;\nRemoteInterfaceMap_DNP.MetAvg_Precip.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.Precip;\nRemoteInterfaceMap_DNP.MetAvg_SolarPosElevation.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.SolarPosElevation;\nRemoteInterfaceMap_DNP.MetAvg_SolaPosAzimuth.instMag := PPCOutputs_scaled.Diagnostics.MetAvgFbk.SolarPosAzimuth;\n\n\n//Met Station Values - comment out as necessary based on number of met stations\n\nRemoteInterfaceMap_DNP.Met001_POAIrr_TC.instMag := PPCInputs_scaled.MetStationFbk[1].POA_Irr_TC;\nRemoteInterfaceMap_DNP.Met001_POAIrr.instMag := PPCInputs_scaled.MetStationFbk[1].POA_Irr;\nRemoteInterfaceMap_DNP.Met001_GHI.instMag := PPCInputs_scaled.MetStationFbk[1].GHI;\nRemoteInterfaceMap_DNP.Met001_DirectIrr.instMag := PPCInputs_scaled.MetStationFbk[1].DirectIrr;\nRemoteInterfaceMap_DNP.Met001_BackPanelTemp.instMag := PPCInputs_scaled.MetStationFbk[1].BOMTempAvg;\nRemoteInterfaceMap_DNP.Met001_WindSpd.instMag := PPCInputs_scaled.MetStationFbk[1].WindSpd;\nRemoteInterfaceMap_DNP.Met001_WindDir.instMag := PPCInputs_scaled.MetStationFbk[1].WindDir;\nRemoteInterfaceMap_DNP