\tInv004_MODBUS_POU.Disable_Controls := FALSE;\n\tInv005_MODBUS_POU.Disable_Controls := FALSE;\n\tInv006_MODBUS_POU.Disable_Controls := FALSE;\n\tInv007_MODBUS_POU.Disable_Controls := FALSE;\n\tInv008_MODBUS_POU.Disable_Controls := FALSE;\n\tInv009_MODBUS_POU.Disable_Controls := FALSE;\n\tInv010_MODBUS_POU.Disable_Controls := FALSE;\n\tInv011_MODBUS_POU.Disable_Controls := FALSE;\n\tInv012_MODBUS_POU.Disable_Controls := FALSE;\n\tInv013_MODBUS_POU.Disable_Controls := FALSE;\n\tInv014_MODBUS_POU.Disable_Controls := FALSE;\n\tInv015_MODBUS_POU.Disable_Controls := FALSE;\n\tInv016_MODBUS_POU.Disable_Controls := FALSE;\n\tInv017_MODBUS_POU.Disable_Controls := FALSE;\n\tInv018_MODBUS_POU.Disable_Controls := FALSE;\n\tInv019_MODBUS_POU.Disable_Controls := FALSE;\n\tInv020_MODBUS_POU.Disable_Controls := FALSE;\n\tInv021_MODBUS_POU.Disable_Controls := FALSE;\n\tInv022_MODBUS_POU.Disable_Controls := FALSE;\n\tInv023_MODBUS_POU.Disable_Controls := FALSE;\n\tInv024_MODBUS_POU.Disable_Controls := FALSE;\n\tInv025_MODBUS_POU.Disable_Controls := FALSE;\n\tInv026_MODBUS_POU.Disable_Controls := FALSE;\n\tInv027_MODBUS_POU.Disable_Controls := FALSE;\n\tInv028_MODBUS_POU.Disable_Controls := FALSE;\n\tInv029_MODBUS_POU.Disable_Controls := FALSE;\n\tInv030_MODBUS_POU.Disable_Controls := FALSE;\n\tInv031_MODBUS_POU.Disable_Controls := FALSE;\n\tInv032_MODBUS_POU.Disable_Controls := FALSE;\n\tInv033_MODBUS_POU.Disable_Controls := FALSE;\n\tInv034_MODBUS_POU.Disable_Controls := FALSE;\n\tInv035_MODBUS_POU.Disable_Controls := FALSE;\n\tInv036_MODBUS_POU.Disable_Controls := FALSE;\n\tInv037_MODBUS_POU.Disable_Controls := FALSE;\n\tInv038_MODBUS_POU.Disable_Controls := FALSE;\n\tInv039_MODBUS_POU.Disable_Controls := FALSE;\n\tInv040_MODBUS_POU.Disable_Controls := FALSE;\n\tInv041_MODBUS_POU.Disable_Controls := FALSE;\n\tInv042_MODBUS_POU.Disable_Controls := FALSE;\n\tInv043_MODBUS_POU.Disable_Controls := FALSE;\n\tInv044_MODBUS_POU.Disable_Controls := FALSE;\n\tInv045_MODBUS_POU.Disable_Cont