{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b10e6186-f692-49bd-bc3a-8a0a50187fb6","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_EnableDisableComms","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Enable/Disable communication POUs depending on the redundancy configuration and redundancy status\n//If redundancy is not enabled, no logic is needed here -> The communication POUs between PPC/Inverters should always be enabled\n//If redundancy is enabled and the controller is passive, the control input to the inverter communication POUs should be disabled (passive controller will read inverter information only)\n//If redundancy is enabled and the controller is active, the control input to the inverter communication POUs should be enabled (active controller will write commands to the inverters)\nIF RedundancyCfg.En AND (NOT RedundancySts.Sts_CtrlActive) THEN\n\t//Redundancy is enabled and local controller is not active -> Disable control for inverters and other devices\n\t//PPC OPC UA Server -> This will be disabled on the Passive RTAC so that only the Active RTAC will communicate with Ignition\n\tTBE_SCADA_OPCUA_POU.EN := FALSE; \n\t\n\t//Substation Controls\n\tSubstationCtrl_DNP_POU.Disable_Controls := TRUE;\n\t\n\t//Inverter Controls\n\t//Uncomment/Delete lines as necessary\n\t(*\n\tInv001_MODBUS_POU.Disable_Controls := TRUE;\n\tInv002_MODBUS_POU.Disable_Controls := TRUE;\n\tInv003_MODBUS_POU.Disable_Controls := TRUE;\n\tInv004_MODBUS_POU.Disable_Controls := TRUE;\n\tInv005_MODBUS_POU.Disable_Controls := TRUE;\n\tInv006_MODBUS_POU.Disable_Controls := TRUE;\n\tInv007_MODBUS_POU.Disable_Controls := TRUE;\n\tInv008_MODBUS_POU.Disable_Controls := TRUE;\n\tInv009_MODBUS_POU.Disable_Controls := TRUE;\n\tInv010_MODBUS_POU.Disable_Controls := TRUE;\n\tInv011_MODBUS_POU.Disable_Controls := TRUE;\n\tInv012_MODBUS_POU.Disable_Controls := TRUE;\n\tInv013_MODBUS_POU.Disable_Controls := TRUE;\n\tInv014_MODBUS_POU.Disable_Controls := TRUE;\n\tInv015_MODBUS_POU.Disable_Controls := TRUE;\n\tInv016_MODBUS_POU.Disable_Controls := TRUE;\n\tInv017_MODBUS_POU.Disable_Controls := TRUE;\n\tInv018_MODBUS_POU.Disable_Controls := TRUE;\n\tInv019_MODBUS_POU.Disable_Controls := TRUE;\n\tInv020_MODBUS_POU.Disable_Controls := TRUE;\n\tInv021_MODBUS_POU.Disable_Controls := TRUE;\n\tInv022_MODBUS_POU.Disable_Controls := TRUE;\n\tInv023_MODBUS_POU.Disable_Controls := TRUE;\n\tInv024_MODBUS_POU.Disable_Controls := TRUE;\n\tInv025_MODBUS_POU.Disable_Controls := TRUE;\n\tInv026_MODBUS_POU.Disable_Controls := TRUE;\n\tInv027_MODBUS_POU.Disable_Controls := TRUE;\n\tInv028_MODBUS_POU.Disable_Controls := TRUE;\n\tInv029_MODBUS_POU.Disable_Controls := TRUE;\n\tInv030_MODBUS_POU.Disable_Controls := TRUE;\n\tInv031_MODBUS_POU.Disable_Controls := TRUE;\n\tInv032_MODBUS_POU.Disable_Controls := TRUE;\n\tInv033_MODBUS_POU.Disable_Controls := TRUE;\n\tInv034_MODBUS_POU.Disable_Controls := TRUE;\n\tInv035_MODBUS_POU.Disable_Controls := TRUE;\n\tInv036_MODBUS_POU.Dis