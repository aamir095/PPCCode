{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)67bc7af8-6332-45fd-b3b3-76e2f37cc3b9","ParentGuid":"(Guid)08bdae24-9c32-4f12-a214-5f2d30499b5e","Name":"(string)meth_WriteInvCmds","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Updated based on inverter modbus map\n//Inverter001\nInv001_MODBUS.CMD_PSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[1].PCmd) ;\nInv001_MODBUS.CMD_QSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[1].QCmd) ;\nInv001_MODBUS.CMD_Estop.oper.ctlVal  :=  InvCmds_scaled[1].EStop ;\nInv001_MODBUS.CMD_QMode.oper.ctlVal  :=  InvCmds_scaled[1].QMode;\nInv001_MODBUS.CMD_Remote.oper.ctlVal  :=  InvCmds_scaled[1].Remote;\nInv001_MODBUS.CMD_Start.oper.ctlVal  :=  InvCmds_scaled[1].Start ;\nInv001_MODBUS.CMD_PSp.oper.trigger  :=  InvCmds_scaled[1].PTrigger ;\nInv001_MODBUS.CMD_QSp.oper.trigger  :=  InvCmds_scaled[1].QTrigger ;\nInv001_MODBUS.CMD_Estop.oper.trigger  :=  InvCmds_scaled[1].EStopTrigger ;\nInv001_MODBUS.CMD_QMode.oper.trigger  :=  InvCmds_scaled[1].QModeTrigger;\nInv001_MODBUS.CMD_Remote.oper.trigger  :=  InvCmds_scaled[1].RemoteTrigger ;\nInv001_MODBUS.CMD_Start.oper.trigger  :=  InvCmds_scaled[1].StartTrigger;\n\nIF InvCmds_scaled[1].PTrigger THEN\n\tSCADA_GVL.PTriggerCounter := SCADA_GVL.PTriggerCounter + 1;\nEND_IF\nIF InvCmds_scaled[1].QTrigger THEN\n\tSCADA_GVL.QTriggerCounter := SCADA_GVL.QTriggerCounter + 1; \nEND_IF\n\n//Inverter002\nInv002_MODBUS.CMD_PSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[2].PCmd) ;\nInv002_MODBUS.CMD_QSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[2].QCmd) ;\nInv002_MODBUS.CMD_Estop.oper.ctlVal  :=  InvCmds_scaled[2].EStop ;\nInv002_MODBUS.CMD_QMode.oper.ctlVal  :=  InvCmds_scaled[2].QMode;\nInv002_MODBUS.CMD_Remote.oper.ctlVal  :=  InvCmds_scaled[2].Remote;\nInv002_MODBUS.CMD_Start.oper.ctlVal  :=  InvCmds_scaled[2].Start ;\nInv002_MODBUS.CMD_PSp.oper.trigger  :=  InvCmds_scaled[2].PTrigger ;\nInv002_MODBUS.CMD_QSp.oper.trigger  :=  InvCmds_scaled[2].QTrigger ;\nInv002_MODBUS.CMD_Estop.oper.trigger  :=  InvCmds_scaled[2].EStopTrigger ;\nInv002_MODBUS.CMD_QMode.oper.trigger  :=  InvCmds_scaled[2].QModeTrigger;\nInv002_MODBUS.CMD_Remote.oper.trigger  :=  InvCmds_scaled[2].RemoteTrigger ;\nInv002_MODBUS.CMD_Start.oper.trigger  :=  InvCmds_scaled[2].StartTrigger;\n\n//Inverter003\nInv003_MODBUS.CMD_PSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[3].PCmd) ;\nInv003_MODBUS.CMD_QSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[3].QCmd) ;\nInv003_MODBUS.CMD_Estop.oper.ctlVal  :=  InvCmds_scaled[3].EStop ;\nInv003_MODBUS.CMD_QMode.oper.ctlVal  :=  InvCmds_scaled[3].QMode;\nInv003_MODBUS.CMD_Remote.oper.ctlVal  :=  InvCmds_scaled[3].Remote;\nInv003_MODBUS.CMD_Start.oper.ctlVal  :=  InvCmds_scaled[3].Start ;\nInv003_MODBUS.CMD_PSp.oper.trigger  :=  InvCmds_scaled[3].PTrigger ;\nInv003_MODBUS.CMD_QSp.oper.trigger  :=  InvCmds_scaled[3].QTrigger ;\nInv003_MODBUS.CMD_Estop.oper.trigger  :=  InvCmds_scaled[3].EStopTrigger ;\nInv003_MODBUS.CMD_QMode.oper.trigger  :=  InvCmds_scaled[3].QModeTrigger;\nInv003_MODBUS.CMD_Remote.oper.trigger  :=  InvCmds_scaled[3].RemoteTrigger ;\nInv003_MODBUS.CMD_Start.oper.trigger  :=  InvCmds_scaled[3].StartTrigger;\n\n//Inverter004\nInv004_MODBUS.CMD_PSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[4].PCmd) ;\nInv004_MODBUS.CMD_QSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[4].QCmd) ;\nInv004_MODBUS.CMD_Estop.oper.ctlVal  :=  InvCmds_scaled[4].EStop ;\nInv004_MODBUS.CMD_QMode.oper.ctlVal  :=  InvCmds_scaled[4].QMode;\nInv004_MODBUS.CMD_Remote.oper.ctlVal  :=  InvCmds_scaled[4].Remote;\nInv004_MODBUS.CMD_Start.oper.ctlVal  :=  InvCmds_scaled[4].Start ;\nInv004_MODBUS.CMD_PSp.oper.trigger  :=  InvCmds_scaled[4].PTrigger ;\nInv004_MODBUS.CMD_QSp.oper.trigger  :=  InvCmds_scaled[4].QTrigger ;\nInv004_MODBUS.CMD_Estop.oper.trigger  :=  InvCmds_scaled[4].EStopTrigger ;\nInv004_MODBUS.CMD_QMode.oper.trigger  :=  InvCmds_scaled[4].QModeTrigger;\nInv004_MODBUS.CMD_Remote.oper.trigger  :=  InvCmds_scaled[4].RemoteTrigger ;\nInv004_MODBUS.CMD_Start.oper.trigger  :=  InvCmds_scaled[4].StartTrigger;\n\n//Inverter005\nInv005_MODBUS.CMD_PSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[5].PCmd) ;\nInv005_MODBUS.CMD_QSp.oper.ctlVal  :=  REAL_TO_DINT(InvCmds_scaled[5].QCmd) ;\nInv005_MODBUS.CMD_Estop.oper.ctlVal  :=  InvCmds_scaled[5].EStop ;\nInv005_MODBUS.CMD_QMode.oper.ctlVal  :=  InvCmds_scaled[5].QMode;\nInv005_MODBUS.CMD_Remote.oper.ctlVal  :=  InvCmds_scaled[5].Remote;\nInv005_MODBUS.CMD_Start.oper.ctlVal  :=  InvCmds_scaled[5].Start ;\nInv005_MODBUS.CMD_PSp.oper.trigger  :=  InvCmds_scaled[5].PTrigger ;\nInv005_MODBUS.CMD_QSp.oper.trigger  :=  InvCmds_scaled[5].QTrigger ;\nInv005_MODBUS.CMD_Estop.oper.trigger  :=  InvCmds_scaled[5].EStopTrigger ;\nInv005_MODBUS.CMD_QMode.oper.trigger  :=  InvCmds_scaled[5].QModeTrigger;\nInv005_MODBUS.CMD_Remote.oper.trigger  :=  InvCmds_scaled[5].RemoteTrigger ;\nInv005_MODBUS.CMD_Start.oper.trigger  :=  InvCmds_scaled[5].StartTrigger;\n","LineInfoPersistence":"(string)67bc7af8-6332-45fd-b3b3-76e2f37cc3