Reactive Power Feedback\n\tHVMeterFilter_V\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for HV Meter Voltage Feedback\n\tHVMeterFilter_PF\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for HV Meter Power Factor Feedback\n\tHVMeterFilter_Freq\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for HV Meter Frequency Feedback\n\tMVMeterFilter_P\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for MV Meter Active Power Feedback \n\tMVMeterFilter_Q\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for MV Meter Reactive Power Feedback\n\tMVMeterFilter_V\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for MV Meter Voltage Feedback\n\tMVMeterFilter_PF\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for MV Meter Power Factor Feedback\n\tMVMeterFilter_Freq\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF fb_ExpFilter; \t\t\t\t\t\t//Array of filter function blocks for MV Meter Frequency Feedback\nEND_VAR","LineInfoPersistence":"(string)1a7f2d18-51af-4417-86b2-87659935c5ef_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)725","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","233bc97c":"{233bc97c-69fe-4d29-b40e-a9a9b854044e}","24449d48":"{24449d48-c96a-49c4-b9d1-a4ea34aedce3}","32d3375e":"{32d3375e-c010-41e2-9e43-b2fbf4f2b374}","4b8bcc79":"{4b8bcc79-5980-4868-b49e-005a8148859b}","4f1e43e3":"{4f1e43e3-0667-4421-ad70-d7adf37c167a}","584effbc":"{584effbc-813e-443a-bf78-ad9c8d49db41}","5ae2e111":"{5ae2e111-ecff-4a21-b647-2d4da63f