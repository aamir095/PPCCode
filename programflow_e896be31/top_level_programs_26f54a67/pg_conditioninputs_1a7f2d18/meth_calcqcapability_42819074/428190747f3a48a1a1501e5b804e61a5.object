{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)42819074-7f3a-48a1-a150-1e5b804e61a5","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_CalcQCapability","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through inverters to determine reactive power capability of PV inverters\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\t\n\tIF i > 0 THEN\n\t\t//Calculate available reactive power absorption/injection capacity. Logic is based on Qnom and inverter running status. Modify as necessary if Inverter reports dynamic available reactive power absorption/injection capability. \n\t\tIF UnitTypeCfg[InvCfg[i].UnitTypeID].NumModules > 1 THEN\n\t\t\t//Calculate available injection/absorption capacity depending on module status\n\t\t\tIF NOT InvFbk_raw[i].Sts_Offline AND InvFbk_raw[i].Sts_Running AND InvFbk_raw[i].Sts_Module1Running AND InvFbk_raw[i].Sts_Module2Running THEN\n\t\t\t\t//Inverter is online, running, and both modules are running\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\tELSIF NOT InvFbk_raw[i].Sts_Offline AND InvFbk_raw[i].Sts_Running AND (InvFbk_raw[i].Sts_Module1Running OR InvFbk_raw[i].Sts_Module2Running) THEN\n\t\t\t\t//Inverter is online, running, and at least one module is running (Logic assumes equal distribution of reactive power capability between modules)\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr / 2);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr / 2);\n\t\t\tEND_IF\n\t\tELSE\n\t\t\t//Inverter only has one module -> calculate injection/absorption capacity depending on inverter running status\n\t\t\tIF NOT InvFbk_raw[i].Sts_Offline AND InvFbk_raw[i].Sts_Running THEN\n\t\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[InvCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\tEND_IF\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n//Loop through EMS units to determine reactive power capability of EMS units\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 THEN\n\t\tIF NOT EMSFbk_raw[i].Sts_Offline AND EMSFbk_raw[i].Sts_Running THEN\n\t\t\ttmpTotal_QCapAbs := tmpTotal_QCapAbs + (UnitTypeCfg[EMSCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\t\ttmpTotal_QCapInj := tmpTotal_QCapInj + (UnitTypeCfg[EMSCfg[i].UnitTypeID].Qnom * kVArToMVAr);\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n\n//Convert reactive power absorption/injection capability from MVAr to pu\nQCapAbs := tmpTotal_QCapAbs / PlantCfg.Sbase;\nQCapInj\t:= tmpTotal_QCapInj\t/ PlantCfg.Sbase;","LineInfoPersistence":"(string)42819074-7f3a-48a1-a150-1e5b804e61a5_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCalculate Plant-Level Reactive Power Capability\n///|\tThis will be calculated based on Inverter/EMS availability and Inverter/EMS reactive power capability\nMETHOD meth_CalcQCapability\nVAR_INPUT\n\t///Raw inverter feedback, directly from inverters\n\tInvFbk_raw: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\t///Raw EMS feedback, directly from EMS\n\tEMSFbk_raw: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\t///Array of Inverter device configuration structs\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\n\t///Array of EMS device configuration structs\n\tEMSCfg: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg;\n\t///Plant configuration struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Site reactive power absorption capacity based on inverter availability and nominal reactive power capability\n\tQCapAbs: REAL;\n\t///[pu], Site reactive power injection capacity based on inverter availability and nominal reactive power capability\n\tQCapInj: REAL;\nEND_VAR\nVAR\n\t///Indexing variable\t\n\ti: UINT;\n\t///temporary Diagnostic total reactive power absorption capacity\n\ttmpTotal_QCapAbs: REAL;\n\t///temporary Diagnostic total reactive power injection capacity\n\ttmpTotal_QCapInj: REAL;\n\t///Conversion factor from kVAr to MVAr\n\tkVArToMVAr: REAL := 0.001;\nEND_VAR\n","LineInfoPersistence":"(string)42819074-7f3a-48a1-a150-1e5b804e61a5_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}