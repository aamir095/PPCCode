{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)a07e0c00-0f5a-4fa0-b140-07a9ec0197e6","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_MeterModeLogic","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Determine meter mode and meter values for POI Meter\nMeterFbk_pu.Sts_MeterMode := 0;\nMeterFbk_pu :=  faultedMeterFbk; \nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 AND HVMeterCfg[i].MeterType = TBE_PPC.enum_MeterType.POI AND NOT HVMeterFbk_pu[i].STS_flt THEN\n\t\t//Valid Meter POI Found - Update Meter Mode and HVMeterFbk output\n\t\tMeterFbk_pu := HVMeterFbk_pu[i];\n\t\tMeterFbk_pu.Sts_MeterMode := UINT_TO_INT(i);\n\t\tEXIT;\n\tEND_IF\nEND_FOR\n\nIF MeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.POIFeederMeterFbk.Sts_flt THEN\n\t//No valid HV Meter was found, but an MV meter is available - use MV Feeder Meter Fbk\n\tMeterFbk_pu.Sts_flt := VirtualMeterFbk.POIFeederMeterFbk.Sts_flt; \n\tMeterFbk_pu.Sts_P := VirtualMeterFbk.POIFeederMeterFbk.Sts_P; \n\tMeterFbk_pu.Sts_Q := VirtualMeterFbk.POIFeederMeterFbk.Sts_Q; \n\tMeterFbk_pu.Sts_MeterMode := 100; \t//Meter Mode 100 = Virtual MV Feeder Meter Fbk used\nEND_IF\n\nIF MeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.POIInvMeterFbk.Sts_flt THEN\n\t//No valid HV or MV Meter was found, but Virtual Inv Meter is available - use Inverter Virtual Meter Fbk\n\tMeterFbk_pu.Sts_flt := VirtualMeterFbk.POIInvMeterFbk.Sts_flt; \n\tMeterFbk_pu.Sts_P := VirtualMeterFbk.POIInvMeterFbk.Sts_P; \n\tMeterFbk_pu.Sts_Q := VirtualMeterFbk.POIInvMeterFbk.Sts_Q; \n\tMeterFbk_pu.Sts_MeterMode := 101; \t//Meter Mode 101 = Virtual Inverter/Unit Meter Fbk used\nEND_IF\n\n//Determine meter mode and meter values for PV Meter\nPVMeterFbk_pu.Sts_MeterMode := 0;\nPVMeterFbk_pu :=  faultedMeterFbk; \nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 AND HVMeterCfg[i].MeterType = TBE_PPC.enum_MeterType.PV AND NOT HVMeterFbk_pu[i].STS_flt THEN\n\t\t//Valid HV PV Meter Found - Update Meter Mode and PVMeterFbk output\n\t\tPVMeterFbk_pu := HVMeterFbk_pu[i];\n\t\tPVMeterFbk_pu.Sts_MeterMode := UINT_TO_INT(i);\n\t\tEXIT;\n\tEND_IF\nEND_FOR\n\nIF PVMeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.PVFeederMeterFbk.Sts_flt THEN\n\t//No valid HV Meter was found, but an MV meter is available - use MV Feeder Meter Fbk\n\tPVMeterFbk_pu.Sts_flt := VirtualMeterFbk.PVFeederMeterFbk.Sts_flt; \n\tPVMeterFbk_pu.Sts_P := VirtualMeterFbk.PVFeederMeterFbk.Sts_P; \n\tPVMeterFbk_pu.Sts_Q := VirtualMeterFbk.PVFeederMeterFbk.Sts_Q; \n\tPVMeterFbk_pu.Sts_MeterMode := 100; \t//Meter Mode 100 = Virtual MV Feeder Meter Fbk used\nEND_IF\n\nIF PVMeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.PVInvMeterFbk.Sts_flt THEN\n\t//No valid HV or MV Meter was found, but Virtual Inv Meter is available - use Inverter Virtual Meter Fbk\n\tPVMeterFbk_pu.Sts_flt := VirtualMeterFbk.PVInvMeterFbk.Sts_flt; \n\tPVMeterFbk_pu.Sts_P := VirtualMeterFbk.PVInvMeterFbk.Sts_P; \n\tPVMeterFbk_pu.Sts_Q := VirtualMeterFbk.PVInvMeterFbk.Sts_Q; \n\tPVMeterFbk_pu.Sts_MeterMode := 101; \t//Meter Mode 101 = Virtual Inverter/Unit Meter Fbk used\nEND_IF\n\n//Determine meter mode and meter values for PV Meter\nBESSMeterFbk_pu.Sts_MeterMode := 0;\nBESSMeterFbk_pu :=  faultedMeterFbk; \nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 AND HVMeterCfg[i].MeterType = TBE_PPC.enum_MeterType.BESS AND NOT HVMeterFbk_pu[i].STS_flt THEN\n\t\t//Valid HV PV Meter Found - Update Meter Mode and PVMeterFbk output\n\t\tBESSMeterFbk_pu := HVMeterFbk_pu[i];\n\t\tBESSMeterFbk_pu.Sts_MeterMode := UINT_TO_INT(i);\n\t\tEXIT;\n\tEND_IF\nEND_FOR\n\nIF BESSMeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.BESSFeederMeterFbk.Sts_flt THEN\n\t//No valid HV Meter was found, but an MV meter is available - use MV Feeder Meter Fbk\n\tBESSMeterFbk_pu.Sts_flt := VirtualMeterFbk.BESSFeederMeterFbk.Sts_flt; \n\tBESSMeterFbk_pu.Sts_P := VirtualMeterFbk.BESSFeederMeterFbk.Sts_P; \n\tBESSMeterFbk_pu.Sts_Q := VirtualMeterFbk.BESSFeederMeterFbk.Sts_Q; \n\tBESSMeterFbk_pu.Sts_MeterMode := 100; \t//Meter Mode 100 = Virtual MV Feeder Meter Fbk used\nEND_IF\n\nIF BESSMeterFbk_pu.Sts_MeterMode = 0 AND NOT VirtualMeterFbk.BESSInvMeterFbk.Sts_flt THEN\n\t//No valid HV or MV Meter was found, but Virtual Inv Meter is available - use Inverter Virtual Meter Fbk\n\tBESSMeterFbk_pu.Sts_flt := VirtualMeterFbk.BESSInvMeterFbk.Sts_flt; \n\tBESSMeterFbk_pu.Sts_P := VirtualMeterFbk.BESSInvMeterFbk.Sts_P; \n\tBESSMeterFbk_pu.Sts_Q := VirtualMeterFbk.BESSInvMeterFbk.Sts_Q; \n\tBESSMeterFbk_pu.Sts_MeterMode := 101; \t//Meter Mode 101 = Virtual Inverter/Unit Meter Fbk used\nEND_IF\n","LineInfoPersistence":"(string)a07e0c00-0f5a-4fa0-b140-07a9ec0197e6_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tMeter Mode Logic - Determine which meter feedback to use based on online/offline status of meters\n///|\tIf any HV meters are online, use the first available HV meter\n///|\tIf HV meter is not available, use virtual meter calculated from MV/Feeder meter values\n///|\tIf virtual HV/Feeder meter is not available, use virtual meter calculated from inverter/ems units\nMETHOD meth_MeterModeLogic\nVAR_INPUT\n\t///Array of HV Meter Data\n\tHVMeterFbk_pu: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///Array of MV Meter Data\n\tMVMeterFbk_pu: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///Array of HV Meter Configuration\n\tHVMeterCfg: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///Array of HV Meter Configuration\n\tMVMeterCfg: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///Structure of virtual meter feedback\n\tVirtualMeterFbk: dt_VirtualMeters;\nEND_VAR\nVAR_OUTPUT\n\t///Meter Data (either POI Meter or Virtual Meter from MV Meters) that should be used as feedback for PPC Logic\n\tMeterFbk_pu: TBE_PPC.dt_MeterFbk;\n\t///PV Meter Data used for PV Control (for PVS plants only)\n\tPVMeterFbk_pu: TBE_PPC.dt_MeterFbk;\n\t///BESS Meter Data used for BESS Control (for PVS plants only)\n\tBESSMeterFbk_pu: TBE_PPC.dt_MeterFbk;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\tfaultedMeterFbk: TBE_PPC.dt_MeterFbk := (Sts_flt:= TRUE, STS_VMag := 0.0, STS_VAng := 0.0, STS_IMag := 0.0, STS_IAng := 0.0, STS_Freq := 0.0, STS_P := 0.0, STS_Q := 0.0, STS_VLLAvg := 0.0, STS_IAvg := 0.0, STS_PF := 0.0, STS_Qlty := 536);\nEND_VAR\n","LineInfoPersistence":"(string)a07e0c00-0f5a-4fa0-b140-07a9ec0197e6_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}