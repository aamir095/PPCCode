{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b2bbb5a5-7157-4306-a258-3fea3ad2b188","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_LDC","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Calculate losses for LDC\nIF MeterFbk.Sts_MeterMode = 1 AND PlantCfg.LDCCfg.LDCEn THEN\n\tLDCSts.LDCVDrop:=(MeterFbk.STS_IMag*COS(MeterFbk.STS_Phi)* PlantCfg.LDCCfg.Rc + MeterFbk.STS_IMag*SIN(MeterFbk.STS_Phi)*PlantCfg.LDCCfg.Xc)/PlantCfg.VoltageCfg.Vbase;\n\tLDCSts.LDCPDrop:=MeterFbk.STS_Isign*MeterFbk.STS_IMag*MeterFbk.STS_IMag*PlantCfg.LDCCfg.Rc/PlantCfg.Sbase;\n\tLDCSts.LDCQDrop:=MeterFbk.STS_Isign*MeterFbk.STS_IMag*MeterFbk.STS_IMag*PlantCfg.LDCCfg.Xc/PlantCfg.Sbase;\n  (*  ELSIF LDCSts.MeterMode=2 AND U1_Cfg.LDCEn THEN\n\tLDCSts.LDCVDrop:=(U1_PMHV2.STS_IMag*COS(U1_PMHV2.STS_Phi)*U1_Cfg.Rc + U1_PMHV2.STS_IMag*SIN(U1_PMHV2.STS_Phi)*U1_Cfg.Xc)/U1_Cfg.Vbase;\n\tLDCSts.LDCPDrop:=U1_PMHV2.STS_Isign*U1_PMHV2.STS_IMag*U1_PMHV2.STS_IMag*U1_Cfg.Rc/U1_Cfg.Sbase; \n\tLDCSts.LDCQDrop:=U1_PMHV2.STS_Isign*U1_PMHV2.STS_IMag*U1_PMHV2.STS_IMag*U1_Cfg.Xc/U1_Cfg.Sbase;   *)\t//There's no MM2  AE 1/6/23\nELSE\n\tLDCSts.LDCVDrop:=0.0;\n\tLDCSts.LDCPDrop:=0.0;\n\tLDCSts.LDCQDrop:=0.0;                             \nEND_IF\n\nIF PlantCfg.LDCCfg.LDCEn THEN\n\t//Limit the LDC on voltage \n\tIF LDCSts.LDCVDrop<PlantCfg.LDCCfg.LDCvmin THEN\n\t\tLDCSts.LDCVDrop:=PlantCfg.LDCCfg.LDCvmin;\n\tELSIF LDCSts.LDCVDrop>PlantCfg.LDCCfg.LDCvmax THEN\n\t\tLDCSts.LDCVDrop:=PlantCfg.LDCCfg.LDCvmax;\n\tEND_IF\n\t//Limit the LDC on active power \n\tIF LDCSts.LDCPDrop<PlantCfg.LDCCfg.LDCpmin THEN\n\t\tLDCSts.LDCPDrop:=PlantCfg.LDCCfg.LDCpmin;\n\tELSIF LDCSts.LDCPDrop>PlantCfg.LDCCfg.LDCpmax THEN\n\t\tLDCSts.LDCPDrop:=PlantCfg.LDCCfg.LDCpmax;\n\tEND_IF\n\t//Limit the LDC on reactive power \n\tIF LDCSts.LDCQDrop<PlantCfg.LDCCfg.LDCqmin THEN\n\t\tLDCSts.LDCQDrop:=PlantCfg.LDCCfg.LDCqmin;\n\tELSIF LDCSts.LDCQDrop>PlantCfg.LDCCfg.LDCqmax THEN\n\t\tLDCSts.LDCQDrop:=PlantCfg.LDCCfg.LDCqmax;\n\tEND_IF\nEND_IF","LineInfoPersistence":"(string)b2bbb5a5-7157-4306-a258-3fea3ad2b188_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tLine drop compensation method\nMETHOD meth_LDC\nVAR_INPUT\n\t///Plant configuration struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Meter feedback\n\tMeterFbk: TBE_PPC.dt_MeterFbk;\nEND_VAR\nVAR_OUTPUT\n\t///LDC Status\n\tLDCSts: TBE_PPC.dt_LDCSts;\nEND_VAR\n","LineInfoPersistence":"(string)b2bbb5a5-7157-4306-a258-3fea3ad2b188_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}