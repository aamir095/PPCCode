{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)1c21121c-7319-43e7-8cda-ba8b85ee7169","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionMetStationFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumMetStations BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over all values\n\t\tMetStationFbk_pu[i] := MetStationFbk_raw[i]; \n\t\t//Filter raw value\n\t\tIrr_Temp := MetStationFbk_raw[i].POA_Irr_TC / MetStationCfg.MaxIrr; \n\t\tPOA_Irr_TC_filt[i](Tcon := MetStationCfg.FiltTime, Interval := PPC.TaskTime, RawIn := Irr_Temp, Outmin := 0, Outmax := 2, Out => MetStationFbk_pu[i].POA_Irr_TC);\n\t\t\n\t\t//Calculate Average Back of Module Surface Temp -> 12 BOM temps are available, but not all will be used. Only include the temp in the average if quality is good\n\t\tFOR j := 1 TO 12 BY 1 DO\n\t\t\tIF MetStationFbk_pu[i].BOMTempQArr[j] AND fun_IsValidReal(MetStationFbk_pu[i].BomTempArr[j]) THEN\n\t\t\t\t//Quality is good and value is not NaN -> Include BOM Temp in average\n\t\t\t\tBOMTempSum := BOMTempSum + MetStationFbk_pu[i].BOMTempArr[j];\n\t\t\t\tBOMTemp_n := BOMTemp_n + 1;\n\t\t\tEND_IF\n\t\tEND_FOR\n\t\t\n\t\t//Calculate average BOM Temp\n\t\tIF BOMTemp_n > 0 THEN\n\t\t\tMetStationFbk_pu[i].BOMTempAvg := BOMTempSum / BOMTemp_n;\n\t\tELSE\n\t\t\tMetStationFbk_pu[i].BOMTempAvg := 0; \n\t\tEND_IF\n\t\t\n\t\t//Reset BOM Temp/Sum counter so that it is 0 for each met station\n\t\tBOMTemp_n  := 0; \n\t\tBOMTempSum := 0;\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)1c21121c-7319-43e7-8cda-ba8b85ee7169_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition met station feedback to percentage units\nMETHOD meth_ConditionMetStationFbk\nVAR_INPUT\n\t///Met station feedback values, raw/unscaled values\n\tMetStationFbk_raw: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\t///Met station configuration structure\n\tMetStationCfg: TBE_PPC.dt_MetStationCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Met station feedback values\n\tMetStationFbk_pu: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\nEND_VAR\nVAR\n\t///Indexing variable for met stations\n\ti: UINT;\n\t///Indexing variable for BOM temp array\n\tj: UINT;\n\t///Temporary value for conditioned irradiance\n\tIrr_Temp: REAL;\n\t///Sum of BOM Temp values\n\tBOMTempSum: REAL;\n\t///Count of valid BOM Temp values\n\tBOMTemp_n: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)1c21121c-7319-43e7-8cda-ba8b85ee7169_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}