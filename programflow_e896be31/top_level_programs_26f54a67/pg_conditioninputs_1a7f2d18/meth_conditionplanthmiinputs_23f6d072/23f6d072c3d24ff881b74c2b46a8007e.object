{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)23f6d072-c3d2-4ff8-81b7-4c2b46a8007e","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionPlantHMIInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire structure\nPlantHMIInputs_pu := PlantHMIInputs_raw; \n\n//Scale/Condition values as necessary\n//Real Power Related\nPlantHMIInputs_pu.ActivePwr.PSp_POI := PlantHMIInputs_raw.ActivePwr.PSp_POI / PlantCfg.Sbase;\t\t\t\t\t\t\t//Scale from MW to pu\nPlantHMIInputs_pu.ActivePwr.PSp_PV := PlantHMIInputs_raw.ActivePwr.PSp_PV / PlantCfg.Sbase; \t\t\t\t\t\t\t//Scale from MW to pu\nPlantHMIInputs_pu.ActivePwr.PSp_BESS := PlantHMIInputs_raw.ActivePwr.PSp_BESS / PlantCfg.Sbase; \t\t\t\t\t\t//Scale from MW to pu\nPlantHMIInputs_pu.ActivePwr.FreqTestSp_Hz := PlantHMIInputs_raw.ActivePwr.FreqTestSp_Hz / PlantCfg.FreqCfg.FreqBase; \t//Scale from Hz to pu\nPlantHMIInputs_pu.ActivePwr.FreqTestTime_sec := PlantHMIInputs_raw.ActivePwr.FreqTestTime_sec * 1000;\t\t\t\t\t//Convert from sec to ms\n\n//Reactive Power Related\nPlantHMIInputs_pu.ReactivePwr.QSp := PlantHMIInputs_raw.ReactivePwr.QSp / PlantCfg.Sbase; \t\t\t\t\t\t\t\t//Scale from MVar to pu\nPlantHMIInputs_pu.ReactivePwr.VSp := PlantHMIInputs_raw.ReactivePwr.VSp / PlantCfg.VoltageCfg.Vbase; \t\t\t\t\t//Scale from kV to pu\n\n//Voltage Test Related\nPlantHMIInputs_pu.TestInputs.VoltageTestSp := PlantHMIInputs_raw.TestInputs.VoltageTestSp / PlantCfg.VoltageCfg.Vbase;\t//Scale from kV to pu\nPlantHMIInputs_pu.TestInputs.VoltageTestTime := PlantHMIInputs_raw.TestInputs.VoltageTestTime * 1000;\t\t\t\t\t//SCale from sec to ms\n","LineInfoPersistence":"(string)23f6d072-c3d2-4ff8-81b7-4c2b46a8007e_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_ConditionPlantHMIInputs\nVAR_INPUT\n\t///Plant HMI Inputs, raw/unscaled values\n\tPlantHMIInputs_raw: TBE_PPC.dt_PlantHMIInputs;\n\t///Plant Configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Plant HMI Inputs, conditioned to pu\n\tPlantHMIInputs_pu: TBE_PPC.dt_PlantHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)23f6d072-c3d2-4ff8-81b7-4c2b46a8007e_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}