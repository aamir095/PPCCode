{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)41a5a02e-0400-4414-82d9-2585e271bd44","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionEMSFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over entire structure\n\t\tEMSFbk_pu[i] := EMSFbk_raw[i]; \n\t\t\n\t\t//Scale/Condition values as necessary -> Scaling will be dependent on EMS modbus register scaling. Output values from this method should be in percentage units. \n\t\tEMSFbk_pu[i].Sts_P := EMSFbk_raw[i].Sts_P / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom; \n\t\tEMSFbk_pu[i].Sts_Q := EMSFbk_raw[i].Sts_Q / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom; \n\t\tEMSFbk_pu[i].Sts_SOC := EMSFbk_raw[i].Sts_SOC / 100.0; \n\t\tEMSFbk_pu[i].Sts_PF := EMSFbk_raw[i].Sts_PF; \n\t\tEMSFbk_pu[i].Sts_Freq := EMSFbk_raw[i].Sts_Freq; \n\t\tEMSFbk_pu[i].Sts_Ia := EMSFbk_raw[i].Sts_Ia; \n\t\tEMSFbk_pu[i].Sts_Ib := EMSFbk_raw[i].Sts_Ib; \n\t\tEMSFbk_pu[i].Sts_Ic := EMSFbk_raw[i].Sts_Ic; \n\t\tEMSFbk_pu[i].Sts_Vab := EMSFbk_raw[i].Sts_Vab; \n\t\tEMSFbk_pu[i].Sts_Vbc := EMSFbk_raw[i].Sts_Vbc; \n\t\tEMSFbk_pu[i].Sts_Vca := EMSFbk_raw[i].Sts_Vca; \n\t\tEMSFbk_pu[i].Sts_PDischCap := EMSFbk_raw[i].Sts_PDischCap / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t//Convert from kW to pu\n\t\tEMSFbk_pu[i].Sts_PChrgCap := EMSFbk_raw[i].Sts_PChrgCap / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t//Convert from kW to pu\n\t\tEMSFbk_pu[i].Sts_QCapAbs := EMSFbk_raw[i].Sts_QCapAbs / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t//Convert from kVar to pu\n\t\tEMSFbk_pu[i].Sts_QCapInj := EMSFbk_raw[i].Sts_QCapInj / UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t//Convert from kVar to pu\n\t\t\n\t\t//Set Min/Max SOC Flags based on SOC Fbk\n\t\tEMSSOCLimFlags[i](Val := EMSFbk_pu[i].Sts_SOC, MinVal := PlantCfg.BESSCfg.SOCMin, MaxVal := PlantCfg.BESSCfg.SOCMax, Hyst := PlantCfg.BESSCfg.SOCHyst);\n\t\tEMSFbk_pu[i].Sts_MaxSOCFlag := EMSSOCLimFlags[i].MaxFlag;\n\t\tEMSFbk_pu[i].Sts_MinSOCFlag := EMSSOCLimFlags[i].MinFlag;\n\tEND_IF\nEND_FOR\n\n//Determine plant-level EMS status tags used in core logic\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 THEN\n\t\t//Determine number of inverters w/ comm fault, running, or stopped (num comm fault + running + stopped = total EMS count)\n\t\tIF EMSFbk_pu[i].Sts_Offline THEN\n\t\t\tNumEMSCommFault := NumEMSCommFault + 1;\n\t\tELSIF EMSFbk_pu[i].Sts_Running THEN\n\t\t\tNumEMSRunning := NumEMSRunning + 1;\n\t\tELSE\n\t\t\tNumEMSStopped := NumEMSStopped + 1;\n\t\tEND_IF\n\t\t\n\t\t//Determine number of EMS w/ Min or Max SOC flag set -> EMS can only have one SOC flag set at a time\n\t\tIF EMSFbk_pu[i].Sts_MaxSOCFlag THEN\n\t\t\tNumEMSMaxSOC := NumEMSMaxSOC + 1;\n\t\tELSIF EMSFbk_pu[i].Sts_MinSOCFlag THEN\n\t\t\tNumEMSMinSOC := NumEMSMinSOC + 1;\n\t\tEND_IF\n\t\t\n\t\t//Determine number of EMS modules that are in P Auto mode\n\t\tIF (NOT EMSFbk_pu[i].Sts_Offline) AND EMS_GVL.U1_EMS[i].STS_PAuto THEN\n\t\t\tNumEMSinPAuto := NumEMSinPAuto + 1;\n\t\tEND_IF\n\t\t\n\t\t//Calculate total system capacity based on individual ems fbk\n\t\tIF (NOT EMSFbk_pu[i].Sts_Offline) AND (NOT EMSFbk_pu[i].Sts_Faulted) THEN\n\t\t\t//EMS is online and not faulted - add to online counter\n\t\t\tEMSOnlineSumDischPwr := EMSOnlineSumDischPwr + EMSFbk_pu[i].Sts_PDischCap * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom; \t//Add values in kW\n\t\t\tEMSOnlineSumChrgPwr := EMSOnlineSumChrgPwr + EMSFbk_pu[i].Sts_PChrgCap * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t\t//Add values in kW\n\t\t\tSumActivePwr := SumActivePwr + EMSFbk_pu[i].Sts_P * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t\t\t\t\t\t\t\t//Add values in kW\n\t\t\tSumReactivePwr := SumReactivePwr + EMSFbk_pu[i].Sts_Q * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t\t\t\t\t\t\t//Add values in kVar\n\t\t\tSumQCapAbs := SumQCapAbs + EMSFbk_pu[i].Sts_QCapAbs * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t\t\t\t\t\t\t//Add values in kVar\n\t\t\tSumQCapInj := SumQCapInj + EMSFbk_pu[i].Sts_QCapInj * UnitTypeCfg[EMSCfg[i].UnitTypeID].Snom;\t\t\t\t\t\t\t//Add values in kVar\n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n//Write temp values to EMSDiagnosticsStructure\nPlantEMSSts.NumEMSCommFault := NumEMSCommFault; \nPlantEMSSts.NumEMSMaxSOC := NumEMSMaxSOC; \nPlantEMSSts.NumEMSMinSOC := NumEMSMinSOC; \nPlantEMSSts.NumEMSRunning := NumEMSRunning; \nPlantEMSSts.NumEMSStopped := NumEMSStopped; \nPlantEMSSts.NumEMSinPAuto := NumEMSinPAuto; \n\n//Calculate total system capacity of EMS modules\nPlantEMSSts.Total_DischCap := EMSOnlineSumDischPwr / 1000.0 / PlantCfg.Sbase;\t//Convert from kW to pu, Sbase_BESS\nPlantEMSSts.Total_ChargeCap := EMSOnlineSumChrgPwr / 1000.0 / PlantCfg.Sbase;\t//Convert from kW to pu, Sbase_BESS\nPlantEMSSts.Total_GrossMW := SumActivePwr / 1000.0 / PlantCfg.Sbase;\t\t\t//Convert from kW to pu, Sbase_BESS\nPlantEMSSts.Total_GrossMVAR := SumReactivePwr / 1000.0 / PlantCfg.Sbase;\t\t\t//Convert from kVar to pu, Sbase\nPlantEMSSts.Total_QCapAbs := SumQCapAbs / 1000.0 / PlantCfg.Sbase;\t\t\t\t\t//Convert from kVar to Sbase\nPlantEMSSts.Total_QCapInj := SumQCapInj / 1000.0 / PlantCfg.Sbase;\t\t\t\t\t//Convert from kVar to Sbase\n","LineInfoPersistence":"(string)41a5a02e-0400-4414-82d9-2585e271bd44_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition EMS Feedback Values\n///|\tCondition EMS based on EMS config scaling values\n///|\tCondition to CORE values (ie 0-1) and CONDITIONED values (ie kW, kV, etc.)\nMETHOD meth_ConditionEMSFbk\nVAR_INPUT\n\t///Raw EMS feedback, directly from EMS\n\tEMSFbk_raw: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\tEMSCfg: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg;\n\t///Plant configuration struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Conditioned EMS feedback\n\tEMSFbk_pu: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\t///Structure of plant-level EMS status/diagnostic values\n\tPlantEMSSts: TBE_PPC.dt_PlantEMSDiagnostics;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\n\t///Number of EMS modules w/ comm fault\n\tNumEMSCommFault: UINT;\n\t///Number of EMS modules that are communicating and running\n\tNumEMSRunning: UINT;\n\t///Number of EMS modules that are communicating but not running\n\tNumEMSStopped: UINT;\n\t///Number of EMS modules w/ Max SOC flag set\n\tNumEMSMaxSOC: UINT;\n\t///Number of EMS modules w/ Min SOC flag set\t\n\tNumEMSMinSOC: UINT;\n\t///Number of EMS modules that are communicating an in PAuto\n\tNumEMSinPAuto: UINT;\n\t///[pu], Sum of available discharge power from all EMS modules that are online and not faulted\n\tEMSOnlineSumDischPwr: REAL;\n\t///[pu], Sum of available charging power from all EMS modules that are online and not faulted\n\tEMSOnlineSumChrgPwr: REAL;\n\t///Sum of EMS active power\n\tSumActivePwr: REAL;\n\t///Sum of EMS reactive power\n\tSumReactivePwr: REAL;\n\t///Sum of EMS reactive power absorption capacity\n\tSumQCapAbs: REAL;\n\t///Sum of EMS reactive power injection capacity\n\tSumQCapInj: REAL;\nEND_VAR\n","LineInfoPersistence":"(string)41a5a02e-0400-4414-82d9-2585e271bd44_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}