{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)58157cc5-e0a8-43c7-9143-faa3cf6aee74","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_CalcHSL","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Calculate average irradiance\nFOR i := 0 TO SiteConstants.NumMetStations BY 1 DO\n\tIF i > 0 THEN\n\t\t//Determine if met station feedback is valid\n\t\tIF MetStationFbk_pu[i].POA_Irr_TC > MinIrr AND MetStationFbk_pu[i].POA_Irr_TC <= MaxIrr AND (NOT MetStationFbk_pu[i].Offline) THEN\n\t\t\tIrrSum := IrrSum + MetStationFbk_pu[i].POA_Irr_TC;\n\t\t\tIrrCount := IrrCount + 1; \n\t\tEND_IF\n\tEND_IF\nEND_FOR\nIF IrrCount > 0 THEN\n\tIrrAvg := IrrSum / IrrCount; \t//Calculate average irradiance [0-1]\nELSE\n\tIrrAvg := 0; \nEND_IF\n\n//Determine number of inverters that are online and not faulted\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\tIF (NOT InvFbk_pu[i].Sts_Offline) AND (NOT InvFbk_pu[i].Sts_Faulted) AND i >= 1 THEN\n\t\t\t//Inverter is online and not faulted - add to 'online' counter\n\t\t\tInvsOnline := InvsOnline + 1; \n\t\t\tInvOnlineSumPwr := InvOnlineSumPwr + UnitTypeCfg[InvCfg[i].UnitTypeID].Snom;\n\t\tEND_IF\n\tEND_IF\nEND_FOR\nIF SiteConstants.NumInvs > 0 THEN\n\tPctInvsOnline := TO_REAL(InvsOnline) / TO_REAL(SiteConstants.NumInvs); \nELSE\n\tPctInvsOnline := 0; \nEND_IF\n\n//Calculate HSL as Pct of Available Power * Irradiance Pct. Limit the HSL to between 0 and HOL\nPctAvailablePwr := InvOnlineSumPwr / 1000.0 / PlantCfg.Sbase;\t\t\t//Convert sum of inverter available pwr (in kW) to MW, divide by Sbase to get pu. \nHSL_PV := LIMIT(0, IrrAvg * PctAvailablePwr * Efficiency, PlantCfg.ActivePwrCfg.PMax_PV); \n\n//Calculate POI HSL - will be sum of BESS and PV HSL, POI HSL will be in pu Sbase\nHSL_POI := ((HSL_PV * PlantCfg.Sbase) + (PlantEMSSts.Total_DischCap * PlantCfg.Sbase)) / PlantCfg.Sbase;\n\n//Limit HSL_POI to between 0 and Plant HOL\nHSL_POI := LIMIT(0, HSL_POI, PlantCfg.HOL);\n","LineInfoPersistence":"(string)58157cc5-e0a8-43c7-9143-faa3cf6aee74_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tMethod to calculate High Sustainable Limit (HSL)\n///|\tCalculation is based on met station irradiance data and inverters that are online\nMETHOD meth_CalcHSL\nVAR_INPUT\n\t///[pu], Met station feedback\n\tMetStationFbk_pu: ARRAY[0..SiteConstants.NumMetStations] OF TBE_PPC.dt_MetStationFbk;\n\t///[pu], Array of inverter feedback values\n\tInvFbk_pu: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\t///[pu], Array of EMS feedback values\n\tEMSFbk_pu: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_BESSFbk;\n\t///[pu], Structure of plant-level EMS diagnostics\n\tPlantEMSSts: TBE_PPC.dt_PlantEMSDiagnostics;\n\t///[pu], Meter feedback\n\tMeterFbk_pu: TBE_PPC.dt_MeterFbk;\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\t///Inverter configuration structure\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\n\t///EMS configuration structure\n\tEMSCfg: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceCfg;\n\t///Plant configuration struct\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu, Sbase], POI High sustainable limit - Sum of PV and BESS HSL\n\tHSL_POI: REAL;\n\t///[pu, Sbase_PV], PV High sustainable limit\n\tHSL_PV: REAL;\n\t///[pu, Sbase_BESS], EMS/BESS available discharge capacity\n\tPDischCap_BESS: REAL;\n\t///[pu, Sbase_PV], EMS/BESS available charge capacity\n\tPChrgCap_BESS: REAL;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\t///Sum of irradiance measurements (used for avg measurement)\n\tIrrSum: REAL;\n\t///Counter of irradiance values (used for avg measurement)\n\tIrrCount: INT;\n\t///[pu], Average irradiance measurement across all met stations\n\tIrrAvg: REAL;\n\t///Counter of inverters that are online\n\tInvsOnline: INT;\n\t///Percentage of inverters that are online\n\tPctInvsOnline: REAL;\n\t///[kva], Sum of apparent power ratings for all online inverters that are not faulted\n\tInvOnlineSumPwr: REAL;\n\t///[pu], Available inverter power divided by Plant POI Limit\n\tPctAvailablePwr: REAL;\n\t///[pu], If irradiance is below this value, do not include it in average calculation\n\tMinIrr: REAL := 0;\n\t///[pu], If irradiance is above this value, do not include it in average calculation \n\tMaxIrr: REAL := 1.2;\n\t///Efficiency factor -> 1.0 by default, which means Inverter Pwr = AC Export Pwr\n\tEfficiency: REAL := 1.0;\nEND_VAR\n","LineInfoPersistence":"(string)58157cc5-e0a8-43c7-9143-faa3cf6aee74_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}