{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)ecb41fda-2494-4e53-b1d2-fe293f310da6","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ValidateMeterFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through HV Meters and validate the inputs\nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\t// set output values from raw to write any values that aren't validated\n\tHvMeterFbk_valid[i] := HvMeterFbk_raw[i];\n\t\n\t// check relevant meter fbk values for validity\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_Freq) THEN\n\t\tHvMeterFbk_lastValid[i].Sts_Freq := HvMeterFbk_raw[i].STS_Freq;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_IA) THEN\n\t\tHvMeterFbk_lastValid[i].STS_IA := HvMeterFbk_raw[i].STS_IA;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_IB) THEN\n\t\tHvMeterFbk_lastValid[i].STS_IB := HvMeterFbk_raw[i].STS_IB;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_IC) THEN\n\t\tHvMeterFbk_lastValid[i].STS_IC := HvMeterFbk_raw[i].STS_IC;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_VAN) THEN\n\t\tHvMeterFbk_lastValid[i].STS_VAN := HvMeterFbk_raw[i].STS_VAN;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_VBN) THEN\n\t\tHvMeterFbk_lastValid[i].STS_VBN := HvMeterFbk_raw[i].STS_VBN;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_VCN) THEN\n\t\tHvMeterFbk_lastValid[i].STS_VCN := HvMeterFbk_raw[i].STS_VCN;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].Sts_VMag) THEN\n\t\tHvMeterFbk_lastValid[i].Sts_VMag := HvMeterFbk_raw[i].Sts_VMag;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_VAng) THEN\n\t\tHvMeterFbk_lastValid[i].STS_VAng := HvMeterFbk_raw[i].STS_VAng;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_IMag) THEN\n\t\tHvMeterFbk_lastValid[i].STS_IMag := HvMeterFbk_raw[i].STS_IMag;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].STS_IAng) THEN\n\t\tHvMeterFbk_lastValid[i].STS_IAng := HvMeterFbk_raw[i].STS_IAng;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].Sts_P) THEN\n\t\tHvMeterFbk_lastValid[i].Sts_P := HvMeterFbk_raw[i].Sts_P;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(HvMeterFbk_raw[i].Sts_Q) THEN\n\t\tHvMeterFbk_lastValid[i].Sts_Q := HvMeterFbk_raw[i].Sts_Q;\n\tELSE\n\t\tHvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\t// replace output values with last valid values\n\tHVMeterFbk_valid[i].STS_Freq\t \t:= HvMeterFbk_lastValid[i].STS_Freq;\n\tHVMeterFbk_valid[i].STS_IA\t\t\t:= HvMeterFbk_lastValid[i].STS_IA;\n\tHVMeterFbk_valid[i].STS_IB\t\t\t:= HvMeterFbk_lastValid[i].STS_IB;\n\tHVMeterFbk_valid[i].STS_IC\t\t\t:= HvMeterFbk_lastValid[i].STS_IC;\n\tHVMeterFbk_valid[i].STS_VAN\t\t\t:= HvMeterFbk_lastValid[i].STS_VAN;\n\tHVMeterFbk_valid[i].STS_VBN\t\t\t:= HvMeterFbk_lastValid[i].STS_VBN;\n\tHVMeterFbk_valid[i].STS_VCN\t\t\t:= HvMeterFbk_lastValid[i].STS_VCN;\n\tHVMeterFbk_valid[i].Sts_VMag\t\t:= HvMeterFbk_lastValid[i].Sts_VMag;\n\tHVMeterFbk_valid[i].STS_VAng\t\t:= HvMeterFbk_lastValid[i].STS_VAng;\n\tHVMeterFbk_valid[i].STS_IMag\t\t:= HvMeterFbk_lastValid[i].STS_IMag;\n\tHVMeterFbk_valid[i].STS_IAng\t\t:= HvMeterFbk_lastValid[i].STS_IAng;\n\tHVMeterFbk_valid[i].Sts_P\t\t\t:= HvMeterFbk_lastValid[i].Sts_P;\n\tHVMeterFbk_valid[i].Sts_Q\t\t\t:= HvMeterFbk_lastValid[i].Sts_Q;\n\t\n\t// check for invalid data fault\n\tHvMeterInvalidTON[i](IN := HvMeterInvalid[i], PT := PlantCfg.MeterOfflineDelayTime); \n\t\n\tIF HvMeterInvalidTON[i].Q THEN\n\t\tHvMeterFbk_valid[i].Sts_flt := TRUE;\n\tEND_IF\nEND_FOR\n\n\n//Loop through the MV Meters and validate the inputs\nFOR i := 0 TO SiteConstants.NumMVMeters BY 1 DO\n\t// set output values from raw to write any values that aren't validated\n\tMvMeterFbk_valid[i] := MvMeterFbk_raw[i];\n\t\n\t// check relevant meter fbk values for validity\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_Freq) THEN\n\t\tMvMeterFbk_lastValid[i].Sts_Freq := MvMeterFbk_raw[i].STS_Freq;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_IA) THEN\n\t\tMvMeterFbk_lastValid[i].STS_IA := MvMeterFbk_raw[i].STS_IA;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_IB) THEN\n\t\tMvMeterFbk_lastValid[i].STS_IB := MvMeterFbk_raw[i].STS_IB;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_IC) THEN\n\t\tMvMeterFbk_lastValid[i].STS_IC := MvMeterFbk_raw[i].STS_IC;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_VAN) THEN\n\t\tMvMeterFbk_lastValid[i].STS_VAN := MvMeterFbk_raw[i].STS_VAN;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_VBN) THEN\n\t\tMvMeterFbk_lastValid[i].STS_VBN := MvMeterFbk_raw[i].STS_VBN;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_VCN) THEN\n\t\tMvMeterFbk_lastValid[i].STS_VCN := MvMeterFbk_raw[i].STS_VCN;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].Sts_VMag) THEN\n\t\tMvMeterFbk_lastValid[i].Sts_VMag := MvMeterFbk_raw[i].Sts_VMag;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_VAng) THEN\n\t\tMvMeterFbk_lastValid[i].STS_VAng := MvMeterFbk_raw[i].STS_VAng;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_IMag) THEN\n\t\tMvMeterFbk_lastValid[i].STS_IMag := MvMeterFbk_raw[i].STS_IMag;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\tIF fun_IsValidReal(MvMeterFbk_raw[i].STS_IAng) THEN\n\t\tMvMeterFbk_lastValid[i].STS_IAng := MvMeterFbk_raw[i].STS_IAng;\n\tELSE\n\t\tMvMeterInvalid[i] := TRUE;\n\tEND_IF\n\t\n\t// replace output values with last valid values\n\tMvMeterFbk_valid[i].STS_Freq\t \t:= MvMeterFbk_lastValid[i].STS_Freq;\n\tMvMeterFbk_valid[i].STS_IA\t\t\t:= MvMeterFbk_lastValid[i].STS_IA;\n\tMvMeterFbk_valid[i].STS_IB\t\t\t:= MvMeterFbk_lastValid[i].STS_IB;\n\tMvMeterFbk_valid[i].STS_IC\t\t\t:= MvMeterFbk_lastValid[i].STS_IC;\n\tMvMeterFbk_valid[i].STS_VAN\t\t\t:= MvMeterFbk_lastValid[i].STS_VAN;\n\tMvMeterFbk_valid[i].STS_VBN\t\t\t:= MvMeterFbk_lastValid[i].STS_VBN;\n\tMvMeterFbk_valid[i].STS_VCN\t\t\t:= MvMeterFbk_lastValid[i].STS_VCN;\n\tMvMeterFbk_valid[i].Sts_VMag\t\t:= MvMeterFbk_lastValid[i].Sts_VMag;\n\tMvMeterFbk_valid[i].STS_VAng\t\t:= MvMeterFbk_lastValid[i].STS_VAng;\n\tMvMeterFbk_valid[i].STS_IMag\t\t:= MvMeterFbk_lastValid[i].STS_IMag;\n\tMvMeterFbk_valid[i].STS_IAng\t\t:= MvMeterFbk_lastValid[i].STS_IAng;\n\t\n\t// check for invalid data fault\n\tMvMeterInvalidTON[i](IN := MvMeterInvalid[i], PT := PlantCfg.MeterOfflineDelayTime); \n\t\n\tIF MvMeterInvalidTON[i].Q THEN\n\t\tMvMeterFbk_valid[i].Sts_flt := TRUE;\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)ecb41fda-2494-4e53-b1d2-fe293f310da6_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_ValidateMeterFbk\nVAR_INPUT\n\tHVMeterFbk_raw\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; //HV Meter Fbk, raw/unscaled values\n\tMVMeterFbk_raw\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; //MV Meter Fbk, raw/unscaled values\n\tPlantCfg\t\t\t\t: TBE_PPC.dt_PlantCfg; //Plant configuration structure\n\tHVMeterCfg\t\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg; //Array of HV meter configuration structures\n\tMVMeterCfg\t\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg; //Array of MV meter configuration structures\nEND_VAR\nVAR_OUTPUT\n\tHVMeterFbk_valid\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; //HV Meter Fbk, validated values\n\tMVMeterFbk_valid\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; //MV Meter Fbk, validated values\nEND_VAR\nVAR\n\tHVMeterInvalid\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF BOOL; //HV Meter invalid data flag\n\tMVMeterInvalid\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF BOOL; //MV Meter invalid data flag\n\ti\t\t\t\t\t\t: DINT; //Indexing Variable\nEND_VAR\nVAR_INST\n\tHVMeterFbk_lastValid\t: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk; //HV Meter Fbk, last validated values - stored in memory between cycles\n\tMVMeterFbk_lastValid\t: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk; //MV Meter Fbk, last validated values - stored in memory between cycles\n\t\n\tHvMeterInvalidTON\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TON; //Array of meter invalid timers - used to set fault if meter data is invalid\n\tMVMeterInvalidTON\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TON; //Array of MV meter invalid timers - used to set fault if meter data is invalid\nEND_VAR\n","LineInfoPersistence":"(string)ecb41fda-2494-4e53-b1d2-fe293f310da6_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}