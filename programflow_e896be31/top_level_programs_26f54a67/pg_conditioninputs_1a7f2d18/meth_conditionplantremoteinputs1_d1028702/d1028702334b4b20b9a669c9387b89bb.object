{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d1028702-334b-4b20-b9a6-69c9387b89bb","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionPlantRemoteInputs1","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire structure\nPlantRemoteInputs1_pu := PlantRemoteInputs1_raw; \n\n//Scale/Condition values as necessary\n//Real Power Related\nPlantRemoteInputs1_pu.PSp_POI := PlantRemoteInputs1_raw.PSp_POI / PlantCfg.Sbase; \t\t\t\t//Scale from MW to pu using POI Sbase\nPlantRemoteInputs1_pu.PSp_PV := PlantRemoteInputs1_raw.PSp_PV / PlantCfg.Sbase; \t\t\t\t//Scale from MW to pu using PV Sbase\nPlantRemoteInputs1_pu.PSp_BESS := PlantRemoteInputs1_raw.PSp_BESS / PlantCfg.Sbase;\t\t\t\t//Scale from MW to pu using BESS Sbase\n\n//Reactive Power Related\nPlantRemoteInputs1_pu.QSp := PlantRemoteInputs1_raw.QSp / PlantCfg.Sbase; \t\t\t\t\t\t//Scale from MVar to pu\nPlantRemoteInputs1_pu.VSp := PlantRemoteInputs1_raw.VSp / PlantCfg.VoltageCfg.Vbase; \t\t\t//Scale from kV to pu\n\n//Ramp Rates - Convert from MW/min or MVAr/min to pu/s\nPlantRemoteInputs1_pu.PUpLim_POI := PlantRemoteInputs1_raw.PUpLim_POI / PlantCfg.Sbase / 60.0; \t\t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.PDnLim_POI := PlantRemoteInputs1_raw.PDnLim_POI / PlantCfg.Sbase / 60.0; \t\t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.PUpLim_PV := PlantRemoteInputs1_raw.PUpLim_PV / PlantCfg.Sbase / 60.0; \t\t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.PDnLim_PV := PlantRemoteInputs1_raw.PDnLim_PV / PlantCfg.Sbase / 60.0; \t\t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.PUpLim_BESS := PlantRemoteInputs1_raw.PUpLim_BESS / PlantCfg.Sbase / 60.0; \t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.PDnLim_BESS := PlantRemoteInputs1_raw.PDnLim_BESS / PlantCfg.Sbase / 60.0; \t//Convert from MW/min to pu/s\nPlantRemoteInputs1_pu.QUpLim := PlantRemoteInputs1_raw.QUpLim / PlantCfg.Sbase / 60.0; \t\t\t\t//Convert from MVAr/min to pu/s\nPlantRemoteInputs1_pu.QDnLim := PlantRemoteInputs1_raw.QDnLim / PlantCfg.Sbase / 60.0; \t\t\t\t//Convert from MVAr/min to pu/s\nPlantRemoteInputs1_pu.QUpLim_VMode := PlantRemoteInputs1_raw.QUpLim_VMode / PlantCfg.Sbase / 60.0; \t\t\t\t//Convert from MVAr/min to pu/s\nPlantRemoteInputs1_pu.QDnLim_VMode := PlantRemoteInputs1_raw.QDnLim_VMode / PlantCfg.Sbase / 60.0; \t\t\t\t//Convert from MVAr/min to pu/s","LineInfoPersistence":"(string)d1028702-334b-4b20-b9a6-69c9387b89bb_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition plant inputs from remote source\n///|\tConvert from enginering units to pu for use in core logic\nMETHOD meth_ConditionPlantRemoteInputs1\nVAR_INPUT\n\t///Plant remote inputs in raw/unscaled form\n\tPlantRemoteInputs1_raw: TBE_PPC.dt_PlantRemoteInputs;\n\t///Plant Configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///Plant remote inputs in pu (for use in core logic)\n\tPlantRemoteInputs1_pu: TBE_PPC.dt_PlantRemoteInputs;\nEND_VAR\n","LineInfoPersistence":"(string)d1028702-334b-4b20-b9a6-69c9387b89bb_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}