{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)543d2827-7582-4c37-acf6-2814f90015bd","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionInvFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 THEN\n\t\t//Move over entire structure\n\t\tInvFbk_pu[i] := InvFbk_raw[i]; \n\t\t\n\t\t//Scale/Condition values as necessary -> Scaling will be dependent on inverter modbus register scaling. Output values from this method should be in percentage units. \n\t\tInvFbk_pu[i].Sts_P := (InvFbk_raw[i].Sts_P * UnitTypeCfg[InvCfg[i].UnitTypeID].PFbk_toW / 1000.0) / UnitTypecfg[InvCfg[i].UnitTypeID].Snom; \t\t\t//Converted to pu\n\t\tInvFbk_pu[i].Sts_Q := (InvFbk_raw[i].Sts_Q * UnitTypeCfg[InvCfg[i].UnitTypeID].QFbk_toVar / 1000.0) / UnitTypeCfg[InvCfg[i].UnitTypeID].Snom; \t\t\t//Converted to pu\n\t\tInvFbk_pu[i].Sts_PF := InvFbk_raw[i].Sts_PF * UnitTypeCfg[InvCfg[i].UnitTypeID].PFFbk_toPu;\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Converted to pu\n\t\tInvFbk_pu[i].Sts_Freq := InvFbk_raw[i].Sts_Freq * UnitTypeCfg[InvCfg[i].UnitTypeID].FreqFbk_toHz; \t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to Hz using scaling factor\n\t\tInvFbk_pu[i].Sts_Ia := InvFbk_raw[i].Sts_Ia * UnitTypeCfg[InvCfg[i].UnitTypeID].IFbk_toA; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to A using scaling factor\n\t\tInvFbk_pu[i].Sts_Ib := InvFbk_raw[i].Sts_Ib * UnitTypeCfg[InvCfg[i].UnitTypeID].IFbk_toA;  \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to A using scaling factor\n\t\tInvFbk_pu[i].Sts_Ic := InvFbk_raw[i].Sts_Ic * UnitTypeCfg[InvCfg[i].UnitTypeID].IFbk_toA;  \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to A using scaling factor\n\t\tInvFbk_pu[i].Sts_Vab := InvFbk_raw[i].Sts_Vab * UnitTypeCfg[InvCfg[i].UnitTypeID].VFbk_toV;  \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to V using scaling factor\n\t\tInvFbk_pu[i].Sts_Vbc := InvFbk_raw[i].Sts_Vbc * UnitTypeCfg[InvCfg[i].UnitTypeID].VFbk_toV;  \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to V using scaling factor\n\t\tInvFbk_pu[i].Sts_Vca := InvFbk_raw[i].Sts_Vca * UnitTypeCfg[InvCfg[i].UnitTypeID].VFbk_toV;  \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Convert to V using scaling factor\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)543d2827-7582-4c37-acf6-2814f90015bd_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition Inverter Inputs\n///|\tCondition inputs based on inverter config scaling values\n///|\tCondition to CORE values (ie 0-1) and CONDITIONED values (ie kW, kV, etc.)\nMETHOD meth_ConditionInvFbk\nVAR_INPUT\n\t///Raw inverter feedback, directly from inverters\n\tInvFbk_raw: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\n\t///Unit type configuration\n\tUnitTypeCfg: ARRAY[0..SiteConstants.NumUnitTypes] OF TBE_PPC.dt_UnitTypeCfg;\n\t///Array of device configuration structs\n\tInvCfg: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceCfg;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], Conditioned inverter feedback\n\tInvFbk_pu: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\nEND_VAR\nVAR\n\t///Indexing variable\t\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)543d2827-7582-4c37-acf6-2814f90015bd_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}