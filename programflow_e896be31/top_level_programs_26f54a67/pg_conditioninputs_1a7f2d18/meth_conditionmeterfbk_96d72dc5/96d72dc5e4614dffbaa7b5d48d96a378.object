{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)96d72dc5-e461-4dff-baa7-b5d48d96a378","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionMeterFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Loop through HV Meters and condition the inputs\nFOR i := 0 TO SiteConstants.NumHVMeters BY 1 DO\n\tIF i > 0 THEN\n\t\tIF NOT HVMeterFbk_raw[i].STS_flt THEN\n\t\t\t//Move all raw inputs to the conditioned structure so values that need no conditioning are copied over\n\t\t\tHVMeterFbk_pu[i] := HVMeterFbk_raw[i];\n\t\t\t\n\t\t\t//Convert Frequency to pu based on FreqBase\n\t\t\tHVMeterFbk_pu[i].Sts_Freq_raw := HVMeterFbk_raw[i].STS_Freq * HVMeterCfg[i].FreqScale_toHz / PlantCfg.FreqCfg.FreqBase; \n\t\t\t\n\t\t\t//Condition Voltage Feedback\n\t\t\tIF HVMeterCfg[i].VFbkType = TBE_PPC.enum_VFbkType.PhaseNeutral THEN\n\t\t\t\t//Meter Feedback includes phase/neutral voltage only -> Condition phase/neutral feedback and calculate phase/phase feedback\n\t\t\t\t//Condition Voltage feedback to pu based on voltage base\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAN := HVMeterFbk_raw[i].Sts_VAN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBN := HVMeterFbk_raw[i].Sts_VBN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCN := HVMeterFbk_raw[i].Sts_VCN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\t\n\t\t\t\t//Calculate approximate Phase/Phase voltage by multiplying Phase/Neutral voltage by Sqrt(3)\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAB := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VAN * SQRT(3));\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBC := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VBN * SQRT(3));\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCA := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VCN * SQRT(3));\n\t\t\tELSIF HVMeterCfg[i].VFbkType = TBE_PPC.enum_VFbkType.PhasePhase THEN\n\t\t\t\t//Meter Feedback includes phase/phase voltage only -> Condition phase/phase feedback and calculate phase/neutral feedback\n\t\t\t\t//Condition Voltage feedback to pu based on voltage base\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAB := HVMeterFbk_raw[i].Sts_VAB * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBC := HVMeterFbk_raw[i].Sts_VBC * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCA := HVMeterFbk_raw[i].Sts_VCA * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\t\n\t\t\t\t//Calculate approximate Phase/Neutral voltage by multiplying Phase/Phase voltage by Sqrt(3)\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAN := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VAB / SQRT(3));\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBN := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VBC / SQRT(3));\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCN := LREAL_TO_REAL(HVMeterFbk_pu[i].Sts_VCA / SQRT(3));\n\t\t\tELSE\n\t\t\t\t//Meter Feedback includes phase/phase and phase/neutral voltage -> Condition feedback\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAN := HVMeterFbk_raw[i].Sts_VAN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBN := HVMeterFbk_raw[i].Sts_VBN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCN := HVMeterFbk_raw[i].Sts_VCN * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VAB := HVMeterFbk_raw[i].Sts_VAB * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VBC := HVMeterFbk_raw[i].Sts_VBC * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\t\tHVMeterFbk_pu[i].Sts_VCA := HVMeterFbk_raw[i].Sts_VCA * HVMeterCfg[i].VScale_toV / (PlantCfg.VoltageCfg.Vbase * 1000);\n\t\t\tEND_IF\n\t\t\t\n\t\t\t//Condition compensated and uncompensated active and reactive power values to percentage units\n\t\t\tHVMeterFbk_pu[i].Sts_P_Comp := HVMeterFbk_raw[i].Sts_P_Comp * HVMeterCfg[i].PScale_toW / (PlantCfg.SBase * 1000000);\n\t\t\tHVMeterFbk_pu[i].Sts_P_UC := HVMeterFbk_raw[i].Sts_P_UC * HVMeterCfg[i].PScale_toW / (PlantCfg.SBase * 1000000);\n\t\t\tHVMeterFbk_pu[i].Sts_Q_Comp := HVMeterFbk_raw[i].Sts_Q_Comp * HVMeterCfg[i].QScale_toVAr / (PlantCfg.SBase * 1000000);\n\t\t\tHVMeterFbk_pu[i].Sts_Q_UC := HVMeterFbk_raw[i].Sts_Q_UC * HVMeterCfg[i].QScale_toVAr / (PlantCfg.SBase * 1000000);\n\t\t\t\n\t\t\tIF HVMeterCfg[i].SEL735 THEN\n\t\t\t\t//Meter is SEL-735 or equivalent and will provide synchrophasor data. P/Q need to be calculated based on Voltage/Current Feedback\n\n\t\t\t\t//Condition inputs that require it in the HV Conditioned Structure\n\t\t\t\tIF HVMeterFbk_pu[i].STS_VAng < 0 THEN\n\t\t\t\t\tHVMeterFbk_pu[i].STS_VAng := 360.0 + HVMeterFbk_pu[i].STS_VAng; \n\t\t\t\tEND_IF\n\t\t\t\tIF HVMeterFbk_pu[i].STS_IAng < 0 THEN\n\t\t\t\t\tHVMeterFbk_pu[i].STS_IAng := 360.0 + HVMeterFbk_pu[i].STS_IAng; \n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\tIF HVMeterFbk_pu[i].STS_VAng - HVMeterFbk_pu[i].STS_IAng < 0 THEN\n\t\t\t\t\tHVMeterFbk_pu[i].STS_Phi := DEG_TO_RAD(360.0 + HVMeterFbk_pu[i].STS_VAng - HVMeterFbk_pu[i].STS_IAng);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].STS_Phi := DEG_TO_RAD(HVMeterFbk_pu[i].STS_VAng - HVMeterFbk_pu[i].STS_IAng); \n\t\t\t\tEND_IF\n\t\t\t\tHVMeterFbk_pu[i].STS_VLLAvg := LREAL_TO_REAL(HVMeterFbk_pu[i].STS_VMag * SQRT(3) / (PlantCfg.VoltageCfg.Vbase * 1000));\n\t\t\t\tHVMeterFbk_pu[i].STS_IAvg := (HVMeterFbk_pu[i].STS_IA + HVMeterFbk_pu[i].STS_IB + HVMeterFbk_pu[i].STS_IC)/3;\n\t\t\t\tIF HVMeterFbk_pu[i].STS_IMag <> 0 THEN\n\t\t\t\t\tHVMeterFbk_pu[i].STS_ISign := HVMeterFbk_pu[i].STS_IMag / ABS(HVMeterFbk_pu[i].STS_IMag);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].STS_ISign := 1; \n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\t//Calculate active power feedback using synchrophasor calculation, scale to pu based on Sbase and invert if necessary\n\t\t\t\t//Active Power is calculated as P = 3 * V * I * Cos(phi)\n\t\t\t\tIF HVMeterCfg[1].PInvert THEN \n\t\t\t\t\tHVMeterFbk_pu[i].Sts_P_raw := (3 * HVMeterFbk_pu[i].STS_VMag * HVMeterFbk_pu[i].STS_IMag * COS(HVMeterFbk_pu[i].STS_Phi)) / ((PlantCfg.SBase) * 1000000);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_P_raw := -(3 * HVMeterFbk_pu[i].STS_VMag * HVMeterFbk_pu[i].STS_IMag * COS(HVMeterFbk_pu[i].STS_Phi)) / ((PlantCfg.SBase) * 1000000);\n\t\t\t\tEND_IF\n\t\t\t\n\t\t\t\t//Calculate reactive power feedback using synchrophasor calculation, scale to pu based on Sbase and invert if necessary   \n\t\t\t\t//Reactive Power is calculated as Q = 3 * V * I * Sin(phi)  \n\t\t\t\tIF HVMeterCfg[1].QInvert THEN\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_Q_raw := (3 * HVMeterFbk_pu[i].STS_VMag * HVMeterFbk_pu[i].STS_IMag * SIN(HVMeterFbk_pu[i].STS_Phi)) / ((PlantCfg.SBase) * 1000000); \n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_Q_raw := -(3 * HVMeterFbk_pu[i].STS_VMag * HVMeterFbk_pu[i].STS_IMag * SIN(HVMeterFbk_pu[i].STS_Phi)) / ((PlantCfg.SBase) * 1000000); \n\t\t\t\tEND_IF\t\n\t\t\t\n\t\t\t\t//Calculate Power Factor based on P and Q Feedback\n\t\t\t\tIF (HVMeterFbk_pu[i].Sts_P_raw * HVMeterFbk_pu[i].Sts_P_raw + HVMeterFbk_pu[i].Sts_Q_raw * HVMeterFbk_pu[i].Sts_Q_raw) <> 0 THEN\t\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_PF_raw := (HVMeterFbk_pu[i].Sts_Q_raw / ABS(HVMeterFbk_pu[i].Sts_Q_raw)) *HVMeterFbk_pu[i].Sts_P_raw / SQRT(HVMeterFbk_pu[i].Sts_P_raw * HVMeterFbk_pu[i].Sts_P_raw + HVMeterFbk_pu[i].Sts_Q_raw * HVMeterFbk_pu[i].Sts_Q_raw);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_PF_raw := 1; \t\t//Protect against divide by 0 -> set PF to 1 if P/Q feedback is 0\n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\t//Protection against PF NaN\n\t\t\t\tIF NOT Fun_IsValidReal(HVMeterFbk_pu[i].Sts_PF_raw) THEN\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_PF_raw := 1.0; \n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\tHVMeterFbk_pu[i].Sts_Qlty := 192;                //Data quality\n\t\t\t\tHVMeterFbk_pu[i].Sts_Vreg_raw := HVMeterFbk_pu[i].STS_VLLAvg - LDCSts.LDCVDrop; \n\t\t\tELSE\n\t\t\t\t//Meter is NOT SEL-735 and will not provide synchrophasor data. \n\t\t\t\t//Scale Feedback w/out calculations for synchrophasor data\n\t\t\t\tIF HVMeterCfg[i].PInvert THEN\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_P_raw := -HVMeterFbk_raw[i].Sts_P * HVMeterCfg[i].PScale_toW / (PlantCfg.SBase * 1000000);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_P_raw := HVMeterFbk_raw[i].Sts_P * HVMeterCfg[i].PScale_toW / (PlantCfg.SBase * 1000000);\n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\tIF HVMeterCfg[i].QInvert THEN\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_Q_raw := -HVMeterFbk_raw[i].Sts_Q * HVMeterCfg[i].QScale_toVAr / (PlantCfg.SBase * 1000000);\n\t\t\t\tELSE\n\t\t\t\t\tHVMeterFbk_pu[i].Sts_Q_raw := HVMeterFbk_raw[i].Sts_Q * HVMeterCfg[i].QScale_toVAr / (PlantCfg.SBase * 1000000);\n\t\t\t\tEND_IF\n\t\t\t\t\n\t\t\t\tHVMeterFbk_pu[i].Sts_PF_raw := HVMeterFbk_raw[i].Sts_PF * HVMeterCfg[i].PFScale; \n\t\t\t\tHVMeterFbk_pu[i].Sts_IA := HVMeterFbk_raw[i].Sts_IA * HVMeterCfg[i].IScale_toA;\n\t\t\t\tHVMeterFbk_pu[i].Sts_IB := HVMeterFbk_raw[i].Sts_IB * HVMeterCfg[i].IScale_toA;\n\t\t\t\tHVMeterFbk_pu[i].Sts_IC := HVMeterFbk_raw[i].Sts_IC * HVMeterCfg[i].IScale_toA;\n\t\t\t\t\n\t\t\t\t//Calculate Line-Line Average Voltage and Vreg\n\t\t\t\tHVMeterFbk_pu[i].Sts_VLLAvg := (HVMeterFbk_pu[i].Sts_VAB + HVMeterFbk_pu[i].Sts_VBC + HVMeterFbk_pu[i].Sts_VCA) / 3.0;\n\t\t\t\tHVMeterFbk_pu[i].Sts_Vreg_raw := HVMeterFbk_pu[i].STS_VLLAvg - LDCSts.LDCVDrop; \n\t\t\tEND_IF\n\t\t\t\n\t\t\t//Feedback Filtering - Raw values will be stored in the _raw tags\n\t\t\t//Only values used for Control will be filtered (P, Q, VLL_Avg, PF, and Frequency)\n\t\t\tHVMeterFilter_P[i](Tcon := PlantCfg.ActivePwrCfg.Tp, Interval := PPC.TaskTime, RawIn := HVMeterFbk_pu[i].Sts_P_raw, OutMin := -1, OutMax := 1, Out => HVMeterFbk_pu[i].Sts_P);\n\t\t\tHVMeterFilter_Q[i](Tcon := PlantCfg.ReactivePwrCfg.Tq, Interval := PPC.TaskTime, RawIn := HVMeterFbk_pu[i].Sts_Q_raw, OutMin := -1, OutMax := 1, Out => HVMeterFbk_pu[i].Sts_Q);\n\t\t\tHVMeterFilter_V[i](Tcon := PlantCfg.VoltageCfg.FiltTime, Interval := PPC.TaskTime, RawIn := HVMeterFbk_pu[i].Sts_Vreg_raw, OutMin := -0.5, OutMax := 1.5, Out => HVMeterFbk_pu[i].Sts_Vreg);\n\t\t\tHVMeterFilter_PF[i](Tcon := PlantCfg.PFCfg.FiltTime, Interval := PPC.TaskTime, RawIn := HVMeterFbk_pu[i].Sts_PF_raw, OutMin := -1, OutMax := 1, Out => HVMeterFbk_pu[i].Sts_PF);\n\t\t\tHVMeterFilter_Freq[i](Tcon := PlantCfg.FreqCfg.FiltTime, Interval := PPC.TaskTime, RawIn := HVMeterFbk_pu[i].Sts_Freq_raw, OutMin := 0, OutMax := 2, Out => HVMeterFbk_pu[i].Sts_Freq);\n\t\tELSE\n\t\t\t//Meter is faulted\n\t\t\tHVMeterFbk_pu[i] := faultedMeterFbk; \n\t\tEND_IF\n\tEND_IF\nEND_FOR\n\n\n//Loop through the MV Meters and condition the inputs\nFOR i := 0 TO SiteConstants.NumMVMeters BY 1 DO\n\tIF i > 0 THEN\n\t\tIF NOT MVMeterFbk_raw[i].STS_flt THEN\n\t\t\t//Move all raw inputs to the conditioned structure so values that need no conditioning are copied over\n\t\t\tMVMeterFbk_pu[i] := MVMeterFbk_raw[i];\n\t\t\t\n\t\t\t//Condition inputs that require it in the MV Conditioned Structure\n\t\t\tIF MVMeterFbk_pu[i].STS_VAng < 0 THEN\n\t\t\t\tMVMeterFbk_pu[i].STS_VAng := 360.0 + MVMeterFbk_pu[i].STS_VAng; \n\t\t\tEND_IF\n\t\t\tIF MVMeterFbk_pu[i].STS_IAng < 0 THEN\n\t\t\t\tMVMeterFbk_pu[i].STS_IAng := 360.0 + MVMeterFbk_pu[i].STS_IAng; \n\t\t\tEND_IF\n\t\t\tMVMeterFbk_pu[i].Sts_Freq_raw := MVMeterFbk_raw[i].STS_Freq / PlantCfg.FreqCfg.FreqBase; \n\t\t\tIF MVMeterFbk_pu[i].STS_VAng - MVMeterFbk_pu[i].STS_IAng < 0 THEN\n\t\t\t\tMVMeterFbk_pu[i].STS_Phi := DEG_TO_RAD(360.0 + MVMeterFbk_pu[i].STS_VAng - MVMeterFbk_pu[i].STS_IAng);\n\t\t\tELSE\n\t\t\t\tMVMeterFbk_pu[i].STS_Phi := DEG_TO_RAD(MVMeterFbk_pu[i].STS_VAng - MVMeterFbk_pu[i].STS_IAng); \n\t\t\tEND_IF\n\t\t\tMVMeterFbk_pu[i].STS_VLLAvg := LREAL_TO_REAL(MVMeterFbk_pu[i].STS_VMag * SQRT(3) / (PlantCfg.VoltageCfg.Vbase * 1000));\n\t\t\tMVMeterFbk_pu[i].STS_IAvg := (MVMeterFbk_pu[i].STS_IA + MVMeterFbk_pu[i].STS_IB + MVMeterFbk_pu[i].STS_IC)/3;\n\t\t\tIF MVMeterFbk_pu[i].STS_IMag <> 0 THEN\n\t\t\t\tMVMeterFbk_pu[i].STS_ISign := MVMeterFbk_pu[i].STS_IMag / ABS(MVMeterFbk_pu[i].STS_IMag);\n\t\t\tELSE\n\t\t\t\tMVMeterFbk_pu[i].STS_ISign := 1; \n\t\t\tEND_IF\n\t\t\t//Calculate active power feedback and convert to pu Sbase\n\t\t\tMVMeterFbk_pu[i].STS_P_raw := -(3*MVMeterFbk_pu[i].STS_VMag*MVMeterFbk_pu[i].STS_IMag*COS(MVMeterFbk_pu[i].STS_Phi))/((PlantCfg.SBase)*1000000);\n\t\t\t\n\t\t\t//Invert active power, if PInvert\n\t\t\tIF MVMeterCfg[i].PInvert THEN \n\t\t\t\tMVMeterFbk_pu[i].STS_P_raw:=-MVMeterFbk_pu[i].STS_P_raw;\n\t\t\tEND_IF\n\t\t\tMVMeterFbk_pu[i].STS_Q_raw:=-(3*MVMeterFbk_pu[i].STS_VMag*MVMeterFbk_pu[i].STS_IMag*SIN(MVMeterFbk_pu[i].STS_Phi))/((PlantCfg.SBase)*1000000);    //Reactive power\n\t\t\t\n\t\t\t//Invert reactive power, if Invert   \n\t\t\tIF MVMeterCfg[i].QInvert THEN \n\t\t\t\tMVMeterFbk_pu[i].STS_Q_raw:=-MVMeterFbk_pu[i].STS_Q_raw;\n\t\t\tEND_IF\t\n\t\t\n\t\t\t\t //END_IF\n\t\t\tMVMeterFbk_pu[i].Sts_PF_raw := (MVMeterFbk_pu[i].STS_Q_raw / ABS(MVMeterFbk_pu[i].STS_Q_raw)) * MVMeterFbk_pu[i].STS_P_raw / SQRT(MVMeterFbk_pu[i].STS_P_raw * MVMeterFbk_pu[i].STS_P_raw + MVMeterFbk_pu[i].STS_Q_raw * MVMeterFbk_pu[i].STS_Q_raw);\n\t\t\t//Protection against PF NaN\n\t\t\tIF NOT Fun_IsValidReal(MVMeterFbk_pu[i].Sts_PF_raw) THEN\n\t\t\t\tMVMeterFbk_pu[i].Sts_PF_raw := 1.0; \n\t\t\tEND_IF\n\t\t\tMVMeterFbk_pu[i].Sts_Qlty := 192;                //Data quality\n\t\t\tMVMeterFbk_pu[i].Sts_Vreg_raw := MVMeterFbk_pu[i].STS_VLLAvg;\n\t\t\t\n\t\t\t//Feedback Filtering - Raw values will be stored in the _raw tags\n\t\t\t//Only values used for Control will be filtered (P, Q, VLL_Avg, PF, and Frequency)\n\t\t\tMVMeterFilter_P[i](Tcon := PlantCfg.ActivePwrCfg.Tp, Interval := PPC.TaskTime, RawIn := MVMeterFbk_pu[i].Sts_P_raw, OutMin := -1, OutMax := 1, Out => MVMeterFbk_pu[i].Sts_P);\n\t\t\tMVMeterFilter_Q[i](Tcon := PlantCfg.ReactivePwrCfg.Tq, Interval := PPC.TaskTime, RawIn := MVMeterFbk_pu[i].Sts_Q_raw, OutMin := -1, OutMax := 1, Out => MVMeterFbk_pu[i].Sts_Q);\n\t\t\tMVMeterFilter_V[i](Tcon := PlantCfg.VoltageCfg.FiltTime, Interval := PPC.TaskTime, RawIn := MVMeterFbk_pu[i].Sts_Vreg_raw, OutMin := -1, OutMax := 1, Out => MVMeterFbk_pu[i].Sts_Vreg);\n\t\t\tMVMeterFilter_PF[i](Tcon := PlantCfg.PFCfg.FiltTime, Interval := PPC.TaskTime, RawIn := MVMeterFbk_pu[i].Sts_PF_raw, OutMin := -1, OutMax := 1, Out => MVMeterFbk_pu[i].Sts_PF);\n\t\t\tMVMeterFilter_Freq[i](Tcon := PlantCfg.FreqCfg.FiltTime, Interval := PPC.TaskTime, RawIn := MVMeterFbk_pu[i].Sts_Freq_raw, OutMin := -1, OutMax := 1, Out => MVMeterFbk_pu[i].Sts_Freq);\n\t\tELSE\n\t\t\t//Meter is faulted\n\t\t\tMVMeterFbk_pu[i] := faultedMeterFbk; \n\t\tEND_IF\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)96d72dc5-e461-4dff-baa7-b5d48d96a378_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition Meter Inputs Method\n///|\tLoop through HV and MV meter feedback arrays and condition inputs\nMETHOD meth_ConditionMeterFbk\nVAR_INPUT\n\t///HV Meter Fbk, raw/unscaled values\n\tHVMeterFbk_raw: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///MV Meter Fbk, raw/unscaled values\n\tMVMeterFbk_raw: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///Plant configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\n\t///Array of HV meter configuration structures\n\tHVMeterCfg: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///Array of MV meter configuration structures\n\tMVMeterCfg: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterCfg;\n\t///PDC Status\n\tLDCSts: TBE_PPC.dt_LDCSts;\nEND_VAR\nVAR_OUTPUT\n\t///[pu], HV Meter Fbk, scaled to pu\n\tHVMeterFbk_pu: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\t///[pu], MV Meter Fbk, scaled to pu\n\tMVMeterFbk_pu: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: DINT;\n\tfaultedMeterFbk: TBE_PPC.dt_MeterFbk := (STS_Flt := TRUE, STS_VMag := 0.0, STS_VAng := 0.0, STS_IMag := 0.0, STS_IAng := 0.0, STS_Freq := 0.0, STS_P := 0.0, STS_Q := 0.0, STS_VLLAvg := 0.0, STS_IAvg := 0.0, STS_PF := 0.0, STS_Qlty := 536, Sts_flt := TRUE);\nEND_VAR\n","LineInfoPersistence":"(string)96d72dc5-e461-4dff-baa7-b5d48d96a378_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}