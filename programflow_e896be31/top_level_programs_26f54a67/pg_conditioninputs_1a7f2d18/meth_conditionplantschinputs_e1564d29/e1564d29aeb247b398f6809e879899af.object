{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)e1564d29-aeb2-47b3-98f6-809e879899af","ParentGuid":"(Guid)1a7f2d18-51af-4417-86b2-87659935c5ef","Name":"(string)meth_ConditionPlantSchInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire structure\nPlantSchInputs_pu := PlantSchInputs_raw; \n\n//Scale/Condition values as necessary\n//Real Power Related\nPlantSchInputs_pu.ActivePwr.PSp_PV := PlantSchInputs_raw.ActivePwr.PSp_PV / PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t\t//Scale from MW to pu\nPlantSchInputs_pu.ActivePwr.FreqTestSp_Hz := PlantSchInputs_raw.ActivePwr.FreqTestSp_Hz / PlantCfg.FreqCfg.FreqBase; \t\t\t\t\t\t//Scale from Hz to pu\n\n//Reactive Power Related\nPlantSchInputs_pu.ReactivePwr.QSp := PlantSchInputs_raw.ReactivePwr.QSp / PlantCfg.Sbase; \t\t\t\t\t\t\t\t\t\t\t\t\t//Scale from MVar to pu\nPlantSchInputs_pu.ReactivePwr.VSp := PlantSchInputs_raw.ReactivePwr.VSp / PlantCfg.VoltageCfg.Vbase; \t\t\t\t\t\t\t\t\t\t//Scale from kV to pu","LineInfoPersistence":"(string)e1564d29-aeb2-47b3-98f6-809e879899af_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tCondition plant inputs from scheduler\n///|\tConvert from enginering units to pu for use in core logic\nMETHOD meth_ConditionPlantSchInputs\nVAR_INPUT\n\t///Plant remote inputs in raw/unscaled form\n\tPlantSchInputs_raw: TBE_PPC.dt_PlantHMIInputs;\n\t///Plant Configuration structure\n\tPlantCfg: TBE_PPC.dt_PlantCfg;\nEND_VAR\nVAR_OUTPUT\n\t///Plant remote inputs in pu (for use in core logic)\n\tPlantSchInputs_pu: TBE_PPC.dt_PlantHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)e1564d29-aeb2-47b3-98f6-809e879899af_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}