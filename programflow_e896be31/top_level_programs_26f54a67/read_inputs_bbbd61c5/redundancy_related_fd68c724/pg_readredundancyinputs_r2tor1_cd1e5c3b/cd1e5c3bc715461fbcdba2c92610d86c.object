{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)cd1e5c3b-c715-461f-bcdb-a2c92610d86c","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_ReadRedundancyInputs_R2ToR1","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)fd68c724-0bd1-4cfd-a6d7-c0c336669ede"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Call methods to read inputs from remote/redundant controller -> Methods will access output vars instantiated within this program\n\n//Configuration tags from remote controller - Plant Cfg tags only will be passed from remote -> local controller\nmeth_ReadPlantCfgEng(); \n\n//Plant HMI Inputs\nmeth_ReadPlantHMIInputs();\n\n//Device HMI Inputs\nmeth_ReadInvHMIInputs();\nmeth_ReadEMSHMIInputs(); \nmeth_ReadCapBankHMIInputs();\n\n//Remote Controller Inputs (Redundancy-specific inputs)\nmeth_ReadRemoteCtrlInputs();\n\n//Read redundnacy related inputs\nmeth_ReadRedundancyHMIInputs();\n\n//Read capacitor bank configuration struct and number of operations\nmeth_ReadCapBankCfg(); \n","LineInfoPersistence":"(string)cd1e5c3b-c715-461f-bcdb-a2c92610d86c_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM pg_ReadRedundancyInputs_R2ToR1\nVAR_OUTPUT\n\tPlantCfg_Eng\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t//Plant Configuration struct (in engineering units)\n\tPlantHMIInputs\t\t: TBE_PPC.dt_PlantHMIInputs;\t\t\t\t\t\t\t\t\t\t\t//Plant HMI Inputs\n\tRedundancyHMIInputs\t: TBE_PPC.dt_RedundancyHMIInputs;\t\t\t\t\t\t\t\t\t\t//Redundancy HMI Inputs\n\tRemoteCtrlInputs\t: TBE_PPC.dt_RemoteCtrlInputs;\t\t\t\t\t\t\t\t\t\t\t//Remote control inputs\n\tCapBankHMIInputsArr\t: ARRAY[0..10] OF TBE_PPC.dt_CapBankHMIInputs;\t\t\t\t\t\t\t//Array of cap bank HMI Inputs -> to move to DNP Server tags\n\tInvHMIInputsArr\t\t: ARRAY[0..150] OF TBE_PPC.dt_DeviceHMIInputs;\t\t\t\t\t\t\t//Array of inverter HMI Inputs -> to move to DNP Server tags\n\tEMSHMIInputsArr\t\t: ARRAY[0..4] OF TBE_PPC.dt_DeviceHMIInputs;\t\t\t\t\t\t\t//Array of EMS HMI Inputs -> to move to DNP Server tags\n\tRedundancySts\t\t: TBE_PPC.dt_RedundancyDiagnostics;\t\t\t\t\t\t\t\t\t\t//Redundancy diagnostics structure\n\tCapBankCfg\t\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Capacitor bank configuration structs\n\tCapBankNumOper\t\t: ARRAY[0..10] OF UINT;\t\t\t\t\t\t\t\t\t\t\t\t\t//Array of capacitor bank number of operations\n\tCapOpenThreshArr\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t//Array of capacitor bank open threshold values\n\tCapCloseThreshArr\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t//Array of capacitor bank close threshold values\n\tCapNomRatingArr\t\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t\t\t\t\t\t//Array of capacitor bank nominal ratings\n\tRemoteSourceInputs1\t: TBE_PPC.dt_PlantRemoteInputs; \t\t\t\t\t\t\t\t\t\t//Inputs from remote source 1\nEND_VAR","LineInfoPersistence":"(string)cd1e5c3b-c715-461f-bcdb-a2c92610d86c_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)71","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}