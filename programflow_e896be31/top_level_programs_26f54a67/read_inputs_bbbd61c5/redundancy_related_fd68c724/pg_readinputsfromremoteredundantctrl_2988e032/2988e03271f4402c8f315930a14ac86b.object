{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)2988e032-71f4-402c-8f31-5930a14ac86b","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_ReadInputsFromRemoteRedundantCtrl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)fd68c724-0bd1-4cfd-a6d7-c0c336669ede"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Read inputs from redundant controller -> Remote Controller will be a DNP Server. This method will store the individual values coming across the DNP server into the Inputs and Cfg Structure\n\nIF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC1 THEN\n\t//Enable R2 to R1 DNP Client -> Read values from the R2 to R1 DNP Client\n\tRedundancyClient_R1ToR2_DNP_POU.En := FALSE;\n\tRedundancyClient_R2ToR1_DNP_POU.En := TRUE;\t\t//Enable R2 -> R1 Client\n\tPPCDNPServer_R2ToR1_DNP_POU.EN := FALSE;\n\tPPCDNPServer_R1ToR2_DNP_POU.EN := TRUE;\t\t\t//Enable R1 -> R2 Server\n\t\n\tpg_ReadRedundancyInputs_R2ToR1(PlantCfg_Eng => PlantCfg_Eng_Remote,\n\t\tPlantHMIInputs => PPCInputs_Remote.PlantHMIInputs,\n\t\tInvHMIInputsArr => InvHMIInputsArr,\n\t\tEMSHMIInputsArr => EMSHMIInputsArr,\n\t\tCapBankHMIInputsArr => CapBankHMIInputsArr,\n\t\tRedundancyHMIInputs => PPCInputs_Remote.RedundancyHMIInputs,\n\t\tRemoteCtrlInputs => PPCInputs_Remote.RemoteCtrlInputs,\n\t\tRedundancySts => PPCInputs_Remote.RedundancySts_Local,\n\t\tCapBankCfg => CapBankCfg_Remote,\n\t\tCapBankNumOper => CapBankNumOperArr,\n\t\tCapOpenThreshArr => CapOpenThreshArr,\n\t\tCapCloseThreshArr => CapCloseThreshArr,\n\t\tCapNomRatingArr => CapNomRatingArr,\n\t\tRemoteSourceInputs1 => PPCInputs_Remote.PlantRemoteInputs1);\n\n\t//Temp code\n\tIF RedundancyClient_R2ToR1_DNP_POU.Offline THEN\n\t\tPPCInputs_Remote.RedundancySts_Local.Sts_CommsGood := FALSE;\n\t\tPPCInputs_Remote.RedundancySts_Local.Sts_CtrlActive := FALSE;\n\t\tPPCInputs_Remote.RedundancySts_Local.STS_Enabled := FALSE;\n\tEND_IF\n\t\t\nELSIF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC2 THEN\n\t//Enable R1 to R2 DNP Client -> Read values from the R1 to R2 DNP Client\n\tRedundancyClient_R1ToR2_DNP_POU.En := TRUE;\t\t//Enable R1 -> R2 Client\n\tRedundancyClient_R2ToR1_DNP_POU.En := FALSE;\n\tPPCDNPServer_R2ToR1_DNP_POU.EN := TRUE;\t\t\t//Enable R2 -> R1 Server\n\tPPCDNPServer_R1ToR2_DNP_POU.EN := FALSE;\t\t\t\n\t\n\tpg_ReadRedundancyInputs_R1ToR2(PlantCfg_Eng => PlantCfg_Eng_Remote,\n\t\tPlantHMIInputs => PPCInputs_Remote.PlantHMIInputs,\n\t\tInvHMIInputsArr => InvHMIInputsArr,\n\t\tEMSHMIInputsArr => EMSHMIInputsArr,\n\t\tCapBankHMIInputsArr => CapBankHMIInputsArr,\n\t\tRedundancyHMIInputs => PPCInputs_Remote.RedundancyHMIInputs,\n\t\tRemoteCtrlInputs => PPCInputs_Remote.RemoteCtrlInputs,\n\t\tRedundancySts => PPCInputs_Remote.RedundancySts_Local,\n\t\tCapBankCfg => CapBankCfg_Remote,\n\t\tCapBankNumOper => CapBankNumOperArr,\n\t\tCapOpenThreshArr => CapOpenThreshArr,\n\t\tCapCloseThreshArr => CapCloseThreshArr,\n\t\tCapNomRatingArr => CapNomRatingArr,\n\t\tRemoteSourceInputs1 => PPCInputs_Remote.PlantRemoteInputs1);\nEND_IF\n\n//Move inverter HMI Inputs from input variable to array w/ length of 150 -> DNP server has fields for 150 inverters \nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tPPCInputs_Remote.InvHMIInputs[i] := InvHMIInputsArr[i];\nEND_FOR\n\n//Move EMS HMI Inputs from input variable to array w/ length of 2 -> DNP server has fields for 2 EMS modules\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tPPCInputs_Remote.EMSHMIInputs[i] := EMSHMIInputsArr[i];\nEND_FOR\n\n//Move Cap Bank HMI Inputs from input variable to array w/ length of 10 -> DNP server has fields for 10 cap banks\nFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\tPPCInputs_Remote.CapBankHMIInputs[i] := CapBankHMIInputsArr[i];\n\tCapBankCfg_Remote.CapCloseThresh[i] := CapCloseThreshArr[i];\n\tCapBankCfg_Remote.CapOpenThresh[i] := CapOpenThreshArr[i];\n\tCapBankCfg_Remote.CapNomRating[i] := CapNomRatingArr[i];\n\tCapBankNumOper_Remote[i] := CapBankNumOperArr[i];\nEND_FOR\n\n//Call Program to enable/disable Meter C37 Connections\npg_EnableDisableC37Meters(RedundancyCfg := RedundancyCfg); ","LineInfoPersistence":"(string)2988e032-71f4-402c-8f31-5930a14ac86b_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRead inputs from remote controller via the DNP connection between controllers. \n|\tEach RTAC will serve as a DNP Server. Each RTAC will have two DNP client connections - only one of these DNP client connections will be used (the client connection to the remote RTAC)\n*)\nPROGRAM pg_ReadInputsFromRemoteRedundantCtrl\nVAR_INPUT\n\tRedundancyCfg\t\t\t: TBE_PPC.dt_RedundancyCfg;\t\t\t//Redundancy configuration struct\nEND_VAR\nVAR_OUTPUT\n\tPPCInputs_Remote\t\t: dt_PPCInputs; \t\t\t\t\t\t\t\t\t//Structure of PPC Inputs from remote PPC\n\tPlantCfg_Eng_Remote\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t\t\t//Configuration structure from remote PPC\n\tCapBankCfg_Remote\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t//Cap Bank configuration struct from remote PPC\n\tCapBankNumOper_Remote\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t//Array of number of cap bank operations, from remote PPC\nEND_VAR\nVAR\n\ti\t\t\t\t\t: UINT;\t\t\t\t\t\t\t\t\t\t\t\t//Indexing variable\n\tCapBankHMIInputsArr\t: ARRAY[0..10] OF TBE_PPC.dt_CapBankHMIInputs;\t\t//Array of cap bank HMI Inputs -> to move to DNP Server tags\n\tInvHMIInputsArr\t\t: ARRAY[0..150] OF TBE_PPC.dt_DeviceHMIInputs;\t\t//Array of inverter HMI Inputs -> to move to DNP Server tags\n\tEMSHMIInputsArr\t\t: ARRAY[0..4] OF TBE_PPC.dt_DeviceHMIInputs;\t\t//Array of EMS HMI Inputs -> to move to DNP Server tags\n\tCapBankNumOper\t\t: ARRAY[0..10] OF UINT;\t\t\t\t\t\t\t\t//Array of capacitor bank number of operations\n\tCapOpenThreshArr\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t//Array of capacitor bank open threshold values\n\tCapCloseThreshArr\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t//Array of capacitor bank close threshold values\n\tCapNomRatingArr\t\t: ARRAY[0..10] OF REAL;\t\t\t\t\t\t\t\t//Array of capacitor bank nominal ratings\n\tCapBankNumOperArr\t: ARRAY[0..10] OF UINT;\t\t\t\t\t\t\t\t//Array of capacitor bank number of operations\nEND_VAR","LineInfoPersistence":"(string)2988e032-71f4-402c-8f31-5930a14ac86b_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)138","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}