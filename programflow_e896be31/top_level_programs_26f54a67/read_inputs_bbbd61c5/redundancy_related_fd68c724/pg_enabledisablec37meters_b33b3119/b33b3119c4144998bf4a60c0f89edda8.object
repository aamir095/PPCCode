{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b33b3119-c414-4998-bf4a-60c0f89edda8","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_EnableDisableC37Meters","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)fd68c724-0bd1-4cfd-a6d7-c0c336669ede"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC1 THEN\n\t//This code block will run on RTAC1 only -> Enable meter connections required for RTAC1 and Disable meter connections for RTAC2\n\t//Enable RTAC1 Meters\n\t//PM1_C37_118_POU.EN := TRUE;\n\t\n\t//Disable RTAC2 Meters\n\t\nELSIF SystemTags.Serial_Number.strVal = RedundancyCfg.SN_RTAC2 THEN\n\t//This code block will run on RTAC2 only -> Enable meter connections required for RTAC2 and Disable meter connections for RTAC1\n\t//Enable RTAC2 Meters\n\t\n\t//Disable RTAC1 Meters\n\t//PM1_C37_118_POU.EN := FALSE;\n\t\nELSE\n\t//Incorrect configuration -> do nothing\nEND_IF","LineInfoPersistence":"(string)b33b3119-c414-4998-bf4a-60c0f89edda8_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tProgram to enable/disable C37 meters for redundant PPCs\n|\tPPC program will include C37 client devices for all meters. However, only certain C37 clients will be used for RTAC1 while others will be used for RTAC2\n|\tThis program will enable the relevant meter connections and disable the meter connections that are not required\n*)\nPROGRAM pg_EnableDisableC37Meters\nVAR_INPUT\n\tRedundancyCfg\t\t\t: TBE_PPC.dt_RedundancyCfg;\t\t\t//Redundancy configuration struct\nEND_VAR\nVAR\nEND_VAR","LineInfoPersistence":"(string)b33b3119-c414-4998-bf4a-60c0f89edda8_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)38","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}