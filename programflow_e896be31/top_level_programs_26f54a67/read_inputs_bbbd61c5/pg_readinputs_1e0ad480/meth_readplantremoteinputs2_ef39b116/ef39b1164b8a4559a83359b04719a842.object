{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)ef39b116-4b8a-4559-a833-59b04719a842","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadPlantRemoteInputs2","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Update based on site remote input requirements\n//Active Power Inputs\nPlantRemoteInputs2_raw.PSp_POI := RemoteInterfaceMap_DNP.Rem2Psp.status.instMag;\nPlantRemoteInputs2_raw.PSp_PV := RemoteInterfaceMap_DNP.Rem2PSpPV.status.instMag;\nPlantRemoteInputs2_raw.PSp_BESS := RemoteInterfaceMap_DNP.Rem2PSpBESS.status.instMag;\nPlantRemoteInputs2_raw.PClosedLoopCtrlEn := RemoteInterfaceMap_DNP.Rem2PClosedLoopCtrlEn.status.stVal;\n\n//Reactive Power Inputs\nIF UseQModeBoolInputs THEN\n\t//Use PF/V/Q Ctrl En boolean inputs to determine desired reactive power operating mode\n\tIF RemoteInterfaceMap_DNP.Rem2PFCtrlEn.status.stVal THEN\n\t\tPlantRemoteInputs2_raw.QOpMode := Cfg_GVL.PlantCfg.AVR_PF;\n\tELSIF RemoteInterfaceMap_DNP.Rem2VCtrlEn.status.stVal THEN\n\t\tPlantRemoteInputs2_raw.QOpMode := Cfg_GVL.PlantCfg.AVR_V;\n\tELSE\n\t\tPlantRemoteInputs2_raw.QOpMode := Cfg_GVL.PlantCfg.AVR_Q;\n\tEND_IF\nELSE\n\t//Use Integer Input (Rem2QMd) to determine desired reactive power operating mode\n\tPlantRemoteInputs2_raw.QOpMode := REAL_TO_UINT(RemoteInterfaceMap_DNP.Rem2Qmd.status.instMag);\nEND_IF\n\nPlantRemoteInputs2_raw.QSp := RemoteInterfaceMap_DNP.Rem2QSp.status.instMag;\nPlantRemoteInputs2_raw.VSp := RemoteInterfaceMap_DNP.Rem2Vsp.status.instMag;\nPlantRemoteInputs2_raw.PFSp := RemoteInterfaceMap_DNP.Rem2PFSp.status.instMag;\nPlantRemoteInputs2_raw.QClosedLoopCtrlEn := RemoteInterfaceMap_DNP.Rem2PClosedLoopCtrlEn.status.stVal;\n\n//Ramp Rates\nPlantRemoteInputs2_raw.PUpLim_POI := RemoteInterfaceMap_DNP.Rem2PRampUpRate_POI.status.instMag;\nPlantRemoteInputs2_raw.PDnLim_POI := RemoteInterfaceMap_DNP.Rem2PRampDnRate_POI.status.instMag;\nPlantRemoteInputs2_raw.PUpLim_PV := RemoteInterfaceMap_DNP.Rem2PRampUpRate_PV.status.instMag;\nPlantRemoteInputs2_raw.PDnLim_PV := RemoteInterfaceMap_DNP.Rem2PRampDnRate_PV.status.instMag;\nPlantRemoteInputs2_raw.PUpLim_BESS := RemoteInterfaceMap_DNP.Rem2PRampUpRate_BESS.status.instMag;\nPlantRemoteInputs2_raw.PDnLim_BESS := RemoteInterfaceMap_DNP.Rem2PRampDnRate_BESS.status.instMag;\nPlantRemoteInputs2_raw.QUpLim := RemoteInterfaceMap_DNP.Rem2QRampUpRate.status.instMag;\nPlantRemoteInputs2_raw.QDnLim := RemoteInterfaceMap_DNP.Rem2QRampDnRate.status.instMag;\nPlantRemoteInputs2_raw.QUpLim_VMode := RemoteInterfaceMap_DNP.Rem2QRampUpRate_Vmode.status.instMag;\nPlantRemoteInputs2_raw.QDnLim_VMode := RemoteInterfaceMap_DNP.Rem2QRampDnRate_Vmode.status.instMag;\n\n//Heartbeat/Other\nPlantRemoteInputs2_raw.Heartbeat := REAL_TO_INT(RemoteInterfaceMap_DNP.Rem2Heartbeat.status.instMag);\n","LineInfoPersistence":"(string)ef39b116-4b8a-4559-a833-59b04719a842_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead Remote Plant Inputs\n///|\tPlant inputs will come from remote source 2 (ie not SEL HMI or Ignition)\nMETHOD meth_ReadPlantRemoteInputs2\nVAR_OUTPUT\n\tPlantRemoteInputs2_raw: TBE_PPC.dt_PlantRemoteInputs;\nEND_VAR\nVAR\n\t///Set to True to use Reactive Power Mode Boolean Selection Inputs (Q/V/PF Ctrl En bits), Set to False to use the Qmd integer input\n\tUseQModeBoolInputs: BOOL := FALSE;\nEND_VAR\n","LineInfoPersistence":"(string)ef39b116-4b8a-4559-a833-59b04719a842_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}