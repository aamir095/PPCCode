{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)77d2e717-ed30-4b85-8250-73c844abf5ef","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadEMSHMIInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Read EMS Device inputs from the SCADA GVL\nEMSHMIInputs_raw := SCADA_GVL.EMSHMIInputs; \n\n//Move data from the SCADA GVL to the HMI Inputs Arr\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 THEN\n\t\tEMSHMIInputsArr[i] := EMSHMIInputs_raw[i];\n\tEND_IF\nEND_FOR\n\n//Boolean Inputs\nIF Cfg_GVL.EnableSELHMICtrl THEN\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Estop.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Estop := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Estop.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Estop := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_PAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].PAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_PAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].PAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_QAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].QAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_QAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].QAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Reset.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Reset := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Reset.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Reset := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Reset2.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Reset2 := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Reset2.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Reset2 := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Run.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_Run.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[1].Run := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Estop.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Estop := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Estop.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Estop := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_PAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].PAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_PAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].PAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_QAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].QAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_QAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].QAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Reset.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Reset := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Reset.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Reset := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Reset2.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Reset2 := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Reset2.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Reset2 := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Run.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_Run.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[2].Run := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Estop.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Estop := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Estop.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Estop := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_PAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].PAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_PAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].PAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_QAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].QAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_QAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].QAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Reset.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Reset := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Reset.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Reset := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Reset2.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Reset2 := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Reset2.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Reset2 := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Run.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_Run.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[3].Run := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Estop.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Estop := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Estop.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Estop := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_PAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].PAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_PAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].PAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_QAutoEn.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].QAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_QAutoEn.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].QAutoEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Reset.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Reset := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Reset.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Reset := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Reset2.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Reset2 := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Reset2.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Reset2 := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Run.operLatchOn.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_Run.operLatchOff.ctlVal THEN\n\t\tEMSHMIInputsArr[4].Run := FALSE;\n\tEND_IF\n\t\n\t\n\t//Analog  Inputs\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_PSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[1].PSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_PSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_QSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[1].QSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_1_QSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_PSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[2].PSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_PSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_QSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[2].QSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_2_QSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_PSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[3].PSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_PSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_QSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[3].QSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_3_QSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_PSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[4].PSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_PSp.oper.setMag;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_QSp.oper.trigger THEN\n\t\tEMSHMIInputsArr[4].QSp := PPCDNPServerMap_DNP.SCADA_GVL_EMSHMIInputs_4_QSp.oper.setMag;\n\tEND_IF\nEND_IF\n\n//Move values from the temp array to the SCADA GVL and to the EMSHMIInputs_raw structure (output of this method)\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 AND i <= 4 THEN\n\t\tEMSHMIInputs_raw[i] := EMSHMIInputsArr[i]; \n\t\tSCADA_GVL.EMSHMIInputs[i] := EMSHMIInputsArr[i];\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)77d2e717-ed30-4b85-8250-73c844abf5ef_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead EMS HMI Inputs\n///|\tRead all EMS level HMI Inputs and assign to output structure\n///|\tEMS HMI Inputs can come from the SCADA GVL/OPC UA Server or from the SEL HMI/DNP Server\n///|\tThe DNP Server has a fixed size of available EMS inputs (4 EMS Units). For this reason, the values in the SCADA GVL will be moved to a temporary array (with fixed size of 4 EMS) \n///|\tIf any inputs are updated via the DNP Server, they will be updated in the temporary array, and then the values in the temporary array will be written back to the SCADA GVL. \n///|\tThe purpose of the temporary array is to allow for the OPC UA Server to have a variable number of EMS wile the DNP Server has a fixed number of EMS. \nMETHOD meth_ReadEMSHMIInputs\nVAR_OUTPUT\n\tEMSHMIInputs_raw: ARRAY[0..SiteConstants.NumEMS] OF TBE_PPC.dt_DeviceHMIInputs;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\t///Temporary array for managing inputs from the DNP server w/ fixed array size of 4 EMS Units\n\tEMSHMIInputsArr: ARRAY[0..4] OF TBE_PPC.dt_DeviceHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)77d2e717-ed30-4b85-8250-73c844abf5ef_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}