nputsArr[99].Estop);\n\tEND_IF\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_PAutoEn.operLatchOn.ctlVal THEN\n\t\tInvHMIInputsArr[99].PAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_PAutoEn.operLatchOff.ctlVal THEN\n\t\tInvHMIInputsArr[99].PAutoEn := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_PAutoEn.operPulse.ctlVal THEN\n\t\tInvHMIInputsArr[99].PAutoEn := NOT(InvHMIInputsArr[99].PAutoEn);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_PSp.oper.trigger THEN\n\t\tInvHMIInputsArr[99].PSp := (PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_PSp.oper.setMag);\n\tEND_IF\t\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_QAutoEn.operLatchOn.ctlVal THEN\n\t\tInvHMIInputsArr[99].QAutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_QAutoEn.operLatchOff.ctlVal THEN\n\t\tInvHMIInputsArr[99].QAutoEn := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_QAutoEn.operPulse.ctlVal THEN\n\t\tInvHMIInputsArr[99].QAutoEn := NOT(InvHMIInputsArr[99].QAutoEn);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_QSp.oper.trigger THEN\n\t\tInvHMIInputsArr[99].QSp := (PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_QSp.oper.setMag);\n\tEND_IF\t\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset.operLatchOn.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset.operLatchOff.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset.operPulse.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset := NOT(InvHMIInputsArr[99].Reset);\n\tEND_IF\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset2.operLatchOn.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset2 := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset2.operLatchOff.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset2 := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Reset2.operPulse.ctlVal THEN\n\t\tInvHMIInputsArr[99].Reset2 := NOT(InvHMIInputsArr[99].Reset2);\n\tEND_IF\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Run.operLatchOn.ctlVal THEN\n\t\tInvHMIInputsArr[99].Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Run.operLatchOff.ctlVal THEN\n\t\tInvHMIInputsArr[99].Run := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_DeviceHMIInputs_99_Run.operPulse.ctlVal THEN\n\t\tInvHMIInputsArr[99].Run := NOT(InvHMIInputsArr[99].Run);\n\tEND_IF\nEND_IF\n\n//Move values from the temp array to the SCADA GVL and to the InvHMIInputs_raw structure (output of this method)\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i > 0 AND i <= 150 THEN\n\t\tSCADA_GVL.DeviceHMIInputs[i] := InvHMIInputsArr[i]; \n\t\tInvHMIInputs_raw[i] := InvHMIInputsArr[i];\n\tEND_IF\nEND_FOR\n\n//Reset the 'reset' input for each inverter -> Value has been passed to InvHMIInputs_raw structure and logic will look at rising edge only\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tSCADA_GVL.DeviceHMIInputs[i].Reset := FALSE;\n\tSCADA_GVL.DeviceHMIInputs[i].Reset2 := FALSE;\nEND_FOR","LineInfoPersistence":"(string)5f6d9111-6a18-4511-917f-d56e84b9a466_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead Inverter HMI Inputs\n///|\tRead all inverter level HMI Inputs and assign to output structure\n///|\tInverter HMI Inputs can come from the SCADA GVL/OPC UA Server or from the SEL HMI/DNP Server\n///|\tThe DNP Server has a fixed size of available inverter inputs (150 inverters). For this reason, the values in the SCADA GVL will be moved to a temporary array (with fixed size of 150 inverters) \n///|\tIf any inputs are updated via the DNP Server, they will be updated in the temporary array, and then the values in the temporary array will be written back to the SCADA GVL. \n///|\tThe purpose of the temporary array is to allow for the OPC UA Server to have a variable number of inverters wile the DNP Server has a fixed number of inverters. \nMETHOD meth_ReadInvHMIInputs\nVAR_OUTPUT\n\tInvHMIInputs_raw: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceHMIInputs;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\t///Temporary array for managing inputs from the DNP server w/ fixed array size of 150 inverters\n\tInvHMIInputsArr: ARRAY[0..150] OF TBE_PPC.dt_DeviceHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)5f6d9111-6a18-4511-917f-d56e84b9a466_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}