puts_raw structure\nFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\tIF i > 0 THEN\n\t\tCapBankHMIInputs_raw[i] := CapBankHMIInputsArr[i]; \n\t\tSCADA_GVL.CapBankHMIInputs[i] := CapBankHMIInputsArr[i];\n\tEND_IF\nEND_FOR\n\n//Unlatch manual open/close commands\nFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\tIF i > 0 THEN\n\t\tSCADA_GVL.CapBankHMIInputs[i].CmdCloseManual := FALSE;\n\t\tSCADA_GVL.CapBankHMIInputs[i].CmdOpenManual := FALSE;\t\n\tEND_IF\nEND_FOR","LineInfoPersistence":"(string)170d79ac-d5f0-4fdc-a784-56483b4084d8_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead cap bank inputs from HMI\n///|\tCap Bank HMI Inputs can come from the SCADA GVL/OPC UA Server or from the SEL HMI/DNP Server\n///|\tThe DNP Server has a fixed size of available Cap Bank inputs (10 Cap Banks). For this reason, the values in the SCADA GVL will be moved to a temporary array (with fixed size of 10 Cap Banks) \n///|\tIf any inputs are updated via the DNP Server, they will be updated in the temporary array, and then the values in the temporary array will be written back to the SCADA GVL. \n///|\tThe purpose of the temporary array is to allow for the OPC UA Server to have a variable number of Cap Banks wile the DNP Server has a fixed number of Cap Banks. \nMETHOD meth_ReadCapBankHMIInputs\nVAR_OUTPUT\n\t///Capacitor bank inputs from HMI\n\tCapBankHMIInputs_raw: ARRAY[0..SiteConstants.NumCapBanks] OF TBE_PPC.dt_CapBankHMIInputs;\nEND_VAR\nVAR\n\t///Indexing Variable\n\ti: UINT;\n\t///Temporary array for managing inputs from the DNP server w/ fixed array size of 10 cap banks\n\tCapBankHMIInputsArr: ARRAY[0..10] OF TBE_PPC.dt_CapBankHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)170d79ac-d5f0-4fdc-a784-56483b4084d8_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}