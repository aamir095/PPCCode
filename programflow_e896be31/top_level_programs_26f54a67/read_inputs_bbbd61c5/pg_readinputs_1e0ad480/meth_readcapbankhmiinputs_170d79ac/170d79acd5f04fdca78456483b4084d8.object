oEn);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdCloseManual.operLatchOn.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdCloseManual := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdCloseManual.operLatchOff.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdCloseManual := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdCloseManual.operPulse.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdCloseManual := NOT(CapBankHMIInputsArr[1].CmdCloseManual);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdOpenManual.operLatchOn.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdOpenManual := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdOpenManual.operLatchOff.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdOpenManual := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_1_CmdOpenManual.operPulse.ctlVal THEN\n\t\tCapBankHMIInputsArr[1].CmdOpenManual := NOT(CapBankHMIInputsArr[1].CmdOpenManual);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_AutoEn.operLatchOn.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].AutoEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_AutoEn.operLatchOff.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].AutoEn := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_AutoEn.operPulse.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].AutoEn := NOT(CapBankHMIInputsArr[10].AutoEn);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_CmdCloseManual.operLatchOn.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].CmdCloseManual := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_CmdCloseManual.operLatchOff.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].CmdCloseManual := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_CmdCloseManual.operPulse.ctlVal THEN\n\t\tCapBankHMIInputsArr[10].CmdCloseManual := NOT(CapBankHMIInputsArr[10].CmdCloseManual);\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_CapBankHMIInputs_10_CmdOpenMa