{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8492a8e9-6cee-4cc0-96ac-fef8b2228a7e","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadMeterFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//HV Meter Inputs\n//HV Meter 1\nMeterOfflineTON[1](IN := PM1_C37_118_POU.Offline, PT := Cfg_GVL.PlantCfg.MeterOfflineDelayTime); \nHVMeterFbk[1].STS_flt\t\t:= MeterOfflineTON[1].Q;\nHVMeterFbk[1].STS_Freq\t \t:= PM1_PMUTagList.FREQ.mag;\nHVMeterFbk[1].STS_IA\t\t:= PM1_PMUTagList.IAPM.cVal.mag;\nHVMeterFbk[1].STS_IB\t\t:= PM1_PMUTagList.IBPM.cVal.mag;\nHVMeterFbk[1].STS_IC\t\t:= PM1_PMUTagList.ICPM.cVal.mag;\nHVMeterFbk[1].STS_VAN\t\t:= PM1_PMUTagList.VAPM.cVal.mag;\nHVMeterFbk[1].STS_VBN\t\t:= PM1_PMUTagList.VBPM.cVal.mag;\nHVMeterFbk[1].STS_VCN\t\t:= PM1_PMUTagList.VCPM.cVal.mag;\nHVMeterFbk[1].Sts_VMag\t\t:= PM1_PMUTagList.V1PM.cVal.mag; \nHVMeterFbk[1].STS_VAng\t\t:= PM1_PMUTagList.V1PM.cVal.ang;\nHVMeterFbk[1].STS_IMag\t\t:= PM1_PMUTagList.I1PM.cVal.mag;\nHVMeterFbk[1].STS_IAng\t\t:= PM1_PMUTagList.I1PM.cVal.ang;\n\n\n(*\n//MV Meter Inputs\nMVMeterOfflineTON[1](IN := PM2_C37_118_POU.Offline, PT := Cfg_GVL.PlantCfg.MeterOfflineDelayTime); \nMVMeterFbk[1].STS_flt\t\t:= MVMeterOfflineTON[1].Q;\nMVMeterFbk[1].STS_Freq\t \t:= PM2_C37_118.FREQ.mag;\nMVMeterFbk[1].STS_IA\t\t:= PM2_C37_118.IAPM.cVal.mag;\nMVMeterFbk[1].STS_IB\t\t:= PM2_C37_118.IBPM.cVal.mag;\nMVMeterFbk[1].STS_IC\t\t:= PM2_C37_118.ICPM.cVal.mag;\nMVMeterFbk[1].STS_VAN\t\t:= PM2_C37_118.VAPM.cVal.mag;\nMVMeterFbk[1].STS_VBN\t\t:= PM2_C37_118.VBPM.cVal.mag;\nMVMeterFbk[1].STS_VCN\t\t:= PM2_C37_118.VCPM.cVal.mag;\nMVMeterFbk[1].Sts_VMag\t\t:= PM2_C37_118.V1PM.cVal.mag; \nMVMeterFbk[1].STS_VAB\t\t:= PM2_C37_118.VABPM.cVal.mag;\nMVMeterFbk[1].STS_VBC\t\t:= PM2_C37_118.VBCPM.cVal.mag;\nMVMeterFbk[1].STS_VCA\t\t:= PM2_C37_118.VCAPM.cVal.mag;\nMVMeterFbk[1].STS_VAng\t\t:= PM2_C37_118.V1PM.cVal.ang;\nMVMeterFbk[1].STS_IMag\t\t:= PM2_C37_118.I1PM.cVal.mag;\nMVMeterFbk[1].STS_IAng\t\t:= PM2_C37_118.I1PM.cVal.ang;\n\n\nMVMeterOfflineTON[2](IN := PM3_C37_118_POU.Offline, PT := Cfg_GVL.PlantCfg.MeterOfflineDelayTime); \nMVMeterFbk[2].STS_flt\t\t:= MVMeterOfflineTON[2].Q;\nMVMeterFbk[2].STS_Freq\t \t:= PM3_C37_118.FREQ.mag;\nMVMeterFbk[2].STS_IA\t\t:= PM3_C37_118.IAPM.cVal.mag;\nMVMeterFbk[2].STS_IB\t\t:= PM3_C37_118.IBPM.cVal.mag;\nMVMeterFbk[2].STS_IC\t\t:= PM3_C37_118.ICPM.cVal.mag;\nMVMeterFbk[2].STS_VAN\t\t:= PM3_C37_118.VAPM.cVal.mag;\nMVMeterFbk[2].STS_VBN\t\t:= PM3_C37_118.VBPM.cVal.mag;\nMVMeterFbk[2].STS_VCN\t\t:= PM3_C37_118.VCPM.cVal.mag;\nMVMeterFbk[2].Sts_VMag\t\t:= PM3_C37_118.V1PM.cVal.mag; \nMVMeterFbk[2].STS_VAB\t\t:= PM3_C37_118.VABPM.cVal.mag;\nMVMeterFbk[2].STS_VBC\t\t:= PM3_C37_118.VBCPM.cVal.mag;\nMVMeterFbk[2].STS_VCA\t\t:= PM3_C37_118.VCAPM.cVal.mag;\nMVMeterFbk[2].STS_VAng\t\t:= PM3_C37_118.V1PM.cVal.ang;\nMVMeterFbk[2].STS_IMag\t\t:= PM3_C37_118.I1PM.cVal.mag;\nMVMeterFbk[2].STS_IAng\t\t:= PM3_C37_118.I1PM.cVal.ang;\n*)\n//Override Inputs - For Testing Only\nIF Test_GVL.OvrdPMHV1Inputs THEN\n\tHVMeterFbk[1].STS_flt\t\t:= PMHV1_Offline;\n\tHVMeterFbk[1].STS_Freq\t \t:= Test_GVL.PMHV1_Freq; \n\tHVMeterFbk[1].STS_IA\t\t:= Test_GVL.PMHV1_I; \n\tHVMeterFbk[1].STS_IB\t\t:= Test_GVL.PMHV1_I; \n\tHVMeterFbk[1].STS_IC\t\t:= Test_GVL.PMHV1_I; \n\tHVMeterFbk[1].STS_VAN\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1000.0 / LREAL_TO_REAL(SQRT(3));\n\tHVMeterFbk[1].STS_VBN\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1000.0 / LREAL_TO_REAL(SQRT(3));\n\tHVMeterFbk[1].STS_VCN\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1000.0 / LREAL_TO_REAL(SQRT(3));\n\tHVMeterFbk[1].STS_VAB\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase* 1000.0 ;\n\tHVMeterFbk[1].STS_VBC\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase* 1000.0 ;\n\tHVMeterFbk[1].STS_VCA\t\t:= Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase* 1000.0 ;\n\tHVMeterFbk[1].Sts_VMag\t\t:= Test_GVL.PMHV1_VMag;\n\tHVMeterFbk[1].STS_VAng\t\t:= Test_GVL.PMHV1_VAng;\n\tHVMeterFbk[1].STS_IMag\t\t:= Test_GVL.PMHV1_I; \n\tHVMeterFbk[1].STS_IAng\t\t:= Test_GVL.PMHV1_IAng; \t\n\t(*\n\tHVMeterFbk[2].Sts_flt\t\t:= PMHV2_Offline;\n\tHVMeterFbk[2].Sts_Freq \t\t:= 60000;\t\t//[Hz * 1000]\n\tHVMeterFbk[2].Sts_P\t\t\t:= 9000;\t\t//[kW]\n\tHVMeterFbk[2].Sts_Q\t\t\t:= 20000;\t\t//[kVAr]\n\tHVMeterFbk[2].STS_VAN\t\t:= 199;\t\t//[V*10]\n\tHVMeterFbk[2].STS_VBN\t\t:= 199;\t\t//[V*10]\n\tHVMeterFbk[2].STS_VCN\t\t:= 199;\t\t//[V*10]\n\tHVMeterFbk[2].Sts_PF\t\t:= 990;\t\t\t//[PF * 1000]\n\tHVMeterFbk[2].Sts_IA\t\t:= 100;\t\t\t//[A*10]\n\tHVMeterFbk[2].Sts_IB\t\t:= 100;\t\t\t//[A*10]\n\tHVMeterFbk[2].Sts_IC\t\t:= 100;\t\t\t//[A*10]\n\t*)\n\t(*\n\tMVMeterFbk[1].Sts_VMag\t\t:= Test_GVL.PMHV1_VMag;\n\tMVMeterFbk[1].STS_VAng\t\t:= Test_GVL.PMHV1_VAng;\n\tMVMeterFbk[1].STS_IMag\t\t:= Test_GVL.PMHV1_I; \n\tMVMeterFbk[1].STS_IAng\t\t:= Test_GVL.PMHV1_IAng; \n\tMVMeterFbk[1].STS_flt\t\t:= PMMV1_Offline;\n\tMVMeterFbk[1].STS_Freq\t \t:= Test_GVL.PMHV1_Freq;  *)\nEND_IF\n(*\nIF Test_GVL.OvrdPMMV1Inputs THEN\n\tMVMeterFbk[1].STS_flt\t\t:= Test_GVL.PMMV1_Offline;\n\tMVMeterFbk[1].STS_Freq\t \t:= Test_GVL.PMMV1_Freq; \n\tMVMeterFbk[1].STS_IA\t\t:= Test_GVL.PMMV1_I; \n\tMVMeterFbk[1].STS_IB\t\t:= Test_GVL.PMMV1_I; \n\tMVMeterFbk[1].STS_IC\t\t:= Test_GVL.PMMV1_I; \n\tMVMeterFbk[1].STS_VAN\t\t:= Test_GVL.PMMV1_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[1].STS_VBN\t\t:= Test_GVL.PMMV1_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[1].STS_VCN\t\t:= Test_GVL.PMMV1_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[1].STS_VAB\t\t:= Test_GVL.PMMV1_V;\n\tMVMeterFbk[1].STS_VBC\t\t:= Test_GVL.PMMV1_V;\n\tMVMeterFbk[1].STS_VCA\t\t:= Test_GVL.PMMV1_V;\n\tMVMeterFbk[1].Sts_VMag\t\t:= Test_GVL.PMMV1_VMag;\n\tMVMeterFbk[1].STS_VAng\t\t:= Test_GVL.PMMV1_VAng;\n\tMVMeterFbk[1].STS_IMag\t\t:= Test_GVL.PMMV1_I; \n\tMVMeterFbk[1].STS_IAng\t\t:= Test_GVL.PMMV1_IAng; \t\nEND_IF\n\nIF Test_GVL.OvrdPMMV2Inputs THEN\n\tMVMeterFbk[2].STS_flt\t\t:= Test_GVL.PMMV2_Offline;\n\tMVMeterFbk[2].STS_Freq\t \t:= Test_GVL.PMMV2_Freq; \n\tMVMeterFbk[2].STS_IA\t\t:= Test_GVL.PMMV2_I; \n\tMVMeterFbk[2].STS_IB\t\t:= Test_GVL.PMMV2_I; \n\tMVMeterFbk[2].STS_IC\t\t:= Test_GVL.PMMV2_I; \n\tMVMeterFbk[2].STS_VAN\t\t:= Test_GVL.PMMV2_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[2].STS_VBN\t\t:= Test_GVL.PMMV2_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[2].STS_VCN\t\t:= Test_GVL.PMMV2_V / LREAL_TO_REAL(SQRT(3));\n\tMVMeterFbk[2].STS_VAB\t\t:= Test_GVL.PMMV2_V;\n\tMVMeterFbk[2].STS_VBC\t\t:= Test_GVL.PMMV2_V;\n\tMVMeterFbk[2].STS_VCA\t\t:= Test_GVL.PMMV2_V;\n\tMVMeterFbk[2].Sts_VMag\t\t:= Test_GVL.PMMV2_VMag;\n\tMVMeterFbk[2].STS_VAng\t\t:= Test_GVL.PMMV2_VAng;\n\tMVMeterFbk[2].STS_IMag\t\t:= Test_GVL.PMMV2_I; \n\tMVMeterFbk[2].STS_IAng\t\t:= Test_GVL.PMMV2_IAng; \t\nEND_IF\n\nIF Test_GVL.UseSimMeter THEN\n\tHVMeterFbk[1].STS_flt\t\t:= PM1_Sim_MODBUS_POU.Offline;\n\tHVMeterFbk[1].STS_Freq\t \t:= PM1_Sim_MODBUS.Freq.instMag;\n\tHVMeterFbk[1].STS_IA\t\t:= PM1_Sim_MODBUS.IMag.instMag;\n\tHVMeterFbk[1].STS_IB\t\t:= PM1_Sim_MODBUS.IMag.instMag;\n\tHVMeterFbk[1].STS_IC\t\t:= PM1_Sim_MODBUS.IMag.instMag;\n\tHVMeterFbk[1].STS_VAN\t\t:= PM1_Sim_MODBUS.VMag.instMag;\n\tHVMeterFbk[1].STS_VBN\t\t:= PM1_Sim_MODBUS.VMag.instMag;\n\tHVMeterFbk[1].STS_VCN\t\t:= PM1_Sim_MODBUS.VMag.instMag;\n\tHVMeterFbk[1].STS_VAB\t\t:= PM1_Sim_MODBUS.VMag.instMag;\n\tHVMeterFbk[1].Sts_VMag\t\t:= PM1_Sim_MODBUS.VMag.instMag;\n\tHVMeterFbk[1].STS_VAng\t\t:= PM1_Sim_MODBUS.VAng.instMag;\n\tHVMeterFbk[1].STS_IMag\t\t:= PM1_Sim_MODBUS.IMag.instMag;\n\tHVMeterFbk[1].STS_IAng\t\t:= PM1_Sim_MODBUS.IAng.instMag;\nEND_IF\n*)","LineInfoPersistence":"(string)8492a8e9-6cee-4cc0-96ac-fef8b2228a7e_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead Meter Inputs Method - Move values from Comms Registers to HV and MV Meter Fbk Arrays\n///|\tAll values read in from the meter will be RAW values and need to be conditioned in the Input Conditioning Program\nMETHOD meth_ReadMeterFbk\nVAR_OUTPUT\n\tHVMeterFbk: ARRAY[0..SiteConstants.NumHVMeters] OF TBE_PPC.dt_MeterFbk;\n\tMVMeterFbk: ARRAY[0..SiteConstants.NumMVMeters] OF TBE_PPC.dt_MeterFbk;\nEND_VAR\n","LineInfoPersistence":"(string)8492a8e9-6cee-4cc0-96ac-fef8b2228a7e_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}