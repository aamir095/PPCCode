{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8a0a15ff-7f21-4310-bfe2-35baefa82a86","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadRedundancyHMIInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Read values from DNP Server\nIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC1.operLatchOn.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1 := TRUE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC1.operLatchOff.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1 := FALSE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC1.operPulse.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1 := NOT(SCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1);\nEND_IF\nIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC2.operLatchOn.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2 := TRUE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC2.operLatchOff.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2 := FALSE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeEn_RTAC2.operPulse.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2 := NOT(SCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2);\nEND_IF\nIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC1.operLatchOn.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC1 := TRUE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC1.operLatchOff.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC1 := FALSE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC1.operPulse.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC1 := NOT(SCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC1);\nEND_IF\nIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC2.operLatchOn.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC2 := TRUE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC2.operLatchOff.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC2 := FALSE;\nELSIF PPCDNPServerMap_DNP.SCADA_GVL_RedundancyHMIInputs_MaintModeDis_RTAC2.operPulse.ctlVal THEN\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC2 := NOT(SCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC2);\nEND_IF\n\n//Read redundancy inputs from SCADA GVL\nRedundancyHMIInputs_raw := SCADA_GVL.RedundancyHMIInputs; \n\n//Reset maintenance mode inputs back to FALSE after 1 cycle -> Logic will operate on rising edge only, but value must remain TRUE for 1 cycle to pass to remote controller (in write outputs)\nIF RedundancyHMIInputs_prev.MaintModeEn_RTAC1 THEN\n\tResetDelay := ResetDelay + 1;\n\tIF ResetDelay > 10 THEN\n\t\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1 := FALSE;\n\t\tResetDelay := 0; \n\tEND_IF\nEND_IF\nIF RedundancyHMIInputs_prev.MaintModeEn_RTAC2 THEN\n\tResetDelay := ResetDelay + 1;\n\tIF ResetDelay > 10 THEN\n\t\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2 := FALSE;\n\t\tResetDelay := 0; \n\tEND_IF\nEND_IF\nIF RedundancyHMIInputs_prev.MaintModeDis_RTAC1 THEN\n\tResetDelay := ResetDelay + 1;\n\tIF ResetDelay > 10 THEN\n\t\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC1 := FALSE;\n\t\tResetDelay := 0; \n\tEND_IF\nEND_IF\nIF RedundancyHMIInputs_prev.MaintModeDis_RTAC2 THEN\n\tResetDelay := ResetDelay + 1;\n\tIF ResetDelay > 10 THEN\n\t\tSCADA_GVL.RedundancyHMIInputs.MaintModeDis_RTAC2 := FALSE;\n\t\tResetDelay := 0; \n\tEND_IF\nEND_IF\n\n//Set previous value\nRedundancyHMIInputs_prev := SCADA_GVL.RedundancyHMIInputs; ","LineInfoPersistence":"(string)8a0a15ff-7f21-4310-bfe2-35baefa82a86_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tRead redundancy related inputs from HMI\n///|\tThese inputs will be considered 'Local'\nMETHOD meth_ReadRedundancyHMIInputs\nVAR_OUTPUT\n\tRedundancyHMIInputs_raw: TBE_PPC.dt_RedundancyHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)8a0a15ff-7f21-4310-bfe2-35baefa82a86_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}