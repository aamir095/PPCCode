{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b590fbc0-3682-4ffe-b7dc-c7b80eb44105","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadPlantHMIInputs","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Read Plant HMI Inputs from the SEL HMI/DNP Server -> Update values in the SCADA GVL on a DNP trigger\n\n//EnableSELHMICntl command from SEL HMI --> Can enable/disable SEL HMI controls\nIF PPCDNPServerMap_DNP.Cfg_GVL_EnableSELHMICntl.operLatchOn.ctlVal THEN\n\tCfg_GVL.EnableSELHMICtrl := TRUE;\nELSIF PPCDNPServerMap_DNP.Cfg_GVL_EnableSELHMICntl.operLatchOff.ctlVal THEN\n\tCfg_GVL.EnableSELHMICtrl := FALSE;\nELSIF PPCDNPServerMap_DNP.Cfg_GVL_EnableSELHMICntl.operPulse.ctlVal THEN\n\tCfg_GVL.EnableSELHMICtrl := NOT Cfg_GVL.EnableSELHMICtrl;\nEND_IF\n\nIF Cfg_GVL.EnableSELHMICtrl THEN\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_BESSChrgPriorityEn.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.BESSChrgPriorityEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_BESSChrgPriorityEn.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.BESSChrgPriorityEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_ClosedLoopCtrlEn_PV.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_PV := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_ClosedLoopCtrlEn_PV.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_PV := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_ClosedLoopCtrlEn_BESS.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_BESS := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_ClosedLoopCtrlEn_BESS.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_BESS := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_BESS.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_BESS := TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_BESS.oper.ctlVal);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_POI.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_POI := TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_POI.oper.ctlVal);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_PV.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_PV := TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_CmdMode_PV.oper.ctlVal);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestEn.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestEn.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestSp_Hz.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestSp_Hz := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestSp_Hz.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestTime_sec.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestTime_sec := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_FreqTestTime_sec.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_LDCEn.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.LDCEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_LDCEn.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.LDCEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_BESS.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_BESS := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_BESS.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_POI.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_POI := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_POI.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_PV.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_PV := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PSp_PV.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PTestTime_sec.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ActivePwr.PTestTime_sec := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ActivePwr_PTestTime_sec.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_ClosedLoopCtrlEn.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.ClosedLoopCtrlEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_ClosedLoopCtrlEn.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.ClosedLoopCtrlEn := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_CmdMode.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.CmdMode := TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_CmdMode.oper.ctlVal);\n\tEND_IF\t\n\t//Casting boolean inputs for reactive power mode to an integer value\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_EnVARCtrl.operLatchOn.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.OpMode := 3;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_EnVoltageCtrl.operLatchOn.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.OpMode := 1;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_EnPFCtrl.operLatchOn.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.OpMode := 2;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_OpMode.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.OpMode := TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_OpMode.oper.ctlVal);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_PFSp.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.PFSp := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_PFSp.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_QSp.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.QSp := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_QSp.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_VSp.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_ReactivePwr_VSp.oper.setMag);\n\tEND_IF\t\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_Run.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.Run := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_Run.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.Run := FALSE;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestsEn.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestsEn := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestsEn.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestsEn := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestsEn.operPulse.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestsEn := NOT SCADA_GVL.PlantHMIInputs.TestInputs.TestsEn;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestStart.operLatchOn.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestStart := TRUE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestStart.operLatchOff.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestStart := FALSE;\n\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestStart.operPulse.ctlVal THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestStart := NOT SCADA_GVL.PlantHMIInputs.TestInputs.TestStart;\n\tEND_IF\n\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestNum.oper.trigger THEN\n\t\tSCADA_GVL.PlantHMIInputs.TestInputs.TestNum := DINT_TO_UINT(PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_TestNum.oper.ctlVal);\n\tEND_IF\n\t\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestEn.operLatchOn.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestEn := TRUE;\n\t\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestEn.operLatchOff.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestEn := FALSE;\n\t\tELSIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestEn.operPulse.ctlVal THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestEn := NOT(SCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestEn);\n\t\tEND_IF\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestSp.oper.trigger THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestSp := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestSp.oper.setMag);\n\t\tEND_IF\t\n\t\tIF PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestTime.oper.trigger THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestTime := (PPCDNPServerMap_DNP.SCADA_GVL_PlantHMIInputs_TestInputs_VoltageTestTime.oper.setMag);\n\t\tEND_IF\t\n\n\t\nEND_IF\n\n//Move plant inputs from the SCADA GVL to the PlantHMIInputs_raw structure (passed out of this method)\nPlantHMIInputs_raw := SCADA_GVL.PlantHMIInputs;\n\n//Unlatch Freq Test En input (controller will use rising edge only)\nIF FreqTestEn_Prev THEN\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestEn := FALSE;\nEND_IF\nFreqTestEn_Prev := PlantHMIInputs_raw.ActivePwr.FreqTestEn;\n\n//Unlatch Voltage Test En input (controller will use rising edge only)\nIF VoltageTestEn_Prev THEN\n\tSCADA_GVL.PlantHMIInputs.TestInputs.VoltageTestEn := FALSE;\nEND_IF\nVoltageTestEn_Prev := PlantHMIInputs_raw.TestInputs.VoltageTestEn;\n\n//Unlatch Auto Test Start Input (Controller will use rising edge only)\nSCADA_GVL.PlantHMIInputs.TestInputs.TestStart := FALSE;\n","LineInfoPersistence":"(string)b590fbc0-3682-4ffe-b7dc-c7b80eb44105_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_ReadPlantHMIInputs\nVAR_OUTPUT\n\t///Structure of Plant level HMI Inputs\n\tPlantHMIInputs_raw: TBE_PPC.dt_PlantHMIInputs;\nEND_VAR\n","LineInfoPersistence":"(string)b590fbc0-3682-4ffe-b7dc-c7b80eb44105_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}