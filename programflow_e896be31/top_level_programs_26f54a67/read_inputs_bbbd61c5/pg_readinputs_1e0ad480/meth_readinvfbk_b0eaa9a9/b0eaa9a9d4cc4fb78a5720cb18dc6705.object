{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)b0eaa9a9-d4cc-4fb7-8a57-20cb18dc6705","ParentGuid":"(Guid)1e0ad480-2148-4ede-aa42-d868f74b4f8a","Name":"(string)meth_ReadInvFbk","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Updated based on inverter modbus map\n//Inverter001 - Sungrow Inverter\nInvFbk[1].Sts_Offline  \t:=  Inv001_MODBUS_POU.Offline;\nInvFbk[1].Sts_P  \t\t:=  Inv001_MODBUS.Sts_P_W.instMag; //[kW];\nInvFbk[1].Sts_Q  \t\t:=  Inv001_MODBUS.Sts_Q_Var.instMag;//[kVar];\nInvFbk[1].Sts_Ia  \t\t:=  Inv001_MODBUS.Sts_IA_A.instMag;//[A*10];\nInvFbk[1].Sts_Ib  \t\t:=  Inv001_MODBUS.Sts_IB_A.instMag;//[A*10];\nInvFbk[1].Sts_Ic  \t\t:=  Inv001_MODBUS.Sts_IC_A.instMag;//[A*10];\nInvFbk[1].Sts_Vab  \t\t:=  Inv001_MODBUS.Sts_VAB_V.instMag;//[V*10];\nInvFbk[1].Sts_Vbc  \t\t:=  Inv001_MODBUS.Sts_VBC_V.instMag;//[V*10];\nInvFbk[1].Sts_Vca  \t\t:=  Inv001_MODBUS.Sts_VCA_V.instMag;//[V*10];\nInvFbk[1].Sts_Freq  \t:=  Inv001_MODBUS.Sts_Freq_Hz.instMag;//[Hz*10];\nInvFbk[1].Sts_PF  \t\t:=  Inv001_MODBUS.Sts_PF.instMag;//[PF*1000];\nInvFbk[1].Sts_PSp  \t\t:=  DINT_TO_REAL(Inv001_MODBUS.CMD_PSp.status.stVal);//[Pct*10];\nInvFbk[1].Sts_Qsp  \t\t:=  DINT_TO_REAL(Inv001_MODBUS.CMD_QSp.status.stVal);//[kVar*10];\nInvFbk[1].Sts_Running\t:= Inv001_MODBUS.Sts_Overall_WorkState.stVal = 1;\nInvFbk[1].Sts_Stopped\t:= Inv001_MODBUS.Sts_Overall_WorkState.stVal = 0;\n\n//Inverter002 - Sungrow Inverter\nInvFbk[2].Sts_Offline  \t:=  Inv002_MODBUS_POU.Offline;\nInvFbk[2].Sts_P  \t\t:=  Inv002_MODBUS.Sts_P_W.instMag; //[kW];\nInvFbk[2].Sts_Q  \t\t:=  Inv002_MODBUS.Sts_Q_Var.instMag;//[kVar];\nInvFbk[2].Sts_Ia  \t\t:=  Inv002_MODBUS.Sts_IA_A.instMag;//[A*10];\nInvFbk[2].Sts_Ib  \t\t:=  Inv002_MODBUS.Sts_IB_A.instMag;//[A*10];\nInvFbk[2].Sts_Ic  \t\t:=  Inv002_MODBUS.Sts_IC_A.instMag;//[A*10];\nInvFbk[2].Sts_Vab  \t\t:=  Inv002_MODBUS.Sts_VAB_V.instMag;//[V*10];\nInvFbk[2].Sts_Vbc  \t\t:=  Inv002_MODBUS.Sts_VBC_V.instMag;//[V*10];\nInvFbk[2].Sts_Vca  \t\t:=  Inv002_MODBUS.Sts_VCA_V.instMag;//[V*10];\nInvFbk[2].Sts_Freq  \t:=  Inv002_MODBUS.Sts_Freq_Hz.instMag;//[Hz*10];\nInvFbk[2].Sts_PF  \t\t:=  Inv002_MODBUS.Sts_PF.instMag;//[PF*1000];\nInvFbk[2].Sts_PSp  \t\t:=  DINT_TO_REAL(Inv002_MODBUS.CMD_PSp.status.stVal);//[Pct*10];\nInvFbk[2].Sts_Qsp  \t\t:=  DINT_TO_REAL(Inv002_MODBUS.CMD_QSp.status.stVal);//[kVar*10];\nInvFbk[2].Sts_Running\t:= Inv002_MODBUS.Sts_Overall_WorkState.stVal = 1;\nInvFbk[2].Sts_Stopped\t:= Inv002_MODBUS.Sts_Overall_WorkState.stVal = 0;\n\n//Inverter003 - Sungrow Inverter\nInvFbk[3].Sts_Offline  \t:=  Inv003_MODBUS_POU.Offline;\nInvFbk[3].Sts_P  \t\t:=  Inv003_MODBUS.Sts_P_W.instMag; //[kW];\nInvFbk[3].Sts_Q  \t\t:=  Inv003_MODBUS.Sts_Q_Var.instMag;//[kVar];\nInvFbk[3].Sts_Ia  \t\t:=  Inv003_MODBUS.Sts_IA_A.instMag;//[A*10];\nInvFbk[3].Sts_Ib  \t\t:=  Inv003_MODBUS.Sts_IB_A.instMag;//[A*10];\nInvFbk[3].Sts_Ic  \t\t:=  Inv003_MODBUS.Sts_IC_A.instMag;//[A*10];\nInvFbk[3].Sts_Vab  \t\t:=  Inv003_MODBUS.Sts_VAB_V.instMag;//[V*10];\nInvFbk[3].Sts_Vbc  \t\t:=  Inv003_MODBUS.Sts_VBC_V.instMag;//[V*10];\nInvFbk[3].Sts_Vca  \t\t:=  Inv003_MODBUS.Sts_VCA_V.instMag;//[V*10];\nInvFbk[3].Sts_Freq  \t:=  Inv003_MODBUS.Sts_Freq_Hz.instMag;//[Hz*10];\nInvFbk[3].Sts_PF  \t\t:=  Inv003_MODBUS.Sts_PF.instMag;//[PF*1000];\nInvFbk[3].Sts_PSp  \t\t:=  DINT_TO_REAL(Inv003_MODBUS.CMD_PSp.status.stVal);//[Pct*10];\nInvFbk[3].Sts_Qsp  \t\t:=  DINT_TO_REAL(Inv003_MODBUS.CMD_QSp.status.stVal);//[kVar*10];\nInvFbk[3].Sts_Running\t:= Inv003_MODBUS.Sts_Overall_WorkState.stVal = 1;\nInvFbk[3].Sts_Stopped\t:= Inv003_MODBUS.Sts_Overall_WorkState.stVal = 0;\n\n//Inverter004 - Sungrow Inverter\nInvFbk[4].Sts_Offline  \t:=  Inv004_MODBUS_POU.Offline;\nInvFbk[4].Sts_P  \t\t:=  Inv004_MODBUS.Sts_P_W.instMag; //[kW];\nInvFbk[4].Sts_Q  \t\t:=  Inv004_MODBUS.Sts_Q_Var.instMag;//[kVar];\nInvFbk[4].Sts_Ia  \t\t:=  Inv004_MODBUS.Sts_IA_A.instMag;//[A*10];\nInvFbk[4].Sts_Ib  \t\t:=  Inv004_MODBUS.Sts_IB_A.instMag;//[A*10];\nInvFbk[4].Sts_Ic  \t\t:=  Inv004_MODBUS.Sts_IC_A.instMag;//[A*10];\nInvFbk[4].Sts_Vab  \t\t:=  Inv004_MODBUS.Sts_VAB_V.instMag;//[V*10];\nInvFbk[4].Sts_Vbc  \t\t:=  Inv004_MODBUS.Sts_VBC_V.instMag;//[V*10];\nInvFbk[4].Sts_Vca  \t\t:=  Inv004_MODBUS.Sts_VCA_V.instMag;//[V*10];\nInvFbk[4].Sts_Freq  \t:=  Inv004_MODBUS.Sts_Freq_Hz.instMag;//[Hz*10];\nInvFbk[4].Sts_PF  \t\t:=  Inv004_MODBUS.Sts_PF.instMag;//[PF*1000];\nInvFbk[4].Sts_PSp  \t\t:=  DINT_TO_REAL(Inv004_MODBUS.CMD_PSp.status.stVal);//[Pct*10];\nInvFbk[4].Sts_Qsp  \t\t:=  DINT_TO_REAL(Inv004_MODBUS.CMD_QSp.status.stVal);//[kVar*10];\nInvFbk[4].Sts_Running\t:= Inv004_MODBUS.Sts_Overall_WorkState.stVal = 1;\nInvFbk[4].Sts_Stopped\t:= Inv004_MODBUS.Sts_Overall_WorkState.stVal = 0;\n\n//Inverter005 - Sungrow Inverter\nInvFbk[5].Sts_Offline  \t:=  Inv005_MODBUS_POU.Offline;\nInvFbk[5].Sts_P  \t\t:=  Inv005_MODBUS.Sts_P_W.instMag; //[kW];\nInvFbk[5].Sts_Q  \t\t:=  Inv005_MODBUS.Sts_Q_Var.instMag;//[kVar];\nInvFbk[5].Sts_Ia  \t\t:=  Inv005_MODBUS.Sts_IA_A.instMag;//[A*10];\nInvFbk[5].Sts_Ib  \t\t:=  Inv005_MODBUS.Sts_IB_A.instMag;//[A*10];\nInvFbk[5].Sts_Ic  \t\t:=  Inv005_MODBUS.Sts_IC_A.instMag;//[A*10];\nInvFbk[5].Sts_Vab  \t\t:=  Inv005_MODBUS.Sts_VAB_V.instMag;//[V*10];\nInvFbk[5].Sts_Vbc  \t\t:=  Inv005_MODBUS.Sts_VBC_V.instMag;//[V*10];\nInvFbk[5].Sts_Vca  \t\t:=  Inv005_MODBUS.Sts_VCA_V.instMag;//[V*10];\nInvFbk[5].Sts_Freq  \t:=  Inv005_MODBUS.Sts_Freq_Hz.instMag;//[Hz*10];\nInvFbk[5].Sts_PF  \t\t:=  Inv005_MODBUS.Sts_PF.instMag;//[PF*1000];\nInvFbk[5].Sts_PSp  \t\t:=  DINT_TO_REAL(Inv005_MODBUS.CMD_PSp.status.stVal);//[Pct*10];\nInvFbk[5].Sts_Qsp  \t\t:=  DINT_TO_REAL(Inv005_MODBUS.CMD_QSp.status.stVal);//[kVar*10];\nInvFbk[5].Sts_Running\t:= Inv005_MODBUS.Sts_Overall_WorkState.stVal = 1;\nInvFbk[5].Sts_Stopped\t:= Inv005_MODBUS.Sts_Overall_WorkState.stVal = 0;\n\n//Override feedback - for testing only\nIF Test_GVL.OvrdInvInputs THEN\n\tFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\t\tIF i > 0 THEN\n\t\t\tInvFbk[i].Sts_Offline := Invs_Offline;\n\t\t\tInvFbk[i].Sts_Running := TRUE;\n\t\t\tInvFbk[i].Sts_Stopped := FALSE;\n\t\t\tInvFbk[i].Sts_Faulted := FALSE;\n\t\t\tInvFbk[i].Sts_Freq := 6000;\n\t\t\tInvFbk[i].Sts_Vab := 6450; \n\t\t\tInvFbk[i].Sts_Vbc := 6460; \n\t\t\tInvFbk[i].Sts_Vca := 6470; \n\t\t\tInvFbk[i].Sts_CabTemp := 30.0;\n\t\t\tInvFbk[i].Sts_IntTemp := 30.0; \n\t\t\tInvFbk[i].Sts_P := Test_GVL.InvFbk_P[i] * 1000.0;\n\t\t\tInvFbk[i].Sts_Q := Test_GVL.InvFbk_Q[i] * 1000.0;\n\t\t\tInvFbk[i].Sts_OpCmdFbk := 207;\n\t\tEND_IF\n\tEND_FOR\nEND_IF\n","LineInfoPersistence":"(string)b0eaa9a9-d4cc-4fb7-8a57-20cb18dc6705_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_ReadInvFbk\nVAR_OUTPUT\n\t///Inverter feedback values\n\tInvFbk: ARRAY[0..SiteConstants.NumInvs] OF TBE_PPC.dt_DeviceFbk;\nEND_VAR\nVAR\n\t///Indexing variable\n\ti: UINT;\nEND_VAR\n","LineInfoPersistence":"(string)b0eaa9a9-d4cc-4fb7-8a57-20cb18dc6705_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}