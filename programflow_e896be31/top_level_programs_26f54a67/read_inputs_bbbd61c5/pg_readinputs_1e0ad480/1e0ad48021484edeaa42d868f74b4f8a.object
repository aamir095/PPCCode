lse"}},"AreElementsSpaceOptimized":"(bool)True"}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tRead Inputs Program - read inputs from external devices and store in appropriate structures\n*)\nPROGRAM pg_ReadInputs\nVAR_OUTPUT\n\tPPCInputs_raw\t\t: dt_PPCInputs; \t\t\t\t\t\t\t\t\t\t//PPC Inputs structure (raw/unscaled values)\n\tPPCInputs_Remote_pu\t: dt_PPCInputs; \t\t\t\t\t\t\t\t\t\t//Structure of PPC Inputs from Active PPC\n\tPlantCfg_Remote\t\t\t\t\t: TBE_PPC.dt_PlantCfg;\t\t\t\t\t\t//Configuration structure from active PPC\n\tCapBankCfg_Remote\t\t: dt_CapBankCfg;\t\t\t\t\t\t\t\t\t//Cap Bank configuration struct from remote PPC\n\tCapBankNumOper_Remote\t: ARRAY[0..SiteConstants.NumCapBanks] OF UINT;\t\t//Array of number of cap bank operations, from remote PPC\nEND_VAR\nVAR\n    MeterOfflineTON\t\t\t\t: ARRAY[0..SiteConstants.NumHVMeters] OF TON;\t\t//Array of meter offline timers - used to determine if meter is offline\n\tMVMeterOfflineTON\t\t\t: ARRAY[0..SiteConstants.NumMVMeters] OF TON;\t\t//Array of MV meter offline timers - used to determine if meter is offline\n\tFreqTestEn_Prev\t\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t//Previous value of frequency test en -> rising edge will be used\n\tVoltageTestEn_Prev\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t\t//Previous value of voltage test en -> rising edge will be used\n\tRedundancyHMIInputs_prev\t: TBE_PPC.dt_RedundancyHMIInputs;\t\t\t\t\t//Previous value of redundancy  HMI  Inputs\n\tResetDelay\t\t\t\t\t: INT;\t\t\t\t\t\t\t\t\t\t\t\t//Reset delay counter - for redundancy HMI Inputs\n\t\n\t//testing\n\tPMHV1_Offline\t\t\t\t: BOOL;\n\tPMHV2_Offline\t\t\t\t: BOOL;\n\tPMMV1_Offline\t\t\t\t: BOOL;\n\tInvs_Offline\t\t\t\t: BOOL;\n\t\nEND_VAR","LineInfoPersistence":"(string)1e0ad480-2148-4ede-aa42-d868f74b4f8a_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)231","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"A