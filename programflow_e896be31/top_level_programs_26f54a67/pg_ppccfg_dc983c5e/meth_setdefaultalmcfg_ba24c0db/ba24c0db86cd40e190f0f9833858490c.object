{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)ba24c0db-86cd-40e1-90f0-f9833858490c","ParentGuid":"(Guid)dc983c5e-a5ef-4427-98ef-692e6c67f980","Name":"(string)meth_SetDefaultAlmCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Time Configuration\nCfg_GVL.PlantCfg_Eng.AlmCfg.ThreshTime := T#1s; //Default threshold time of 1s\n//Feedback alarm configuration values\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.LoLo := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMin_POI - (Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMin_POI * 0.02); \t//Default value = 2% less than PMin\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.Lo := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMin_POI - (Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMin_POI * 0.01); \t//Default value = 1% less than PMin\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.Hi := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMax_POI + (Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMax_POI * 0.05); \t//Default value = 0.5% greater than PMax \nCfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.HiHi := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMax_POI + (Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PMax_POI * 0.01); \t//Default value = 1% greater than PMax\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.LoLo := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmin * 1.05;\t//Default value = 5% less than QMin\nCfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.Lo := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmin * 1.01;\t\t//Default value = 1% less than QMin \nCfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.Hi := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmax * 1.01;\t\t//Default value = 1% greater than Qmax \nCfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.HiHi := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmax * 1.05;\t//Default value = 5% greater than Qmax \n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.LoLo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.95;\t//Default value = 5% less than Vbase \nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.Lo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.97;\t//Default value = 3% less than Vbase \nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.Hi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.03;\t//Default value = 3% greater than Vbase  \nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.HiHi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.05;\t//Default value = 5% greater than Vbase  \n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.LoLo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.95;\t//Default value = 5% less than Vbase  \nCfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.Lo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.97;\t\t//Default value = 3% less than Vbase \nCfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.Hi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.03;\t\t//Default value = 3% greater than Vbase   \nCfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.HiHi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.05;\t//Default value = 5% greater than Vbase  \n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.LoLo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.95;\t//Default value = 5% less than Vbase  \nCfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.Lo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.97;\t\t//Default value = 3% less than Vbase \nCfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.Hi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.03;\t\t//Default value = 3% greater than Vbase   \nCfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.HiHi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.05;\t//Default value = 5% greater than Vbase  \n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.LoLo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.95;\t//Default value = 5% less than Vbase  \nCfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.Lo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 0.97;\t\t//Default value = 3% less than Vbase \nCfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.Hi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.03;\t\t//Default value = 3% greater than Vbase   \nCfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.HiHi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase * 1.05;\t//Default value = 5% greater than Vbase   \n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.LoLo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.95;\t//Default value = 5% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.Lo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.97;\t\t//Default value = 3% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.Hi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.03;\t\t//Default value = 3% greater calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.HiHi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.05;\t//Default value = 5% greater than calculated VLN based on Vbase\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.LoLo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.95;\t//Default value = 5% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.Lo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.97;\t\t//Default value = 3% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.Hi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.03;\t\t//Default value = 3% greater calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.HiHi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.05;\t//Default value = 5% greater than calculated VLN based on Vbase\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.LoLo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.95;\t//Default value = 5% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.Lo := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 0.97;\t\t//Default value = 3% less than calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.Hi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.03;\t\t//Default value = 3% greater calculated VLN based on Vbase\nCfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.HiHi := (Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase / LREAL_TO_REAL(SQRT(3))) * 1.05;\t//Default value = 5% greater than calculated VLN based on Vbase\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFFbk.LoLo := Cfg_GVL.PlantCfg_Eng.PFCfg.PFMin + 0.05;\t\t\t\t\t\t\t\t\t\t//Default value = 5% greater than PFMin\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFFbk.Lo := Cfg_GVL.PlantCfg_Eng.PFCfg.PFMin + 0.01;\t\t\t\t\t\t\t\t\t\t//Default value = 1% greater than PFMin\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFFbk.Hi := Cfg_GVL.PlantCfg_Eng.PFCfg.PFMax - 0.01;\t\t\t\t\t\t\t\t\t\t//Default value = 1% less than PFMax\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFFbk.HiHi := Cfg_GVL.PlantCfg_Eng.PFCfg.PFMax - 0.05;\t\t\t\t\t\t\t\t\t\t//Default value = 5% less than PFMax\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.LoLo := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase * 0.99;\t\t\t\t\t\t\t\t//Default value = 1% less than freq base (59.4 Hz)\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.Lo := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase + Cfg_GVL.PlantCfg_Eng.FreqCfg.FDbd2;\t//Default value = Low frequency deadband value\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.Hi := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase + Cfg_GVL.PlantCfg_Eng.FreqCfg.FDbd1;\t//Default value = High frequency deadbadn value\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.HiHi := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase * 1.01;\t\t\t\t\t\t\t\t//Default value = 1% greater than freq base (60.6 Hz)\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.LoLo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase * 0.95;\t\t\t\t\t\t\t//Default value = 5% less than MV base\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.Lo := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase * 0.97;\t\t\t\t\t\t\t//Default vlaue = 3% less than MV base\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.Hi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase * 1.03;\t\t\t\t\t\t\t//Default value = 3% greater than MV base\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.HiHi := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase * 1.05;\t\t\t\t\t\t\t//Default value = 5% greater than MV base\n\n//Measurement Deviation Alarms\nCfg_GVL.PlantCfg_Eng.AlmCfg.PMeasDev.Hi := 0.5;\t\t\t//Default value = 0.5 MW\nCfg_GVL.PlantCfg_Eng.AlmCfg.PMeasDev.HiHi := 1;\t\t\t//Default value = 1MW\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.QMeasDev.Hi := 0.5;\t\t\t//Default value = 0.5 MVar\nCfg_GVL.PlantCfg_Eng.AlmCfg.QMeasDev.HiHi := 1;\t\t\t//Default value = 1 MVar\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgMeasDev.Hi := 0.5;\t\t//Default value = 0.5 kV\nCfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgMeasDev.HiHi := 1;\t//Default value = 1 kV\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFMeasDev.Hi := 0.01; \t\t//Default value = 0.01\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFMeasDev.HiHi := 0.03; \t//Default value = 0.03\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqMeasDev.Hi := 0.01;\t\t//Default value = 0.01 Hz/10 mHz\nCfg_GVL.PlantCfg_Eng.AlmCfg.FreqMeasDev.HiHi := 0.02;\t//Default value = 0.02 Hz/20 mHz\n\n//SP/Fbk Deviation Alarms\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpPOIDev.Hi := 0.5;\t\t\t\t//Default value = 0.5 MW\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpPOIDev.HiHi := 1;\t\t\t//Default value = 1 MW\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpPVDev.Hi := 0.5;\t\t\t\t//Default value = 0.5 MW\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpPVDev.HiHi := 1;\t\t\t//Default value = 1 MW\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpBESSDev.Hi := 0.5;\t\t\t\t//Default value = 0.5 MW\nCfg_GVL.PlantCfg_Eng.AlmCfg.PSpBESSDev.HiHi := 1;\t\t\t//Default value = 1 MW\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.QSpDev.Hi := 0.5;\t\t\t\t//Default value = 0.5 MVar\nCfg_GVL.PlantCfg_Eng.AlmCfg.QSpDev.HiHi := 1;\t\t\t//Default value = 1 MVar\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.VSpDev.Hi := 1;\t\t\t\t//Default value = 1 kV\nCfg_GVL.PlantCfg_Eng.AlmCfg.VSpDev.HiHi := 3;\t\t\t//Default value = 3 kV\n\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFSpDev.Hi := 0.005;\t\t//Default value = 0.005\nCfg_GVL.PlantCfg_Eng.AlmCfg.PFSpDev.HiHi := 0.01;\t\t//Default value = 0.01;\n\n//Ride Through Configuration Values\nCfg_GVL.PlantCfg_Eng.AlmCfg.LFRT := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTMin;\nCfg_GVL.PlantCfg_Eng.AlmCfg.HFRT := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTMax;\nCfg_GVL.PlantCfg_Eng.AlmCfg.FRT_Hyst := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTHis;\t\t\t\t\t\t\t\t\t\t\nCfg_GVL.PlantCfg_Eng.AlmCfg.LVRT := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMin;\nCfg_GVL.PlantCfg_Eng.AlmCfg.HVRT := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMax;\nCfg_GVL.PlantCfg_Eng.AlmCfg.VRT_Hyst := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTHis;\n\n//Voltage Phase Deviations\nCfg_GVL.PlantCfg_Eng.AlmCfg.VPhaseNeutralDeviation.LoLo := -3;\t\t//Default Value = -3%\nCfg_GVL.PlantCfg_Eng.AlmCfg.VPhaseNeutralDeviation.Lo := -1;\t\t//Default Value = -1%\nCfg_GVL.PlantCfg_Eng.AlmCfg.VPhaseNeutralDeviation.Hi := 1;\t\t\t//Default Value = 1%\nCfg_GVL.PlantCfg_Eng.AlmCfg.VPhaseNeutralDeviation.HiHi := 3;\t\t//Default Value = 3%\n\n\n//SEL Hardware Related Configuration Values\nCfg_GVL.PlantCfg_Eng.AlmCfg.CPUBurden.Hi := 60;\t\t\t\t\t//Default value = 60%\nCfg_GVL.PlantCfg_Eng.AlmCfg.CPUBurden.HiHi := 90;\t\t\t\t//Default Value = 90%\nCfg_GVL.PlantCfg_Eng.AlmCfg.SupplyVoltage.Hi := 340 * 1.1;\t\t//Default Value = 110% of nominal 340V (peak to peak voltage for 240VAC supply)\nCfg_GVL.PlantCfg_Eng.AlmCfg.SupplyVoltage.Lo := 340 * 0.9;\t\t//Default Value = 90% of nominal 340V (peak to peak voltage for 240VAC supply)","LineInfoPersistence":"(string)ba24c0db-86cd-40e1-90f0-f9833858490c_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tMethod to set the default values for alarm configuration\nMETHOD meth_SetDefaultAlmCfg\n","LineInfoPersistence":"(string)ba24c0db-86cd-40e1-90f0-f9833858490c_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}