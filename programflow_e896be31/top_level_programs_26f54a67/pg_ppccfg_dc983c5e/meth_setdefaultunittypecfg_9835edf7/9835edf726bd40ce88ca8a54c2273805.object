{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)9835edf7-26bd-40ce-88ca-8a54c2273805","ParentGuid":"(Guid)dc983c5e-a5ef-4427-98ef-692e6c67f980","Name":"(string)meth_SetDefaultUnitTypeCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Default unit type configuration\n//Template program is configured with the following standard unit types. If an additional unit type is required, add is at unit type 9 and increment SiteConstants.NumUnitTypes to 9. \n//Unit Type 1 = Sungrow 3600\n//Unit Type 2 = Sungrow 4400\n//Unit Type 3 = SMA 4200\n//Unit Type 4 = SMA 4400\n//Unit Type 5 = SGRE 4300\n//Unit Type 6 = SGRE 4500\n//Unit Type 7 = Hitachi 3900\n//Unit Type 8 = Hitachi 7800\n\n//Unit Type 1 - Sungrow 3600\nCfg_GVL.UnitTypeCfg[1].Desc   \t\t\t\t:= 'Sungrow 3600'; \t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[1].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.Sungrow;\t//Sungrow Inverter Function Block\nCfg_GVL.UnitTypeCfg[1].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[1].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[1].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[1].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 3600 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[1].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 3600 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[1].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 3600 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[1].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 3600 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[1].Snom  \t \t\t\t:= 3600;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[1].Qnom\t\t\t\t\t:= 2160;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 3600 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[1].VDCnom   \t\t\t:= 1.5;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[1].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[1].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[1].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[1].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[1].CmdDelayPT   \t\t:= T#100MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[1].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[1].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[1].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[1].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[1].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[1].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[1].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[1].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[1].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[1].PFbk_toW\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[1].QFbk_toVar\t\t\t:= -1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var (negated for SG)\nCfg_GVL.UnitTypeCfg[1].PFFbk_toPu\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[1].FreqFbk_toHz\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[1].IFbk_toA\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[1].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[1].PCmd_fromPu\t\t\t:= 1000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (Percent * 10)\nCfg_GVL.UnitTypeCfg[1].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[1].Snom * -10.0;\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (kVAR * 10 + negated for SG)\n//Inverter Start/Stop Retry\t\nCfg_GVL.UnitTypeCfg[1].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[1].InvStartConfirmT\t\t:= T#4M;\t\t\t\t\t\t\t\t//[N/A],Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[1].InvStopConfirmT\t\t:= T#4M;\t\t\t\t\t\t\t\t//[N/A],Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[1].MaxCmdRetries\t\t:= 4;\t\t\t\t\t\t\t\t\t//[N/A], Start/Stop Retries after initial command\n\n//Unit Type 2 - Sungrow 4400\nCfg_GVL.UnitTypeCfg[2].Desc   \t\t\t\t:= 'Sungrow 4400'; \t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[2].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.Sungrow;\t//Sungrow Inverter Function Block\nCfg_GVL.UnitTypeCfg[2].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[2].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[2].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[2].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 4400 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[2].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 4400 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[2].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 4400 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[2].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 4400 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[2].Snom  \t \t\t\t:= 4400;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[2].Qnom\t\t\t\t\t:= 2640;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 4400 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[2].VDCnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[2].VACnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[2].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[2].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[2].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[2].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[2].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[2].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[2].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[2].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[2].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[2].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[2].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[2].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[2].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[2].PFbk_toW\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[2].QFbk_toVar\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var (negated for SG)\nCfg_GVL.UnitTypeCfg[2].PFFbk_toPu\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[2].FreqFbk_toHz\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[2].IFbk_toA\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[2].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[2].PCmd_fromPu\t\t\t:= 1000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (Percent * 10)\nCfg_GVL.UnitTypeCfg[2].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[2].Snom * -10.0;\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (kVAR * 10 + negated for SG)\n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[2].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[2].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[2].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[2].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n//Unit Type 3 - SMA 4200\nCfg_GVL.UnitTypeCfg[3].Desc   \t\t\t\t:= 'SMA 4200'; \t\t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[3].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SMA;\t\t//SMA Inverter Function Block\nCfg_GVL.UnitTypeCfg[3].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[3].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[3].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[3].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[3].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[3].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[3].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[3].Snom  \t \t\t\t:= 4200;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[3].Qnom\t\t\t\t\t:= 2520;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[3].VDCnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[3].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[3].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[3].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[3].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[3].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[3].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[3].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[3].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[3].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[3].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[3].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[3].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[3].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[3].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[3].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[3].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[3].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[3].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[3].IFbk_toA\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[3].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[3].PCmd_fromPu\t\t\t:= 10000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (Percent * 100)\nCfg_GVL.UnitTypeCfg[3].QCmd_fromPu\t\t\t:= 10000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (Percent * 100)\n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[3].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[3].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[3].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[3].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n//Unit Type 4 - SMA 4400\nCfg_GVL.UnitTypeCfg[4].Desc   \t\t\t\t:= 'SMA 4400'; \t\t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[4].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SMA;\t\t//SMA Inverter Function Block\nCfg_GVL.UnitTypeCfg[4].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[4].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[4].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[4].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[4].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[4].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[4].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[4].Snom  \t \t\t\t:= 4400;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[4].Qnom\t\t\t\t\t:= 2640;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[4].VDCnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[4].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[4].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[4].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[4].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[4].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[4].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[4].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[4].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[4].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[4].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[4].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[4].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[4].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[4].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[4].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[4].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[4].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[4].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[4].IFbk_toA\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[4].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[4].PCmd_fromPu\t\t\t:= 10000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (Percent * 100)\nCfg_GVL.UnitTypeCfg[4].QCmd_fromPu\t\t\t:= 10000.0;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (Percent * 100)\n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[4].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[4].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[4].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[4].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n//Unit Type 5 - Siemens Gamesa (SGRE) Proteus PV4300\nCfg_GVL.UnitTypeCfg[5].Desc   \t\t\t\t:= 'SGRE Proteus PV4300';\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[5].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SGRE;\t\t//SGRE Inverter Function Block\nCfg_GVL.UnitTypeCfg[5].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[5].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[5].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[5].Qmax1   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value\nCfg_GVL.UnitTypeCfg[5].Qmax2   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value\nCfg_GVL.UnitTypeCfg[5].Qmax3   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value\nCfg_GVL.UnitTypeCfg[5].Qmax4   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value\nCfg_GVL.UnitTypeCfg[5].Snom  \t \t\t\t:= 4299;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[5].Qnom\t\t\t\t\t:= 4299;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter\nCfg_GVL.UnitTypeCfg[5].VDCnom   \t\t\t:= 1.5;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[5].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[5].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[5].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[5].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[5].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[5].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[5].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[5].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[5].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[5].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[5].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[5].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[5].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[5].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[5].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[5].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[5].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[5].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[5].IFbk_toA\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[5].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[5].PCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[5].Snom;\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (kW)\nCfg_GVL.UnitTypeCfg[5].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[5].Snom;\t\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (kVAr)\n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[5].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[5].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[5].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[5].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n//Unit Type 6 - Siemens Gamesa (SGRE) Proteus PV4500\nCfg_GVL.UnitTypeCfg[6].Desc   \t\t\t\t:= 'SGRE Proteus PV4500';\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[6].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SGRE;\t\t//SGRE Inverter Function Block\nCfg_GVL.UnitTypeCfg[6].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[6].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[6].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[6].Qmax1   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value\nCfg_GVL.UnitTypeCfg[6].Qmax2   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value\nCfg_GVL.UnitTypeCfg[6].Qmax3   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value\nCfg_GVL.UnitTypeCfg[6].Qmax4   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value\nCfg_GVL.UnitTypeCfg[6].Snom  \t \t\t\t:= 4504;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[6].Qnom\t\t\t\t\t:= 4504;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter\nCfg_GVL.UnitTypeCfg[6].VDCnom   \t\t\t:= 1.5;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[6].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[6].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[6].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[6].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[6].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[6].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[6].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[6].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[6].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[6].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[6].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[6].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[6].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[6].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[6].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[6].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[6].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[6].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[6].IFbk_toA\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[6].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[6].PCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[6].Snom;\t\t//[N/A], Scaling factor to convert active power command from pu to Modbus Units (kW)\nCfg_GVL.UnitTypeCfg[6].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[6].Snom;\t\t//[N/A], Scaling factor to convert reactive power command from pu to Modbus Units (kVAr)\n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[6].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[6].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[6].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[6].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n//Unit Type 7 - Hitachi 3900\nCfg_GVL.UnitTypeCfg[7].Desc   \t\t\t\t:= 'Hitachi 3900'; \t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[7].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SMA;\t\t//SMA Inverter Function Block\nCfg_GVL.UnitTypeCfg[7].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[7].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[7].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[7].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[7].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[7].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[7].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[7].Snom  \t \t\t\t:= 3900;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[7].Qnom\t\t\t\t\t:= 2340;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[7].VDCnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[7].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[7].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[7].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[7].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[7].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[7].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[7].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[7].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[7].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[7].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[7].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[7].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[7].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[7].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[7].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[7].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[7].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[7].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[7].IFbk_toA\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[7].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[7].PCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[7].Snom *10.0;\t//[kW], Scaling factor to convert active power command from pu to Modbus Units \nCfg_GVL.UnitTypeCfg[7].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[7].Snom *10.0;\t//[kVAR], Scaling factor to convert reactive power command from pu to Modbus Units \n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[7].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[7].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[7].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[7].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n\n\n//Unit Type 8 - Hitachi 7800\nCfg_GVL.UnitTypeCfg[8].Desc   \t\t\t\t:= 'Hitachi 7800'; \t\t\t\t\t//Inverter manufacturer and model\nCfg_GVL.UnitTypeCfg[8].InvFB\t\t\t\t:= TBE_PPC.enum_InvFBType.SMA;\t\t//SMA Inverter Function Block\nCfg_GVL.UnitTypeCfg[8].NumModules \t\t\t:= 1;\t\t\t\t\t\t\t\t//Number of Modules that inverter has\nCfg_GVL.UnitTypeCfg[8].Pmax   \t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Maximum active power limit of inverter (set to 1 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[8].Pmin   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Minimum active power limit of inverter (set to 0 pu for PV inverters)\nCfg_GVL.UnitTypeCfg[8].Qmax1   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 1, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[8].Qmax2   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 2, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[8].Qmax3   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 3, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[8].Qmax4   \t\t\t\t:= 0.6;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Q Limit in Quadrant 4, Positive Value - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[8].Snom  \t \t\t\t:= 7800;\t\t\t\t\t\t\t//[kVA], Nominal apparent power rating of inverter\nCfg_GVL.UnitTypeCfg[8].Qnom\t\t\t\t\t:= 4680;\t\t\t\t\t\t\t//[kVAr], Nominal reactive power rating of inverter - Calculated based on 4200 kVA apparent power rating and 0.8 PF limitation\nCfg_GVL.UnitTypeCfg[8].VDCnom   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[kV], Inverter nominal DC voltage\nCfg_GVL.UnitTypeCfg[8].VACnom   \t\t\t:= 0.63;\t\t\t\t\t\t\t//[kV], Inverter nominal AC voltage\nCfg_GVL.UnitTypeCfg[8].Pdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for active power command - command will only be triggered if active power command changes by > Pdb\nCfg_GVL.UnitTypeCfg[8].Qdb   \t\t\t\t:= 0;\t\t\t\t\t\t\t\t//[pu, Sbase Inv], Deadband for reactive power command - command will only be triggered if reactive power command changes by > Qdb\nCfg_GVL.UnitTypeCfg[8].WakeUpPT   \t\t\t:= T#5S;\t\t\t\t\t\t\t//Time threshold to send command to inverter (sent to keep inverter 'awake' if no other commands are sent)\nCfg_GVL.UnitTypeCfg[8].CmdDelayPT   \t\t:= T#200MS;\t\t\t\t\t\t\t//Time threshold for analog commands (used to meter how fast analog commands are written to inverter)\nCfg_GVL.UnitTypeCfg[8].Idcmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum DC current limit\nCfg_GVL.UnitTypeCfg[8].Iacmax   \t\t\t:= 0;\t\t\t\t\t\t\t\t//[A], Maximum AC current limit\nCfg_GVL.UnitTypeCfg[8].BoolWritePT  \t\t:= T#2S;\t\t\t\t\t\t\t//Time threshold for boolean commands (used to meter how fast boolean commands are written to inverter)\n//Limiting logic configuration\nCfg_GVL.UnitTypeCfg[8].InvLimLogicCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter limiting logic (will limit active power command based on active power feedback)\nCfg_GVL.UnitTypeCfg[8].InvLim_x  \t\t\t:= InvLim_x_Default;\t\t\t\t//[pu Error], Default array for Inverter Limiting Logic (x values)\nCfg_GVL.UnitTypeCfg[8].InvLim_y  \t\t\t:= InvLim_y_Default; \t\t\t\t//[pu, Sbase Inv], Default array for Inverter Limiting Logic (y values)\nCfg_GVL.UnitTypeCfg[8].InvRampRateCtrlEn  \t:= TRUE;\t\t\t\t\t\t\t//Set to True to enable inverter ramp rate logic (will limit inverter ramp rate when PID error is small to prevent overshoot)\nCfg_GVL.UnitTypeCfg[8].RampRate_x  \t\t\t:= RampRate_x_Default; \t\t\t\t//[pu Error], Default array for inverter ramp rate control (x values)\nCfg_GVL.UnitTypeCfg[8].RampRate_y  \t\t\t:= RampRate_y_Default; \t\t\t\t//[pu/s], Default array for inverter ramp rate control (y values)\n//Inverter Scaling Configuration\nCfg_GVL.UnitTypeCfg[8].PFbk_toW\t\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert active power feedback from Modbus Units to W\nCfg_GVL.UnitTypeCfg[8].QFbk_toVar\t\t\t:= 0.001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert reactive power feedback from Modbus Units to Var\nCfg_GVL.UnitTypeCfg[8].PFFbk_toPu\t\t\t:= 0.0001;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert Power Factor feedback from Modbus Units to pu\nCfg_GVL.UnitTypeCfg[8].FreqFbk_toHz\t\t\t:= 0.01;\t\t\t\t\t\t\t//[N/A], Scaling factor to convert frequency feedback from Modbus Units to Hz\nCfg_GVL.UnitTypeCfg[8].IFbk_toA\t\t\t\t:= 1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert current feedback from Modbus Units to A\nCfg_GVL.UnitTypeCfg[8].VFbk_toV\t\t\t\t:= 0.1;\t\t\t\t\t\t\t\t//[N/A], Scaling factor to convert voltage feedback from Modbus Units to V\nCfg_GVL.UnitTypeCfg[8].PCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[8].Snom *10.0;//[kW], Scaling factor to convert active power command from pu to Modbus Units \nCfg_GVL.UnitTypeCfg[8].QCmd_fromPu\t\t\t:= Cfg_GVL.UnitTypeCfg[8].Snom *10.0;//[kVAR], Scaling factor to convert reactive power command from pu to Modbus Units \n//Inverter Start/Stop Retry\nCfg_GVL.UnitTypeCfg[8].StartStopRetryEn\t\t:= FALSE;\t\t\t\t\t\t\t\t//[N/A], Enable/Disable Mulitple Inverter Start/Stop Retry Function\nCfg_GVL.UnitTypeCfg[8].InvStartConfirmT     := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter start confirmation time once PPC commanded start\nCfg_GVL.UnitTypeCfg[8].InvStopConfirmT      := T#4M;    \t\t\t\t\t\t\t//[N/A], Inverter stop confirmation time once PPC commanded stop\nCfg_GVL.UnitTypeCfg[8].MaxCmdRetries        := 4;       \t\t\t\t\t\t\t//[N/A], Start/Stop retries after initial command\n","LineInfoPersistence":"(string)9835edf7-26bd-40ce-88ca-8a54c2273805_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tSet default unit type configuration values\n///|\tThis method will set the default values only - will only run when retained vars are reset (or if forced manually)\nMETHOD meth_SetDefaultUnitTypeCfg\nVAR\n\t///[pu Error], Default array for Inverter Limiting Logic (x values)\n\tInvLim_x_Default: ARRAY[0..3] OF REAL := [0, 0.02, 0.05, 1];\n\t///[pu Inv Capacity], Default array for Inverter Limiting Logic (y values)\n\tInvLim_y_Default: ARRAY[0..3] OF REAL := [0.02, 0.02, 0.1, 0.1];\n\t///[pu Error], Default array for inverter ramp rate control (x values)\n\tRampRate_x_Default: ARRAY[0..3] OF REAL := [0, 0.02, 0.05, 1];\n\t///[pu/s], Default array for inverter ramp rate control (y values)\n\tRampRate_y_Default: ARRAY[0..3] OF REAL := [0.002, 0.002, 0.004, 0.004];\nEND_VAR\n","LineInfoPersistence":"(string)9835edf7-26bd-40ce-88ca-8a54c2273805_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}