{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)bbaf393d-83d6-417a-bf45-590e9ffc4576","ParentGuid":"(Guid)dc983c5e-a5ef-4427-98ef-692e6c67f980","Name":"(string)meth_SetDefaultMeterCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Meter configuration\nCfg_GVL.HVMeterCfg[1].En := TRUE; \t\t\t\t\t\t\t\t\t\t\t//Configuration tag to enable meter\nCfg_GVL.HVMeterCfg[1].PInvert := FALSE; \t\t\t\t\t\t\t\t\t//Configuration tag to invert active power feedback\nCfg_GVL.HVMeterCfg[1].QInvert := FALSE;\t\t\t\t\t\t\t\t\t\t//Configuration tag to invert reactive power feedback\nCfg_GVL.HVMeterCfg[1].IInvert := FALSE;\t\t\t\t\t\t\t\t\t\t//Configuration tag to invert current feedback\nCfg_GVL.HVMeterCfg[1].MeterType := TBE_PPC.enum_MeterType.POI;\t\t\t\t//Meter Feedback Configuration type - POI, PV or BESS\nCfg_GVL.HVMeterCfg[1].VFbkType := TBE_PPC.enum_VFbkType.PhaseNeutral;\t\t//SEL-735 will provide Phase-Neutral voltage feedback only\nCfg_GVL.HVMeterCfg[1].PScale_toW := 1; \t\t\t\t\t\t\t\t\t\t//Scale factor to convert active power feedback to Watts\nCfg_GVL.HVMeterCfg[1].QScale_toVAr := 1; \t\t\t\t\t\t\t\t\t//Scale factor to convert reactive power feedback to VArs\nCfg_GVL.HVMeterCfg[1].FreqScale_toHz := 1; \t\t\t\t\t\t\t\t\t//Scale factor to convert frequency feedback to Hz\nCfg_GVL.HVMeterCfg[1].VScale_toV := 1; \t\t\t\t\t\t\t\t\t\t//Scale factor to convert voltage feedback to V\nCfg_GVL.HVMeterCfg[1].IScale_toA := 1; \t\t\t\t\t\t\t\t\t\t//Scale factor to convert current feedback to A\nCfg_GVL.HVMeterCfg[1].PFScale := 1; \t\t\t\t\t\t\t\t\t\t//Scale factor to convert power factor feedback to PF [-1 to 1]\nCfg_GVL.HVMeterCfg[1].SEL735 := TRUE;\t\t\t\t\t\t\t\t\t\t//True = Meter is SEL-735, False = Meter is not SEL-735 and will not provide synchrophasor data\n\n(*\nCfg_GVL.HVMeterCfg[2].En := TRUE; \nCfg_GVL.HVMeterCfg[2].PInvert := FALSE; \t\t\t\t\t\t\t\t\t//Configuration tag to invert active power feedback\nCfg_GVL.HVMeterCfg[2].QInvert := FALSE;\t\t\t\t\t\t\t\t\t\t//Configuration tag to invert reactive power feedback\nCfg_GVL.HVMeterCfg[2].IInvert := FALSE;\t\t\t\t\t\t\t\t\t\t//Configuration tag to invert current feedback\nCfg_GVL.HVMeterCfg[2].MeterType := TBE_PPC.enum_MeterType.POI;\t\t\t\t//Meter Feedback Configuration type - POI, PV or BESS\nCfg_GVL.HVMeterCfg[2].VFbkType := TBE_PPC.enum_VFbkType.PhaseNeutral;\t\t//SEL-735 will provide Phase-Neutral voltage feedback only\nCfg_GVL.HVMeterCfg[2].PScale_toW := 1000; \t\t\t\t\t\t\t\t\t//Scale factor to convert active power feedback to Watts\nCfg_GVL.HVMeterCfg[2].QScale_toVAr := 1000;\t\t\t\t\t\t\t\t//Scale factor to convert reactive power feedback to VArs\nCfg_GVL.HVMeterCfg[2].FreqScale_toHz := 0.001;\t\t\t\t\t\t\t\t//Scale factor to convert frequency feedback to Hz\nCfg_GVL.HVMeterCfg[2].VScale_toV := 1000;\t\t\t\t\t\t\t\t\t//Scale factor to convert voltage feedback to V\nCfg_GVL.HVMeterCfg[2].IScale_toA := 0.01;\t\t\t\t\t\t\t\t\t//Scale factor to convert current feedback to A\nCfg_GVL.HVMeterCfg[2].PFScale := 0.001;\t\t\t\t\t\t\t\t\t\t//Scale factor to convert power factor feedback to PF [-1 to 1]\nCfg_GVL.HVMeterCfg[2].SEL735 := FALSE;\t\t\t\t\t\t\t\t\t\t//True = Meter is SEL-735, False = Meter is not SEL-735 and will not provide synchrophasor data *)\n\n\n//MV Meter Configuration for PVS plant\n\n//MV Meter 1 - PV Branch Meter\n(*\nCfg_GVL.MVMeterCfg[1].En := TRUE;\nCfg_GVL.MVMeterCfg[1].PInvert := FALSE; \nCfg_GVL.MVMeterCfg[1].QInvert := FALSE;\nCfg_GVL.MVMeterCfg[1].IInvert := FALSE;\nCfg_GVL.MVMeterCfg[1].MeterType := TBE_PPC.enum_MeterType.PV;\n\n*)\n\n//MV Meter 2 - BESS Branch Meter\n(*\nCfg_GVL.MVMeterCfg[2].En := TRUE;\nCfg_GVL.MVMeterCfg[2].PInvert := FALSE; \nCfg_GVL.MVMeterCfg[2].QInvert := FALSE;\nCfg_GVL.MVMeterCfg[2].IInvert := FALSE;\nCfg_GVL.MVMeterCfg[2].MeterType := TBE_PPC.enum_MeterType.BESS;\n*)\n","LineInfoPersistence":"(string)bbaf393d-83d6-417a-bf45-590e9ffc4576_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD meth_SetDefaultMeterCfg\n","LineInfoPersistence":"(string)bbaf393d-83d6-417a-bf45-590e9ffc4576_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}