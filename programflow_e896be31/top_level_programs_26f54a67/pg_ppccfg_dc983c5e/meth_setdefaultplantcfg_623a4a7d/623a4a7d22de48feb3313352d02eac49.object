{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)623a4a7d-22de-48fe-b331-3352d02eac49","ParentGuid":"(Guid)dc983c5e-a5ef-4427-98ef-692e6c67f980","Name":"(string)meth_SetDefaultPlantCfg","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Plant-Level\nCfg_GVL.PlantCfg_Eng.Sbase\t\t\t\t\t\t\t\t:= 18; \t\t\t\t\t\t\t\t\t\t//[MVa], Site nominal apparent power capacity (AC capacity of site)\nCfg_GVL.PlantCfg_Eng.Sbase_PV\t\t\t\t\t\t\t:= 18;\t\t\t\t\t\t\t\t\t\t//[MVa], PV nominal apparent power capacity (AC capacity of PV portion of site), Sbase_PV should be the same as Sbase for PV only sites\nCfg_GVL.PlantCfg_Eng.Sbase_BESS\t\t\t\t\t\t\t:= 0;\t\t\t\t\t\t\t\t\t\t//[MVa], BESS/EMS nominal apparent power capacity (AC capacity of BESS/EMS portion of site)\nCfg_GVL.PlantCfg_Eng.HOL\t\t\t\t\t\t\t\t:= 10; \t\t\t\t\t\t\t\t\t\t//[MVa], Site High Operating Limit/Point of Interconnection Limit\nCfg_GVL.PlantCfg_Eng.PlantType\t\t\t\t\t\t\t:= TBE_PPC.enum_PlantType.PV;\t            //Plant Configuration Type (PV Only, PVS Co-Located, PVS Hybrid, or Storage Only)\nCfg_GVL.PlantCfg_Eng.SchedEn\t\t\t\t\t\t\t:= FALSE; \t\t\t\t\t\t\t\t\t//Enable/Disable plant scheduler\nCfg_GVL.PlantCfg_Eng.PQPriorityCtrlEn\t\t\t\t\t:= FALSE; \t\t\t\t\t\t\t\t\t//Enable/Disable P/Q Priority Control\nCfg_GVL.PlantCfg_Eng.MeterOfflineDelayTime\t\t\t\t:= T#2S; \t\t\t\t\t\t\t\t\t//[t], Meter is considered offline after POU reports it is offline for this amount of time\nCfg_GVL.PlantCfg_Eng.AutoStartEn\t\t\t\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t//Enable/Disable Auto-Start\nCfg_GVL.PlantCfg_Eng.AVR_PF\t\t\t\t\t\t\t\t:= 2; \t\t\t\t\t\t\t\t\t\t//Integer identifier for Power Factor Q Operating Mode\nCfg_GVL.PlantCfg_Eng.AVR_Q\t\t\t\t\t\t\t\t:= 3; \t\t\t\t\t\t\t\t\t\t//Integer identifier for Reactive power Q Operating Mode\nCfg_GVL.PlantCfg_Eng.AVR_V\t\t\t\t\t\t\t\t:= 1; \t\t\t\t\t\t\t\t\t\t//Integer identifier for Voltage Q operating mode\nCfg_GVL.PlantCfg_Eng.AVR_VLM\t\t\t\t\t\t\t:= 4; \t\t\t\t\t\t\t\t\t\t//Integer identifier for Voltage Limit Q operating mode\n\n//Active Power Config\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PDeltaEn \t\t\t\t:= FALSE; \t\t\t\t\t//Enable/Disable Active power delta control (not used)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.Tp \t\t\t\t\t:= 20;\t\t\t\t\t\t//[ms], Active power feedback filter time constant\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmax_POI \t\t\t\t:= 10;\t\t\t\t\t\t//[MW], Max active power generation allowed at POI\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmin_POI \t\t\t\t:= 0; \t\t\t\t\t\t//[MW], Minimum active power generation/consumption allowed at POI (negative value = grid charging enabled, this value should be 0 for PV only sites)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PmaxMan_POI\t\t\t:= 10;\t\t\t\t\t\t//[MW], Maximum manual active power POI command\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PminMan_POI\t\t\t:= 0; \t\t\t\t\t\t//[MW], Minimum manual active power POI command\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PDnLim_POI \t\t\t:= 2;\t \t\t\t\t\t//[MW/min], POI active power ramp up rate\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PUpLim_POI \t\t\t:= 2;\t \t\t\t\t\t//[MW/min], POI active power ramp down rate\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmax_PV \t\t\t\t:= 10;\t\t\t\t\t\t//[MW], Max active power generation allowed from PV portion of site\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmin_PV \t\t\t\t:= 0; \t\t\t\t\t\t//[MW], Minimum active power generation/consumption allowed from PV portion of site\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PmaxMan_PV\t\t\t:= 10;\t\t\t\t\t\t//[MW], Maximum manual active power PV command\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PminMan_PV\t\t\t:= 0; \t\t\t\t\t\t//[MW], Minimum manual active power PV command\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PDnLim_PV \t\t\t:= 2;\t \t\t\t\t\t//[MW/min], PV active power ramp up rate\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PUpLim_PV \t\t\t:= 2;\t \t\t\t\t\t//[MW/min], PV active power ramp down rate\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.LoGainDb \t:= 0; \t\t\t\t\t\t//PID low gain deadband (if separate hi/lo gains are used)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.LoGainLmt \t:= 0.1; \t\t\t\t\t//PID low gain limit (if separate hi/lo gains are used)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.KpHi \t\t:= 0.2; \t\t\t\t\t//PV/POI active power PID - proportional gain (High)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.KpLo \t\t:= 0.2;  \t\t\t\t\t//PV/POI active power PID - proportional gain (Low)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.KiLo \t\t:= 0.4;  \t\t\t\t\t//PV/POI active power PID - integral gain (High)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.KiHi \t\t:= 0.4;  \t\t\t\t\t//PV/POI active power PID - integral gain (Low)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PIDTuning.ITrackEn \t:= FALSE; \t\t\t\t\t//Enable/Disable PV/POI PID integral tracking\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.POperEn_POI\t\t\t:= TRUE; \t\t\t\t\t//Enable/disable POI active power operator station mode\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1En_POI\t\t\t:= TRUE;\t\t\t\t\t//Enable/disable POI active power remote mode 1\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2En_POI \t\t\t:= FALSE;\t\t\t\t\t//Enable/disable POI active power remote mode 2\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRemCurtailEn_POI\t\t:= FALSE;\t\t\t\t\t//Enable/disable POI active power remote curtailment\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1RampRateEn_POI\t:= FALSE;\t\t\t\t\t//Enable/disable ability to use POI ramp rate supplied from remote source 1\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2RampRateEn_POI\t:= FALSE;\t\t\t\t\t//Enable/disable ability to use POI ramp rate supplied from remote source 2\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.ADSRampRateEn_POI\t\t:= FALSE;\t\t\t\t\t//Enable/disable automatic ramp rate calculation for CAISO ADS (ADS must be configured as remote source 1)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.AGCRampRateEn_POI\t\t:= FALSE;\t\t\t\t\t//Enable/disable bypass of ramp rate for CAISO AGC (AGC must be configured as remote source 2)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.POperEn_PV\t\t\t:= TRUE;  \t\t\t\t\t//Enable/disable PV active power operator station mode (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1En_PV\t\t\t:= FALSE;\t\t\t\t\t//Enable/disable PV active power remote mode 1 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2En_PV \t\t\t:= FALSE;\t\t\t\t\t//Enable/disable PV active power remote mode 2 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRemCurtailEn_PV\t\t:= FALSE;\t\t\t\t\t//Enable/disable PV active power remote curtailment (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1RampRateEn_PV\t:= FALSE;\t\t\t\t\t//Enable/disable ability to use PV ramp rate supplied from remote source 1 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2RampRateEn_PV\t:= FALSE;\t\t\t\t\t//Enable/disable ability to use PV ramp rate supplied from remote source 2 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.ADSRampRateEn_PV\t\t:= FALSE;\t\t\t\t\t//Enable/disable automatic ramp rate calculation for CAISO ADS (for co-located plants only, ADS must be configured as remote source 1)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.AGCRampRateEn_PV\t\t:= FALSE;\t\t\t\t\t//Enable/disable bypass of ramp rate for CAISO AGC (for co-located plants only, AGC must be configured as remote source 2)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.POperEn_BESS\t\t\t:= TRUE;  \t\t\t\t\t//Enable/disable BESS/EMS active power operator station mode (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1En_BESS\t\t\t:= FALSE;\t\t\t\t\t//Enable/disable BESS/EMS active power remote mode 1 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2En_BESS \t\t\t:= FALSE;\t\t\t\t\t//Enable/disable BESS/EMS active power remote mode 2 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRemCurtailEn_BESS\t:= FALSE;\t\t\t\t\t//Enable/disable BESS/EMS active power remote curtailment (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem1RampRateEN_BESS \t:= FALSE;\t\t\t\t\t//Enable/disable ability to use BESS ramp rate supplied from remote source 1 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PRem2RampRateEN_BESS \t:= FALSE;\t\t\t\t\t//Enable/disable ability to use BESS ramp rate supplied from remote source 2 (for co-located plants only)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.ADSRampRateEn_BESS\t:= FALSE;\t\t\t\t\t//Enable/disable automatic ramp rate calculation for CAISO ADS (for co-located plants only, ADS must be configured as remote source 1)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.AGCRampRateEn_BESS\t:= FALSE;\t\t\t\t\t//Enable/disable bypass of ramp rate for CAISO AGC (for co-located plants only, AGC must be configured as remote source 2)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.AWUEn \t\t\t\t:= TRUE;\t\t\t\t\t//Enable/disable plant active power PID Anti-windup\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.AWUBuffer \t\t\t:= 4;\t\t\t\t\t\t//[%], Plant active power PID anti-windup buffer value (PID is allowed to output Max Inv Fbk + Buffer value)\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtEn \t\t\t:= TRUE;\t\t\t\t\t//Enable/Disable plant active power PID overshoot prevention logic\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtResponse \t:= 0;\t\t\t\t\t\t//[% per cycle], Value that will be subtracted off of the PID output when overshoot deadband 1 is exceeded\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtDbd1 \t\t:= 0.5;\t\t\t\t\t\t//[%], Overshoot prevention phase 1 will be enabled when PID PV > SP by this percentage value\nCfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtDbd2 \t\t:= 2;\t\t\t\t\t\t//[%], Overshoot prevention phase 2 (cap PID output at HOL) will be enabled when PID PV > SP by this percentage value\n\n//Reactive Power Config\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.VoltVarPmin   \t\t:= 0;\t\t\t\t\t\t//[MW], Threshold that active power feedback must be above to enable reactive power control (if night vars are not enabled)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.VoltVarOffPmin   \t:= 0;\t\t\t\t\t\t//[MW], Threshold that active power feedback must be below to disasble reactive power control (if night vars are not enabled), \nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmax   \t\t\t\t:= 15;\t\t\t\t\t    //[MVar], Maximum reactive power output at POI\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmin   \t\t\t\t:= -15;\t\t\t\t     \t//[MVar], Minimum reactive power output at POI\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Tq   \t\t\t\t:= 20;\t\t\t\t\t\t//[ms], Reactive power feedback filter time constant\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Kc   \t\t\t\t:= 0;\t\t\t\t\t\t//Reactive power droop value (unused)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Dbd   \t\t\t\t:= 0;\t\t\t\t\t\t//Reactive power deadband value (unused)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PQMax   \t\t\t:= 0;\t\t\t\t\t\t//Unused\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PQMin   \t\t\t:= 0;\t\t\t\t\t\t//Unused\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QAtNight   \t\t\t:= TRUE;\t\t\t\t\t//Enable/Disable reactive power control at night/in absence of active power\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QCntrlEn   \t\t\t:= TRUE;\t\t\t\t\t//Enable/Disable reactive power Q op mode\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRefUpLim   \t\t:= 10;\t\t\t\t    \t//[MVar/min], Reactive power ramp up rate (used in Q and PF modes)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRefDnLim   \t\t:= 10;\t\t\t\t    \t//[MVar/min], Reactive power ram pdown rate (used in Q and PF modes)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.LoGainDb \t:= 0.01; \t\t\t\t\t//Reactive power PID low gain deadband (if separate hi/lo gains are used)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.LoGainLmt\t:= 0.2; \t\t\t\t\t//Reactive power PID low gain limit (if separate hi/lo gains are used)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.KpHi \t\t:= 0.25; \t\t\t\t\t//Reactive power PID proportional gain (High)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.KpLo \t\t:= 0.25; \t\t\t\t\t//Reactive power PID proportional gain (Low) \nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.KiLo \t\t:= 0.5;  \t\t\t\t\t//Reactive power PID integral gain (High)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.KiHi \t\t:= 0.5;  \t\t\t\t\t//Reactive power PID integral gain (Low)\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.PIDTuning.ITrackEn \t:= FALSE; \t\t\t\t\t//Reactive power PID enable/disable integral tracking\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QOperEn\t\t\t\t:= TRUE; \t\t\t\t\t//Enable/Disable reactive power operatior station command mode\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRem1En\t\t\t\t:= TRUE; \t\t\t\t\t//Enable/Disable reactive power remote mode 1\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRem2En\t\t\t\t:= FALSE; \t\t\t\t\t//Enable/Disable reactive power remote mode 2\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.UseCURLData\t\t\t:= FALSE;\t\t\t\t\t//Set to true to use reactive power CURL points to calculate reactive power setpoint limits based on active power feedback. Set to false to use standard min/max limits\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[0]\t\t:= 0;\t\t\t\t\t\t//[MW], 1st index of Array of active power feedback values used to calculate Q capacity - Q will only be limited between these points, last value must be HOL\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[1]\t\t:= 0;\t\t\t\t\t\t//[MW], 2nd index of Array of active power feedback values used to calculate Q capacity - Q will only be limited between these points, last value must be HOL\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[2]\t\t:= 0;\t\t\t\t\t\t//[MW], 3rd index of Array of active power feedback values used to calculate Q capacity - Q will only be limited between these points, last value must be HOL\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[0]\t:= 0;\t\t\t\t\t\t//[MVar], 1st index of Array of reactive power max values used to calculate Q capacity - Q max will be calculated based on a linear interpolation of xVals, QMaxVals, and PFbk\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[1]\t:= 0;\t\t\t\t\t\t//[MVar], 2nd index of Array of reactive power max values used to calculate Q capacity - Q max will be calculated based on a linear interpolation of xVals, QMaxVals, and PFbk\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[2]\t:= 0;\t\t\t\t\t\t//[MVar], 3rd index of Array of reactive power max values used to calculate Q capacity - Q max will be calculated based on a linear interpolation of xVals, QMaxVals, and PFbk\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[0]\t:= 0;\t\t\t\t\t\t//[MVar], 1st index of Array of reactive power min values used to calculate Q capacity - Q min will be calculated based on an linear interpolation of xVals, QMinVals, and PFbk\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[1]\t:= 0;\t\t\t\t\t\t//[MVar], 2nd index of Array of reactive power min values used to calculate Q capacity - Q min will be calculated based on an linear interpolation of xVals, QMinVals, and PFbk\nCfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[2]\t:= 0;\t\t\t\t\t\t//[MVar], 3rd index of Array of reactive power min values used to calculate Q capacity - Q min will be calculated based on an linear interpolation of xVals, QMinVals, and PFbk\n\n//Voltage Config\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase   \t\t\t\t:= 345;\t\t\t\t\t\t\t\t\t\t\t\t\t//[kV], Site Nominal Voltage (HV Bus)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase   \t\t\t\t:= 34.5;\t\t\t\t\t\t\t\t\t\t\t\t//[kV], Site Nominal Voltage (MV Bus)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VMax   \t\t\t\t\t:= 1.05 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase;\t\t//[kV], Site maximum voltage (setpoint will be limited to this maximum value)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VMin   \t\t\t\t\t:= 0.95 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase;\t\t//[kV], Site minimum voltage (setpoint will be limited to this minimum value)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.MVMax   \t\t\t\t:= 1.05 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase;\t\t//[kV], Site maximum MV bus voltage\nCfg_GVL.PlantCfg_Eng.VoltageCfg.MVMin   \t\t\t\t:= 0.95 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVbase;\t\t//[kV], Site minimum MV bus voltage\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMax   \t\t\t\t:= 1.1 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase;\t\t\t//[kV], Voltage ride through event maximum voltage\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMin   \t\t\t\t:= 0.9 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase;\t\t\t//[kV], Voltage ride through event minimum voltage\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VRTHis   \t\t\t\t:= 0.0015 * Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vbase;\t\t//[kV], Voltage ride through event hysteresis\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VRTTime   \t\t\t\t:= T#5S; \t\t\t\t\t\t\t\t\t\t\t\t//[t], Voltage ride through time (unused)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Kpv   \t\t\t\t\t:= 1.0;\t\t\t\t\t\t\t\t\t\t\t\t\t//Voltage PID proportional gain (unused)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Kiv   \t\t\t\t\t:= 1.0;\t\t\t\t\t\t\t\t\t\t\t\t\t//Voltage PID integral gain (unused)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Vfrz   \t\t\t\t\t:= 0.9;\t\t\t\t\t\t\t\t\t\t\t\t\t//unused\t\t\t\t\t\t\t\t\t\t\t\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VLMdb   \t\t\t\t:= 0.001;\t\t\t\t\t\t\t\t\t\t\t\t//unused\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Vrefuplim   \t\t\t:= 10;\t\t\t\t\t\t\t\t\t\t\t\t\t//[MVAR/min], Reactive power ramp rate when in voltage droop mode\nCfg_GVL.PlantCfg_Eng.VoltageCfg.Vrefdnlim   \t\t\t:= 10;\t\t\t\t\t\t\t\t\t\t\t\t\t//[MVAR/mi], Reactive power ramp down rate when in voltage droop mode\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VcompFlag   \t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable reactive droop\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VCntrlEn   \t\t\t\t:= TRUE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable voltage droop control\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VPICntrlEn   \t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable voltage PID control (unused)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.MVVLMEn   \t\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable MV Voltage Limit Control\nCfg_GVL.PlantCfg_Eng.VoltageCfg.RefFlag   \t\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable voltage PID control (unused)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VAbsDroop   \t\t\t:= 4.997;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Voltage Droop Percentage for reactive power absorption - If voltage Fbk > SP by this percentage, full reactive power capability of site will be used\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VInjDroop   \t\t\t:= 4.997;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Voltage Droop Percentage for reactive power injection - if Voltage Fbk < SP by this percentage, full reactive power capability of site will be used\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VDroopMin   \t\t\t:= 0.2;\t\t\t\t\t\t\t\t\t\t\t\t\t//[%], Minimum voltage droop percentage\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VDroopHyst\t\t   \t\t:= 0.001;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Voltage Droop Hysteresis - Difference between voltage SP and Fbk must change by more than this hysteresis value for droop calculation to re-run\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VDbHigh\t\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t\t\t\t\t//[kV], Voltage deadband above the setpoint - If voltage is within the deadband region, then Q Sp will be 0\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VDbLow\t\t\t\t\t:= 1;\t\t\t\t\t\t\t\t\t\t\t\t\t//[kV], Voltage deadband below the setpoint - If voltage is within the deadband region, then Q Sp will be 0 (this should be a positive value)\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VLmtCntrlEn   \t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable voltage limit control mode\nCfg_GVL.PlantCfg_Eng.VoltageCfg.FiltTime\t\t\t\t:= 20;\t\t\t\t\t\t\t\t\t\t\t\t\t//[ms], Filter time constant for Voltage Feedback used for droop logic\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VSchEn\t\t\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable Voltage Scheduler Function\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VQDroopEn\t\t\t\t:= TRUE;\t\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable Voltage w/Reactive Droop Control\nCfg_GVL.PlantCfg_Eng.VoltageCfg.VQDroopGain\t\t\t\t:= 0.01;\t\t\t\t\t\t\t\t\t\t\t\t//[kV/MVA], Voltage-reactive power droop gain (change in voltage per MVA) \n\n//Voltage Schedule Config (if applicable)\n// Schedule 1 Config\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].ID := 1;                          // [N/A], Voltage schedule ID\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].TimeSlot[1].StartHR := 0;         // [hr], Time slot 1 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].TimeSlot[2].StartHR := 6;         // [hr], Time slot 2 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].TimeSlot[3].StartHR := 9;         // [hr], Time slot 3 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].TimeSlot[4].StartHR := 21;        // [hr], Time slot 4 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].VSp_kV[1] := 345;                 // [kV], Voltage setpoint for time slot 1\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].VSp_kV[2] := 346;                 // [kV], Voltage setpoint for time slot 2\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].VSp_kV[3] := 347;                 // [kV], Voltage setpoint for time slot 3\nCfg_GVL.PlantCfg_Eng.VSchCfg[1].VSp_kV[4] := 348;                 // [kV], Voltage setpoint for time slot 4\n// Schedule 2 Config\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].ID := 2;                          // [N/A], Voltage schedule ID\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].TimeSlot[1].StartHR := 0;         // [hr], Time slot 1 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].TimeSlot[2].StartHR := 6;         // [hr], Time slot 2 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].TimeSlot[3].StartHR := 12;        // [hr], Time slot 3 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].TimeSlot[4].StartHR := 21;        // [hr], Time slot 4 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].VSp_kV[1] := 346;                 // [kV], Voltage setpoint for time slot 1\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].VSp_kV[2] := 347;                 // [kV], Voltage setpoint for time slot 2\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].VSp_kV[3] := 348;                 // [kV], Voltage setpoint for time slot 3\nCfg_GVL.PlantCfg_Eng.VSchCfg[2].VSp_kV[4] := 349;                 // [kV], Voltage setpoint for time slot 4\n// Schedule 3 Config\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].ID := 3;                          // [N/A], Voltage schedule ID\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].TimeSlot[1].StartHR := 0;         // [hr], Time slot 1 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].TimeSlot[2].StartHR := 6;         // [hr], Time slot 2 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].TimeSlot[3].StartHR := 18;        // [hr], Time slot 3 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].TimeSlot[4].StartHR := 21;        // [hr], Time slot 4 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].VSp_kV[1] := 347;                 // [kV], Voltage setpoint for time slot 1\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].VSp_kV[2] := 348;                 // [kV], Voltage setpoint for time slot 2\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].VSp_kV[3] := 349;                 // [kV], Voltage setpoint for time slot 3\nCfg_GVL.PlantCfg_Eng.VSchCfg[3].VSp_kV[4] := 350;                 // [kV], Voltage setpoint for time slot 4\n// Schedule 4 Config\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].ID := 4;                          // [N/A], Voltage schedule ID\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].TimeSlot[1].StartHR := 0;         // [hr], Time slot 1 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].TimeSlot[2].StartHR := 6;         // [hr], Time slot 2 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].TimeSlot[3].StartHR := 18;        // [hr], Time slot 3 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].TimeSlot[4].StartHR := 21;        // [hr], Time slot 4 start hour\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].VSp_kV[1] := 348;                 // [kV], Voltage setpoint for time slot 1\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].VSp_kV[2] := 349;                 // [kV], Voltage setpoint for time slot 2\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].VSp_kV[3] := 350;                 // [kV], Voltage setpoint for time slot 3\nCfg_GVL.PlantCfg_Eng.VSchCfg[4].VSp_kV[4] := 351;                 // [kV], Voltage setpoint for time slot 4\n\n//Power Factor Config\nCfg_GVL.PlantCfg_Eng.PFCfg.PFMax   \t\t\t\t\t\t:= 0.95;\t//[N/A], Lagging power factor limit (PF setpoint will be limited to between this value and 1)\nCfg_GVL.PlantCfg_Eng.PFCfg.PFMin   \t\t\t\t\t\t:= -0.95;\t//[N/A], Leading power factor limit (PF setpoint will be limited to between this value and -1)\nCfg_GVL.PlantCfg_Eng.PFCfg.PFCntrlEn   \t\t\t\t\t:= TRUE;\t//Enable/Disable Power Factor control\nCfg_GVL.PlantCfg_Eng.PFCfg.PFLmtEn   \t\t\t\t\t:= FALSE;\t//Enable/Disable power factor limit mode\nCfg_GVL.PlantCfg_Eng.PFCfg.FiltTime\t\t\t\t\t\t:= 20; \t\t//[ms], Filter time constant used for PF feedback\n\n//BESS Cfg (if applicable)\nCfg_GVL.PlantCfg_Eng.BESSCfg.BESSPOICtrlEn \t\t\t:= TRUE;\t\t//Enable/Disable ability of BESS/EMS to control active power export/consumption at POI\t\t\t\t\t\t\t\t\t\t\t\t\nCfg_GVL.PlantCfg_Eng.BESSCfg.GridChrgEn \t\t\t:= TRUE;\t\t//Enable/Disable grid charging (ie active power consumption will be allowed)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PMax \t\t\t\t\t:= 24; \t\t\t//[MW], Maximum active power generation of BESS portion of site\nCfg_GVL.PlantCfg_Eng.BESSCfg.PMin \t\t\t\t\t:= -24; \t\t//[MW], Minimum active power generation of BESS portion of site (negative value = consumption is allowed)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PMaxMan \t\t\t\t:= 24; \t\t\t//[MW], Maximum manual BESS/EMS active power command\nCfg_GVL.PlantCfg_Eng.BESSCfg.PMinMan \t\t\t\t:= -24; \t\t//[MW], Minimum manual BESS/EMS active power command\nCfg_GVL.PlantCfg_Eng.BESSCfg.SOCMax \t\t\t\t:= 95; \t\t\t//[%], Maximum SOC of BESS/EMS - BESS POI Ctrl will be disabled if SOC > SOCMax\nCfg_GVL.PlantCfg_Eng.BESSCfg.SOCMin \t\t\t\t:= 5; \t\t\t//[%], Minimum SOC of BESS/EMS - BESS POI Ctrl will be disabled if SOC < SOCMin\nCfg_GVL.PlantCfg_Eng.BESSCfg.SOCHyst\t\t\t\t:= 2;\t\t\t//[%], SOC Hysteresis value for setting Min/Max SOC Flags\nCfg_GVL.PlantCfg_Eng.BESSCfg.PUpLim\t\t\t\t\t:= 10;\t\t\t//[MW/min], BESS/EMS active power ramp up rate\nCfg_GVL.PlantCfg_Eng.BESSCfg.PDnLim\t\t\t\t\t:= 10;\t\t\t//[MW/min], BESS/EMS active power ramp down rate\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.ITrackEn \t:= TRUE; \t\t//Enable/Disable BESS PID integral tracking\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.LoGainDb \t:= 0; \t\t\t//BESS PID low gain deadband (if low/high gains are used)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.LoGainLmt \t:= 0; \t\t\t//BESS PID low gain low (if low/high gains are used)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.KpLo \t\t:= 0.2; \t\t//BESS PID proportional gain (Low)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.KpHi \t\t:= 0.2;  \t\t//BESS PID proportional gain (High)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.KiLo \t\t:= 0.3;  \t\t//BESS PID integral gain (Low)\nCfg_GVL.PlantCfg_Eng.BESSCfg.PIDTuning.KiHi \t\t:= 0.3;  \t\t//BESS PID integral gain (High)\nCfg_GVL.PlantCfg_Eng.BESSCfg.AWUEn\t\t\t\t\t:= TRUE;\t\t//BESS Anti-Windup Enable/Disable\nCfg_GVL.PlantCfg_Eng.BESSCfg.AWUBuffer\t\t\t\t:= 4;\t\t\t//[%], BESS Anti-Windup Buffer\n\n//Freq Config\nCfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase   \t\t\t\t:= 60.0;\t\t\t\t\t\t\t\t\t\t\t//[Hz], Nominal site frequency\nCfg_GVL.PlantCfg_Eng.FreqCfg.FreqCtrlEn_PV \t\t\t    := TRUE;\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable Primary Frequency Response Frequency Control for PV portion of site\nCfg_GVL.PlantCfg_Eng.FreqCfg.FreqMax   \t\t\t\t\t:= 61;\t\t\t\t\t\t\t\t\t\t\t\t//[Hz], Maximum frequency (used for alarming)\nCfg_GVL.PlantCfg_Eng.FreqCfg.FreqMin   \t\t\t\t\t:= 59;\t\t\t\t\t\t\t\t\t\t\t\t//[Hz], Minimum frequency (used for alarming)\nCfg_GVL.PlantCfg_Eng.FreqCfg.FRTMax   \t\t\t\t\t:= 1.05 * Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase;\t//[Hz], Frequency ride through event maximum frequency\nCfg_GVL.PlantCfg_Eng.FreqCfg.FRTMin   \t\t\t\t\t:= 0.95 * Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase;\t//[Hz], Frequency ride through event minimum frequency\nCfg_GVL.PlantCfg_Eng.FreqCfg.FRTHis   \t\t\t\t\t:= 0.01 * Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqBase;\t//[Hz], Frequency ride through event hysteresis\nCfg_GVL.PlantCfg_Eng.FreqCfg.FRTTime   \t\t\t\t\t:= T#5S; \t\t\t\t\t\t\t\t\t\t\t//[t], Frequency ride through event time (unused)\nCfg_GVL.PlantCfg_Eng.FreqCfg.FDbd1   \t\t\t\t\t:= 0.036;\t\t\t\t\t\t\t\t\t\t\t//[Hz], Frequency deadband for Primary Frequency Response, over-frequency\nCfg_GVL.PlantCfg_Eng.FreqCfg.FDbd2   \t\t\t\t\t:= -0.036;\t\t\t\t\t\t\t\t\t\t\t//[Hz], Frequency deadband for Primary Frequency Response, under-frequency (must be negative value)\nCfg_GVL.PlantCfg_Eng.FreqCfg.DDn   \t\t\t\t\t\t:= 5;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Over-frequency droop percentage\nCfg_GVL.PlantCfg_Eng.FreqCfg.DUp   \t\t\t\t\t\t:= 5;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Under-frequency droop percentage\nCfg_GVL.PlantCfg_Eng.FreqCfg.UseHSL\t\t\t\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t//True = HSL is used in frequency droop calculation, False = HOL is used in frequency droop calculation\nCfg_GVL.PlantCfg_Eng.FreqCfg.FiltTime\t\t\t\t\t:= 20; \t\t\t\t\t\t\t\t\t\t\t\t//[ms], Frequency feedback filter time constant\nCfg_GVL.PlantCfg_Eng.FreqCfg.LatchOnTmr_PT\t\t\t\t:= T#1S;\t\t\t\t\t\t\t\t\t\t\t//[t], Time threshold that frequency must be outside of deadband value to trigger PFR\nCfg_GVL.PlantCfg_Eng.FreqCfg.LatchOffTmr_PT\t\t\t\t:= T#1S;\t\t\t\t\t\t\t\t\t\t\t//[t], Time threshold that frequency must be within deadband value to release/disable PFR\nCfg_GVL.PlantCfg_Eng.FreqCfg.FreqCtrlEn_BESS\t\t\t:= FALSE;\t\t\t\t\t\t\t\t\t\t\t//Enable/Disable Primary Frequency Response Control for BESS portion of site\nCfg_GVL.PlantCfg_Eng.FreqCfg.DDn_BESS\t\t\t\t\t:= 5;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Over-frequency droop percentage for BESS PFR\nCfg_GVL.PlantCfg_Eng.FreqCfg.DUp_BESS\t\t\t\t\t:= 5;\t\t\t\t\t\t\t\t\t\t\t\t//[%], Under-frequency droop percentage for BESS PFR\nCfg_GVL.PlantCfg_Eng.FreqCfg.LatchOnTmr_PT_BESS\t\t\t:= T#1S;\t\t\t\t\t\t\t\t\t\t\t//[t], Time threshold that frequency must be outside of deadband value to trigger BESS PFR\nCfg_GVL.PlantCfg_Eng.FreqCfg.LatchOffTmr_PT_BESS\t\t:= T#1S;\t\t\t\t\t\t\t\t\t\t\t//[t], Time threshold that frequency must be within deadband value to release/disable BESS PFR\n\n\n//Fast Frequency Response Cfg (if appilicabl)\nCfg_GVL.PlantCfg_Eng.FFRCfg.FFREn_PV              := TRUE;       //[True = FFR is enabled, False = FFR Disabled] for PV\nCfg_GVL.PlantCfg_Eng.FFRCfg.FFREn_BESS            := TRUE;       //[True = FFR is enabled, False = FFR Disabled] for BESS\nCfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqRespEn        := TRUE;        //[True = Overfrequency response enabled, False = Overfrequency response disabled]\nCfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqRespEn       := TRUE;        //[True = Underfrequency response enabled, False = Underfrequency response disabled]\nCfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqDbd           := 0.036;\t\t  //Overfrequency deadband - Overfrequency response will be activated if frequency exceeds Nominal Frequency + OverFreqDbd\nCfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqDbd          := -0.036;\t  //Underfrequency deadband - Underfrequency response will be activated if frequency is less than Nominal Frequency + UnderFreqDbd (value must be negative)\nCfg_GVL.PlantCfg_Eng.FFRCfg.DroopModeEn           := TRUE;        //[True = FFR droop mode enabled - active power adjustment will be calculated based on droop %, False = FFR fixed magnitude mode enabled - active power adjustment will be fixed value]\nCfg_GVL.PlantCfg_Eng.FFRCfg.RecoverTime           := T#10S;       //[t], FFR will be disabled for this duration after FFR event is deactivated and FFR adjustment has reached 0\n//Droop Mode \nCfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqDroopCoeff   := 5;  \t      //[%], Underfrequency droop coefficient - active power adjustment will be calculated using this droop value for underfrequency events\nCfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqDrooopCoeff   := 5;    \t      //[%], Overfrequency droop coefficient - active power adjustment will be calculated using this droop value for overfrequency events\n//Fixed Magnitude Mode \nCfg_GVL.PlantCfg_Eng.FFRCfg.FixedMagFreqContEn    := FALSE;\t\t  // TRUE = hold until measured freq returns to deadband, FALSE = release after SustainTime\nCfg_GVL.PlantCfg_Eng.FFRCfg.FixedMagAdj_PV        := 10;          //[%] Active power value that is added (during underfrequency events) or subtracted (during overfrequency events) to/from the plant-level active power setpoint during an FFR event when fixed magnitude mode is used for PV\nCfg_GVL.PlantCfg_Eng.FFRCfg.FixedMagAdj_BESS      := 10;          //[%] Active power value that is added (during underfrequency events) or subtracted (during overfrequency events) to/from the plant-level active power setpoint during an FFR event when fixed magnitude mode is used for BESS\nCfg_GVL.PlantCfg_Eng.FFRCfg.SustainTime           := T#30S;       //[t], Amount of time that the fixed magnitude adjustment will be held once an FFR event is triggered and fixed magnitude mode is used\nCfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqResetThresh   := 0.01;         //[Hz], Overfrequency reset threshold - if the frequency falls below Nominal Frequency + Reset Threshold, then the fixed magnitude FFR will be deactivated and the active power adjustment will ramp to 0\nCfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqResetThresh  := -0.01;       //[Hz], Underfrequency reset threshold - if the frequency rises above Nominal Frequency + Reset Threshold, then the fixed magnitude FFR will be deactivated and the active power adjustment will ramp to 0 (value must be negative)\nCfg_GVL.PlantCfg_Eng.FFRCfg.RecoverRampUpRate     := 5;     \t  //[MW/min], Ramp rate used to ramp the adjustment back to 0 during the recovery of an overfrequency event (FFR output is ramping from negative value to 0)\nCfg_GVL.PlantCfg_Eng.FFRCfg.RecoverRampDnRate     := 5; \t      //[MW/min], Ramp rate used to ramp the adjustment back to 0 during the recovery of an underfrequency event (FFR output is ramping from positive value to 0)\n\n\n//Cap Bank Config - Not part of PlantCfg - Uncomment/add lines as necessary based on how many capacitor banks are present\nCfg_GVL.CapBankCfg_Eng.QMeasSrc \t\t\t\t:= TBE_PPC.enum_QSource.HVMeter;\t\t\t//0 = HV reactive power feedback is used for cap bank control, 1 = MV reactive power feedback is used for cap bank control, 2 = Inverter Q sum is used for cap bank control\nCfg_GVL.CapBankCfg_Eng.CapCloseThresh[1]\t\t:= 10;\t\t\t\t\t\t\t\t\t\t//[MVar], Reactive power threshold value above which capacitor bank 1 will be closed\nCfg_GVL.CapBankCfg_Eng.CapOpenThresh[1]\t\t\t:= -10;\t\t\t\t\t\t\t\t\t\t//[MVar], Reactive power threshold value above which capacitor bank 1 will be opened\nCfg_GVL.CapBankCfg_Eng.CapNomRating[1]\t\t\t:= 10;\t\t\t\t\t\t\t\t\t\t//[MVar], Capacitor Bank 1 nominal reactive power rating\nCfg_GVL.CapBankCfg_Eng.CapCloseThresh[2]\t\t:= 20;\t\t\t\t\t\t\t\t\t\t//[MVar], Reactive power threshold value above which capacitor bank 2 will be closed\nCfg_GVL.CapBankCfg_Eng.CapOpenThresh[2]\t\t\t:= -20;\t\t\t\t\t\t\t\t\t\t//[MVar], Reactive power threshold value above which capacitor bank 2 will be opened\nCfg_GVL.CapBankCfg_Eng.CapNomRating[2]\t\t\t:= 10;\t\t\t\t\t\t\t\t\t\t//[MVar], Capacitor Bank 2 nominal reactive power rating\n(*\nCfg_GVL.CapBankCfg_Eng.CapCloseThresh[3]\t\t:= 30;\t\t\t\t\t\t\t\t\t\t//MVar\nCfg_GVL.CapBankCfg_Eng.CapOpenThresh[3]\t\t\t:= -30; \t\t\t\t\t\t\t\t\t//MVar\nCfg_GVL.CapBankCfg_Eng.CapNomRating[3]\t\t\t:= 10;\t\t\t\t\t\t\t\t\t\t//[MVar], Capacitor Bank 3 nominal reactive power rating\n*)\nCfg_GVL.CapBankCfg_Eng.SuspendTime   \t\t\t:= T#5S;\t\t\t\t\t\t\t\t\t//Unused\nCfg_GVL.CapBankCfg_Eng.OpTime   \t\t\t\t:= T#500MS;\t\t\t\t\t\t\t\t\t//[t], Time that capacitor bank open/close command will remain true\nCfg_GVL.CapBankCfg_Eng.ThreshWaitTime\t\t\t:= T#10S;\t\t\t\t\t\t\t\t\t//[t], Time that the reactive power feedback must be above/below the close/open threshold values to issue a close/open command\n\n\n//Met Station Config\nCfg_GVL.PlantCfg_Eng.MetStationCfg.MaxIrr\t\t\t:= 1000; \t//[W/m2], 1000 considered to be 'full-sun'\nCfg_GVL.PlantCfg_Eng.MetStationCfg.FiltTime\t\t\t:= 50;\t\t//[ms], filter time for met station\nCfg_GVL.PlantCfg.MetStationCfg.Angle_lim[0]\t \t\t:= 0;\t\t//[Deg], Minimum angle for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.Angle_lim[1]\t\t:= 360;\t\t//[Deg], Maximum angle for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.DirectIrr_lim[0]\t \t:= -100;\t//[W/m2], Minimum Direct irradiance for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.DirectIrr_lim[1]\t:= 2000;\t//[W/m2], Maximum Direct irradiance for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.GHI_lim[0]\t \t\t:= -100;\t//[W/m2], Minimum GHI irradiance for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.GHI_lim[1]\t\t:= 2000;\t//[W/m2], Maximum GHI irradiance for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.POA_lim[0]\t \t\t:= -100;\t//[W/m2], Minimum POA irradiance for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.POA_lim[1]\t\t:= 2000;\t//[W/m2], Maximum POA irradiance for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.Precip_lim[0]\t \t:= 0;\t\t//[mm], Minimum precipiation for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.Precip_lim[1]\t:= 360;\t\t//[mm], Maximum precipiation for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.Pressure_lim[0]\t \t:= 300;\t\t//[hPa], Minimum pressure for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.Pressure_lim[1]\t:= 1200;\t//[hPa], Maximum pressure for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.RH_lim[0]\t \t\t:= 0;\t\t//[%], Minimum relative humidity for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.RH_lim[1]\t\t:= 100;\t\t//[%], Maximum relative humidity for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.Temp_lim[0]\t \t\t:= -50;\t\t//[C], Minimum temperature for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.Temp_lim[1]\t\t:= 60;\t\t//[C], Maximum temperature for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.WindDir_lim[0]\t \t:= 0;\t\t//[Deg], Minimum wind direction for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.WindDir_lim[1]\t:= 360;\t\t//[Deg], Maximum wind direction for data to be considered value\nCfg_GVL.PlantCfg.MetStationCfg.WindSpd_lim[0]\t \t:= 0;\t\t//[m/s], Minimum wind speed for data to be considered value\nCfg_GVL.PlantCfg_Eng.MetStationCfg.WindSpd_lim[1]\t:= 75;\t\t//[m/s], Maximum wind speed for data to be considered value\n\n","LineInfoPersistence":"(string)623a4a7d-22de-48fe-b331-3352d02eac49_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)///\n///|\tSet default plant configuration values\n///|\tThis method will set the default values only - will only run when retained vars are reset (or if forced manually)\n///|\tAll values within this program will be in engineering units (refer to comments)\nMETHOD meth_SetDefaultPlantCfg\n","LineInfoPersistence":"(string)623a4a7d-22de-48fe-b331-3352d02eac49_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}