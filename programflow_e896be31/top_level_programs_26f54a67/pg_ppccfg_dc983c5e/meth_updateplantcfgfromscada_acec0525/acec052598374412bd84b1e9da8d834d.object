{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)acec0525-9837-4412-bd84-b1e9da8d834d","ParentGuid":"(Guid)dc983c5e-a5ef-4427-98ef-692e6c67f980","Name":"(string)meth_UpdatePlantCfgFromSCADA","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Move over entire PlantCfg structure and then scale non-boolean values as necessary\nCfg_GVL.PlantCfg := Cfg_GVL.PlantCfg_Eng;\n\n//Plant-Level\nCfg_GVL.PlantCfg.HOL := Cfg_GVL.PlantCfg_Eng.HOL / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu\n\n//Active Power Config\nCfg_GVL.PlantCfg.ActivePwrCfg.Pmax_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmax_POI / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.Pmin_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmin_POI / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.PmaxMan_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PmaxMan_POI / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.PminMan_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PminMan_POI / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.PDnLim_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PDnLim_POI / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.PUpLim_POI := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PUpLim_POI / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase\nCfg_GVL.PlantCfg.ActivePwrCfg.Pmax_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmax_PV / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t//Convert from MW to pu on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.Pmin_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.Pmin_PV / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t//Convert from MW to pu on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.PmaxMan_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PmaxMan_PV / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.PminMan_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PminMan_PV / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.PDnLim_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PDnLim_PV / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.PUpLim_PV := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PUpLim_PV / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase_PV\nCfg_GVL.PlantCfg.ActivePwrCfg.AWUBuffer := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.AWUBuffer / 100.0; \t\t\t\t\t\t\t//Convert from pct to pu\nCfg_GVL.PlantCfg.ActivePwrCfg.PPIDOvshtResponse := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtResponse / 100.0;\t\t\t\t//Convert from pct to pu\nCfg_GVL.PlantCfg.ActivePwrCfg.PPIDOvshtDbd1 := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtDbd1 / 100.0;\t\t\t\t\t\t//Convert from pct to pu\nCfg_GVL.PlantCfg.ActivePwrCfg.PPIDOvshtDbd2 := Cfg_GVL.PlantCfg_Eng.ActivePwrCfg.PPIDOvshtDbd2 / 100.0;\t\t\t\t\t\t//Convert from pct to pu\n\n//Reactive Power Config\nCfg_GVL.PlantCfg.ReactivePwrCfg.VoltVarPmin := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.VoltVarPmin / Cfg_GVL.PlantCfg.Sbase;\t\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.VoltVarOffPmin := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.VoltVarOffPmin / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to pu on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.Qmax := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmax / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t\t\t\t//Convert from MVar to pu on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.Qmin := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.Qmin / Cfg_GVL.PlantCfg.Sbase;\t\t\t\t\t\t\t//Convert from MVar to pu on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.QRefUpLim := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRefUpLim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t\t//Convert from MVar/min to pu/s on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.QRefDnLim := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.QRefDnLim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t\t//Convert from MVar/min to pu/s on Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_xVals[0] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[0] / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_xVals[1] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[1] / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_xVals[2] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_xVals[2] / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MW to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMinVals[0] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[0] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMinVals[1] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[1] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMinVals[2] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMinVals[2] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMaxVals[0] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[0] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMaxVals[1] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[1] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\nCfg_GVL.PlantCfg.ReactivePwrCfg.CURL_QMaxVals[2] := Cfg_GVL.PlantCfg_Eng.ReactivePwrCfg.CURL_QMaxVals[2] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVAr to Sbase\n\n//Voltage Config\nCfg_GVL.PlantCfg.VoltageCfg.VMax := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VMax / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t\t//Convert from kV to pu on Vbase\nCfg_GVL.PlantCfg.VoltageCfg.VMin := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VMin / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t\t//Convert from kV to pu on Vbase\nCfg_GVL.PlantCfg.VoltageCfg.MVMax := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVMax / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\t\t//Convert from kV to pu on MVbase\nCfg_GVL.PlantCfg.VoltageCfg.MVMin := Cfg_GVL.PlantCfg_Eng.VoltageCfg.MVMin / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\t\t//Convert from kV to pu on MVbase\nCfg_GVL.PlantCfg.VoltageCfg.VRTMax := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMax / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu on Vbase\nCfg_GVL.PlantCfg.VoltageCfg.VRTMin := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTMin / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu on Vbase\nCfg_GVL.PlantCfg.VoltageCfg.VRTHis := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VRTHis / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu on Vbase\nCfg_GVL.PlantCfg.VoltageCfg.Vrefuplim := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vrefuplim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t//Convert from MVar/min to pu/s on Sbase\nCfg_GVL.PlantCfg.VoltageCfg.Vrefdnlim := Cfg_GVL.PlantCfg_Eng.VoltageCfg.Vrefdnlim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t//Convert from MVAr/min to pu/s on Sbase\nCfg_GVL.PlantCfg.VoltageCfg.VAbsDroop := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VAbsDroop / 100.0;\t\t\t\t\t\t\t\t//Convert from percentage to pu\nCfg_GVL.PlantCfg.VoltageCfg.VInjDroop := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VInjDroop / 100.0;\t\t\t\t\t\t\t\t//Convert from percentage to pu\nCfg_GVL.PlantCfg.VoltageCfg.VDroopMin := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VDroopMin / 100.0;\t\t\t\t\t\t\t\t//Convert from percentage to pu\nCfg_GVL.PlantCfg.VoltageCfg.VDroopHyst := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VDroopHyst / 100.0;\t\t\t\t\t\t\t//Convert from percentage to pu\nCfg_GVL.PlantCfg.VoltageCfg.VDbHigh := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VDbHigh / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\nCfg_GVL.PlantCfg.VoltageCfg.VDbLow := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VDbLow / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\nCfg_GVL.PlantCfg.VoltageCfg.VQDroopGain := Cfg_GVL.PlantCfg_Eng.VoltageCfg.VQDroopGain/Cfg_GVL.PlantCfg.VoltageCfg.Vbase/Cfg_GVL.PlantCfg.Sbase; \t//Convert from kV/MVAR to pu/pu\n\n//Voltage Scheduler Config\nFOR i := 1 TO 6 BY 1 DO\n\tCfg_GVL.PlantCfg.VSchCfg[i].VSp_kV[1] := Cfg_GVL.PlantCfg_Eng.VSchCfg[i].VSp_kV[1]  / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\n\tCfg_GVL.PlantCfg.VSchCfg[i].VSp_kV[2] := Cfg_GVL.PlantCfg_Eng.VSchCfg[i].VSp_kV[2] / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\n\tCfg_GVL.PlantCfg.VSchCfg[i].VSp_kV[3] := Cfg_GVL.PlantCfg_Eng.VSchCfg[i].VSp_kV[3] / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\n\tCfg_GVL.PlantCfg.VSchCfg[i].VSp_kV[4] := Cfg_GVL.PlantCfg_Eng.VSchCfg[i].VSp_kV[4] / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\t\t//Convert from kV to pu\nEND_FOR\n\n\n//Power Factor Config - no scaling needed\n\n//Freq Config\nCfg_GVL.PlantCfg.FreqCfg.FreqMax := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqMax / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FreqMin := Cfg_GVL.PlantCfg_Eng.FreqCfg.FreqMin / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FRTMax := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTMax / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FRTMin := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTMin / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FRTHis := Cfg_GVL.PlantCfg_Eng.FreqCfg.FRTHis / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FDbd1 := Cfg_GVL.PlantCfg_Eng.FreqCfg.FDbd1 / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FreqCfg.FDbd2 := Cfg_GVL.PlantCfg_Eng.FreqCfg.FDbd2 / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nIF Cfg_GVL.PlantCfg_Eng.FreqCfg.DDn <> 0 THEN\n\tCfg_GVL.PlantCfg.FreqCfg.DDn := 100.0 / Cfg_GVL.PlantCfg_Eng.FreqCfg.DDn;\t\t\t\t\t\t\t\t\t//Convert from % to pu Sbase/pu Freq (100 divided by droop percentage to arrive at active power response per change in frequency)\nEND_IF\nIF Cfg_GVL.PlantCfg_Eng.FreqCfg.DUp <> 0 THEN\n\tCfg_GVL.PlantCfg.FreqCfg.DUp := 100.0 / Cfg_GVL.PlantCfg_Eng.FreqCfg.DUp;\t\t\t\t\t\t\t\t\t//Convert from % to pu Sbase/pu Freq (100 divided by droop percentage to arrive at active power response per change in frequency)\nEND_IF\nIF Cfg_GVL.PlantCfg_Eng.FreqCfg.DDn_BESS <> 0 THEN\n\tCfg_GVL.PlantCfg.FreqCfg.DDn_BESS := 100.0 / Cfg_GVL.PlantCfg_Eng.FreqCfg.DDn_BESS;\t\t\t\t\t\t\t//Convert from % to pu Sbase/pu Freq (100 divided by droop percentage to arrive at active power response per change in frequency)\nEND_IF\nIF Cfg_GVL.PlantCfg_Eng.FreqCfg.DUp_BESS <> 0 THEN\n\tCfg_GVL.PlantCfg.FreqCfg.DUp_BESS := 100.0 / Cfg_GVL.PlantCfg_Eng.FreqCfg.DUp_BESS;\t\t\t\t\t\t\t//Convert from % to pu Sbase/pu Freq (100 divided by droop percentage to arrive at active power response per change in frequency)\nEND_IF\n\n//FFR Config\nCfg_GVL.PlantCfg.FFRCfg.OverFreqDbd\t\t\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqDbd / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FFRCfg.UnderFreqDbd\t\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqDbd / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nIF Cfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqDroopCoeff <> 0 THEN\n\tCfg_GVL.PlantCfg.FFRCfg.UnderFreqDroopCoeff\t:= 100.0 / Cfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqDroopCoeff;\t\t//Convert from % to pu Sbase/pu Freq\nEND_IF\nIF Cfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqDrooopCoeff <> 0 THEN\n\tCfg_GVL.PlantCfg.FFRCfg.OverFreqDrooopCoeff\t:= 100.0 / Cfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqDrooopCoeff;\t\t//Convert from % to pu Sbase/pu Freq\nEND_IF\nCfg_GVL.PlantCfg.FFRCfg.OverFreqResetThresh\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.OverFreqResetThresh / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FFRCfg.UnderFreqResetThresh\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.UnderFreqResetThresh / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\t//Convert from Hz to pu on FreqBase\nCfg_GVL.PlantCfg.FFRCfg.RecoverRampUpRate\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.RecoverRampUpRate / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t\t//Convert from MW/min to pu/s on Sbase\nCfg_GVL.PlantCfg.FFRCfg.RecoverRampDnRate\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.RecoverRampDnRate / Cfg_GVL.PlantCfg.Sbase / 60.0;\t\t\t//Convert from MW/min to pu/s on Sbase\nCfg_GVL.PlantCfg.FFRCfg.FixedMagAdj_PV\t\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.FixedMagAdj_PV / 100.0;\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.PlantCfg.FFRCfg.FixedMagAdj_PV\t\t\t:= Cfg_GVL.PlantCfg_Eng.FFRCfg.FixedMagAdj_PV / 100.0;\t\t\t\t\t\t\t\t\t\t//Convert from % to pu\n\n//BESS Cfg (if applicable)\nCfg_GVL.PlantCfg.BESSCfg.PMax := Cfg_GVL.PlantCfg_Eng.BESSCfg.PMax / Cfg_GVL.PlantCfg.Sbase_BESS;\t\t\t\t//Convert from MW to pu on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.PMin := Cfg_GVL.PlantCfg_Eng.BESSCfg.PMin / Cfg_GVL.PlantCfg.Sbase_BESS;\t\t\t\t//Convert from MW to pu on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.PMaxMan := Cfg_GVL.PlantCfg_Eng.BESSCfg.PMaxMan / Cfg_GVL.PlantCfg.Sbase;\t\t\t//Convert from MW to pu on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.PMinMan := Cfg_GVL.PlantCfg_Eng.BESSCfg.PMinMan / Cfg_GVL.PlantCfg.Sbase;\t\t\t//Convert from MW to pu on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.SOCMax := Cfg_GVL.PlantCfg_Eng.BESSCfg.SOCMax / 100.0;\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.PlantCfg.BESSCfg.SOCMin := Cfg_GVL.PlantCfg_Eng.BESSCfg.SOCMin / 100.0;\t\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.PlantCfg.BESSCfg.SOCHyst := Cfg_GVL.PlantCfg_Eng.BESSCfg.SOCHyst / 100.0;\t\t\t\t\t\t\t\t//Convert from % to pu\nCfg_GVL.PlantCfg.BESSCfg.PUpLim := Cfg_GVL.PlantCfg_Eng.BESSCfg.PUpLim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.PDnLim := Cfg_GVL.PlantCfg_Eng.BESSCfg.PDnLim / Cfg_GVL.PlantCfg.Sbase / 60.0;\t//Convert from MW/min to pu/s on Sbase_BESS\nCfg_GVL.PlantCfg.BESSCfg.AWUBuffer := Cfg_GVL.PlantCfg_Eng.BESSCfg.AWUBuffer / 100.0;\t\t\t\t\t//Convert from percentage to pu\n\n//Cap Bank Config\nCfg_GVL.CapBankCfg := Cfg_GVL.CapBankCfg_Eng; \t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t//Move over entire stucture\nFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\tCfg_GVL.CapBankCfg.CapOpenThresh[i] := Cfg_GVL.CapBankCfg_Eng.CapOpenThresh[i] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVar to pu on Sbase\n\tCfg_GVL.CapBankCfg.CapCloseThresh[i] := Cfg_GVL.CapBankCfg_Eng.CapCloseThresh[i] / Cfg_GVL.PlantCfg.Sbase;\t//Convert from MVar to pu on Sbase\n\tCfg_GVL.CapBankCfg.CapNomRating[i] := Cfg_GVL.CapBankCfg_Eng.CapNomRating[i] / Cfg_GVL.PlantCfg.Sbase;\t\t//Convert from MVar to pu on Sbase\nEND_FOR\n\n//Alarms Cfg -> Scale alarm limit values from Eng. Units to pu\nCfg_GVL.PlantCfg.AlmCfg.FreqFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.Hi / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.FreqFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.HiHi / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.FreqFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.Lo / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.FreqFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqFbk.LoLo / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.PFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.Lo / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.PFbk.LoLo / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.Lo / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.QFbk.LoLo / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.VABFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VABFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VABFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VABFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VABFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VANFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VANFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VANFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VANFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VANFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBCFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBCFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBCFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBCFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBCFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBNFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBNFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBNFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VBNFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VBNFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCAFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCAFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCAFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCAFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCAFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCNFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCNFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCNFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VCNFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VCNFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.Hi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.Lo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.Vbase;\n\n\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk_MV.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.Hi / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk_MV.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.HiHi / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk_MV.Lo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.Lo / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\nCfg_GVL.PlantCfg.AlmCfg.VLLAvgFbk_MV.LoLo := Cfg_GVL.PlantCfg_Eng.AlmCfg.VLLAvgFbk_MV.LoLo / Cfg_GVL.PlantCfg.VoltageCfg.MVbase;\n\nCfg_GVL.PlantCfg.AlmCfg.FreqMeasDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqMeasDev.Hi / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.FreqMeasDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.FreqMeasDev.HiHi / Cfg_GVL.PlantCfg.FreqCfg.FreqBase;\nCfg_GVL.PlantCfg.AlmCfg.PMeasDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PMeasDev.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PMeasDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PMeasDev.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpPOIDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpPOIDev.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpPOIDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpPOIDev.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpPVDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpPVDev.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpPVDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpPVDev.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpBESSDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpBESSDev.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.PSpBESSDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.PSpBESSDev.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QMeasDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.QMeasDev.Hi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QMeasDev.HiHi := Cfg_GVL.PlantCfg_Eng.AlmCfg.QMeasDev.HiHi / Cfg_GVL.PlantCfg.Sbase;\nCfg_GVL.PlantCfg.AlmCfg.QSpDev.Hi := Cfg_GVL.PlantCfg_Eng.AlmCfg.QSpDev