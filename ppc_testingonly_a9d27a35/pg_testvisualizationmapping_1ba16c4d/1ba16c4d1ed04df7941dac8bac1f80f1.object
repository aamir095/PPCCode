{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)1ba16c4d-1ed0-4df7-941d-ac8bac1f80f1","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_TestVisualizationMapping","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)a9d27a35-5d0e-47e7-b54d-814d6137b7ad"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Update the PPCSts GVL in the Visu library - this GVL will be read-only by the visu library\nTBE_Visus.PPCSts.PCtrl_Aux_Outputs := SCADA_GVL.PlantDiagnostics.PCtrl_Aux_Outputs;\nTBE_Visus.PPCSts.QCtrl_Aux_Outputs := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs;\nTBE_Visus.PPCSts.OpModeSts := SCADA_GVL.PlantDiagnostics.OpModeSts;\nTBE_Visus.PPCSts.PV_PCtrlDiagnostics := SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics;\nTBE_Visus.PPCSts.BESS_PCtrlDiagnostics := SCADA_GVL.PlantDiagnostics.BESS_PCtrlDiagnostics;\nTBE_Visus.PPCSts.PSp_Diagnostics := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics;\nTBE_Visus.PPCSts.QCtrlDiagnostics := SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics;\nTBE_Visus.PPCSts.PlantInvDiagnostics := SCADA_GVL.PlantDiagnostics.PlantInvDiagnostics;\nTBE_Visus.PPCSts.PlantEMSDiagnostics := SCADA_GVL.PlantDiagnostics.PlantEMSDiagnostics;\nTBE_Visus.PPCSts.HSL := SCADA_GVL.PlantDiagnostics.HSL;\nTBE_Visus.PPCSts.ActivePwrPotentialOutput := SCADA_GVL.PlantDiagnostics.ActivePwrPotentialOutput;\nTBE_Visus.PPCSts.MetAvgFbk := SCADA_GVL.PlantDiagnostics.MetAvgFbk;\nTBE_Visus.PPCSts.PlantHMIInputs := SCADA_GVL.PlantHMIInputs;\nTBE_Visus.PPCSts.PlantRemoteInputs1 := SCADA_GVL.PlantRemoteInputs1;\nTBE_Visus.PPCSts.PlantRemoteInputs2 := SCADA_GVL.PlantRemoteInputs2;\nTBE_Visus.PPCSts.PlantCurtailmentInputs := SCADA_GVL.PlantCurtailmentInputs;\n\n//Map Inputs from Visualization Screen\n\nIF TBE_Visus.Visu_GVL.Plant_EnableGUIInputs THEN\n\t//Plant Level Inputs\n\tSCADA_GVL.PlantHMIInputs.Run := TBE_Visus.Visu_GVL.Plant_Run;\n\t\n\t//Real Power Inputs\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_PV := TBE_Visus.Visu_GVL.P_ClosedLoopEn_PV;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.ClosedLoopCtrlEn_BESS := TBE_Visus.Visu_GVL.P_ClosedLoopEn_BESS;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_POI := TBE_Visus.Visu_GVL.P_CmdMode;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_PV := TBE_Visus.Visu_GVL.PV_CmdMode;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.CmdMode_BESS := TBE_Visus.Visu_GVL.BESS_CmdMode;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_POI := TBE_Visus.Visu_GVL.P_Sp;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_PV := TBE_Visus.Visu_GVL.PV_P_Sp;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.PSp_BESS := TBE_Visus.Visu_GVL.BESS_P_Sp;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.BESSChrgPriorityEn := TBE_Visus.Visu_GVL.BESS_ChrgPriEn; \n\t\n\t//Active Power Remote Inputs - POI\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI = 1 THEN\n\t\tRemoteInterfaceMap_DNP.Rem1Psp.oper.setMag := TBE_Visus.Visu_GVL.Rem1_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem1Psp.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem1Psp.oper.trigger := FALSE;\n\tEND_IF\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI = 2 THEN\n\t\tRemoteInterfaceMap_DNP.Rem2Psp.oper.setMag := TBE_Visus.Visu_GVL.Rem2_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem2Psp.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem2Psp.oper.trigger := FALSE;\n\tEND_IF\n\tIF TBE_Visus.Visu_GVL.P_CurtailEn THEN\n\t\tRemoteInterfaceMap_DNP.RemCurtailPLim.oper.setMag := TBE_Visus.Visu_GVL.P_CurtailSP;\n\t\tRemoteInterfaceMap_DNP.RemCurtailPLim.oper.trigger := TRUE;\n\t\tRemoteInterfaceMap_DNP.CurtailmentFlag.operLatchOn.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.CurtailmentFlag.operLatchOff.ctlVal := FALSE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.RemCurtailPLim.oper.trigger := FALSE;\n\t\tRemoteInterfaceMap_DNP.CurtailmentFlag.operLatchOff.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.CurtailmentFlag.operLatchOn.ctlVal := FALSE;\n\tEND_IF\n\t\n\t//Active Power Remote Inputs - PV (for co-located plants)\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_PV = 1 THEN\n\t\tRemoteInterfaceMap_DNP.Rem1PspPV.oper.setMag := TBE_Visus.Visu_GVL.PV_Rem1_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem1PspPV.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem1PspPV.oper.trigger := FALSE;\n\tEND_IF\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_PV = 2 THEN\n\t\tRemoteInterfaceMap_DNP.Rem2PspPV.oper.setMag := TBE_Visus.Visu_GVL.PV_Rem2_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem2PspPV.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem2PspPV.oper.trigger := FALSE;\n\tEND_IF\n\tIF TBE_Visus.Visu_GVL.PV_CurtailEn THEN\n\t\tRemoteInterfaceMap_DNP.RemCurtailPVLim.oper.setMag := TBE_Visus.Visu_GVL.PV_CurtailSP;\n\t\tRemoteInterfaceMap_DNP.RemCurtailPVLim.oper.trigger := TRUE;\n\t\tRemoteInterfaceMap_DNP.PVCurtailmentFlag.operLatchOn.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.PVCurtailmentFlag.operLatchOff.ctlVal := FALSE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.RemCurtailPVLim.oper.trigger := FALSE;\n\t\tRemoteInterfaceMap_DNP.PVCurtailmentFlag.operLatchOff.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.PVCurtailmentFlag.operLatchOn.ctlVal := FALSE;\n\tEND_IF\n\t\n\t//Active Power Remote Inputs - BESS (for co-located plants)\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_BESS = 1 THEN\n\t\tRemoteInterfaceMap_DNP.Rem1PspBESS.oper.setMag := TBE_Visus.Visu_GVL.BESS_Rem1_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem1PspBESS.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem1PspBESS.oper.trigger := FALSE;\n\tEND_IF\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_BESS = 2 THEN\n\t\tRemoteInterfaceMap_DNP.Rem2PspBESS.oper.setMag := TBE_Visus.Visu_GVL.BESS_Rem2_PSp;\n\t\tRemoteInterfaceMap_DNP.Rem2PspBESS.oper.trigger := TRUE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.Rem2PspBESS.oper.trigger := FALSE;\n\tEND_IF\n\tIF TBE_Visus.Visu_GVL.BESS_CurtailEn THEN\n\t\tRemoteInterfaceMap_DNP.RemCurtailBESSLim.oper.setMag := TBE_Visus.Visu_GVL.BESS_CurtailSP;\n\t\tRemoteInterfaceMap_DNP.RemCurtailBESSLim.oper.trigger := TRUE;\n\t\tRemoteInterfaceMap_DNP.BESSCurtailmentFlag.operLatchOn.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.BESSCurtailmentFlag.operLatchOff.ctlVal := FALSE;\n\tELSE\n\t\tRemoteInterfaceMap_DNP.RemCurtailBESSLim.oper.trigger := FALSE;\n\t\tRemoteInterfaceMap_DNP.BESSCurtailmentFlag.operLatchOff.ctlVal := TRUE;\n\t\tRemoteInterfaceMap_DNP.BESSCurtailmentFlag.operLatchOn.ctlVal := FALSE;\n\tEND_IF\n\t\t\n\t//Frequency Inputs\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestEn := TBE_Visus.Visu_GVL.Freq_EnableTest;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestSp_Hz := TBE_Visus.Visu_GVL.Freq_TestSP_Hz;\n\tSCADA_GVL.PlantHMIInputs.ActivePwr.FreqTestTime_sec := TBE_Visus.Visu_GVL.Freq_Time_s;\n\t\n\t//Reactive Power Inputs\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.ClosedLoopCtrlEn := TBE_Visus.Visu_GVL.Q_ClosedLoopEn;\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.CmdMode := TBE_Visus.Visu_GVL.Q_CmdMode;\n\t//SCADA_GVL.PlantHMIInputs.ReactivePwr.QMode := TBE_Visus.Visu_GVL.Q_Mode; \n\t//Convert Q mode to enable bits\n\tSCADA_GVL.PlantHMIInputs.ReactivePwr.OpMode := TBE_Visus.Visu_GVL.Q_Mode;\n\t\n\t//Reactive Power Remote Source 1 Inputs\n\t//Set trigger to false\n\tRemoteInterfaceMap_DNP.Rem1QSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem1VSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem1PFSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem1Qmd.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem2QSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem2VSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem2PFSp.oper.trigger := FALSE;\n\tRemoteInterfaceMap_DNP.Rem2Qmd.oper.trigger := FALSE;\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode = 0 THEN\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_Q THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.QSp := TBE_Visus.Visu_GVL.Q_Sp;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_V THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.VSp := TBE_Visus.Visu_GVL.V_Sp;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_PF THEN\n\t\t\tSCADA_GVL.PlantHMIInputs.ReactivePwr.PFSp := TBE_Visus.Visu_GVL.PF_Sp;\n\t\tEND_IF\n\tEND_IF\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode = 1 THEN\n\t\tRemoteInterfaceMap_DNP.Rem1Qmd.oper.setMag := TBE_Visus.Visu_GVL.Rem1_Q_Mode;\n\t\tRemoteInterfaceMap_DNP.Rem1Qmd.oper.trigger := TRUE;\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_Q THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem1QSp.oper.setMag := TBE_Visus.Visu_GVL.Rem1_QSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem1QSp.oper.trigger := TRUE;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_V THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem1VSp.oper.setMag := TBE_Visus.Visu_GVL.Rem1_VSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem1VSp.oper.trigger := TRUE;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_PF THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem1PFSp.oper.setMag := TBE_Visus.Visu_GVL.Rem1_PFSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem1PFSp.oper.trigger := TRUE;\n\t\tEND_IF\n\tEND_IF\n\tIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode = 2 THEN\n\t\tRemoteInterfaceMap_DNP.Rem2Qmd.oper.setMag := TBE_Visus.Visu_GVL.Rem2_Q_Mode;\n\t\tRemoteInterfaceMap_DNP.Rem2Qmd.oper.trigger := TRUE;\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_Q THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem2QSp.oper.setMag := TBE_Visus.Visu_GVL.Rem2_QSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem2QSp.oper.trigger := TRUE;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_V THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem2VSp.oper.setMag := TBE_Visus.Visu_GVL.Rem2_VSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem2VSp.oper.trigger := TRUE;\n\t\tEND_IF\n\t\tIF SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = Cfg_GVL.PlantCfg.AVR_PF THEN\n\t\t\tRemoteInterfaceMap_DNP.Rem2PFSp.oper.setMag := TBE_Visus.Visu_GVL.Rem2_PFSp;\n\t\t\tRemoteInterfaceMap_DNP.Rem2PFSp.oper.trigger := TRUE;\n\t\tEND_IF\n\tEND_IF\n\t\n\t//Inverter Inputs\n\tTBE_Visus.Visu_GVL.NumInvs := UINT_TO_INT(SiteConstants.NumInvs);\n\tFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\t\tIF i >= 1 AND i < 100 THEN\n\t\t\t//All to auto/manual\n\t\t\tIF TBE_Visus.Visu_GVL.AllInvsPAuto THEN\n\t\t\t\tTBE_Visus.Visu_GVL.InvCtrl[i].PAutoEn := TRUE; \n\t\t\tEND_IF\n\t\t\tIF TBE_Visus.Visu_GVL.AllInvsPMan THEN\n\t\t\t\tTBE_Visus.Visu_GVL.InvCtrl[i].PAutoEn := FALSE; \n\t\t\tEND_IF\n\t\t\tIF TBE_Visus.Visu_GVL.AllInvsQAuto THEN\n\t\t\t\tTBE_Visus.Visu_GVL.InvCtrl[i].QAutoEn := TRUE; \n\t\t\tEND_IF\n\t\t\tIF TBE_Visus.Visu_GVL.AllInvsQMan THEN\n\t\t\t\tTBE_Visus.Visu_GVL.InvCtrl[i].QAutoEn := FALSE; \n\t\t\tEND_IF\n\t\t\t//Write to SCADA GVL\n\t\t\tSCADA_GVL.DeviceHMIInputs[i].PAutoEn := TBE_Visus.Visu_GVL.InvCtrl[i].PAutoEn;\n\t\t\tSCADA_GVL.DeviceHMIInputs[i].QAutoEn := TBE_Visus.Visu_GVL.InvCtrl[i].QAutoEn;\n\t\tEND_IF\n\tEND_FOR\n\t\n\tTBE_Visus.Visu_GVL.NumEMS := UINT_TO_INT(SiteConstants.NumEMS);\n\tFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\t\tIF i >= 1 AND i < 100 THEN\n\t\t\t//All to auto manual\n\t\t\tIF TBE_Visus.Visu_GVL.AllEMSPAuto THEN\n\t\t\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].PAutoEn := TRUE;\n\t\t\tEND_IF\n\t\t\tIF TBE_Visus.Visu_GVL.AllEMSPMan THEN\n\t\t\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].PAutoEn := FALSE;\n\t\t\tEND_IF;\n\t\t\tIF TBE_Visus.Visu_GVL.AllEMSQAuto THEN\n\t\t\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].QAutoEn := TRUE;\n\t\t\tEND_IF\n\t\t\tIF TBE_Visus.Visu_GVL.AllEMSQMan THEN\n\t\t\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].QAutoEn := FALSE;\n\t\t\tEND_IF\n\t\t\t//Write to SCADA GVL\n\t\t\tSCADA_GVL.EMSHMIInputs[i].PAutoEn := TBE_Visus.Visu_GVL.EMSCtrl[i].PAutoEn;\n\t\t\tSCADA_GVL.EMSHMIInputs[i].QAutoEn := TBE_Visus.Visu_GVL.EMSCtrl[i].QAutoEn;\n\t\tEND_IF\n\tEND_FOR\n\t\n\t//Capacitor bank inputs\n\tSubstationCtrl_DNP.CapSw_MVMeter_QFbk.instMag := TBE_Visus.Visu_GVL.Cap_QFbk;\n\tFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tIF i = 1 AND SiteConstants.NumCapBanks >= 1 THEN\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].AutoEn := TBE_Visus.Visu_GVL.Cap1_AutoEn;\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].CmdCloseManual := TBE_Visus.Visu_GVL.Cap1_ManClose;\n\t\t\tTBE_Visus.Visu_GVL.Cap1_ManClose := FALSE;\t\t//Return manual close command to FALSE after reading\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].CmdOpenManual := TBE_Visus.Visu_GVL.Cap1_ManOpen;\n\t\t\tTBE_Visus.Visu_GVL.Cap1_ManOpen := FALSE;\t\t//Return manual open command to FALSE after reading\n\t\t\tSubstationCtrl_DNP.Cap1_Close_Avail.stVal := TBE_Visus.Visu_GVL.Cap1_CloseAvail;\n\t\t\tSubstationCtrl_DNP.Cap1_Open_Avail.stVal := TBE_Visus.Visu_GVL.Cap1_OpenAvail;\n\t\t\tIF TBE_Visus.Visu_GVL.Cap1_OvrdFbk THEN\n\t\t\t\tSubstationCtrl_DNP.Cap1_Switch_Sts.stVal := TBE_Visus.Visu_GVL.Cap1_ForceClosed;\n\t\t\tEND_IF\n\t\tEND_IF\n\t\tIF i = 2 AND SiteConstants.NumCapBanks >= 2 THEN\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].AutoEn := TBE_Visus.Visu_GVL.cap2_AutoEn;\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].CmdCloseManual := TBE_Visus.Visu_GVL.cap2_ManClose;\n\t\t\tTBE_Visus.Visu_GVL.cap2_ManClose := FALSE;\t\t//Return manual close command to FALSE after reading\n\t\t\tSCADA_GVL.CapBankHMIInputs[i].CmdOpenManual := TBE_Visus.Visu_GVL.Cap2_ManOpen;\n\t\t\tTBE_Visus.Visu_GVL.cap2_ManOpen := FALSE;\t\t//Return manual open command to FALSE after reading\n\t\t\tSubstationCtrl_DNP.Cap2_Close_Avail.stVal := TBE_Visus.Visu_GVL.Cap2_CloseAvail;\n\t\t\tSubstationCtrl_DNP.Cap2_Open_Avail.stVal := TBE_Visus.Visu_GVL.Cap2_OpenAvail;\n\t\t\tIF TBE_Visus.Visu_GVL.Cap2_OvrdFbk THEN\n\t\t\t\tSubstationCtrl_DNP.Cap2_Switch_Sts.stVal := TBE_Visus.Visu_GVL.Cap2_ForceClosed;\n\t\t\tEND_IF\n\t\tEND_IF\n\tEND_FOR\n\t\n\t//Redundancy Inputs\n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC1 := TBE_Visus.Visu_GVL.Red_MaintenanceModeEn_r1; \n\tSCADA_GVL.RedundancyHMIInputs.MaintModeEn_RTAC2 := TBE_Visus.Visu_GVL.Red_MaintenanceModeEn_r2; \n\t\n\t//Auto Test Inputs\n\tSCADA_GVL.PlantHMIInputs.TestInputs.TestNum := TBE_Visus.Visu_GVL.AutoTestNum;\n\tSCADA_GVL.PlantHMIInputs.TestInputs.TestsEn := TBE_Visus.Visu_GVL.AutoTestsEn;\n\tSCADA_GVL.PlantHMIInputs.TestInputs.TestStart := TBE_Visus.Visu_GVL.AutoTestStart;\nEND_IF\n\n//Map status values to Visualization Screen\n//Plant Status\nTBE_Visus.Visu_GVL.Plant_RunningSts := DINT_TO_BOOL(SCADA_GVL.PlantDiagnostics.OpModeSts.State);\n\n//Real Power Status\nTBE_Visus.Visu_GVL.P_ClosedLoopSts_PV := SCADA_GVL.PlantDiagnostics.OpModeSts.PClosedLoopCtrl_PV;\nTBE_Visus.Visu_GVL.P_ClosedLoopSts_BESS := SCADA_GVL.PlantDiagnostics.OpModeSts.PClosedLoopCtrl_BESS;\nTBE_Visus.Visu_GVL.P_CmdModeSts := SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI;\nTBE_Visus.Visu_GVL.PV_CmdModeSts := SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_PV;\nTBE_Visus.Visu_GVL.BESS_CmdModeSts := SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_BESS;\nTBE_Visus.Visu_GVL.P_Sp_Sts := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_POI_PreRamp;\nTBE_Visus.Visu_GVL.P_PID_CV := SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_CV;\nTBE_Visus.Visu_GVL.P_PID_PV := SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_PV;\nTBE_Visus.Visu_GVL.P_PID_SP := SCADA_GVL.PlantDiagnostics.PV_PCtrlDiagnostics.PPID_SP;\nTBE_Visus.Visu_GVL.PV_POI_Ctrl_Sts := SCADA_GVL.PlantDiagnostics.PCtrl_Aux_Outputs.PV_POI_Ctrl;\nTBE_Visus.Visu_GVL.PV_ClosedLoopPerm := SCADA_GVL.PlantDiagnostics.PCtrl_Aux_Outputs.ClosedLoopPerm_PV;\n\n//BESS related\nTBE_Visus.Visu_GVL.BESS_P_Sp_Sts := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_BESS_PreRamp;\nTBE_Visus.Visu_GVL.BESS_PPID_SP := SCADA_GVL.PlantDiagnostics.BESS_PCtrlDiagnostics.PPID_SP;\nTBE_Visus.Visu_GVL.BESS_PPID_PV := SCADA_GVL.PlantDiagnostics.BESS_PCtrlDiagnostics.PPID_PV;\nTBE_Visus.Visu_GVL.BESS_PPID_CV := SCADA_GVL.PlantDiagnostics.BESS_PCtrlDiagnostics.PPID_CV;\nTBE_Visus.Visu_GVL.BESS_FreqDroopOutput := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.FreqDiag_BESS.FreqDroopOutput;\nTBE_Visus.Visu_GVL.BESS_POI_Ctrl_Sts := SCADA_GVL.PlantDiagnostics.PCtrl_Aux_Outputs.BESS_POI_Ctrl;\nTBE_Visus.Visu_GVL.BESS_ClosedLoopPerm := SCADA_GVL.PlantDiagnostics.PCtrl_Aux_Outputs.ClosedLoopPerm_BESS;\n\n//Reactive Power Status\nTBE_Visus.Visu_GVL.Q_ClosedLoopSts := SCADA_GVL.PlantDiagnostics.OpModeSts.QClosedLoopCtrl;\nTBE_Visus.Visu_GVL.Q_CmdModeSts := SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode;\nTBE_Visus.Visu_GVL.Q_PID_CV := SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_CV;\nTBE_Visus.Visu_GVL.Q_PID_PV := SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_PV;\nTBE_Visus.Visu_GVL.Q_PID_SP := SCADA_GVL.PlantDiagnostics.QCtrlDiagnostics.QPID_SP;\nTBE_Visus.Visu_GVL.Q_QModeActive := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = 3;\nTBE_Visus.Visu_GVL.Q_PFModeActive := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = 2;\nTBE_Visus.Visu_GVL.Q_VModeActive := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode = 1; \nTBE_Visus.Visu_GVL.Q_Sp_Sts := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Qsp;\nTBE_Visus.Visu_GVL.V_Sp_Sts := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Vsp;\nTBE_Visus.Visu_GVL.PF_Sp_Sts := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.PFsp;\n\n//Active Power Tracking\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI <> 0 THEN\n\tTBE_Visus.Visu_GVL.P_Sp := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_POI_PreRamp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI <> 1 THEN\n\tTBE_Visus.Visu_GVL.Rem1_PSp := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_POI_PreRamp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.PCmdMode_POI <> 2 THEN\n\tTBE_Visus.Visu_GVL.Rem2_PSp := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.PSp_POI_PreRamp;\nEND_IF\n\n//Active Power Curtailment\nTBE_Visus.Visu_GVL.P_CurtailFlag := SCADA_GVL.PlantCurtailmentInputs.CurtailmentFlag_POI;\nTBE_Visus.Visu_GVL.P_CurtailLim := SCADA_GVL.PlantCurtailmentInputs.PSp_POI;\nTBE_Visus.Visu_GVL.PV_CurtailFlag := SCADA_GVL.PlantCurtailmentInputs.CurtailmentFlag_PV;\nTBE_Visus.Visu_GVL.PV_CurtailLim := SCADA_GVL.PlantCurtailmentInputs.PSp_PV;\nTBE_Visus.Visu_GVL.BESS_CurtailFlag := SCADA_GVL.PlantCurtailmentInputs.CurtailmentFlag_BESS;\nTBE_Visus.Visu_GVL.BESS_CurtailLim := SCADA_GVL.PlantCurtailmentInputs.PSp_BESS;\n\n//Reactive Power Tracking - Operator Station Commands\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 0 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_Q THEN\n\tTBE_Visus.Visu_GVL.Q_Sp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Qsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 0 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_V THEN\n\tTBE_Visus.Visu_GVL.V_Sp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Vsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 0 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_PF THEN\n\tTBE_Visus.Visu_GVL.PF_Sp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.PFsp;\nEND_IF\n\n//Reactive Power Tracking - Remote 1 Commands\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 1 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_Q THEN\n\tTBE_Visus.Visu_GVL.Rem1_QSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Qsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 1 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_V THEN\n\tTBE_Visus.Visu_GVL.Rem1_VSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Vsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 1 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_PF THEN\n\tTBE_Visus.Visu_GVL.Rem1_PFSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.PFsp;\nEND_IF\n\n//Reactive Power Tracking - Remote 2 Commands\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 2 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_Q THEN\n\tTBE_Visus.Visu_GVL.Rem2_QSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Qsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 2 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_V THEN\n\tTBE_Visus.Visu_GVL.Rem2_VSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.Vsp;\nEND_IF\nIF SCADA_GVL.PlantDiagnostics.OpModeSts.QCmdMode <> 2 OR SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.OpMode <> Cfg_GVL.PlantCfg.AVR_PF THEN\n\tTBE_Visus.Visu_GVL.Rem2_PFSp := SCADA_GVL.PlantDiagnostics.QCtrl_Aux_Outputs.PFsp;\nEND_IF\n\n//Inverter status\nFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\tIF i >= 1 AND i < 100 THEN\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].PAutoSts := SCADA_GVL.InvDeviceDiagnostics[i].Sts_Pauto;\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].QAutoSts := SCADA_GVL.InvDeviceDiagnostics[i].Sts_Qauto;\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].PCmd := SCADA_GVL.InvDeviceDiagnostics[i].Cmd_Psp;\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].PSts := SCADA_GVL.InvDeviceDiagnostics[i].Sts_P;\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].QCmd := SCADA_GVL.InvDeviceDiagnostics[i].Cmd_Qsp;\n\t\tTBE_Visus.Visu_GVL.InvCtrl[i].QSts := SCADA_GVL.InvDeviceDiagnostics[i].Sts_Q;\n\tEND_IF\nEND_FOR\n\n//EMS Status\nFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\tIF i > 0 AND i < 100 THEN\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].PAutoSts := SCADA_GVL.EMSDeviceDiagnostics[i].Sts_Pauto;\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].QAutoSts := SCADA_GVL.EMSDeviceDiagnostics[i].Sts_Qauto;\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].PCmd := SCADA_GVL.EMSDeviceDiagnostics[i].Cmd_Psp;\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].PSts := SCADA_GVL.EMSDeviceDiagnostics[i].Sts_P;\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].QCmd := SCADA_GVL.EMSDeviceDiagnostics[i].Cmd_Qsp;\n\t\tTBE_Visus.Visu_GVL.EMSCtrl[i].QSts := SCADA_GVL.EMSDeviceDiagnostics[i].Sts_Q;\n\tEND_IF\nEND_FOR\n\n//Meter Status\nTBE_Visus.Visu_GVL.Meter01_PFbk := SCADA_GVL.MeterFbk_scaled.Sts_P;\nTBE_Visus.Visu_GVL.Meter01_QFbk := SCADA_GVL.MeterFbk_scaled.Sts_Q;\nTBE_Visus.Visu_GVL.Meter01_VFbk := SCADA_GVL.MeterFbk_scaled.Sts_VLLAvg;\nTBE_Visus.Visu_GVL.Meter01_IFbk := -SCADA_GVL.MeterFbk_scaled.Sts_IMag;\nTBE_Visus.Visu_GVL.Meter01_FreqFbk := SCADA_GVL.MeterFbk_scaled.Sts_Freq;\n\n//PV Meter Status\nTBE_Visus.Visu_GVL.PVMeter_PFbk := SCADA_GVL.MeterFbk_PV.Sts_P;\nTBE_Visus.Visu_GVL.PVMeter_QFbk := SCADA_GVL.MeterFbk_PV.Sts_Q;\nTBE_Visus.Visu_GVL.PVMeter_VFbk := SCADA_GVL.MeterFbk_PV.Sts_VLLAvg;\nTBE_Visus.Visu_GVL.PVMeter_IFbk := -SCADA_GVL.MeterFbk_PV.Sts_IMag;\nTBE_Visus.Visu_GVL.PVMeter_FreqFbk := SCADA_GVL.MeterFbk_PV.Sts_Freq;\n\n//BESS Meter Status\nTBE_Visus.Visu_GVL.BESSMeter_PFbk := SCADA_GVL.MeterFbk_BESS.Sts_P;\nTBE_Visus.Visu_GVL.BESSMeter_QFbk := SCADA_GVL.MeterFbk_BESS.Sts_Q;\nTBE_Visus.Visu_GVL.BESSMeter_VFbk := SCADA_GVL.MeterFbk_BESS.Sts_VLLAvg;\nTBE_Visus.Visu_GVL.BESSMeter_IFbk := -SCADA_GVL.MeterFbk_BESS.Sts_IMag;\nTBE_Visus.Visu_GVL.BESSMeter_FreqFbk := SCADA_GVL.MeterFbk_BESS.Sts_Freq;\n\n//Frequency Ctrl Status\nTBE_Visus.Visu_GVL.P_FreqCtrlEn := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.FreqDiag_POI.FreqDroopEn; \nTBE_Visus.Visu_GVL.P_FreqActive := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.FreqDiag_POI.FreqDroopActive; \nTBE_Visus.Visu_GVL.P_FreqDeviation := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.FreqDiag_POI.FreqDeviation; \nTBE_Visus.Visu_GVL.P_FreqDroopOutput := SCADA_GVL.PlantDiagnostics.PSp_Diagnostics.FreqDiag_POI.FreqDroopOutput; \n\n//Plant Status (KPIs)\nTBE_Visus.Visu_GVL.HSL := SCADA_GVL.PlantDiagnostics.HSL;\nTBE_Visus.Visu_GVL.NumInvsRunning := SCADA_GVL.PlantDiagnostics.PlantInvDiagnostics.TotalPVInv_Generating;\nTBE_Visus.Visu_GVL.NumInvsStopped := SCADA_GVL.PlantDiagnostics.PlantInvDiagnostics.TotalPVInv_NotGenerating;\nTBE_Visus.Visu_GVL.NumInvsUnknown := SCADA_GVL.PlantDiagnostics.PlantInvDiagnostics.TotalPVInv_Unknown;\nTBE_Visus.Visu_GVL.NumEMSRunning := UINT_TO_INT(SCADA_GVL.PlantDiagnostics.PlantEMSDiagnostics.NumEMSRunning);\nTBE_Visus.Visu_GVL.NumEMSStopped := UINT_TO_INT(SCADA_GVL.PlantDiagnostics.PlantEMSDiagnostics.NumEMSStopped);\nTBE_Visus.Visu_GVL.NumEMSUnknown := UINT_TO_INT(SCADA_GVL.PlantDiagnostics.PlantEMSDiagnostics.NumEMSCommFault);\n\n//Redundancy Status\nTBE_Visus.Visu_GVL.RedundancySts[1] := SCADA_GVL.RedundancySts[1];\nTBE_Visus.Visu_GVL.RedundancySts[2] := SCADA_GVL.RedundancySts[2]; \n\n//Cap Bank Status\nFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\tIF i = 1 AND SiteConstants.NumCapBanks >= 1 THEN\n\t\tTBE_Visus.Visu_GVL.Cap1_AutoSts := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].Auto;\n\t\tTBE_Visus.Visu_GVL.Cap1_OpenPerm := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenPerm;\n\t\tTBE_Visus.Visu_GVL.Cap1_ClosePerm := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].ClosePerm;\n\t\tTBE_Visus.Visu_GVL.Cap1_OpenTmrActive := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenWaitTmrActive;\n\t\tTBE_Visus.Visu_GVL.Cap1_CloseTmrActive := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].CloseWaitTmrActive;\n\t\tTBE_Visus.Visu_GVL.Cap1_OpenCmdIssued := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenCmdIssued;\n\t\tTBE_Visus.Visu_GVL.Cap1_CloseCmdIssued := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].CloseCmdIssued;\n\t\tTBE_Visus.Visu_GVL.Cap1_Closed := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].Closed;\n\t\tTBE_Visus.Visu_GVL.Cap1_OpenThresh := Cfg_GVL.CapBankCfg_Eng.CapOpenThresh[i];\n\t\tTBE_Visus.Visu_GVL.Cap1_CloseThresh := Cfg_GVL.CapBankCfg_Eng.CapCloseThresh[i];\n\tEND_IF\n\tIF i = 2 AND SiteConstants.NumCapBanks >= 2 THEN\n\t\tTBE_Visus.Visu_GVL.cap2_AutoSts := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].Auto;\n\t\tTBE_Visus.Visu_GVL.cap2_OpenPerm := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenPerm;\n\t\tTBE_Visus.Visu_GVL.cap2_ClosePerm := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].ClosePerm;\n\t\tTBE_Visus.Visu_GVL.cap2_OpenTmrActive := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenWaitTmrActive;\n\t\tTBE_Visus.Visu_GVL.cap2_CloseTmrActive := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].CloseWaitTmrActive;\n\t\tTBE_Visus.Visu_GVL.cap2_OpenCmdIssued := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].OpenCmdIssued;\n\t\tTBE_Visus.Visu_GVL.cap2_CloseCmdIssued := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].CloseCmdIssued;\n\t\tTBE_Visus.Visu_GVL.cap2_Closed := SCADA_GVL.PlantDiagnostics.CapBankDiagnostics[i].Closed;\n\t\tTBE_Visus.Visu_GVL.cap2_OpenThresh := Cfg_GVL.CapBankCfg_Eng.CapOpenThresh[i];\n\t\tTBE_Visus.Visu_GVL.cap2_CloseThresh := Cfg_GVL.CapBankCfg_Eng.CapCloseThresh[i];\n\tEND_IF\nEND_FOR\n\n//Auto Test Diagnostics\nTBE_Visus.PPCSts.AutoTestSts := SCADA_GVL.TestDiagnostics.AutoTestDiagnostics;","LineInfoPersistence":"(string)1ba16c4d-1ed0-4df7-941d-ac8bac1f80f1_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tTest Visualization Mapping Program\n|\tMap Visualization Input values to OPC map\n|\tMap OPC tags to Visualization status values\n*)\n\nPROGRAM pg_TestVisualizationMapping\nVAR\n\ti\t\t: UINT;\t\t//Indexing variable\nEND_VAR","LineInfoPersistence":"(string)1ba16c4d-1ed0-4df7-941d-ac8bac1f80f1_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)462","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}