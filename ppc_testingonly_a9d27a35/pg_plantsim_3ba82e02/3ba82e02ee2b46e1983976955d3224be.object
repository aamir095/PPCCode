{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)3ba82e02-ee2b-46e1-9839-76955d3224be","ParentGuid":"(Guid)00000000-0000-0000-0000-000000000000","Name":"(string)pg_PlantSim","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)21af5390-2942-461a-bf89-951aaf6999f1","@Value":"(Guid)a9d27a35-5d0e-47e7-b54d-814d6137b7ad"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//Only run program if simulation is enabled\n\n//Only allow onboard or SEL3530 sim\nIF TBE_Visus.Visu_GVL.Plant_Enable3530Sim THEN\n\tTBE_Visus.Visu_GVL.Plant_EnableSim := FALSE;\nEND_IF\nIF TBE_Visus.Visu_GVL.Plant_EnableSim THEN\n\tTBE_Visus.Visu_GVL.Plant_Enable3530Sim := FALSE;\nEND_IF\n\nIF TBE_Visus.Visu_GVL.Plant_EnableSim THEN\n\tTBE_Visus.Visu_GVL.Plant_SimSts := TRUE; \n\tTBE_Visus.Visu_GVL.Plant_Enable3530Sim := FALSE;\n\tTest_GVL.UseSimMeter := FALSE; \n\t//Use override meter values instead of actual\n\tTest_GVL.OvrdPMHV1Inputs := TRUE; \n\tTest_GVL.PMHV1_Offline := FALSE; \n\tTest_GVL.OvrdPMMV1Inputs:= TRUE;\n\tTest_GVL.PMMV1_Offline := FALSE;\n\tTest_GVL.OvrdPMMV2Inputs:= TRUE;\n\tTest_GVL.PMMV2_Offline := FALSE;\n\t//Use Override inverter values instead of actual\n\tTest_GVL.OvrdInvInputs := TRUE; \n\tTest_GVL.OvrdEMSInputs := TRUE;\n\t//Real/Reactive Power Simulation\n\t\n\t//Loop through inverters and calculated real/reactive power feedback w/ Irradiance and random noise in feedback\n\tFOR i := 0 TO SiteConstants.NumInvs BY 1 DO\n\t\tIF TBE_Visus.Visu_GVL.Plant_FbkNoiseEn THEN\n\t\t\t//Determine random value to add to P/Q Feedback\n\t\t\tTBE_Visus.Visu_GVL.Plant_FbkNoiseSts := TRUE; \n\t\t\tt := TIME_TO_UDINT(TIME()); \n\t\t\tRandNoise[i] := NoiseBase - (UDINT_TO_REAL(t MOD i) * TBE_Visus.Visu_GVL.Plant_FbkNoiseVal);\n\t\tELSE\n\t\t\tRandNoise[i] := 0; \n\t\t\tTBE_Visus.Visu_GVL.Plant_FbkNoiseSts := FALSE; \n\t\tEND_IF\n\t\t\n\t\t//Determine meter feedback as sum of inverter feedback values -> Add random noise and apply filter\n\t\tIF FPU.IsRealNaN(InvFbk_P[i]) THEN\n\t\t\tInvFbk_P[i] := ((PPCOutputs_scaled.InvCmds[i].PCmd * InvPCmdSCale + RandNoise[i]) * PFbkDelayScale);\n\t\tELSE\n\t\t\tIF TBE_Visus.Visu_GVL.Plant_POvrdEn THEN\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_POvrdSts := TRUE;\n\t\t\t\tInvFbk_P[i] := ((PPCOutputs_scaled.InvCmds[i].PCmd * InvPCmdSCale * TBE_Visus.Visu_GVL.Plant_POvrdVal + RandNoise[i]) * PFbkDelayScale) + (InvFbk_P[i] * (1-PFbkDelayScale));\n\t\t\tELSE\t\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_POvrdSts := FALSE;\n\t\t\t\tInvFbk_P[i] := ((PPCOutputs_scaled.InvCmds[i].PCmd * InvPCmdSCale + RandNoise[i]) * PFbkDelayScale) + (InvFbk_P[i] * (1-PFbkDelayScale));\n\t\t\tEND_IF\n\t\tEND_IF\n\t\tIF FPU.IsRealNaN(InvFbk_Q[i]) THEN\n\t\t\tInvFbk_Q[i] := ((PPCOutputs_scaled.InvCmds[i].QCmd * InvQCmdSCale + RandNoise[i]) * QFbkDelayScale);\n\t\tELSE\n\t\t\tIF TBE_Visus.Visu_GVL.Plant_QOvrdEn THEN\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_QOvrdSts := TRUE;\n\t\t\t\tInvFbk_Q[i] := ((PPCOutputs_scaled.InvCmds[i].QCmd * InvQCmdSCale * TBE_Visus.Visu_GVL.Plant_QOvrdVal + RandNoise[i]) * QFbkDelayScale) + (InvFbk_Q[i] * (1-QFbkDelayScale));\n\t\t\tELSE\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_QOvrdSts := FALSE;\n\t\t\t\tInvFbk_Q[i] := ((PPCOutputs_scaled.InvCmds[i].QCmd * InvQCmdSCale + RandNoise[i]) * QFbkDelayScale) + (InvFbk_Q[i] * (1-QFbkDelayScale));\n\t\t\tEND_IF\n\t\tEND_IF\n\t\t\n\t\t//Add inverter values to meter sum -> Divide by 1000 to convert kW/kVar to MW/MVar\n\t\tIF NOT FPU.IsRealNaN(InvFbk_P[i]) THEN\n\t\t\tPVMeterFbk_P := PVMeterFbk_P + (InvFbk_P[i]/1000.0);\n\t\tEND_IF\n\t\tIF NOT FPU.IsRealNaN(InvFbk_Q[i]) THEN\n\t\t\tPVMeterFbk_Q := PVMeterFbk_Q + (InvFbk_Q[i]/1000.0); \n\t\tEND_IF\n\t\t\n\t\t//Write inverter feedbacks to Test_GVL\n\t\tTest_GVL.InvFbk_P[i] := InvFbk_P[i];\n\t\tTest_GVL.InvFbk_Q[i] := InvFbk_Q[i]; \n\tEND_FOR\n\t\n\t//Loop through all EMS Modules and determine active/reactive power fbk\n\tFOR i := 0 TO SiteConstants.NumEMS BY 1 DO\n\t\tIF TBE_Visus.Visu_GVL.Plant_FbkNoiseEn THEN\n\t\t\t//Determine random value to add to P/Q Feedback\n\t\t\tTBE_Visus.Visu_GVL.Plant_FbkNoiseSts := TRUE; \n\t\t\tt := TIME_TO_UDINT(TIME()); \n\t\t\tRandNoiseEMS[i] := NoiseBase - (UDINT_TO_REAL(t MOD i) * TBE_Visus.Visu_GVL.Plant_FbkNoiseVal);\n\t\tELSE\n\t\t\tRandNoiseEMS[i] := 0; \n\t\t\tTBE_Visus.Visu_GVL.Plant_FbkNoiseSts := FALSE; \n\t\tEND_IF\n\t\t\n\t\t//Determine meter feedback as sum of inverter feedback values -> Add random noise and apply filter\n\t\tIF FPU.IsRealNaN(EMSFbk_P[i]) THEN\n\t\t\tEMSFbk_P[i] := ((PPCOutputs_scaled.EMSCmds[i].PCmd + RandNoise[i]) * PFbkDelayScale);\n\t\tELSE\n\t\t\tIF TBE_Visus.Visu_GVL.Plant_POvrdEn THEN\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_POvrdSts := TRUE;\n\t\t\t\tEMSFbk_P[i] := ((PPCOutputs_scaled.EMSCmds[i].PCmd * TBE_Visus.Visu_GVL.Plant_POvrdVal + RandNoise[i]) * PFbkDelayScale) + (EMSFbk_P[i] * (1-PFbkDelayScale));\n\t\t\tELSE\t\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_POvrdSts := FALSE;\n\t\t\t\tEMSFbk_P[i] := ((PPCOutputs_scaled.EMSCmds[i].PCmd + RandNoise[i]) * PFbkDelayScale) + (EMSFbk_P[i] * (1-PFbkDelayScale));\n\t\t\tEND_IF\n\t\tEND_IF\n\t\tIF FPU.IsRealNaN(EMSFbk_Q[i]) THEN\n\t\t\tEMSFbk_Q[i] := ((PPCOutputs_scaled.EMSCmds[i].QCmd + RandNoise[i]) * QFbkDelayScale);\n\t\tELSE\n\t\t\tIF TBE_Visus.Visu_GVL.Plant_QOvrdEn THEN\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_QOvrdSts := TRUE;\n\t\t\t\tEMSFbk_Q[i] := ((PPCOutputs_scaled.EMSCmds[i].QCmd * TBE_Visus.Visu_GVL.Plant_QOvrdVal + RandNoise[i]) * QFbkDelayScale) + (EMSFbk_Q[i] * (1-QFbkDelayScale));\n\t\t\tELSE\n\t\t\t\tTBE_Visus.Visu_GVL.Plant_QOvrdSts := FALSE;\n\t\t\t\tEMSFbk_Q[i] := ((PPCOutputs_scaled.EMSCmds[i].QCmd + RandNoise[i]) * QFbkDelayScale) + (EMSFbk_Q[i] * (1-QFbkDelayScale));\n\t\t\tEND_IF\n\t\tEND_IF\n\t\t\n\t\t//Add inverter values to meter sum -> Divide by 1000 to convert kW/kVar to MW/MVar\n\t\tIF NOT FPU.IsRealNaN(EMSFbk_P[i]) THEN\n\t\t\tBESSMeterFbk_P := BESSMeterFbk_P + (EMSFbk_P[i]/1000.0);\n\t\tEND_IF\n\t\tIF NOT FPU.IsRealNaN(EMSFbk_Q[i]) THEN\n\t\t\tBESSMeterFbk_Q := BESSMeterFbk_Q + (EMSFbk_Q[i]/1000.0); \n\t\tEND_IF\n\t\t\n\t\t//Write inverter feedbacks to Test_GVL\n\t\tTest_GVL.EMSFbk_P[i] := EMSFbk_P[i];\n\t\tTest_GVL.EMSFbk_Q[i] := EMSFbk_Q[i]; \n\tEND_FOR\n\t\n\t//Combine BESS + PV Meters for POI Meter\n\tMeterFbk_P := PVMeterFbk_P + BESSMeterFbk_P;\n\tMeterFbk_Q := PVMeterFbk_Q + BESSMeterFbk_Q;\n\t\n\t//Voltage Feedback Biasing\n\tIF TBE_Visus.Visu_GVL.Plant_VoltageOvrdEn THEN\n\t\tTBE_Visus.Visu_GVL.Plant_VoltageOvrdSts := TRUE;\n\t\tTest_GVL.PMHV1_VMag := Cfg_GVL.PlantCfg.VoltageCfg.Vbase * 1000 / LREAL_TO_REAL(SQRT(3)) * TBE_Visus.Visu_GVL.Plant_VoltageOvrdVal; \n\tELSE\n\t\tTest_GVL.PMHV1_VMag := Cfg_GVL.PlantCfg.VoltageCfg.Vbase * 1000 / LREAL_TO_REAL(SQRT(3)); \n\t\tTBE_Visus.Visu_GVL.Plant_VoltageOvrdSts := FALSE;\n\tEND_IF\n\t\n\t//Frequency Feedback Biasing\n\tIF TBE_Visus.Visu_GVL.Plant_FreqOvrdEn THEN\n\t\tTBE_Visus.Visu_GVL.Plant_FreqOvrdSts := TRUE;\n\t\tTest_GVL.PMHV1_Freq := 60.0 * TBE_Visus.Visu_GVL.Plant_FreqOvrdVal; \n\tELSE\n\t\tTBE_Visus.Visu_GVL.Plant_FreqOvrdSts := FALSE;\n\t\tTest_GVL.PMHV1_Freq := 60; \n\tEND_IF\n\t\n\t//Calculate S, PF, and Phi based on P/Q Feedback\n\t//POI Meter\n\tSFbk_MVA := LREAL_TO_REAL(SQRT(EXPT(MeterFbk_P, 2) + EXPT(MeterFbk_Q, 2)));\n\tIF MeterFbk_Q <> 0 AND SFbk_MVA <> 0 THEN\n\t\tPFFbk := (MeterFbk_Q / ABS(MeterFbk_Q)) * MeterFbk_P / SFbk_MVA;\n\tELSIF SFbk_MVA <> 0 THEN\n\t\tPFFbk := MeterFbk_P / SFbk_MVA;\n\tELSE\n\t\tPFFbk := 1.0; \t//Divide by 0 protection\n\tEND_IF\n\tPhiFbk := -ACOS(PFFbk); \n\t\n\t//PV Meter\n\tPV_SFbk_MVA := LREAL_TO_REAL(SQRT(EXPT(PVMeterFbk_P, 2) + EXPT(PVMeterFbk_Q, 2)));\n\tIF PVMeterFbk_Q <> 0 AND PV_SFbk_MVA <> 0 THEN\n\t\tPV_PFFbk := (PVMeterFbk_Q / ABS(PVMeterFbk_Q)) * PVMeterFbk_P / PV_SFbk_MVA;\n\tELSIF PV_SFbk_MVA <> 0 THEN\n\t\tPV_PFFbk := PVMeterFbk_P / PV_SFbk_MVA;\n\tELSE\n\t\tPV_PFFbk := 1.0; \t\t//Divide by 0 protection\n\tEND_IF\n\tPV_PhiFbk := -ACOS(PV_PFFbk);\n\t\n\t//BESS Meter\n\tBESS_SFbk_MVA := LREAL_TO_REAL(SQRT(EXPT(BESSMeterFbk_P, 2) + EXPT(BESSMeterFbk_Q, 2)));\n\tIF BESSMeterFbk_Q <> 0 AND BESS_SFbk_MVA <> 0 THEN\n\t\tBESS_PFFbk := (BESSMeterFbk_Q / ABS(BESSMeterFbk_Q)) * BESSMeterFbk_P / BESS_SFbk_MVA;\n\tELSIF BESS_SFbk_MVA <> 0 THEN\n\t\tBESS_PFFbk := BESSMeterFbk_P / BESS_SFbk_MVA;\n\tELSE\n\t\tBESS_PFFbk := 1.0; \t//Divide by 0 protection\n\tEND_IF\n\tBESS_PhiFbk := -ACOS(BESS_PFFbk);\n\t\n\t//Protect against NaN\n\t//POI Meter\n\tIF FPU.IsRealNaN(PhiFbk) THEN\n\t\tPhiFbk := 0; \n\tEND_IF\n\tIF FPU.IsRealNaN(MeterFbk_P) THEN\n\t\tMeterFbk_P := 0;\n\tEND_IF\n\tIF FPU.IsRealNaN(MeterFbk_Q) THEN\n\t\tMeterFbk_Q := 0; \n\tEND_IF\n\t\n\t//PV Meter\n\tIF FPU.IsRealNaN(PV_PhiFbk) THEN\n\t\tPV_PhiFbk := 0; \n\tEND_IF\n\tIF FPU.IsRealNaN(PVMeterFbk_P) THEN\n\t\tPVMeterFbk_P := 0;\n\tEND_IF\n\tIF FPU.IsRealNaN(PVMeterFbk_Q) THEN\n\t\tPVMeterFbk_Q := 0; \n\tEND_IF\n\t\n\t//BESS Meter\n\tIF FPU.IsRealNaN(BESS_PhiFbk) THEN\n\t\tBESS_PhiFbk := 0; \n\tEND_IF\n\tIF FPU.IsRealNaN(BESSMeterFbk_P) THEN\n\t\tBESSMeterFbk_P := 0;\n\tEND_IF\n\tIF FPU.IsRealNaN(BESSMeterFbk_Q) THEN\n\t\tBESSMeterFbk_Q := 0; \n\tEND_IF\n\t\n\t\n\t//Write meter feedback to C37 client registers\n\t//POI Meter\n\tTest_GVL.PMHV1_VMag := Cfg_GVL.PlantCfg.VoltageCfg.Vbase * 1000 / LREAL_TO_REAL(SQRT(3));\n\tIF COS(PhiFbk) <> 0 THEN\n\t\tTest_GVL.PMHV1_I := -MeterFbk_P * 1000000.0 / 3 / Test_GVL.PMHV1_VMag / COS(PhiFbk);\n\tELSE\n\t\tTest_GVL.PMHV1_I := 0; \n\tEND_IF\n\tTest_GVL.PMHV1_IAng := RAD_TO_DEG(PhiFbk);  \n\t\n\t//PV Meter\n\tTest_GVL.PMMV1_VMag := Cfg_GVL.PlantCfg.VoltageCfg.MVbase * 1000 / LREAL_TO_REAL(SQRT(3));\n\tIF COS(PV_PhiFbk) <> 0 THEN\n\t\tTest_GVL.PMMV1_I := -PVMeterFbk_P * 1000000.0 / 3 / Test_GVL.PMMV1_VMag / COS(PV_PhiFbk);\n\tELSE\n\t\tTest_GVL.PMHV1_I := 0; \n\tEND_IF\n\tTest_GVL.PMMV1_IAng := RAD_TO_DEG(PV_PhiFbk);  \n\t\n\t//BESS Meter\n\tTest_GVL.PMMV2_VMag := Cfg_GVL.PlantCfg.VoltageCfg.MVbase * 1000 / LREAL_TO_REAL(SQRT(3));\n\tIF COS(BESS_PhiFbk) <> 0 THEN\n\t\tTest_GVL.PMMV2_I := -BESSMeterFbk_P * 1000000.0 / 3 / Test_GVL.PMMV2_VMag / COS(BESS_PhiFbk);\n\tELSE\n\t\tTest_GVL.PMMV2_I := 0; \n\tEND_IF\n\tTest_GVL.PMMV2_IAng := RAD_TO_DEG(BESS_PhiFbk);  \n\t\n\t//Cap Bank Simulation\n\tFOR i := 0 TO SiteConstants.NumCapBanks BY 1 DO\n\t\tIF i = 1 AND SiteConstants.NumCapBanks >= 1 THEN\n\t\t\tIF PPCOutputs_scaled.CapBankCmds[i].Close THEN\n\t\t\t\tSubstationCtrl_DNP.Cap1_Switch_Sts.stVal := TRUE;\n\t\t\tELSIF PPCOutputs_scaled.CapBankCmds[i].Open THEN\n\t\t\t\tSubstationCtrl_DNP.Cap1_Switch_Sts.stVal := FALSE;\n\t\t\tEND_IF\n\t\tEND_IF\n\t\tIF i = 2 AND SiteConstants.NumCapBanks >= 2 THEN\n\t\t\tIF PPCOutputs_scaled.CapBankCmds[i].Close THEN\n\t\t\t\tSubstationCtrl_DNP.Cap2_Switch_Sts.stVal := TRUE;\n\t\t\tELSIF PPCOutputs_scaled.CapBankCmds[i].Open THEN\n\t\t\t\tSubstationCtrl_DNP.Cap2_Switch_Sts.stVal := FALSE;\n\t\t\tEND_IF\n\t\tEND_IF\n\tEND_FOR\n\t\n\t//Met station override\n\tTest_GVL.OvrdMetInputs := TRUE; \nELSIF TBE_Visus.Visu_GVL.Plant_Enable3530Sim THEN\n\t//Simulation w/ SEL3530 is enabled\n\tTest_GVL.UseSimMeter := TRUE; \n\tTBE_Visus.Visu_GVL.Plant_EnableSim := FALSE;\n\tTBE_Visus.Visu_GVL.Plant_SimSts := FALSE; \nELSE\n\tTBE_Visus.Visu_GVL.Plant_SimSts := FALSE;\n\tTest_GVL.OvrdPMHV1Inputs := FALSE; \n\tTest_GVL.PMHV1_Offline := TRUE; \n\tTest_GVL.OvrdPMMV1Inputs := FALSE; \n\tTest_GVL.PMMV1_Offline := TRUE; \n\tTest_GVL.OvrdPMMV2Inputs := FALSE; \n\tTest_GVL.PMMV2_Offline := TRUE; \n\tTest_GVL.OvrdInvInputs := FALSE; \n\tTest_GVL.OvrdEMSInputs := FALSE;\n\tTest_GVL.OvrdMetInputs := FALSE;\nEND_IF","LineInfoPersistence":"(string)3ba82e02-ee2b-46e1-9839-76955d3224be_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)(*\n|\tPlant Simulation Program\n|\tThis program simulated inverter, meter, and cap bank field devices\n*)\nPROGRAM pg_PlantSim\nVAR_INPUT\n\tPPCOutputs_scaled\t\t: dt_PPCOutputs; \t\t\t\t\t\t\t\t//Outputs from the PPC, scaled for external devices\nEND_VAR\nVAR\n\t//Control Variables\n\tRandNoiseEn\t\t\t\t: BOOL;\t\t\t\t\t\t\t\t\t\t\t//Enable random noise in inverter feedbacks\n\tPFbkDelayScale\t\t\t: REAL := 0.1;\t\t\t\t\t\t\t\t\t//Scale to delay real power feedback, 0 = No Delay, 1 = No change in feedback\n\tQFbkDelayScale\t\t\t: REAL := 0.1;\t\t\t\t\t\t\t\t\t//Scale to delay reactive power feedback, 0 = No Delay, 1 = No change in feedback\n\t\n\t//Internal Variables\n\ti\t\t\t\t\t\t: UINT; \t\t\t\t\t\t\t\t\t\t//Indexing variable\n\tRandNoise\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF REAL;\t\t//Random noise added to real/reactive power\n\tRandNoiseEMS\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF REAL;\t\t//Random noise added to real/reactive power\n\tNoiseMultiplier\t\t\t: REAL := 1.0;\t\t\t\t\t\t\t\t\t//Scaling value to change amplitude of noise\n\tt\t\t\t\t\t\t: UDINT;\t\t\t\t\t\t\t\t\t\t//Current time, in ms\n\tNoiseBase\t\t\t\t: REAL := 3.0; \t\t\t\t\t\t\t\t\t//Noise = Noise Base - Random Value, allows for negative noise\n\tInvFbk_P\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF REAL;\t\t//[kW], Inverter real power feedback, in kW\n\tInvFbk_Q\t\t\t\t: ARRAY[0..SiteConstants.NumInvs] OF REAL;\t\t//[kVar], Inverter reactive power feedback in kVar\n\tEMSFbk_P\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF REAL;\n\tEMSFbk_Q\t\t\t\t: ARRAY[0..SiteConstants.NumEMS] OF REAL;\n\t//Cap Bank Status\n\tCapClosedSts\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t//Capacitor bank closed status, TRUE = closed, FALSE = open\n\tCapOpenPerm\t\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t//Capacitor bank open permissive\n\tCapClosePerm\t\t\t: ARRAY[0..SiteConstants.NumCapBanks] OF BOOL;\t//Capacitor bank close permissive\n\t\n\t//Meter Fbk Calculation\n\tSFbk_MVA\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[MVA], Apparent power feedback\n\tPV_SFbk_MVA\t\t\t\t: REAL;\n\tBESS_SFbk_MVA\t\t\t: REAL;\n\tPFFbk\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//PF Fbk\n\tPV_PFFbk\t\t\t\t: REAL;\n\tBESS_PFFbk\t\t\t\t: REAL;\n\tPhiFbk\t\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[rad], Angle\n\tPV_PhiFbk\t\t\t\t: REAL;\n\tBESS_PhiFbk\t\t\t\t: REAL;\n\t\n\t//Scaling\n\tInvPCmdScale\t\t\t: REAL := 3.6;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from Inverter active power cmd (in modbus units) to kW\n\tInvQCmdScale\t\t\t: REAL := 0.1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from Inverter reactive power cmd (in modbus units) to kVar\n\tInvPFbkScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from Inverter active power fbk in kW to modbus units\n\tInvQFbkScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from Inverter reactive power fbk in kVar to modbus units\n\tEMSPCmdScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from EMS active power cmd (in modbus units) to kW\n\tEMSQCmdScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from EMS reactive power cmd (in modbus units) to kVar\n\tEMSPFbkScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from EMS active power fbk in kW to modbus units\n\tEMSQFbkScale\t\t\t: REAL := 1;\t\t\t\t\t\t\t\t\t//Conversion factor to convert from EMS reactive power fbk in kVar to modbus units\nEND_VAR\nVAR_TEMP\n\tMeterFbk_P\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[MW], Meter real power feedback, in MW\n\tMeterFbk_Q\t\t\t\t: REAL;\t\t\t\t\t\t\t\t\t\t\t//[MVar], Meter reactive power feedback, in MVar\n\tPVMeterFbk_P\t\t\t: REAL;\n\tPVMeterFbk_Q\t\t\t: REAL;\n\tBESSMeterFbk_P\t\t\t: REAL;\n\tBESSMeterFbk_Q\t\t\t: REAL;\nEND_VAR","LineInfoPersistence":"(string)3ba82e02-ee2b-46e1-9839-76955d3224be_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)417","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}